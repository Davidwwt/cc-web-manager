{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Cp2pHCFqWyL5XJnbHwKpf2","type":"tool_result","content":"     1→import express from 'express';\n     2→import axios from 'axios';\n     3→import { fileURLToPath } from 'url';\n     4→import { dirname, join } from 'path';\n     5→\n     6→const __dirname = dirname(fileURLToPath(import.meta.url));\n     7→const app = express();\n     8→const PORT = process.env.PORT || 3000;\n     9→\n    10→app.use(express.static(join(__dirname, 'public')));\n    11→\n    12→// ─── BTC via CoinGecko (free, no key) ────────────────────────────────────────\n    13→async function getBTCPrice() {\n    14→  const resp = await axios.get('https://api.coingecko.com/api/v3/simple/price', {\n    15→    params: { ids: 'bitcoin', vs_currencies: 'usd', include_24hr_change: 'true' },\n    16→    timeout: 10000,\n    17→  });\n    18→  const d = resp.data.bitcoin;\n    19→  return {\n    20→    price: d.usd,\n    21→    change: (d.usd * d.usd_24h_change) / 100,\n    22→    changePercent: d.usd_24h_change,\n    23→  };\n    24→}\n    25→\n    26→async function getBTCHistory(days) {\n    27→  const resp = await axios.get('https://api.coingecko.com/api/v3/coins/bitcoin/market_chart', {\n    28→    params: { vs_currency: 'usd', days },\n    29→    timeout: 15000,\n    30→  });\n    31→  return resp.data.prices.map(([t, p]) => ({ t, p }));\n    32→}\n    33→\n    34→// ─── Yahoo Finance via direct HTTP ────────────────────────────────────────────\n    35→const YF_HEADERS = {\n    36→  'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/120.0.0.0 Safari/537.36',\n    37→  'Accept': 'application/json',\n    38→  'Accept-Language': 'en-US,en;q=0.9',\n    39→};\n    40→\n    41→async function getYahooPrice(symbol) {\n    42→  const url = `https://query1.finance.yahoo.com/v8/finance/chart/${encodeURIComponent(symbol)}`;\n    43→  const resp = await axios.get(url, {\n    44→    params: { interval: '1d', range: '5d' },\n    45→    headers: YF_HEADERS,\n    46→    timeout: 12000,\n    47→  });\n    48→  const meta = resp.data?.chart?.result?.[0]?.meta;\n    49→  if (!meta) throw new Error(`No data for ${symbol}`);\n    50→  const cur   = meta.regularMarketPrice;\n    51→  const prev  = meta.chartPreviousClose ?? meta.previousClose ?? cur;\n    52→  const change = cur - prev;\n    53→  return {\n    54→    price:         cur,\n    55→    change:        change,\n    56→    changePercent: prev ? (change / prev) * 100 : 0,\n    57→  };\n    58→}\n    59→\n    60→async function getYahooHistory(symbol, range, interval) {\n    61→  const url = `https://query1.finance.yahoo.com/v8/finance/chart/${encodeURIComponent(symbol)}`;\n    62→  const resp = await axios.get(url, {\n    63→    params: { interval, range },\n    64→    headers: YF_HEADERS,\n    65→    timeout: 15000,\n    66→  });\n    67→  const result = resp.data?.chart?.result?.[0];\n    68→  if (!result) throw new Error(`No history for ${symbol}`);\n    69→  const stamps = result.timestamp || [];\n    70→  const closes = result.indicators?.quote?.[0]?.close || [];\n    71→  return stamps\n    72→    .map((ts, i) => ({ t: ts * 1000, p: closes[i] }))\n    73→    .filter(d => d.p != null);\n    74→}\n    75→\n    76→// ─── Range config ─────────────────────────────────────────────────────────────\n    77→const RANGES = {\n    78→  '1d':  { coinDays: 1,   yfRange: '1d',   interval: '5m'  },\n    79→  '1w':  { coinDays: 7,   yfRange: '5d',   interval: '60m' },\n    80→  '1m':  { coinDays: 30,  yfRange: '1mo',  interval: '1d'  },\n    81→  '3m':  { coinDays: 90,  yfRange: '3mo',  interval: '1d'  },\n    82→  '1y':  { coinDays: 365, yfRange: '1y',   interval: '1wk' },\n    83→};\n    84→\n    85→// ─── API Routes ───────────────────────────────────────────────────────────────\n    86→app.get('/api/prices', async (req, res) => {\n    87→  try {\n    88→    const [btc, gold, spx] = await Promise.all([\n    89→      getBTCPrice(),\n    90→      getYahooPrice('GC=F'),\n    91→      getYahooPrice('^GSPC'),\n    92→    ]);\n    93→    res.json({ btc, gold, spx });\n    94→  } catch (err) {\n    95→    console.error('[/api/prices]', err.message);\n    96→    res.status(500).json({ error: err.message });\n    97→  }\n    98→});\n    99→\n   100→app.get('/api/history/:asset', async (req, res) => {\n   101→  const { asset } = req.params;\n   102→  const cfg = RANGES[req.query.range] || RANGES['1m'];\n   103→  try {\n   104→    let data;\n   105→    if (asset === 'btc') {\n   106→      data = await getBTCHistory(cfg.coinDays);\n   107→    } else if (asset === 'gold') {\n   108→      data = await getYahooHistory('GC=F', cfg.yfRange, cfg.interval);\n   109→    } else if (asset === 'spx') {\n   110→      data = await getYahooHistory('^GSPC', cfg.yfRange, cfg.interval);\n   111→    } else {\n   112→      return res.status(400).json({ error: `Unknown asset: ${asset}` });\n   113→    }\n   114→    res.json(data);\n   115→  } catch (err) {\n   116→    console.error(`[/api/history/${asset}]`, err.message);\n   117→    res.status(500).json({ error: err.message });\n   118→  }\n   119→});\n   120→\n   121→app.listen(PORT, () => {\n   122→  console.log(`\\n  Market Dashboard → http://localhost:${PORT}\\n`);\n   123→});\n   124→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"f1d18a4e-a6bc-4349-a656-191f6979a4a6","uuid":"4c8995ae-3746-4c3f-ab15-b22e6554b6a2","tool_use_result":{"type":"text","file":{"filePath":"/home/ubuntu/my-project/server.js","content":"import express from 'express';\nimport axios from 'axios';\nimport { fileURLToPath } from 'url';\nimport { dirname, join } from 'path';\n\nconst __dirname = dirname(fileURLToPath(import.meta.url));\nconst app = express();\nconst PORT = process.env.PORT || 3000;\n\napp.use(express.static(join(__dirname, 'public')));\n\n// ─── BTC via CoinGecko (free, no key) ────────────────────────────────────────\nasync function getBTCPrice() {\n  const resp = await axios.get('https://api.coingecko.com/api/v3/simple/price', {\n    params: { ids: 'bitcoin', vs_currencies: 'usd', include_24hr_change: 'true' },\n    timeout: 10000,\n  });\n  const d = resp.data.bitcoin;\n  return {\n    price: d.usd,\n    change: (d.usd * d.usd_24h_change) / 100,\n    changePercent: d.usd_24h_change,\n  };\n}\n\nasync function getBTCHistory(days) {\n  const resp = await axios.get('https://api.coingecko.com/api/v3/coins/bitcoin/market_chart', {\n    params: { vs_currency: 'usd', days },\n    timeout: 15000,\n  });\n  return resp.data.prices.map(([t, p]) => ({ t, p }));\n}\n\n// ─── Yahoo Finance via direct HTTP ────────────────────────────────────────────\nconst YF_HEADERS = {\n  'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/120.0.0.0 Safari/537.36',\n  'Accept': 'application/json',\n  'Accept-Language': 'en-US,en;q=0.9',\n};\n\nasync function getYahooPrice(symbol) {\n  const url = `https://query1.finance.yahoo.com/v8/finance/chart/${encodeURIComponent(symbol)}`;\n  const resp = await axios.get(url, {\n    params: { interval: '1d', range: '5d' },\n    headers: YF_HEADERS,\n    timeout: 12000,\n  });\n  const meta = resp.data?.chart?.result?.[0]?.meta;\n  if (!meta) throw new Error(`No data for ${symbol}`);\n  const cur   = meta.regularMarketPrice;\n  const prev  = meta.chartPreviousClose ?? meta.previousClose ?? cur;\n  const change = cur - prev;\n  return {\n    price:         cur,\n    change:        change,\n    changePercent: prev ? (change / prev) * 100 : 0,\n  };\n}\n\nasync function getYahooHistory(symbol, range, interval) {\n  const url = `https://query1.finance.yahoo.com/v8/finance/chart/${encodeURIComponent(symbol)}`;\n  const resp = await axios.get(url, {\n    params: { interval, range },\n    headers: YF_HEADERS,\n    timeout: 15000,\n  });\n  const result = resp.data?.chart?.result?.[0];\n  if (!result) throw new Error(`No history for ${symbol}`);\n  const stamps = result.timestamp || [];\n  const closes = result.indicators?.quote?.[0]?.close || [];\n  return stamps\n    .map((ts, i) => ({ t: ts * 1000, p: closes[i] }))\n    .filter(d => d.p != null);\n}\n\n// ─── Range config ─────────────────────────────────────────────────────────────\nconst RANGES = {\n  '1d':  { coinDays: 1,   yfRange: '1d',   interval: '5m'  },\n  '1w':  { coinDays: 7,   yfRange: '5d',   interval: '60m' },\n  '1m':  { coinDays: 30,  yfRange: '1mo',  interval: '1d'  },\n  '3m':  { coinDays: 90,  yfRange: '3mo',  interval: '1d'  },\n  '1y':  { coinDays: 365, yfRange: '1y',   interval: '1wk' },\n};\n\n// ─── API Routes ───────────────────────────────────────────────────────────────\napp.get('/api/prices', async (req, res) => {\n  try {\n    const [btc, gold, spx] = await Promise.all([\n      getBTCPrice(),\n      getYahooPrice('GC=F'),\n      getYahooPrice('^GSPC'),\n    ]);\n    res.json({ btc, gold, spx });\n  } catch (err) {\n    console.error('[/api/prices]', err.message);\n    res.status(500).json({ error: err.message });\n  }\n});\n\napp.get('/api/history/:asset', async (req, res) => {\n  const { asset } = req.params;\n  const cfg = RANGES[req.query.range] || RANGES['1m'];\n  try {\n    let data;\n    if (asset === 'btc') {\n      data = await getBTCHistory(cfg.coinDays);\n    } else if (asset === 'gold') {\n      data = await getYahooHistory('GC=F', cfg.yfRange, cfg.interval);\n    } else if (asset === 'spx') {\n      data = await getYahooHistory('^GSPC', cfg.yfRange, cfg.interval);\n    } else {\n      return res.status(400).json({ error: `Unknown asset: ${asset}` });\n    }\n    res.json(data);\n  } catch (err) {\n    console.error(`[/api/history/${asset}]`, err.message);\n    res.status(500).json({ error: err.message });\n  }\n});\n\napp.listen(PORT, () => {\n  console.log(`\\n  Market Dashboard → http://localhost:${PORT}\\n`);\n});\n","numLines":124,"startLine":1,"totalLines":124}}}
