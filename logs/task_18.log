{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KEjGz6cxL8uuDRkfwDzAFE","type":"tool_result","content":"     1→\"\"\"CC Web Manager — Git Worktree 管理模块\n     2→\n     3→MVP 阶段：单实例运行，仅提供状态查询。\n     4→后续可扩展为多 worktree 并行执行。\n     5→\"\"\"\n     6→import asyncio\n     7→import logging\n     8→import os\n     9→from pathlib import Path\n    10→from typing import Any, Dict, List, Optional\n    11→\n    12→from config import PROJECT_DIR\n    13→\n    14→logger = logging.getLogger(__name__)\n    15→\n    16→\n    17→async def _run_git(*args: str, cwd: Optional[str] = None) -> tuple[int, str, str]:\n    18→    \"\"\"运行 git 命令，返回 (returncode, stdout, stderr)\"\"\"\n    19→    proc = await asyncio.create_subprocess_exec(\n    20→        \"git\", *args,\n    21→        stdout=asyncio.subprocess.PIPE,\n    22→        stderr=asyncio.subprocess.PIPE,\n    23→        cwd=cwd or PROJECT_DIR,\n    24→    )\n    25→    stdout, stderr = await proc.communicate()\n    26→    return proc.returncode, stdout.decode(errors=\"replace\"), stderr.decode(errors=\"replace\")\n    27→\n    28→\n    29→async def list_worktrees() -> List[Dict[str, Any]]:\n    30→    \"\"\"列出当前所有 worktree（包含主仓库）\"\"\"\n    31→    rc, stdout, stderr = await _run_git(\"worktree\", \"list\", \"--porcelain\")\n    32→    if rc != 0:\n    33→        logger.warning(f\"git worktree list 失败: {stderr}\")\n    34→        return []\n    35→\n    36→    worktrees = []\n    37→    current: Dict[str, Any] = {}\n    38→\n    39→    for line in stdout.splitlines():\n    40→        if line.startswith(\"worktree \"):\n    41→            if current:\n    42→                worktrees.append(current)\n    43→            current = {\"path\": line[len(\"worktree \"):].strip(), \"branch\": None, \"head\": None, \"bare\": False}\n    44→        elif line.startswith(\"HEAD \"):\n    45→            current[\"head\"] = line[5:].strip()\n    46→        elif line.startswith(\"branch \"):\n    47→            branch = line[7:].strip()\n    48→            # refs/heads/main -> main\n    49→            current[\"branch\"] = branch.replace(\"refs/heads/\", \"\")\n    50→        elif line == \"bare\":\n    51→            current[\"bare\"] = True\n    52→\n    53→    if current:\n    54→        worktrees.append(current)\n    55→\n    56→    return worktrees\n    57→\n    58→\n    59→async def create_worktree(worktree_id: int, base_branch: str = \"main\") -> str:\n    60→    \"\"\"\n    61→    为 worker 创建独立 worktree 及分支。\n    62→    返回 worktree 路径。\n    63→    \"\"\"\n    64→    project_dir = Path(PROJECT_DIR)\n    65→    worktree_path = str(project_dir.parent / f\"{project_dir.name}-worker-{worktree_id}\")\n    66→    branch_name = f\"worker-{worktree_id}\"\n    67→\n    68→    # 如果已存在就直接返回\n    69→    if Path(worktree_path).exists():\n    70→        logger.info(f\"Worktree 已存在: {worktree_path}\")\n    71→        return worktree_path\n    72→\n    73→    # 创建新分支 + worktree\n    74→    rc, stdout, stderr = await _run_git(\n    75→        \"worktree\", \"add\", \"-b\", branch_name, worktree_path, base_branch\n    76→    )\n    77→    if rc != 0:\n    78→        raise RuntimeError(f\"创建 worktree 失败: {stderr}\")\n    79→\n    80→    logger.info(f\"Worktree 创建成功: {worktree_path} (branch: {branch_name})\")\n    81→    return worktree_path\n    82→\n    83→\n    84→async def remove_worktree(worktree_path: str) -> None:\n    85→    \"\"\"删除指定 worktree（强制）\"\"\"\n    86→    rc, _, stderr = await _run_git(\"worktree\", \"remove\", \"--force\", worktree_path)\n    87→    if rc != 0:\n    88→        logger.warning(f\"删除 worktree 失败: {stderr}\")\n    89→    else:\n    90→        logger.info(f\"Worktree 已删除: {worktree_path}\")\n    91→\n    92→\n    93→async def get_current_branch(cwd: Optional[str] = None) -> str:\n    94→    \"\"\"获取指定目录的当前 Git 分支名\"\"\"\n    95→    rc, stdout, _ = await _run_git(\"branch\", \"--show-current\", cwd=cwd)\n    96→    return stdout.strip() if rc == 0 else \"unknown\"\n    97→\n    98→\n    99→async def commit_changes(message: str, cwd: Optional[str] = None) -> Optional[str]:\n   100→    \"\"\"\n   101→    在指定 worktree 中 add all + commit。\n   102→    返回 commit hash，如果没有变更则返回 None。\n   103→    \"\"\"\n   104→    work_dir = cwd or PROJECT_DIR\n   105→\n   106→    # 检查是否有变更\n   107→    rc, stdout, _ = await _run_git(\"status\", \"--porcelain\", cwd=work_dir)\n   108→    if rc != 0 or not stdout.strip():\n   109→        logger.info(\"没有需要提交的变更\")\n   110→        return None\n   111→\n   112→    # git add -A\n   113→    rc, _, stderr = await _run_git(\"add\", \"-A\", cwd=work_dir)\n   114→    if rc != 0:\n   115→        raise RuntimeError(f\"git add 失败: {stderr}\")\n   116→\n   117→    # git commit\n   118→    rc, _, stderr = await _run_git(\"commit\", \"-m\", message, cwd=work_dir)\n   119→    if rc != 0:\n   120→        raise RuntimeError(f\"git commit 失败: {stderr}\")\n   121→\n   122→    # 获取最新 commit hash\n   123→    rc, stdout, _ = await _run_git(\"rev-parse\", \"HEAD\", cwd=work_dir)\n   124→    return stdout.strip() if rc == 0 else None\n   125→\n   126→\n   127→async def merge_to_main(branch_name: str) -> None:\n   128→    \"\"\"将 worker 分支合并回 main（在主仓库中执行）\"\"\"\n   129→    # 切换到 main\n   130→    rc, _, stderr = await _run_git(\"checkout\", \"main\")\n   131→    if rc != 0:\n   132→        raise RuntimeError(f\"切换到 main 失败: {stderr}\")\n   133→\n   134→    # merge\n   135→    rc, _, stderr = await _run_git(\"merge\", \"--no-ff\", branch_name, \"-m\", f\"Merge {branch_name} into main\")\n   136→    if rc != 0:\n   137→        raise RuntimeError(f\"merge 失败: {stderr}\")\n   138→\n   139→    logger.info(f\"分支 {branch_name} 已合并到 main\")\n   140→\n   141→\n   142→async def delete_branch(branch_name: str) -> None:\n   143→    \"\"\"删除 worker 分支\"\"\"\n   144→    rc, _, stderr = await _run_git(\"branch\", \"-D\", branch_name)\n   145→    if rc != 0:\n   146→        logger.warning(f\"删除分支 {branch_name} 失败: {stderr}\")\n   147→    else:\n   148→        logger.info(f\"分支 {branch_name} 已删除\")\n   149→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01Ce4yJiBd8ysyTXH3pea5HJ","session_id":"4ed89809-b941-4f90-90c8-d74444d0dc9e","uuid":"c7b5beb6-375c-416a-bbce-ef709918b340"}
