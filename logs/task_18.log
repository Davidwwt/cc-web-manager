{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NrFU1Jji6xhwAHH8gyX51h","type":"tool_result","content":"     1→\"\"\"CC Web Manager — FastAPI 后端主文件\"\"\"\n     2→import asyncio\n     3→import json\n     4→import logging\n     5→import os\n     6→import shutil\n     7→from contextlib import asynccontextmanager\n     8→from datetime import datetime\n     9→from pathlib import Path\n    10→from typing import List, Optional\n    11→\n    12→import uvicorn\n    13→from fastapi import (\n    14→    Depends,\n    15→    FastAPI,\n    16→    HTTPException,\n    17→    Query,\n    18→    WebSocket,\n    19→    WebSocketDisconnect,\n    20→)\n    21→from fastapi.responses import FileResponse, HTMLResponse\n    22→from fastapi.staticfiles import StaticFiles\n    23→from pydantic import BaseModel\n    24→\n    25→import database\n    26→import dispatcher\n    27→import worktree_manager\n    28→from config import (\n    29→    ACCESS_TOKEN,\n    30→    BACKUP_DIR,\n    31→    BACKUP_INTERVAL_HOURS,\n    32→    HOST,\n    33→    LOG_DIR,\n    34→    PORT,\n    35→    PROJECT_DIR,\n    36→)\n    37→\n    38→# ---------------------------------------------------------------------------\n    39→# 日志配置\n    40→# ---------------------------------------------------------------------------\n    41→logging.basicConfig(\n    42→    level=logging.INFO,\n    43→    format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\",\n    44→)\n    45→logger = logging.getLogger(__name__)\n    46→\n    47→# ---------------------------------------------------------------------------\n    48→# FastAPI 应用（lifespan 管理启动/关闭）\n    49→# ---------------------------------------------------------------------------\n    50→\n    51→\n    52→@asynccontextmanager\n    53→async def lifespan(app: FastAPI):\n    54→    # 启动\n    55→    await database.init_db()\n    56→    logger.info(\"数据库初始化完成\")\n    57→    asyncio.create_task(dispatcher.ralph_loop())\n    58→    logger.info(\"Ralph Loop 已启动\")\n    59→    asyncio.create_task(_auto_backup())\n    60→    logger.info(\"自动备份已启动\")\n    61→\n    62→    yield\n    63→\n    64→    # 关闭\n    65→    dispatcher.stop_loop()\n    66→    logger.info(\"CC Web Manager 已关闭\")\n    67→\n    68→\n    69→app = FastAPI(title=\"CC Web Manager\", version=\"1.0.0\", lifespan=lifespan)\n    70→\n    71→# ---------------------------------------------------------------------------\n    72→# Token 认证\n    73→# ---------------------------------------------------------------------------\n    74→\n    75→\n    76→def verify_token(token: Optional[str] = Query(None)) -> None:\n    77→    \"\"\"简单 Token 校验（支持 URL 参数 ?token=xxx）\"\"\"\n    78→    if token != ACCESS_TOKEN:\n    79→        raise HTTPException(status_code=401, detail=\"Invalid or missing token\")\n    80→\n    81→\n    82→# ---------------------------------------------------------------------------\n    83→# Pydantic 模型\n    84→# ---------------------------------------------------------------------------\n    85→\n    86→\n    87→class TaskCreate(BaseModel):\n    88→    prompt: str\n    89→\n    90→\n    91→class TaskApprove(BaseModel):\n    92→    pass\n    93→\n    94→\n    95→# ---------------------------------------------------------------------------\n    96→# REST API — 任务管理\n    97→# ---------------------------------------------------------------------------\n    98→\n    99→\n   100→@app.post(\"/api/tasks\", dependencies=[Depends(verify_token)])\n   101→async def create_task(body: TaskCreate):\n   102→    \"\"\"提交新任务\"\"\"\n   103→    if not body.prompt.strip():\n   104→        raise HTTPException(status_code=400, detail=\"prompt 不能为空\")\n   105→    task_id = await database.create_task(body.prompt.strip())\n   106→    task = await database.get_task(task_id)\n   107→    return {\"ok\": True, \"task\": task}\n   108→\n   109→\n   110→@app.get(\"/api/tasks\", dependencies=[Depends(verify_token)])\n   111→async def list_tasks(status: Optional[str] = Query(None)):\n   112→    \"\"\"获取任务列表，可按状态筛选（log 字段截断为最后 2000 字符，减少响应体积）\"\"\"\n   113→    tasks = await database.get_tasks(status)\n   114→    for t in tasks:\n   115→        if t.get(\"log\") and len(t[\"log\"]) > 2000:\n   116→            t[\"log\"] = t[\"log\"][-2000:]\n   117→    return {\"tasks\": tasks}\n   118→\n   119→\n   120→@app.get(\"/api/tasks/{task_id}\", dependencies=[Depends(verify_token)])\n   121→async def get_task(task_id: int):\n   122→    \"\"\"获取单个任务详情\"\"\"\n   123→    task = await database.get_task(task_id)\n   124→    if not task:\n   125→        raise HTTPException(status_code=404, detail=\"任务不存在\")\n   126→    return {\"task\": task}\n   127→\n   128→\n   129→@app.post(\"/api/tasks/{task_id}/approve\", dependencies=[Depends(verify_token)])\n   130→async def approve_task(task_id: int):\n   131→    \"\"\"确认 Plan，将 plan_review 状态的任务推进到 pending（等待执行）\"\"\"\n   132→    task = await database.get_task(task_id)\n   133→    if not task:\n   134→        raise HTTPException(status_code=404, detail=\"任务不存在\")\n   135→    if task[\"status\"] != \"plan_review\":\n   136→        raise HTTPException(status_code=400, detail=f\"任务状态为 {task['status']}，无法确认\")\n   137→    await database.update_task_status(task_id, \"pending\")\n   138→    return {\"ok\": True}\n   139→\n   140→\n   141→@app.post(\"/api/tasks/{task_id}/reject\", dependencies=[Depends(verify_token)])\n   142→async def reject_task(task_id: int):\n   143→    \"\"\"拒绝 Plan，任务标记为 failed\"\"\"\n   144→    task = await database.get_task(task_id)\n   145→    if not task:\n   146→        raise HTTPException(status_code=404, detail=\"任务不存在\")\n   147→    if task[\"status\"] != \"plan_review\":\n   148→        raise HTTPException(status_code=400, detail=f\"任务状态为 {task['status']}，无法拒绝\")\n   149→    await database.update_task_status(task_id, \"failed\", error=\"用户拒绝了执行计划\")\n   150→    return {\"ok\": True}\n   151→\n   152→\n   153→@app.post(\"/api/tasks/{task_id}/retry\", dependencies=[Depends(verify_token)])\n   154→async def retry_task(task_id: int):\n   155→    \"\"\"重试失败的任务\"\"\"\n   156→    task = await database.get_task(task_id)\n   157→    if not task:\n   158→        raise HTTPException(status_code=404, detail=\"任务不存在\")\n   159→    if task[\"status\"] not in (\"failed\",):\n   160→        raise HTTPException(status_code=400, detail=f\"只能重试 failed 状态的任务，当前状态: {task['status']}\")\n   161→    await database.update_task_status(\n   162→        task_id, \"pending\",\n   163→        error=None,\n   164→        log=\"\",\n   165→        started_at=None,\n   166→        completed_at=None,\n   167→    )\n   168→    return {\"ok\": True}\n   169→\n   170→\n   171→@app.delete(\"/api/tasks/{task_id}\", dependencies=[Depends(verify_token)])\n   172→async def delete_task(task_id: int):\n   173→    \"\"\"删除任务\"\"\"\n   174→    ok = await database.delete_task(task_id)\n   175→    if not ok:\n   176→        raise HTTPException(status_code=404, detail=\"任务不存在\")\n   177→    return {\"ok\": True}\n   178→\n   179→\n   180→# ---------------------------------------------------------------------------\n   181→# REST API — 文件浏览\n   182→# ---------------------------------------------------------------------------\n   183→\n   184→\n   185→def _safe_path(rel: str) -> Path:\n   186→    \"\"\"解析相对路径，防止路径穿越\"\"\"\n   187→    base = Path(PROJECT_DIR).resolve()\n   188→    target = (base / rel).resolve()\n   189→    if not str(target).startswith(str(base)):\n   190→        raise HTTPException(status_code=403, detail=\"路径越权\")\n   191→    return target\n   192→\n   193→\n   194→@app.get(\"/api/files\", dependencies=[Depends(verify_token)])\n   195→async def list_files(path: str = Query(\"\")):\n   196→    \"\"\"列出项目目录下的文件树（单层）\"\"\"\n   197→    target = _safe_path(path)\n   198→    if not target.exists():\n   199→        raise HTTPException(status_code=404, detail=\"路径不存在\")\n   200→    if not target.is_dir():\n   201→        raise HTTPException(status_code=400, detail=\"不是目录\")\n   202→\n   203→    items = []\n   204→    try:\n   205→        for entry in sorted(target.iterdir(), key=lambda e: (e.is_file(), e.name)):\n   206→            items.append({\n   207→                \"name\": entry.name,\n   208→                \"path\": str(entry.relative_to(Path(PROJECT_DIR))),\n   209→                \"is_dir\": entry.is_dir(),\n   210→                \"size\": entry.stat().st_size if entry.is_file() else None,\n   211→                \"modified\": datetime.fromtimestamp(entry.stat().st_mtime).isoformat(),\n   212→            })\n   213→    except PermissionError:\n   214→        raise HTTPException(status_code=403, detail=\"无权限\")\n   215→    return {\"path\": path, \"items\": items}\n   216→\n   217→\n   218→@app.get(\"/api/files/{file_path:path}\", dependencies=[Depends(verify_token)])\n   219→async def read_file(file_path: str):\n   220→    \"\"\"读取文件内容（最多 100KB）\"\"\"\n   221→    target = _safe_path(file_path)\n   222→    if not target.exists():\n   223→        raise HTTPException(status_code=404, detail=\"文件不存在\")\n   224→    if not target.is_file():\n   225→        raise HTTPException(status_code=400, detail=\"不是文件\")\n   226→\n   227→    size = target.stat().st_size\n   228→    if size > 100 * 1024:\n   229→        raise HTTPException(status_code=413, detail=\"文件超过 100KB，请直接 SSH 查看\")\n   230→\n   231→    try:\n   232→        content = target.read_text(encoding=\"utf-8\", errors=\"replace\")\n   233→    except Exception as e:\n   234→        raise HTTPException(status_code=500, detail=str(e))\n   235→\n   236→    return {\"path\": file_path, \"content\": content, \"size\": size}\n   237→\n   238→\n   239→# ---------------------------------------------------------------------------\n   240→# REST API — Git\n   241→# ---------------------------------------------------------------------------\n   242→\n   243→\n   244→@app.get(\"/api/git/log\", dependencies=[Depends(verify_token)])\n   245→async def git_log(limit: int = Query(20, ge=1, le=100)):\n   246→    \"\"\"查看最近的 Git 提交记录\"\"\"\n   247→    try:\n   248→        proc = await asyncio.create_subprocess_exec(\n   249→            \"git\", \"log\", f\"--max-count={limit}\",\n   250→            \"--pretty=format:%H|%s|%an|%ai\",\n   251→            stdout=asyncio.subprocess.PIPE,\n   252→            stderr=asyncio.subprocess.PIPE,\n   253→            cwd=PROJECT_DIR,\n   254→        )\n   255→        stdout, stderr = await proc.communicate()\n   256→        if proc.returncode != 0:\n   257→            return {\"commits\": [], \"error\": stderr.decode()}\n   258→        commits = []\n   259→        for line in stdout.decode().splitlines():\n   260→            parts = line.split(\"|\", 3)\n   261→            if len(parts) == 4:\n   262→                commits.append({\n   263→                    \"hash\": parts[0],\n   264→                    \"message\": parts[1],\n   265→                    \"author\": parts[2],\n   266→                    \"date\": parts[3],\n   267→                })\n   268→        return {\"commits\": commits}\n   269→    except Exception as e:\n   270→        return {\"commits\": [], \"error\": str(e)}\n   271→\n   272→\n   273→# ---------------------------------------------------------------------------\n   274→# REST API — 系统状态 & PROGRESS.md\n   275→# ---------------------------------------------------------------------------\n   276→\n   277→\n   278→@app.get(\"/api/progress\", dependencies=[Depends(verify_token)])\n   279→async def get_progress():\n   280→    \"\"\"读取 PROGRESS.md 内容\"\"\"\n   281→    progress_path = Path(__file__).parent / \"PROGRESS.md\"\n   282→    if progress_path.exists():\n   283→        return {\"content\": progress_path.read_text(encoding=\"utf-8\")}\n   284→    return {\"content\": \"PROGRESS.md 不存在\"}\n   285→\n   286→\n   287→@app.get(\"/api/status\", dependencies=[Depends(verify_token)])\n   288→async def get_status():\n   289→    \"\"\"系统状态：队列、worktree、数据库\"\"\"\n   290→    tasks = await database.get_tasks()\n   291→    counts: dict = {}\n   292→    for t in tasks:\n   293→        s = t[\"status\"]\n   294→        counts[s] = counts.get(s, 0) + 1\n   295→\n   296→    worktrees = await worktree_manager.list_worktrees()\n   297→\n   298→    return {\n   299→        \"task_counts\": counts,\n   300→        \"total_tasks\": len(tasks),\n   301→        \"worktrees\": worktrees,\n   302→        \"project_dir\": PROJECT_DIR,\n   303→        \"log_dir\": LOG_DIR,\n   304→    }\n   305→\n   306→\n   307→# ---------------------------------------------------------------------------\n   308→# WebSocket — 任务日志实时推送\n   309→# ---------------------------------------------------------------------------\n   310→\n   311→\n   312→@app.websocket(\"/ws/tasks/{task_id}/log\")\n   313→async def ws_task_log(websocket: WebSocket, task_id: int, token: Optional[str] = Query(None)):\n   314→    if token != ACCESS_TOKEN:\n   315→        await websocket.close(code=4001)\n   316→        return\n   317→\n   318→    await websocket.accept()\n   319→\n   320→    # 先把已有日志一次性发送\n   321→    task = await database.get_task(task_id)\n   322→    if not task:\n   323→        await websocket.send_text(json.dumps({\"error\": \"任务不存在\"}))\n   324→        await websocket.close()\n   325→        return\n   326→\n   327→    existing_log = task.get(\"log\") or \"\"\n   328→    if existing_log:\n   329→        await websocket.send_text(json.dumps({\"type\": \"history\", \"text\": existing_log}))\n   330→\n   331→    # 注册实时日志回调\n   332→    async def send_log(text: str):\n   333→        await websocket.send_text(json.dumps({\"type\": \"log\", \"text\": text}))\n   334→\n   335→    dispatcher.subscribe_log(task_id, send_log)\n   336→\n   337→    try:\n   338→        while True:\n   339→            # 保持连接，等待客户端断开\n   340→            data = await websocket.receive_text()\n   341→            # 可扩展：处理客户端发来的控制指令\n   342→    except WebSocketDisconnect:\n   343→        pass\n   344→    finally:\n   345→        dispatcher.unsubscribe_log(task_id, send_log)\n   346→\n   347→\n   348→# ---------------------------------------------------------------------------\n   349→# WebSocket — 全局事件推送\n   350→# ---------------------------------------------------------------------------\n   351→\n   352→\n   353→@app.websocket(\"/ws/events\")\n   354→async def ws_events(websocket: WebSocket, token: Optional[str] = Query(None)):\n   355→    if token != ACCESS_TOKEN:\n   356→        await websocket.close(code=4001)\n   357→        return\n   358→\n   359→    await websocket.accept()\n   360→\n   361→    async def send_event(event: dict):\n   362→        await websocket.send_text(json.dumps(event))\n   363→\n   364→    dispatcher.subscribe_events(send_event)\n   365→\n   366→    try:\n   367→        while True:\n   368→            await websocket.receive_text()\n   369→    except WebSocketDisconnect:\n   370→        pass\n   371→    finally:\n   372→        dispatcher.unsubscribe_events(send_event)\n   373→\n   374→\n   375→# ---------------------------------------------------------------------------\n   376→# 静态文件 & 前端入口\n   377→# ---------------------------------------------------------------------------\n   378→\n   379→STATIC_DIR = Path(__file__).parent / \"static\"\n   380→\n   381→\n   382→@app.get(\"/\", response_class=HTMLResponse)\n   383→async def index():\n   384→    index_file = STATIC_DIR / \"index.html\"\n   385→    if index_file.exists():\n   386→        return HTMLResponse(content=index_file.read_text(encoding=\"utf-8\"))\n   387→    return HTMLResponse(\"<h1>CC Web Manager</h1><p>index.html not found</p>\")\n   388→\n   389→\n   390→# 也挂载 /static 供直接引用\n   391→if STATIC_DIR.exists():\n   392→    app.mount(\"/static\", StaticFiles(directory=str(STATIC_DIR)), name=\"static\")\n   393→\n   394→\n   395→async def _auto_backup():\n   396→    \"\"\"每小时备份一次数据库\"\"\"\n   397→    while True:\n   398→        await asyncio.sleep(BACKUP_INTERVAL_HOURS * 3600)\n   399→        try:\n   400→            dest = await database.backup_db(BACKUP_DIR)\n   401→            logger.info(f\"数据库备份完成: {dest}\")\n   402→        except Exception:\n   403→            logger.exception(\"数据库备份失败\")\n   404→\n   405→\n   406→# ---------------------------------------------------------------------------\n   407→# 入口\n   408→# ---------------------------------------------------------------------------\n   409→\n   410→if __name__ == \"__main__\":\n   411→    ec2_ip = os.environ.get(\"EC2_IP\", \"your-ec2-ip\")\n   412→    print(\"\\n\" + \"=\" * 60)\n   413→    print(\"🚀 CC Web Manager 启动中...\")\n   414→    print(f\"   地址: http://{HOST}:{PORT}\")\n   415→    print(f\"🔑 访问 Token: {ACCESS_TOKEN}\")\n   416→    print(f\"📱 手机访问: http://{ec2_ip}:{PORT}?token={ACCESS_TOKEN}\")\n   417→    print(\"=\" * 60 + \"\\n\")\n   418→\n   419→    uvicorn.run(\n   420→        \"server:app\",\n   421→        host=HOST,\n   422→        port=PORT,\n   423→        reload=False,\n   424→        log_level=\"info\",\n   425→    )\n   426→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"4ed89809-b941-4f90-90c8-d74444d0dc9e","uuid":"4945be01-1069-4b3a-81c5-75ff6e57b7a8","tool_use_result":{"type":"text","file":{"filePath":"/home/ubuntu/cc-web-manager/server.py","content":"\"\"\"CC Web Manager — FastAPI 后端主文件\"\"\"\nimport asyncio\nimport json\nimport logging\nimport os\nimport shutil\nfrom contextlib import asynccontextmanager\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import List, Optional\n\nimport uvicorn\nfrom fastapi import (\n    Depends,\n    FastAPI,\n    HTTPException,\n    Query,\n    WebSocket,\n    WebSocketDisconnect,\n)\nfrom fastapi.responses import FileResponse, HTMLResponse\nfrom fastapi.staticfiles import StaticFiles\nfrom pydantic import BaseModel\n\nimport database\nimport dispatcher\nimport worktree_manager\nfrom config import (\n    ACCESS_TOKEN,\n    BACKUP_DIR,\n    BACKUP_INTERVAL_HOURS,\n    HOST,\n    LOG_DIR,\n    PORT,\n    PROJECT_DIR,\n)\n\n# ---------------------------------------------------------------------------\n# 日志配置\n# ---------------------------------------------------------------------------\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\",\n)\nlogger = logging.getLogger(__name__)\n\n# ---------------------------------------------------------------------------\n# FastAPI 应用（lifespan 管理启动/关闭）\n# ---------------------------------------------------------------------------\n\n\n@asynccontextmanager\nasync def lifespan(app: FastAPI):\n    # 启动\n    await database.init_db()\n    logger.info(\"数据库初始化完成\")\n    asyncio.create_task(dispatcher.ralph_loop())\n    logger.info(\"Ralph Loop 已启动\")\n    asyncio.create_task(_auto_backup())\n    logger.info(\"自动备份已启动\")\n\n    yield\n\n    # 关闭\n    dispatcher.stop_loop()\n    logger.info(\"CC Web Manager 已关闭\")\n\n\napp = FastAPI(title=\"CC Web Manager\", version=\"1.0.0\", lifespan=lifespan)\n\n# ---------------------------------------------------------------------------\n# Token 认证\n# ---------------------------------------------------------------------------\n\n\ndef verify_token(token: Optional[str] = Query(None)) -> None:\n    \"\"\"简单 Token 校验（支持 URL 参数 ?token=xxx）\"\"\"\n    if token != ACCESS_TOKEN:\n        raise HTTPException(status_code=401, detail=\"Invalid or missing token\")\n\n\n# ---------------------------------------------------------------------------\n# Pydantic 模型\n# ---------------------------------------------------------------------------\n\n\nclass TaskCreate(BaseModel):\n    prompt: str\n\n\nclass TaskApprove(BaseModel):\n    pass\n\n\n# ---------------------------------------------------------------------------\n# REST API — 任务管理\n# ---------------------------------------------------------------------------\n\n\n@app.post(\"/api/tasks\", dependencies=[Depends(verify_token)])\nasync def create_task(body: TaskCreate):\n    \"\"\"提交新任务\"\"\"\n    if not body.prompt.strip():\n        raise HTTPException(status_code=400, detail=\"prompt 不能为空\")\n    task_id = await database.create_task(body.prompt.strip())\n    task = await database.get_task(task_id)\n    return {\"ok\": True, \"task\": task}\n\n\n@app.get(\"/api/tasks\", dependencies=[Depends(verify_token)])\nasync def list_tasks(status: Optional[str] = Query(None)):\n    \"\"\"获取任务列表，可按状态筛选（log 字段截断为最后 2000 字符，减少响应体积）\"\"\"\n    tasks = await database.get_tasks(status)\n    for t in tasks:\n        if t.get(\"log\") and len(t[\"log\"]) > 2000:\n            t[\"log\"] = t[\"log\"][-2000:]\n    return {\"tasks\": tasks}\n\n\n@app.get(\"/api/tasks/{task_id}\", dependencies=[Depends(verify_token)])\nasync def get_task(task_id: int):\n    \"\"\"获取单个任务详情\"\"\"\n    task = await database.get_task(task_id)\n    if not task:\n        raise HTTPException(status_code=404, detail=\"任务不存在\")\n    return {\"task\": task}\n\n\n@app.post(\"/api/tasks/{task_id}/approve\", dependencies=[Depends(verify_token)])\nasync def approve_task(task_id: int):\n    \"\"\"确认 Plan，将 plan_review 状态的任务推进到 pending（等待执行）\"\"\"\n    task = await database.get_task(task_id)\n    if not task:\n        raise HTTPException(status_code=404, detail=\"任务不存在\")\n    if task[\"status\"] != \"plan_review\":\n        raise HTTPException(status_code=400, detail=f\"任务状态为 {task['status']}，无法确认\")\n    await database.update_task_status(task_id, \"pending\")\n    return {\"ok\": True}\n\n\n@app.post(\"/api/tasks/{task_id}/reject\", dependencies=[Depends(verify_token)])\nasync def reject_task(task_id: int):\n    \"\"\"拒绝 Plan，任务标记为 failed\"\"\"\n    task = await database.get_task(task_id)\n    if not task:\n        raise HTTPException(status_code=404, detail=\"任务不存在\")\n    if task[\"status\"] != \"plan_review\":\n        raise HTTPException(status_code=400, detail=f\"任务状态为 {task['status']}，无法拒绝\")\n    await database.update_task_status(task_id, \"failed\", error=\"用户拒绝了执行计划\")\n    return {\"ok\": True}\n\n\n@app.post(\"/api/tasks/{task_id}/retry\", dependencies=[Depends(verify_token)])\nasync def retry_task(task_id: int):\n    \"\"\"重试失败的任务\"\"\"\n    task = await database.get_task(task_id)\n    if not task:\n        raise HTTPException(status_code=404, detail=\"任务不存在\")\n    if task[\"status\"] not in (\"failed\",):\n        raise HTTPException(status_code=400, detail=f\"只能重试 failed 状态的任务，当前状态: {task['status']}\")\n    await database.update_task_status(\n        task_id, \"pending\",\n        error=None,\n        log=\"\",\n        started_at=None,\n        completed_at=None,\n    )\n    return {\"ok\": True}\n\n\n@app.delete(\"/api/tasks/{task_id}\", dependencies=[Depends(verify_token)])\nasync def delete_task(task_id: int):\n    \"\"\"删除任务\"\"\"\n    ok = await database.delete_task(task_id)\n    if not ok:\n        raise HTTPException(status_code=404, detail=\"任务不存在\")\n    return {\"ok\": True}\n\n\n# ---------------------------------------------------------------------------\n# REST API — 文件浏览\n# ---------------------------------------------------------------------------\n\n\ndef _safe_path(rel: str) -> Path:\n    \"\"\"解析相对路径，防止路径穿越\"\"\"\n    base = Path(PROJECT_DIR).resolve()\n    target = (base / rel).resolve()\n    if not str(target).startswith(str(base)):\n        raise HTTPException(status_code=403, detail=\"路径越权\")\n    return target\n\n\n@app.get(\"/api/files\", dependencies=[Depends(verify_token)])\nasync def list_files(path: str = Query(\"\")):\n    \"\"\"列出项目目录下的文件树（单层）\"\"\"\n    target = _safe_path(path)\n    if not target.exists():\n        raise HTTPException(status_code=404, detail=\"路径不存在\")\n    if not target.is_dir():\n        raise HTTPException(status_code=400, detail=\"不是目录\")\n\n    items = []\n    try:\n        for entry in sorted(target.iterdir(), key=lambda e: (e.is_file(), e.name)):\n            items.append({\n                \"name\": entry.name,\n                \"path\": str(entry.relative_to(Path(PROJECT_DIR))),\n                \"is_dir\": entry.is_dir(),\n                \"size\": entry.stat().st_size if entry.is_file() else None,\n                \"modified\": datetime.fromtimestamp(entry.stat().st_mtime).isoformat(),\n            })\n    except PermissionError:\n        raise HTTPException(status_code=403, detail=\"无权限\")\n    return {\"path\": path, \"items\": items}\n\n\n@app.get(\"/api/files/{file_path:path}\", dependencies=[Depends(verify_token)])\nasync def read_file(file_path: str):\n    \"\"\"读取文件内容（最多 100KB）\"\"\"\n    target = _safe_path(file_path)\n    if not target.exists():\n        raise HTTPException(status_code=404, detail=\"文件不存在\")\n    if not target.is_file():\n        raise HTTPException(status_code=400, detail=\"不是文件\")\n\n    size = target.stat().st_size\n    if size > 100 * 1024:\n        raise HTTPException(status_code=413, detail=\"文件超过 100KB，请直接 SSH 查看\")\n\n    try:\n        content = target.read_text(encoding=\"utf-8\", errors=\"replace\")\n    except Exception as e:\n        raise HTTPException(status_code=500, detail=str(e))\n\n    return {\"path\": file_path, \"content\": content, \"size\": size}\n\n\n# ---------------------------------------------------------------------------\n# REST API — Git\n# ---------------------------------------------------------------------------\n\n\n@app.get(\"/api/git/log\", dependencies=[Depends(verify_token)])\nasync def git_log(limit: int = Query(20, ge=1, le=100)):\n    \"\"\"查看最近的 Git 提交记录\"\"\"\n    try:\n        proc = await asyncio.create_subprocess_exec(\n            \"git\", \"log\", f\"--max-count={limit}\",\n            \"--pretty=format:%H|%s|%an|%ai\",\n            stdout=asyncio.subprocess.PIPE,\n            stderr=asyncio.subprocess.PIPE,\n            cwd=PROJECT_DIR,\n        )\n        stdout, stderr = await proc.communicate()\n        if proc.returncode != 0:\n            return {\"commits\": [], \"error\": stderr.decode()}\n        commits = []\n        for line in stdout.decode().splitlines():\n            parts = line.split(\"|\", 3)\n            if len(parts) == 4:\n                commits.append({\n                    \"hash\": parts[0],\n                    \"message\": parts[1],\n                    \"author\": parts[2],\n                    \"date\": parts[3],\n                })\n        return {\"commits\": commits}\n    except Exception as e:\n        return {\"commits\": [], \"error\": str(e)}\n\n\n# ---------------------------------------------------------------------------\n# REST API — 系统状态 & PROGRESS.md\n# ---------------------------------------------------------------------------\n\n\n@app.get(\"/api/progress\", dependencies=[Depends(verify_token)])\nasync def get_progress():\n    \"\"\"读取 PROGRESS.md 内容\"\"\"\n    progress_path = Path(__file__).parent / \"PROGRESS.md\"\n    if progress_path.exists():\n        return {\"content\": progress_path.read_text(encoding=\"utf-8\")}\n    return {\"content\": \"PROGRESS.md 不存在\"}\n\n\n@app.get(\"/api/status\", dependencies=[Depends(verify_token)])\nasync def get_status():\n    \"\"\"系统状态：队列、worktree、数据库\"\"\"\n    tasks = await database.get_tasks()\n    counts: dict = {}\n    for t in tasks:\n        s = t[\"status\"]\n        counts[s] = counts.get(s, 0) + 1\n\n    worktrees = await worktree_manager.list_worktrees()\n\n    return {\n        \"task_counts\": counts,\n        \"total_tasks\": len(tasks),\n        \"worktrees\": worktrees,\n        \"project_dir\": PROJECT_DIR,\n        \"log_dir\": LOG_DIR,\n    }\n\n\n# ---------------------------------------------------------------------------\n# WebSocket — 任务日志实时推送\n# ---------------------------------------------------------------------------\n\n\n@app.websocket(\"/ws/tasks/{task_id}/log\")\nasync def ws_task_log(websocket: WebSocket, task_id: int, token: Optional[str] = Query(None)):\n    if token != ACCESS_TOKEN:\n        await websocket.close(code=4001)\n        return\n\n    await websocket.accept()\n\n    # 先把已有日志一次性发送\n    task = await database.get_task(task_id)\n    if not task:\n        await websocket.send_text(json.dumps({\"error\": \"任务不存在\"}))\n        await websocket.close()\n        return\n\n    existing_log = task.get(\"log\") or \"\"\n    if existing_log:\n        await websocket.send_text(json.dumps({\"type\": \"history\", \"text\": existing_log}))\n\n    # 注册实时日志回调\n    async def send_log(text: str):\n        await websocket.send_text(json.dumps({\"type\": \"log\", \"text\": text}))\n\n    dispatcher.subscribe_log(task_id, send_log)\n\n    try:\n        while True:\n            # 保持连接，等待客户端断开\n            data = await websocket.receive_text()\n            # 可扩展：处理客户端发来的控制指令\n    except WebSocketDisconnect:\n        pass\n    finally:\n        dispatcher.unsubscribe_log(task_id, send_log)\n\n\n# ---------------------------------------------------------------------------\n# WebSocket — 全局事件推送\n# ---------------------------------------------------------------------------\n\n\n@app.websocket(\"/ws/events\")\nasync def ws_events(websocket: WebSocket, token: Optional[str] = Query(None)):\n    if token != ACCESS_TOKEN:\n        await websocket.close(code=4001)\n        return\n\n    await websocket.accept()\n\n    async def send_event(event: dict):\n        await websocket.send_text(json.dumps(event))\n\n    dispatcher.subscribe_events(send_event)\n\n    try:\n        while True:\n            await websocket.receive_text()\n    except WebSocketDisconnect:\n        pass\n    finally:\n        dispatcher.unsubscribe_events(send_event)\n\n\n# ---------------------------------------------------------------------------\n# 静态文件 & 前端入口\n# ---------------------------------------------------------------------------\n\nSTATIC_DIR = Path(__file__).parent / \"static\"\n\n\n@app.get(\"/\", response_class=HTMLResponse)\nasync def index():\n    index_file = STATIC_DIR / \"index.html\"\n    if index_file.exists():\n        return HTMLResponse(content=index_file.read_text(encoding=\"utf-8\"))\n    return HTMLResponse(\"<h1>CC Web Manager</h1><p>index.html not found</p>\")\n\n\n# 也挂载 /static 供直接引用\nif STATIC_DIR.exists():\n    app.mount(\"/static\", StaticFiles(directory=str(STATIC_DIR)), name=\"static\")\n\n\nasync def _auto_backup():\n    \"\"\"每小时备份一次数据库\"\"\"\n    while True:\n        await asyncio.sleep(BACKUP_INTERVAL_HOURS * 3600)\n        try:\n            dest = await database.backup_db(BACKUP_DIR)\n            logger.info(f\"数据库备份完成: {dest}\")\n        except Exception:\n            logger.exception(\"数据库备份失败\")\n\n\n# ---------------------------------------------------------------------------\n# 入口\n# ---------------------------------------------------------------------------\n\nif __name__ == \"__main__\":\n    ec2_ip = os.environ.get(\"EC2_IP\", \"your-ec2-ip\")\n    print(\"\\n\" + \"=\" * 60)\n    print(\"🚀 CC Web Manager 启动中...\")\n    print(f\"   地址: http://{HOST}:{PORT}\")\n    print(f\"🔑 访问 Token: {ACCESS_TOKEN}\")\n    print(f\"📱 手机访问: http://{ec2_ip}:{PORT}?token={ACCESS_TOKEN}\")\n    print(\"=\" * 60 + \"\\n\")\n\n    uvicorn.run(\n        \"server:app\",\n        host=HOST,\n        port=PORT,\n        reload=False,\n        log_level=\"info\",\n    )\n","numLines":426,"startLine":1,"totalLines":426}}}
