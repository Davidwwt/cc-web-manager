{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gg9bWKLthVxhf51MQ6sLYa","type":"tool_result","content":"     1→<!DOCTYPE html>\n     2→<html lang=\"zh-CN\">\n     3→<head>\n     4→<meta charset=\"UTF-8\">\n     5→<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\">\n     6→<meta name=\"theme-color\" content=\"#0d1117\">\n     7→<meta name=\"apple-mobile-web-app-capable\" content=\"yes\">\n     8→<meta name=\"apple-mobile-web-app-status-bar-style\" content=\"black-translucent\">\n     9→<meta name=\"apple-mobile-web-app-title\" content=\"CC Manager\">\n    10→<title>CC Web Manager</title>\n    11→\n    12→<link rel=\"manifest\" href=\"data:application/json,{&quot;name&quot;:&quot;CC Web Manager&quot;,&quot;short_name&quot;:&quot;CC Manager&quot;,&quot;start_url&quot;:&quot;/&quot;,&quot;display&quot;:&quot;standalone&quot;,&quot;background_color&quot;:&quot;%230d1117&quot;,&quot;theme_color&quot;:&quot;%230d1117&quot;,&quot;icons&quot;:[{&quot;src&quot;:&quot;data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🤖</text></svg>&quot;,&quot;sizes&quot;:&quot;any&quot;,&quot;type&quot;:&quot;image/svg+xml&quot;}]}\">\n    13→\n    14→<style>\n    15→/* ===== CSS 变量 ===== */\n    16→:root {\n    17→  --bg:        #0d1117;\n    18→  --bg2:       #161b22;\n    19→  --bg3:       #21262d;\n    20→  --border:    #30363d;\n    21→  --text:      #e6edf3;\n    22→  --text-dim:  #7d8590;\n    23→  --accent:    #58a6ff;\n    24→  --green:     #3fb950;\n    25→  --yellow:    #d29922;\n    26→  --red:       #f85149;\n    27→  --purple:    #bc8cff;\n    28→  --orange:    #ffa657;\n    29→  --radius:    10px;\n    30→  --tab-h:     56px;\n    31→  --safe-bot:  env(safe-area-inset-bottom, 0px);\n    32→}\n    33→\n    34→/* ===== 重置 ===== */\n    35→*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n    36→html, body { height: 100%; overflow: hidden; }\n    37→body {\n    38→  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;\n    39→  background: var(--bg);\n    40→  color: var(--text);\n    41→  font-size: 15px;\n    42→  line-height: 1.5;\n    43→  -webkit-tap-highlight-color: transparent;\n    44→}\n    45→\n    46→/* ===== 布局 ===== */\n    47→#app {\n    48→  display: flex;\n    49→  flex-direction: column;\n    50→  height: 100vh;\n    51→  height: 100dvh;\n    52→}\n    53→\n    54→.page {\n    55→  display: none;\n    56→  flex: 1;\n    57→  overflow-y: auto;\n    58→  -webkit-overflow-scrolling: touch;\n    59→  padding: 12px 12px 0;\n    60→}\n    61→.page.active { display: flex; flex-direction: column; }\n    62→\n    63→/* ===== 底部 Tab 栏 ===== */\n    64→.tab-bar {\n    65→  display: flex;\n    66→  background: var(--bg2);\n    67→  border-top: 1px solid var(--border);\n    68→  height: calc(var(--tab-h) + var(--safe-bot));\n    69→  padding-bottom: var(--safe-bot);\n    70→  flex-shrink: 0;\n    71→}\n    72→.tab-btn {\n    73→  flex: 1;\n    74→  display: flex;\n    75→  flex-direction: column;\n    76→  align-items: center;\n    77→  justify-content: center;\n    78→  gap: 3px;\n    79→  background: none;\n    80→  border: none;\n    81→  color: var(--text-dim);\n    82→  font-size: 10px;\n    83→  cursor: pointer;\n    84→  transition: color .15s;\n    85→  padding: 6px 0;\n    86→}\n    87→.tab-btn .icon { font-size: 22px; line-height: 1; }\n    88→.tab-btn.active { color: var(--accent); }\n    89→\n    90→/* ===== 通用卡片 ===== */\n    91→.card {\n    92→  background: var(--bg2);\n    93→  border: 1px solid var(--border);\n    94→  border-radius: var(--radius);\n    95→  padding: 14px;\n    96→  margin-bottom: 10px;\n    97→}\n    98→\n    99→/* ===== 按钮 ===== */\n   100→.btn {\n   101→  display: inline-flex;\n   102→  align-items: center;\n   103→  justify-content: center;\n   104→  gap: 6px;\n   105→  padding: 10px 18px;\n   106→  border-radius: 8px;\n   107→  border: none;\n   108→  font-size: 14px;\n   109→  font-weight: 600;\n   110→  cursor: pointer;\n   111→  transition: opacity .15s;\n   112→  white-space: nowrap;\n   113→}\n   114→.btn:active { opacity: .7; }\n   115→.btn-primary  { background: var(--accent); color: #0d1117; }\n   116→.btn-success  { background: var(--green);  color: #0d1117; }\n   117→.btn-danger   { background: var(--red);    color: #fff; }\n   118→.btn-warn     { background: var(--yellow); color: #0d1117; }\n   119→.btn-ghost    { background: var(--bg3);    color: var(--text); border: 1px solid var(--border); }\n   120→.btn-sm       { padding: 6px 12px; font-size: 13px; }\n   121→.btn-block    { width: 100%; }\n   122→\n   123→/* ===== 状态徽章 ===== */\n   124→.badge {\n   125→  display: inline-block;\n   126→  padding: 2px 8px;\n   127→  border-radius: 99px;\n   128→  font-size: 11px;\n   129→  font-weight: 700;\n   130→  text-transform: uppercase;\n   131→  letter-spacing: .5px;\n   132→}\n   133→.badge-pending    { background: #30363d; color: var(--text-dim); }\n   134→.badge-planning   { background: #1f3a5f; color: var(--accent); }\n   135→.badge-plan_review{ background: #3a2e00; color: var(--yellow); }\n   136→.badge-executing  { background: #1a3a1a; color: var(--green); }\n   137→.badge-completed  { background: #1a3a1a; color: var(--green); }\n   138→.badge-failed     { background: #3a1a1a; color: var(--red); }\n   139→\n   140→/* ===== 任务输入区 ===== */\n   141→.input-area {\n   142→  display: flex;\n   143→  gap: 8px;\n   144→  margin-bottom: 12px;\n   145→  align-items: flex-end;\n   146→}\n   147→.input-wrap {\n   148→  flex: 1;\n   149→  background: var(--bg2);\n   150→  border: 1px solid var(--border);\n   151→  border-radius: var(--radius);\n   152→  display: flex;\n   153→  align-items: flex-end;\n   154→  overflow: hidden;\n   155→}\n   156→textarea.task-input {\n   157→  flex: 1;\n   158→  background: transparent;\n   159→  border: none;\n   160→  color: var(--text);\n   161→  font-size: 15px;\n   162→  padding: 12px;\n   163→  resize: none;\n   164→  min-height: 48px;\n   165→  max-height: 180px;\n   166→  font-family: inherit;\n   167→  line-height: 1.5;\n   168→  outline: none;\n   169→}\n   170→.voice-btn {\n   171→  background: none;\n   172→  border: none;\n   173→  color: var(--text-dim);\n   174→  font-size: 20px;\n   175→  padding: 12px 10px;\n   176→  cursor: pointer;\n   177→  flex-shrink: 0;\n   178→}\n   179→.voice-btn.listening { color: var(--red); animation: pulse 1s infinite; }\n   180→@keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:.4; } }\n   181→\n   182→/* ===== 任务卡片 ===== */\n   183→.task-card {\n   184→  background: var(--bg2);\n   185→  border: 1px solid var(--border);\n   186→  border-radius: var(--radius);\n   187→  margin-bottom: 10px;\n   188→  overflow: hidden;\n   189→  cursor: pointer;\n   190→  transition: border-color .15s;\n   191→}\n   192→.task-card:active { border-color: var(--accent); }\n   193→.task-header {\n   194→  display: flex;\n   195→  align-items: center;\n   196→  gap: 10px;\n   197→  padding: 12px 14px;\n   198→}\n   199→.task-prompt {\n   200→  flex: 1;\n   201→  font-size: 14px;\n   202→  color: var(--text);\n   203→  overflow: hidden;\n   204→  display: -webkit-box;\n   205→  -webkit-line-clamp: 2;\n   206→  -webkit-box-orient: vertical;\n   207→}\n   208→.task-meta {\n   209→  font-size: 11px;\n   210→  color: var(--text-dim);\n   211→  margin-top: 2px;\n   212→}\n   213→.task-detail {\n   214→  display: none;\n   215→  padding: 0 14px 14px;\n   216→  border-top: 1px solid var(--border);\n   217→}\n   218→.task-detail.open { display: block; }\n   219→.task-full-prompt {\n   220→  background: var(--bg3);\n   221→  border-radius: 6px;\n   222→  padding: 10px;\n   223→  font-size: 13px;\n   224→  margin-bottom: 10px;\n   225→  white-space: pre-wrap;\n   226→  word-break: break-word;\n   227→}\n   228→.task-log-preview {\n   229→  background: #0d1117;\n   230→  border-radius: 6px;\n   231→  padding: 10px;\n   232→  font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;\n   233→  font-size: 12px;\n   234→  color: #7ee787;\n   235→  max-height: 200px;\n   236→  overflow-y: auto;\n   237→  white-space: pre-wrap;\n   238→  word-break: break-word;\n   239→  margin-bottom: 10px;\n   240→}\n   241→.task-actions { display: flex; gap: 8px; flex-wrap: wrap; }\n   242→\n   243→/* ===== 日志终端 ===== */\n   244→.terminal {\n   245→  flex: 1;\n   246→  background: #0d1117;\n   247→  border-radius: var(--radius);\n   248→  padding: 12px;\n   249→  font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;\n   250→  font-size: 12px;\n   251→  color: #7ee787;\n   252→  overflow-y: auto;\n   253→  -webkit-overflow-scrolling: touch;\n   254→  white-space: pre-wrap;\n   255→  word-break: break-word;\n   256→  border: 1px solid var(--border);\n   257→  min-height: 200px;\n   258→}\n   259→.terminal-header {\n   260→  display: flex;\n   261→  align-items: center;\n   262→  justify-content: space-between;\n   263→  margin-bottom: 8px;\n   264→}\n   265→.terminal-title { font-size: 13px; color: var(--text-dim); }\n   266→.terminal-dots { display: flex; gap: 5px; }\n   267→.terminal-dots span {\n   268→  width: 10px; height: 10px; border-radius: 50%;\n   269→}\n   270→.dot-red    { background: #ff5f57; }\n   271→.dot-yellow { background: #febc2e; }\n   272→.dot-green  { background: #28c840; }\n   273→\n   274→/* ===== 文件浏览器 ===== */\n   275→.file-list { list-style: none; }\n   276→.file-item {\n   277→  display: flex;\n   278→  align-items: center;\n   279→  gap: 10px;\n   280→  padding: 10px 14px;\n   281→  border-bottom: 1px solid var(--border);\n   282→  cursor: pointer;\n   283→  font-size: 14px;\n   284→}\n   285→.file-item:last-child { border-bottom: none; }\n   286→.file-item:active { background: var(--bg3); }\n   287→.file-icon { font-size: 18px; width: 24px; text-align: center; }\n   288→.file-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n   289→.file-size { font-size: 11px; color: var(--text-dim); }\n   290→.file-content {\n   291→  background: var(--bg3);\n   292→  border-radius: 6px;\n   293→  padding: 12px;\n   294→  font-family: monospace;\n   295→  font-size: 12px;\n   296→  overflow-x: auto;\n   297→  white-space: pre;\n   298→  margin-top: 8px;\n   299→  max-height: 60vh;\n   300→  overflow-y: auto;\n   301→}\n   302→.breadcrumb {\n   303→  display: flex;\n   304→  align-items: center;\n   305→  gap: 4px;\n   306→  margin-bottom: 10px;\n   307→  font-size: 13px;\n   308→  flex-wrap: wrap;\n   309→}\n   310→.breadcrumb-item { color: var(--accent); cursor: pointer; }\n   311→.breadcrumb-sep  { color: var(--text-dim); }\n   312→.breadcrumb-cur  { color: var(--text-dim); }\n   313→\n   314→/* ===== Git 日志 ===== */\n   315→.commit-item {\n   316→  padding: 10px 0;\n   317→  border-bottom: 1px solid var(--border);\n   318→}\n   319→.commit-item:last-child { border-bottom: none; }\n   320→.commit-hash { font-family: monospace; font-size: 11px; color: var(--purple); }\n   321→.commit-msg  { font-size: 13px; margin: 2px 0; }\n   322→.commit-meta { font-size: 11px; color: var(--text-dim); }\n   323→\n   324→/* ===== 状态页 ===== */\n   325→.stat-grid {\n   326→  display: grid;\n   327→  grid-template-columns: 1fr 1fr;\n   328→  gap: 8px;\n   329→  margin-bottom: 10px;\n   330→}\n   331→.stat-box {\n   332→  background: var(--bg3);\n   333→  border-radius: var(--radius);\n   334→  padding: 12px;\n   335→  text-align: center;\n   336→}\n   337→.stat-num { font-size: 28px; font-weight: 700; }\n   338→.stat-lbl { font-size: 11px; color: var(--text-dim); margin-top: 2px; }\n   339→.progress-content {\n   340→  background: var(--bg3);\n   341→  border-radius: 6px;\n   342→  padding: 12px;\n   343→  font-size: 13px;\n   344→  white-space: pre-wrap;\n   345→  word-break: break-word;\n   346→  max-height: 50vh;\n   347→  overflow-y: auto;\n   348→}\n   349→\n   350→/* ===== 加载、空态 ===== */\n   351→.spinner {\n   352→  display: inline-block;\n   353→  width: 18px; height: 18px;\n   354→  border: 2px solid var(--border);\n   355→  border-top-color: var(--accent);\n   356→  border-radius: 50%;\n   357→  animation: spin .7s linear infinite;\n   358→}\n   359→@keyframes spin { to { transform: rotate(360deg); } }\n   360→.empty { text-align: center; color: var(--text-dim); padding: 40px 0; font-size: 14px; }\n   361→.section-title {\n   362→  font-size: 12px;\n   363→  font-weight: 700;\n   364→  text-transform: uppercase;\n   365→  letter-spacing: .5px;\n   366→  color: var(--text-dim);\n   367→  margin-bottom: 8px;\n   368→}\n   369→\n   370→/* ===== Toast ===== */\n   371→#toast {\n   372→  position: fixed;\n   373→  bottom: calc(var(--tab-h) + var(--safe-bot) + 12px);\n   374→  left: 50%;\n   375→  transform: translateX(-50%);\n   376→  background: var(--bg3);\n   377→  border: 1px solid var(--border);\n   378→  color: var(--text);\n   379→  padding: 10px 18px;\n   380→  border-radius: 99px;\n   381→  font-size: 13px;\n   382→  pointer-events: none;\n   383→  opacity: 0;\n   384→  transition: opacity .2s;\n   385→  white-space: nowrap;\n   386→  z-index: 999;\n   387→}\n   388→#toast.show { opacity: 1; }\n   389→\n   390→/* ===== 选择器 ===== */\n   391→select.filter-select {\n   392→  background: var(--bg3);\n   393→  border: 1px solid var(--border);\n   394→  color: var(--text);\n   395→  padding: 6px 10px;\n   396→  border-radius: 6px;\n   397→  font-size: 13px;\n   398→  outline: none;\n   399→}\n   400→</style>\n   401→</head>\n   402→\n   403→<body>\n   404→<div id=\"app\">\n   405→\n   406→  <!-- ====== 任务页 ====== -->\n   407→  <div class=\"page active\" id=\"page-tasks\">\n   408→\n   409→    <!-- 输入区 -->\n   410→    <div class=\"input-area\">\n   411→      <div class=\"input-wrap\">\n   412→        <textarea class=\"task-input\" id=\"task-input\"\n   413→          placeholder=\"描述你的任务…&#10;Claude Code 会帮你完成\"\n   414→          rows=\"2\"\n   415→          oninput=\"autoResize(this)\"></textarea>\n   416→        <button class=\"voice-btn\" id=\"voice-btn\" onclick=\"toggleVoice()\" title=\"语音输入\">🎤</button>\n   417→      </div>\n   418→      <button class=\"btn btn-primary\" onclick=\"submitTask()\" style=\"height:48px;border-radius:var(--radius)\">\n   419→        发送\n   420→      </button>\n   421→    </div>\n   422→\n   423→    <!-- 筛选 -->\n   424→    <div style=\"display:flex;align-items:center;justify-content:space-between;margin-bottom:10px\">\n   425→      <span class=\"section-title\">任务列表</span>\n   426→      <select class=\"filter-select\" id=\"status-filter\" onchange=\"loadTasks()\">\n   427→        <option value=\"\">全部</option>\n   428→        <option value=\"pending\">待执行</option>\n   429→        <option value=\"executing\">执行中</option>\n   430→        <option value=\"completed\">已完成</option>\n   431→        <option value=\"failed\">失败</option>\n   432→      </select>\n   433→    </div>\n   434→\n   435→    <div id=\"tasks-list\">\n   436→      <div class=\"empty\"><div class=\"spinner\"></div><br>加载中…</div>\n   437→    </div>\n   438→  </div>\n   439→\n   440→  <!-- ====== 日志页 ====== -->\n   441→  <div class=\"page\" id=\"page-logs\">\n   442→    <div class=\"terminal-header\">\n   443→      <div class=\"terminal-dots\">\n   444→        <span class=\"dot-red\"></span>\n   445→        <span class=\"dot-yellow\"></span>\n   446→        <span class=\"dot-green\"></span>\n   447→      </div>\n   448→      <span class=\"terminal-title\" id=\"log-title\">选择一个执行中的任务</span>\n   449→      <button class=\"btn btn-ghost btn-sm\" onclick=\"clearLog()\">清屏</button>\n   450→    </div>\n   451→\n   452→    <div style=\"margin-bottom:8px;display:flex;gap:8px;align-items:center;flex-wrap:wrap\">\n   453→      <select class=\"filter-select\" id=\"log-task-select\" onchange=\"switchLogTask()\">\n   454→        <option value=\"\">-- 选择任务 --</option>\n   455→      </select>\n   456→      <label style=\"font-size:13px;color:var(--text-dim);display:flex;align-items:center;gap:4px\">\n   457→        <input type=\"checkbox\" id=\"auto-scroll\" checked style=\"accent-color:var(--accent)\">\n   458→        自动滚动\n   459→      </label>\n   460→    </div>\n   461→\n   462→    <div class=\"terminal\" id=\"log-output\">等待任务输出…</div>\n   463→  </div>\n   464→\n   465→  <!-- ====== 文件页 ====== -->\n   466→  <div class=\"page\" id=\"page-files\">\n   467→    <div class=\"breadcrumb\" id=\"breadcrumb\">\n   468→      <span class=\"breadcrumb-item\" onclick=\"browseFiles('')\">🏠 根目录</span>\n   469→    </div>\n   470→\n   471→    <div class=\"card\" id=\"file-browser\">\n   472→      <div class=\"empty\"><div class=\"spinner\"></div><br>加载中…</div>\n   473→    </div>\n   474→\n   475→    <!-- Git 日志 -->\n   476→    <div class=\"section-title\" style=\"margin-top:6px\">Git 提交记录</div>\n   477→    <div class=\"card\" id=\"git-log\">\n   478→      <div class=\"empty\"><div class=\"spinner\"></div></div>\n   479→    </div>\n   480→  </div>\n   481→\n   482→  <!-- ====== 状态页 ====== -->\n   483→  <div class=\"page\" id=\"page-status\">\n   484→    <div class=\"stat-grid\" id=\"stat-grid\">\n   485→      <div class=\"stat-box\"><div class=\"stat-num\" id=\"s-pending\">—</div><div class=\"stat-lbl\">待执行</div></div>\n   486→      <div class=\"stat-box\"><div class=\"stat-num\" id=\"s-executing\">—</div><div class=\"stat-lbl\">执行中</div></div>\n   487→      <div class=\"stat-box\"><div class=\"stat-num\" id=\"s-completed\">—</div><div class=\"stat-lbl\">已完成</div></div>\n   488→      <div class=\"stat-box\"><div class=\"stat-num\" id=\"s-failed\">—</div><div class=\"stat-lbl\">失败</div></div>\n   489→    </div>\n   490→\n   491→    <div class=\"section-title\">Worktree 状态</div>\n   492→    <div class=\"card\" id=\"worktree-list\">\n   493→      <div class=\"empty\">加载中…</div>\n   494→    </div>\n   495→\n   496→    <div class=\"section-title\" style=\"margin-top:6px\">PROGRESS.md</div>\n   497→    <div class=\"progress-content\" id=\"progress-content\">加载中…</div>\n   498→\n   499→    <div style=\"margin-bottom:16px\"></div>\n   500→  </div>\n   501→\n   502→  <!-- ====== 底部 Tab 栏 ====== -->\n   503→  <nav class=\"tab-bar\">\n   504→    <button class=\"tab-btn active\" id=\"tab-tasks\"  onclick=\"switchTab('tasks')\">\n   505→      <span class=\"icon\">📋</span>任务\n   506→    </button>\n   507→    <button class=\"tab-btn\" id=\"tab-logs\"  onclick=\"switchTab('logs')\">\n   508→      <span class=\"icon\">📟</span>日志\n   509→    </button>\n   510→    <button class=\"tab-btn\" id=\"tab-files\" onclick=\"switchTab('files')\">\n   511→      <span class=\"icon\">📁</span>文件\n   512→    </button>\n   513→    <button class=\"tab-btn\" id=\"tab-status\" onclick=\"switchTab('status')\">\n   514→      <span class=\"icon\">⚙️</span>状态\n   515→    </button>\n   516→  </nav>\n   517→</div>\n   518→\n   519→<div id=\"toast\"></div>\n   520→\n   521→<script>\n   522→// ============================================================\n   523→// 工具函数\n   524→// ============================================================\n   525→\n   526→const TOKEN = (() => {\n   527→  const params = new URLSearchParams(location.search);\n   528→  const t = params.get('token');\n   529→  if (t) { localStorage.setItem('cc_token', t); return t; }\n   530→  return localStorage.getItem('cc_token') || '';\n   531→})();\n   532→\n   533→function api(path, opts = {}) {\n   534→  const sep = path.includes('?') ? '&' : '?';\n   535→  return fetch(path + sep + 'token=' + encodeURIComponent(TOKEN), {\n   536→    headers: { 'Content-Type': 'application/json', ...(opts.headers || {}) },\n   537→    ...opts,\n   538→  }).then(r => {\n   539→    if (!r.ok) return r.json().then(e => Promise.reject(e.detail || r.statusText));\n   540→    return r.json();\n   541→  });\n   542→}\n   543→\n   544→function wsUrl(path) {\n   545→  const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';\n   546→  return `${proto}//${location.host}${path}?token=${encodeURIComponent(TOKEN)}`;\n   547→}\n   548→\n   549→let _toastTimer;\n   550→function toast(msg, duration = 2500) {\n   551→  const el = document.getElementById('toast');\n   552→  el.textContent = msg;\n   553→  el.classList.add('show');\n   554→  clearTimeout(_toastTimer);\n   555→  _toastTimer = setTimeout(() => el.classList.remove('show'), duration);\n   556→}\n   557→\n   558→function fmtTime(iso) {\n   559→  if (!iso) return '—';\n   560→  const d = new Date(iso + (iso.endsWith('Z') ? '' : 'Z'));\n   561→  return d.toLocaleString('zh-CN', { month: '2-digit', day: '2-digit',\n   562→    hour: '2-digit', minute: '2-digit' });\n   563→}\n   564→\n   565→function fmtSize(bytes) {\n   566→  if (bytes == null) return '';\n   567→  if (bytes < 1024) return bytes + 'B';\n   568→  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + 'KB';\n   569→  return (bytes / 1024 / 1024).toFixed(1) + 'MB';\n   570→}\n   571→\n   572→function autoResize(el) {\n   573→  el.style.height = 'auto';\n   574→  el.style.height = Math.min(el.scrollHeight, 180) + 'px';\n   575→}\n   576→\n   577→// ============================================================\n   578→// Tab 切换\n   579→// ============================================================\n   580→\n   581→function switchTab(name) {\n   582→  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));\n   583→  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));\n   584→  document.getElementById('page-' + name).classList.add('active');\n   585→  document.getElementById('tab-' + name).classList.add('active');\n   586→\n   587→  if (name === 'tasks')  loadTasks();\n   588→  if (name === 'logs')   loadLogTaskList();\n   589→  if (name === 'files')  { browseFiles(_currentFilePath); loadGitLog(); }\n   590→  if (name === 'status') loadStatus();\n   591→}\n   592→\n   593→// ============================================================\n   594→// 全局 WebSocket：事件推送\n   595→// ============================================================\n   596→\n   597→let _evtWs;\n   598→function connectEvents() {\n   599→  _evtWs = new WebSocket(wsUrl('/ws/events'));\n   600→  _evtWs.onmessage = e => {\n   601→    const data = JSON.parse(e.data);\n   602→    if (data.type === 'task_status') {\n   603→      // 刷新任务列表\n   604→      const activePage = document.querySelector('.page.active')?.id;\n   605→      if (activePage === 'page-tasks')  loadTasks();\n   606→      if (activePage === 'page-status') loadStatus();\n   607→      if (activePage === 'page-logs')   loadLogTaskList();\n   608→\n   609→      const statusNames = { executing:'开始执行', completed:'任务完成 ✓', failed:'任务失败 ✗', plan_review:'等待确认计划' };\n   610→      const msg = statusNames[data.status];\n   611→      if (msg) toast(`任务 #${data.task_id}: ${msg}`);\n   612→    }\n   613→  };\n   614→  _evtWs.onclose = () => setTimeout(connectEvents, 3000);\n   615→  _evtWs.onerror = () => _evtWs.close();\n   616→}\n   617→\n   618→// ============================================================\n   619→// 任务页\n   620→// ============================================================\n   621→\n   622→async function submitTask() {\n   623→  const input = document.getElementById('task-input');\n   624→  const prompt = input.value.trim();\n   625→  if (!prompt) { toast('请输入任务描述'); return; }\n   626→\n   627→  try {\n   628→    const res = await api('/api/tasks', {\n   629→      method: 'POST',\n   630→      body: JSON.stringify({ prompt }),\n   631→    });\n   632→    input.value = '';\n   633→    input.style.height = 'auto';\n   634→    toast(`任务 #${res.task.id} 已提交`);\n   635→    loadTasks();\n   636→  } catch (err) {\n   637→    toast('提交失败: ' + err, 4000);\n   638→  }\n   639→}\n   640→\n   641→// Enter 发送（Shift+Enter 换行）\n   642→document.getElementById('task-input').addEventListener('keydown', e => {\n   643→  if (e.key === 'Enter' && !e.shiftKey) {\n   644→    e.preventDefault();\n   645→    submitTask();\n   646→  }\n   647→});\n   648→\n   649→async function loadTasks() {\n   650→  const status = document.getElementById('status-filter').value;\n   651→  const container = document.getElementById('tasks-list');\n   652→\n   653→  try {\n   654→    const res = await api('/api/tasks' + (status ? `?status=${status}` : ''));\n   655→    const tasks = res.tasks;\n   656→\n   657→    if (!tasks.length) {\n   658→      container.innerHTML = '<div class=\"empty\">暂无任务</div>';\n   659→      return;\n   660→    }\n   661→\n   662→    container.innerHTML = tasks.map(t => taskCardHTML(t)).join('');\n   663→  } catch (err) {\n   664→    container.innerHTML = `<div class=\"empty\" style=\"color:var(--red)\">加载失败: ${err}</div>`;\n   665→  }\n   666→}\n   667→\n   668→function taskCardHTML(t) {\n   669→  const statusLabel = {\n   670→    pending: '待执行', planning: '规划中', plan_review: '等待确认',\n   671→    executing: '执行中', completed: '已完成', failed: '失败',\n   672→  }[t.status] || t.status;\n   673→\n   674→  const logPreview = t.log ? `\n   675→    <div class=\"task-log-preview\" id=\"log-preview-${t.id}\">${escHtml(t.log.slice(-2000))}</div>` : '';\n   676→\n   677→  const actions = taskActions(t);\n   678→\n   679→  return `\n   680→<div class=\"task-card\" id=\"task-card-${t.id}\">\n   681→  <div class=\"task-header\" onclick=\"toggleTask(${t.id})\">\n   682→    <div style=\"flex:1;min-width:0\">\n   683→      <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:4px\">\n   684→        <span class=\"badge badge-${t.status}\">${statusLabel}</span>\n   685→        <span style=\"font-size:12px;color:var(--text-dim)\">#${t.id}</span>\n   686→      </div>\n   687→      <div class=\"task-prompt\">${escHtml(t.prompt)}</div>\n   688→      <div class=\"task-meta\">${fmtTime(t.created_at)}${t.completed_at ? ' · 完成: ' + fmtTime(t.completed_at) : ''}</div>\n   689→    </div>\n   690→    <span style=\"color:var(--text-dim);font-size:18px\">›</span>\n   691→  </div>\n   692→  <div class=\"task-detail\" id=\"task-detail-${t.id}\">\n   693→    <div class=\"task-full-prompt\">${escHtml(t.prompt)}</div>\n   694→    ${t.plan ? `<div class=\"section-title\" style=\"margin-bottom:4px\">执行计划</div><div class=\"task-full-prompt\" style=\"color:var(--accent)\">${escHtml(t.plan)}</div>` : ''}\n   695→    ${t.error ? `<div style=\"color:var(--red);font-size:13px;margin-bottom:8px\">错误: ${escHtml(t.error)}</div>` : ''}\n   696→    ${logPreview}\n   697→    <div class=\"task-actions\">${actions}</div>\n   698→  </div>\n   699→</div>`;\n   700→}\n   701→\n   702→function taskActions(t) {\n   703→  const btns = [];\n   704→  if (t.status === 'plan_review') {\n   705→    btns.push(`<button class=\"btn btn-success btn-sm\" onclick=\"approveTask(${t.id})\">✓ 确认执行</button>`);\n   706→    btns.push(`<button class=\"btn btn-danger btn-sm\" onclick=\"rejectTask(${t.id})\">✗ 拒绝</button>`);\n   707→  }\n   708→  if (t.status === 'failed') {\n   709→    btns.push(`<button class=\"btn btn-warn btn-sm\" onclick=\"retryTask(${t.id})\">↺ 重试</button>`);\n   710→  }\n   711→  if (t.status === 'executing') {\n   712→    btns.push(`<button class=\"btn btn-ghost btn-sm\" onclick=\"viewLog(${t.id})\">📟 查看日志</button>`);\n   713→  }\n   714→  if (t.log) {\n   715→    btns.push(`<button class=\"btn btn-ghost btn-sm\" onclick=\"viewLog(${t.id})\">📟 查看日志</button>`);\n   716→  }\n   717→  btns.push(`<button class=\"btn btn-ghost btn-sm\" style=\"color:var(--red)\" onclick=\"deleteTask(${t.id})\">🗑 删除</button>`);\n   718→  return btns.join('');\n   719→}\n   720→\n   721→function toggleTask(id) {\n   722→  const detail = document.getElementById('task-detail-' + id);\n   723→  detail.classList.toggle('open');\n   724→}\n   725→\n   726→async function approveTask(id) {\n   727→  try { await api(`/api/tasks/${id}/approve`, { method: 'POST' }); toast('已确认，任务将开始执行'); loadTasks(); }\n   728→  catch (e) { toast('操作失败: ' + e, 4000); }\n   729→}\n   730→\n   731→async function rejectTask(id) {\n   732→  try { await api(`/api/tasks/${id}/reject`, { method: 'POST' }); toast('已拒绝'); loadTasks(); }\n   733→  catch (e) { toast('操作失败: ' + e, 4000); }\n   734→}\n   735→\n   736→async function retryTask(id) {\n   737→  try { await api(`/api/tasks/${id}/retry`, { method: 'POST' }); toast('任务已重新加入队列'); loadTasks(); }\n   738→  catch (e) { toast('操作失败: ' + e, 4000); }\n   739→}\n   740→\n   741→async function deleteTask(id) {\n   742→  if (!confirm('确定删除任务 #' + id + '?')) return;\n   743→  try { await api(`/api/tasks/${id}`, { method: 'DELETE' }); toast('任务已删除'); loadTasks(); }\n   744→  catch (e) { toast('删除失败: ' + e, 4000); }\n   745→}\n   746→\n   747→function viewLog(id) {\n   748→  document.getElementById('log-task-select').value = id;\n   749→  switchLogTask();\n   750→  switchTab('logs');\n   751→}\n   752→\n   753→// ============================================================\n   754→// 日志页\n   755→// ============================================================\n   756→\n   757→let _logWs = null;\n   758→let _currentLogTaskId = null;\n   759→\n   760→async function loadLogTaskList() {\n   761→  const sel = document.getElementById('log-task-select');\n   762→  const prev = sel.value;\n   763→  try {\n   764→    const res = await api('/api/tasks');\n   765→    const tasks = res.tasks.filter(t => t.log || t.status === 'executing');\n   766→    sel.innerHTML = '<option value=\"\">-- 选择任务 --</option>' +\n   767→      tasks.map(t => `<option value=\"${t.id}\" ${t.id == prev ? 'selected' : ''}>#${t.id} [${t.status}] ${escHtml(t.prompt.slice(0,40))}</option>`).join('');\n   768→    if (prev && !sel.value) sel.value = '';\n   769→  } catch {}\n   770→}\n   771→\n   772→function switchLogTask() {\n   773→  const id = parseInt(document.getElementById('log-task-select').value);\n   774→  if (!id) return;\n   775→  openLogWs(id);\n   776→}\n   777→\n   778→function openLogWs(taskId) {\n   779→  if (_logWs) { _logWs.close(); _logWs = null; }\n   780→  _currentLogTaskId = taskId;\n   781→  document.getElementById('log-title').textContent = `任务 #${taskId}`;\n   782→  document.getElementById('log-output').textContent = '';\n   783→\n   784→  _logWs = new WebSocket(wsUrl(`/ws/tasks/${taskId}/log`));\n   785→  _logWs.onmessage = e => {\n   786→    const data = JSON.parse(e.data);\n   787→    if (data.type === 'history' || data.type === 'log') {\n   788→      appendLog(data.text);\n   789→    }\n   790→  };\n   791→  _logWs.onerror = () => { appendLog('\\n[WebSocket 连接错误]\\n'); };\n   792→  _logWs.onclose = () => { if (_currentLogTaskId === taskId) appendLog('\\n[连接已关闭]\\n'); };\n   793→}\n   794→\n   795→function appendLog(text) {\n   796→  const out = document.getElementById('log-output');\n   797→  out.textContent += text;\n   798→  const autoScroll = document.getElementById('auto-scroll').checked;\n   799→  if (autoScroll) out.scrollTop = out.scrollHeight;\n   800→}\n   801→\n   802→function clearLog() {\n   803→  document.getElementById('log-output').textContent = '';\n   804→}\n   805→\n   806→// ============================================================\n   807→// 文件页\n   808→// ============================================================\n   809→\n   810→let _currentFilePath = '';\n   811→\n   812→async function browseFiles(path) {\n   813→  _currentFilePath = path;\n   814→  updateBreadcrumb(path);\n   815→  const browser = document.getElementById('file-browser');\n   816→  browser.innerHTML = '<div class=\"empty\"><div class=\"spinner\"></div></div>';\n   817→\n   818→  try {\n   819→    const res = await api('/api/files?path=' + encodeURIComponent(path));\n   820→    if (!res.items.length) {\n   821→      browser.innerHTML = '<div class=\"empty\">空目录</div>';\n   822→      return;\n   823→    }\n   824→    browser.innerHTML = `<ul class=\"file-list\">${res.items.map(item => `\n   825→      <li class=\"file-item\" onclick=\"${item.is_dir ? `browseFiles('${item.path}')` : `showFile('${item.path}')`}\">\n   826→        <span class=\"file-icon\">${item.is_dir ? '📁' : fileIcon(item.name)}</span>\n   827→        <span class=\"file-name\">${escHtml(item.name)}</span>\n   828→        <span class=\"file-size\">${item.is_dir ? '' : fmtSize(item.size)}</span>\n   829→      </li>`).join('')}</ul>`;\n   830→  } catch (err) {\n   831→    browser.innerHTML = `<div class=\"empty\" style=\"color:var(--red)\">${err}</div>`;\n   832→  }\n   833→}\n   834→\n   835→async function showFile(path) {\n   836→  const browser = document.getElementById('file-browser');\n   837→  browser.innerHTML = '<div class=\"empty\"><div class=\"spinner\"></div></div>';\n   838→  updateBreadcrumb(path);\n   839→\n   840→  try {\n   841→    const res = await api('/api/files/' + encodeURIComponent(path));\n   842→    browser.innerHTML = `\n   843→      <button class=\"btn btn-ghost btn-sm\" style=\"margin-bottom:8px\" onclick=\"browseFiles('${escAttr(pathParent(path))}')\">← 返回</button>\n   844→      <div class=\"file-content\">${escHtml(res.content)}</div>`;\n   845→  } catch (err) {\n   846→    browser.innerHTML = `<div class=\"empty\" style=\"color:var(--red)\">${err}</div>`;\n   847→  }\n   848→}\n   849→\n   850→function updateBreadcrumb(path) {\n   851→  const bc = document.getElementById('breadcrumb');\n   852→  const parts = path ? path.split('/').filter(Boolean) : [];\n   853→  let html = `<span class=\"breadcrumb-item\" onclick=\"browseFiles('')\">🏠 根目录</span>`;\n   854→  let accum = '';\n   855→  parts.forEach((p, i) => {\n   856→    accum += (accum ? '/' : '') + p;\n   857→    html += `<span class=\"breadcrumb-sep\">/</span>`;\n   858→    if (i < parts.length - 1) {\n   859→      html += `<span class=\"breadcrumb-item\" onclick=\"browseFiles('${escAttr(accum)}')\">${escHtml(p)}</span>`;\n   860→    } else {\n   861→      html += `<span class=\"breadcrumb-cur\">${escHtml(p)}</span>`;\n   862→    }\n   863→  });\n   864→  bc.innerHTML = html;\n   865→}\n   866→\n   867→function pathParent(path) {\n   868→  const parts = path.split('/').filter(Boolean);\n   869→  parts.pop();\n   870→  return parts.join('/');\n   871→}\n   872→\n   873→function fileIcon(name) {\n   874→  const ext = name.split('.').pop().toLowerCase();\n   875→  const map = { py:'🐍', js:'📜', ts:'📜', html:'🌐', css:'🎨', json:'📋',\n   876→    md:'📝', txt:'📝', sh:'⚡', yml:'⚙️', yaml:'⚙️', toml:'⚙️',\n   877→    png:'🖼️', jpg:'🖼️', jpeg:'🖼️', gif:'🖼️', svg:'🖼️',\n   878→    pdf:'📄', zip:'📦', gz:'📦', db:'🗃️' };\n   879→  return map[ext] || '📄';\n   880→}\n   881→\n   882→async function loadGitLog() {\n   883→  const container = document.getElementById('git-log');\n   884→  try {\n   885→    const res = await api('/api/git/log?limit=10');\n   886→    if (!res.commits.length) {\n   887→      container.innerHTML = '<div class=\"empty\">暂无提交记录</div>';\n   888→      return;\n   889→    }\n   890→    container.innerHTML = res.commits.map(c => `\n   891→      <div class=\"commit-item\">\n   892→        <div class=\"commit-hash\">${c.hash.slice(0,8)}</div>\n   893→        <div class=\"commit-msg\">${escHtml(c.message)}</div>\n   894→        <div class=\"commit-meta\">${escHtml(c.author)} · ${fmtTime(c.date)}</div>\n   895→      </div>`).join('');\n   896→  } catch (err) {\n   897→    container.innerHTML = `<div class=\"empty\" style=\"color:var(--red)\">${err}</div>`;\n   898→  }\n   899→}\n   900→\n   901→// ============================================================\n   902→// 状态页\n   903→// ============================================================\n   904→\n   905→async function loadStatus() {\n   906→  try {\n   907→    const res = await api('/api/status');\n   908→    const counts = res.task_counts || {};\n   909→    document.getElementById('s-pending').textContent   = counts.pending   || 0;\n   910→    document.getElementById('s-executing').textContent = counts.executing || 0;\n   911→    document.getElementById('s-completed').textContent = counts.completed || 0;\n   912→    document.getElementById('s-failed').textContent    = counts.failed    || 0;\n   913→\n   914→    const wt = document.getElementById('worktree-list');\n   915→    if (res.worktrees && res.worktrees.length) {\n   916→      wt.innerHTML = res.worktrees.map(w => `\n   917→        <div style=\"padding:8px 0;border-bottom:1px solid var(--border)\">\n   918→          <div style=\"font-size:13px;font-family:monospace\">${escHtml(w.path)}</div>\n   919→          <div style=\"font-size:11px;color:var(--text-dim)\">分支: ${escHtml(w.branch || '—')} · HEAD: ${(w.head||'').slice(0,8)}</div>\n   920→        </div>`).join('');\n   921→    } else {\n   922→      wt.innerHTML = '<div class=\"empty\">暂无 Worktree</div>';\n   923→    }\n   924→  } catch (err) {\n   925→    toast('加载状态失败: ' + err, 3000);\n   926→  }\n   927→\n   928→  try {\n   929→    const res = await api('/api/progress');\n   930→    document.getElementById('progress-content').textContent = res.content || '空';\n   931→  } catch {}\n   932→}\n   933→\n   934→// ============================================================\n   935→// 语音输入\n   936→// ============================================================\n   937→\n   938→let _recognition = null;\n   939→let _listening = false;\n   940→\n   941→function toggleVoice() {\n   942→  if (!('webkitSpeechRecognition' in window || 'SpeechRecognition' in window)) {\n   943→    toast('当前浏览器不支持语音输入');\n   944→    return;\n   945→  }\n   946→\n   947→  if (_listening) {\n   948→    _recognition && _recognition.stop();\n   949→    return;\n   950→  }\n   951→\n   952→  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;\n   953→  _recognition = new SpeechRecognition();\n   954→  _recognition.lang = 'zh-CN';\n   955→  _recognition.continuous = false;\n   956→  _recognition.interimResults = false;\n   957→\n   958→  _recognition.onstart = () => {\n   959→    _listening = true;\n   960→    document.getElementById('voice-btn').classList.add('listening');\n   961→    toast('正在聆听…', 10000);\n   962→  };\n   963→  _recognition.onresult = e => {\n   964→    const text = e.results[0][0].transcript;\n   965→    const input = document.getElementById('task-input');\n   966→    input.value = (input.value + text).trim();\n   967→    autoResize(input);\n   968→  };\n   969→  _recognition.onend = () => {\n   970→    _listening = false;\n   971→    document.getElementById('voice-btn').classList.remove('listening');\n   972→  };\n   973→  _recognition.onerror = e => {\n   974→    toast('语音识别错误: ' + e.error);\n   975→    _listening = false;\n   976→    document.getElementById('voice-btn').classList.remove('listening');\n   977→  };\n   978→\n   979→  _recognition.start();\n   980→}\n   981→\n   982→// ============================================================\n   983→// 安全工具\n   984→// ============================================================\n   985→\n   986→function escHtml(str) {\n   987→  return String(str ?? '')\n   988→    .replace(/&/g, '&amp;')\n   989→    .replace(/</g, '&lt;')\n   990→    .replace(/>/g, '&gt;')\n   991→    .replace(/\"/g, '&quot;');\n   992→}\n   993→\n   994→function escAttr(str) {\n   995→  return String(str ?? '').replace(/'/g, \"\\\\'\");\n   996→}\n   997→\n   998→// ============================================================\n   999→// 初始化\n  1000→// ============================================================\n  1001→\n  1002→connectEvents();\n  1003→loadTasks();\n  1004→\n  1005→// 每 30 秒自动刷新当前页\n  1006→setInterval(() => {\n  1007→  const active = document.querySelector('.page.active')?.id;\n  1008→  if (active === 'page-tasks')  loadTasks();\n  1009→  if (active === 'page-status') loadStatus();\n  1010→}, 30000);\n  1011→</script>\n  1012→</body>\n  1013→</html>\n  1014→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01Ce4yJiBd8ysyTXH3pea5HJ","session_id":"4ed89809-b941-4f90-90c8-d74444d0dc9e","uuid":"59a96639-4a70-49cd-bf7d-78fb535d5ffc"}
