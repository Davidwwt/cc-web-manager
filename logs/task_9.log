 294→      border-top: 1px solid var(--border);\n   295→    }\n   296→    footer a { color: var(--spx); text-decoration: none; }\n   297→\n   298→    @media (max-width: 640px) {\n   299→      header { padding: 16px; }\n   300→      main { padding: 20px 16px 48px; }\n   301→      .current-price { font-size: 1.5rem; }\n   302→    }\n   303→  </style>\n   304→</head>\n   305→<body>\n   306→\n   307→<header>\n   308→  <div class=\"header-left\">\n   309→    <h1>全球市场 <span>行情</span></h1>\n   310→  </div>\n   311→  <div class=\"header-right\">\n   312→    <span class=\"update-time\" id=\"update-time\">--</span>\n   313→    <button class=\"refresh-btn\" id=\"refresh-btn\" onclick=\"refreshAll()\">\n   314→      <svg id=\"refresh-icon\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\"\n   315→           stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n   316→        <polyline points=\"23 4 23 10 17 10\"/><polyline points=\"1 20 1 14 7 14\"/>\n   317→        <path d=\"M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15\"/>\n   318→      </svg>\n   319→      刷新\n   320→    </button>\n   321→  </div>\n   322→</header>\n   323→\n   324→<main>\n   325→  <!-- ── Price Cards ── -->\n   326→  <div class=\"cards-grid\">\n   327→\n   328→    <!-- BTC Card -->\n   329→    <div class=\"asset-card btc\" onclick=\"scrollToChart('btc')\">\n   330→      <div class=\"card-header\">\n   331→        <div class=\"asset-info\">\n   332→          <div class=\"asset-icon\">₿</div>\n   333→          <div>\n   334→            <div class=\"asset-name\">比特币</div>\n   335→            <div class=\"asset-sub\">Bitcoin · BTC/USD</div>\n   336→          </div>\n   337→        </div>\n   338→        <div class=\"asset-badge\">加密货币</div>\n   339→      </div>\n   340→      <div class=\"price-row\">\n   341→        <div class=\"current-price\" id=\"btc-price\"><span class=\"skeleton\" style=\"width:160px;height:32px\">&nbsp;</span></div>\n   342→        <div class=\"price-change\" id=\"btc-pct\"></div>\n   343→      </div>\n   344→      <div class=\"change-detail\" id=\"btc-chg\">&nbsp;</div>\n   345→      <div class=\"card-stats\">\n   346→        <div class=\"stat-item\">\n   347→          <div class=\"label\">市值</div>\n   348→          <div class=\"value\" id=\"btc-mcap\">--</div>\n   349→        </div>\n   350→        <div class=\"stat-item\">\n   351→          <div class=\"label\">24H 成交量</div>\n   352→          <div class=\"value\" id=\"btc-vol\">--</div>\n   353→        </div>\n   354→      </div>\n   355→      <div class=\"sparkline-wrap\"><canvas id=\"btc-spark\"></canvas></div>\n   356→    </div>\n   357→\n   358→    <!-- Gold Card -->\n   359→    <div class=\"asset-card gold\" onclick=\"scrollToChart('gold')\">\n   360→      <div class=\"card-header\">\n   361→        <div class=\"asset-info\">\n   362→          <div class=\"asset-icon\">Au</div>\n   363→          <div>\n   364→            <div class=\"asset-name\">黄金</div>\n   365→            <div class=\"asset-sub\">Gold · XAU/USD · 期货</div>\n   366→          </div>\n   367→        </div>\n   368→        <div class=\"asset-badge\">贵金属</div>\n   369→      </div>\n   370→      <div class=\"price-row\">\n   371→        <div class=\"current-price\" id=\"gold-price\"><span class=\"skeleton\" style=\"width:160px;height:32px\">&nbsp;</span></div>\n   372→        <div class=\"price-change\" id=\"gold-pct\"></div>\n   373→      </div>\n   374→      <div class=\"change-detail\" id=\"gold-chg\">&nbsp;</div>\n   375→      <div class=\"card-stats\">\n   376→        <div class=\"stat-item\">\n   377→          <div class=\"label\">合约</div>\n   378→          <div class=\"value\" id=\"gold-sym\">GC=F</div>\n   379→        </div>\n   380→        <div class=\"stat-item\">\n   381→          <div class=\"label\">单位</div>\n   382→          <div class=\"value\">美元/盎司</div>\n   383→        </div>\n   384→      </div>\n   385→      <div class=\"sparkline-wrap\"><canvas id=\"gold-spark\"></canvas></div>\n   386→    </div>\n   387→\n   388→    <!-- S&P 500 Card -->\n   389→    <div class=\"asset-card spx\" onclick=\"scrollToChart('spx')\">\n   390→      <div class=\"card-header\">\n   391→        <div class=\"asset-info\">\n   392→          <div class=\"asset-icon\">S&P</div>\n   393→          <div>\n   394→            <div class=\"asset-name\">标普500</div>\n   395→            <div class=\"asset-sub\">S&amp;P 500 · ^GSPC</div>\n   396→          </div>\n   397→        </div>\n   398→        <div class=\"asset-badge\">指数</div>\n   399→      </div>\n   400→      <div class=\"price-row\">\n   401→        <div class=\"current-price\" id=\"spx-price\"><span class=\"skeleton\" style=\"width:160px;height:32px\">&nbsp;</span></div>\n   402→        <div class=\"price-change\" id=\"spx-pct\"></div>\n   403→      </div>\n   404→      <div class=\"change-detail\" id=\"spx-chg\">&nbsp;</div>\n   405→      <div class=\"card-stats\">\n   406→        <div class=\"stat-item\">\n   407→          <div class=\"label\">交易所</div>\n   408→          <div class=\"value\">NYSE / NASDAQ</div>\n   409→        </div>\n   410→        <div class=\"stat-item\">\n   411→          <div class=\"label\">单位</div>\n   412→          <div class=\"value\">点</div>\n   413→        </div>\n   414→      </div>\n   415→      <div class=\"sparkline-wrap\"><canvas id=\"spx-spark\"></canvas></div>\n   416→    </div>\n   417→\n   418→  </div>\n   419→\n   420→  <!-- ── Charts ── -->\n   421→  <div class=\"charts-section\">\n   422→\n   423→    <!-- BTC Chart -->\n   424→    <div class=\"chart-card\" id=\"chart-btc\">\n   425→      <div class=\"chart-card-header\">\n   426→        <div class=\"chart-title\">\n   427→          <div class=\"chart-dot btc\"></div>\n   428→          <span class=\"chart-title-text\">比特币 BTC/USD — 价格走势</span>\n   429→        </div>\n   430→        <div class=\"period-tabs\" id=\"btc-periods\">\n   431→          <button class=\"period-btn\" data-asset=\"btc\" data-days=\"7\">7天</button>\n   432→          <button class=\"period-btn active\" data-asset=\"btc\" data-days=\"30\">1月</button>\n   433→          <button class=\"period-btn\" data-asset=\"btc\" data-days=\"90\">3月</button>\n   434→          <button class=\"period-btn\" data-asset=\"btc\" data-days=\"365\">1年</button>\n   435→        </div>\n   436→      </div>\n   437→      <div class=\"chart-wrap\"><canvas id=\"btc-chart\"></canvas></div>\n   438→    </div>\n   439→\n   440→    <!-- Gold Chart -->\n   441→    <div class=\"chart-card\" id=\"chart-gold\">\n   442→      <div class=\"chart-card-header\">\n   443→        <div class=\"chart-title\">\n   444→          <div class=\"chart-dot gold\"></div>\n   445→          <span class=\"chart-title-text\">黄金 XAU/USD — 价格走势</span>\n   446→        </div>\n   447→        <div class=\"period-tabs\" id=\"gold-periods\">\n   448→          <button class=\"period-btn\" data-asset=\"gold\" data-days=\"7\">7天</button>\n   449→          <button class=\"period-btn active\" data-asset=\"gold\" data-days=\"30\">1月</button>\n   450→          <button class=\"period-btn\" data-asset=\"gold\" data-days=\"90\">3月</button>\n   451→          <button class=\"period-btn\" data-asset=\"gold\" data-days=\"365\">1年</button>\n   452→        </div>\n   453→      </div>\n   454→      <div class=\"chart-wrap\"><canvas id=\"gold-chart\"></canvas></div>\n   455→    </div>\n   456→\n   457→    <!-- S&P 500 Chart -->\n   458→    <div class=\"chart-card\" id=\"chart-spx\">\n   459→      <div class=\"chart-card-header\">\n   460→        <div class=\"chart-title\">\n   461→          <div class=\"chart-dot spx\"></div>\n   462→          <span class=\"chart-title-text\">标普500 ^GSPC — 价格走势</span>\n   463→        </div>\n   464→        <div class=\"period-tabs\" id=\"spx-periods\">\n   465→          <button class=\"period-btn\" data-asset=\"spx\" data-days=\"7\">7天</button>\n   466→          <button class=\"period-btn active\" data-asset=\"spx\" data-days=\"30\">1月</button>\n   467→          <button class=\"period-btn\" data-asset=\"spx\" data-days=\"90\">3月</button>\n   468→          <button class=\"period-btn\" data-asset=\"spx\" data-days=\"365\">1年</button>\n   469→        </div>\n   470→      </div>\n   471→      <div class=\"chart-wrap\"><canvas id=\"spx-chart\"></canvas></div>\n   472→    </div>\n   473→\n   474→  </div>\n   475→</main>\n   476→\n   477→<footer>\n   478→  数据来源: <a href=\"https://www.coingecko.com\" target=\"_blank\">CoinGecko</a>（BTC）&nbsp;·&nbsp;\n   479→  <a href=\"https://finance.yahoo.com\" target=\"_blank\">Yahoo Finance</a>（黄金、标普500）&nbsp;·&nbsp;\n   480→  仅供参考，不构成投资建议\n   481→</footer>\n   482→\n   483→<script>\n   484→// ─── Config ────────────────────────────────────────────────────────────────\n   485→const COINGECKO = 'https://api.coingecko.com/api/v3';\n   486→const PROXY     = 'https://api.allorigins.win/raw?url=';\n   487→const YF        = 'https://query1.finance.yahoo.com/v8/finance/chart';\n   488→\n   489→const COLORS = { btc: '#f7931a', gold: '#f5c542', spx: '#38bdf8' };\n   490→\n   491→// ─── State ─────────────────────────────────────────────────────────────────\n   492→const charts = {};   // canvasId → Chart instance\n   493→\n   494→// ─── Number helpers ─────────────────────────────────────────────────────────\n   495→function fmtPrice(n, decimals = 2) {\n   496→  if (n == null) return '--';\n   497→  return '$' + n.toLocaleString('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });\n   498→}\n   499→function fmtPct(n) {\n   500→  if (n == null) return '';\n   501→  return (n >= 0 ? '+' : '') + n.toFixed(2) + '%';\n   502→}\n   503→function fmtLarge(n) {\n   504→  if (n == null) return '--';\n   505→  if (n >= 1e12) return '$' + (n / 1e12).toFixed(2) + ' T';\n   506→  if (n >= 1e9)  return '$' + (n / 1e9).toFixed(2)  + ' B';\n   507→  if (n >= 1e6)  return '$' + (n / 1e6).toFixed(2)  + ' M';\n   508→  return '$' + n.toLocaleString('en-US', { maximumFractionDigits: 0 });\n   509→}\n   510→function fmtDate(ts) {\n   511→  return new Date(ts).toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' });\n   512→}\n   513→function fmtDateHour(ts) {\n   514→  return new Date(ts).toLocaleString('zh-CN', { month: 'short', day: 'numeric', hour: '2-digit' });\n   515→}\n   516→\n   517→// ─── API: BTC (CoinGecko) ───────────────────────────────────────────────────\n   518→async function fetchBTC(days) {\n   519→  const [pr, cr] = await Promise.all([\n   520→    fetch(`${COINGECKO}/simple/price?ids=bitcoin&vs_currencies=usd`\n   521→        + `&include_24hr_change=true&include_market_cap=true&include_24hr_vol=true`),\n   522→    fetch(`${COINGECKO}/coins/bitcoin/market_chart?vs_currency=usd&days=${days}`)\n   523→  ]);\n   524→  if (!pr.ok || !cr.ok) throw new Error('CoinGecko request failed');\n   525→  const pd = await pr.json();\n   526→  const cd = await cr.json();\n   527→\n   528→  const btc = pd.bitcoin;\n   529→  const isHourly = days <= 90;\n   530→  return {\n   531→    price:      btc.usd,\n   532→    pct:        btc.usd_24h_change,\n   533→    marketCap:  btc.usd_market_cap,\n   534→    volume:     btc.usd_24h_vol,\n   535→    history:    cd.prices.map(([ts, p]) => ({\n   536→      label: isHourly && days <= 7 ? fmtDateHour(ts) : fmtDate(ts),\n   537→      price: p\n   538→    }))\n   539→  };\n   540→}\n   541→\n   542→// ─── API: Gold & SPX (Yahoo Finance via CORS proxy) ─────────────────────────\n   543→async function fetchYahoo(symbol, days) {\n   544→  const range    = days <= 7 ? '7d' : days <= 30 ? '1mo' : days <= 90 ? '3mo' : '1y';\n   545→  const interval = days <= 7 ? '60m' : '1d';\n   546→  const yfUrl    = `${YF}/${encodeURIComponent(symbol)}?interval=${interval}&range=${range}`;\n   547→  const resp     = await fetch(PROXY + encodeURIComponent(yfUrl));\n   548→  if (!resp.ok) throw new Error(`Yahoo Finance proxy error (${symbol})`);\n   549→\n   550→  const json   = await resp.json();\n   551→  const result = json?.chart?.result?.[0];\n   552→  if (!result) throw new Error(`No data returned for ${symbol}`);\n   553→\n   554→  const meta      = result.meta;\n   555→  const stamps    = result.timestamp || [];\n   556→  const closes    = result.indicators?.quote?.[0]?.close || [];\n   557→  const prevClose = meta.chartPreviousClose ?? meta.previousClose ?? meta.regularMarketPreviousClose;\n   558→  const cur       = meta.regularMarketPrice;\n   559→  const change    = prevClose ? cur - prevClose : 0;\n   560→  const pct       = prevClose ? (change / prevClose) * 100 : 0;\n   561→  const isHourly  = days <= 7;\n   562→\n   563→  return {\n   564→    price:   cur,\n   565→    pct:     pct,\n   566→    change:  change,\n   567→    history: stamps\n   568→      .map((ts, i) => ({\n   569→        label: isHourly ? fmtDateHour(ts * 1000) : fmtDate(ts * 1000),\n   570→        price: closes[i]\n   571→      }))\n   572→      .filter(d => d.price != null)\n   573→  };\n   574→}\n   575→\n   576→// ─── Chart helpers ──────────────────────────────────────────────────────────\n   577→function buildChartConfig(labels, prices, color, minimal = false) {\n   578→  return {\n   579→    type: 'line',\n   580→    data: {\n   581→      labels,\n   582→      datasets: [{\n   583→        data: prices,\n   584→        borderColor: color,\n   585→        borderWidth: minimal ? 1.5 : 2,\n   586→        pointRadius: 0,\n   587→        tension: 0.35,\n   588→        fill: true,\n   589→        backgroundColor: (ctx) => {\n   590→          const c = ctx.chart.ctx;\n   591→          const h = ctx.chart.height;\n   592→          const g = c.createLinearGradient(0, 0, 0, h);\n   593→          g.addColorStop(0, color + '55');\n   594→          g.addColorStop(1, color + '00');\n   595→          return g;\n   596→        }\n   597→      }]\n   598→    },\n   599→    options: {\n   600→      responsive: true,\n   601→      maintainAspectRatio: false,\n   602→      animation: { duration: 500 },\n   603→      plugins: {\n   604→        legend: { display: false },\n   605→        tooltip: minimal ? { enabled: false } : {\n   606→          mode: 'index',\n   607→          intersect: false,\n   608→          backgroundColor: '#1a2235',\n   609→          borderColor: '#1f2d45',\n   610→          borderWidth: 1,\n   611→          titleColor: '#7a8899',\n   612→          bodyColor: '#e8edf5',\n   613→          callbacks: {\n   614→            label: ctx => ' $' + ctx.parsed.y.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })\n   615→          }\n   616→        }\n   617→      },\n   618→      scales: minimal\n   619→        ? { x: { display: false }, y: { display: false } }\n   620→        : {\n   621→            x: {\n   622→              grid: { color: '#1a2235' },\n   623→              ticks: {\n   624→                color: '#7a8899',\n   625→                font: { size: 11 },\n   626→                maxRotation: 0,\n   627→                maxTicksLimit: 8,\n   628→                autoSkip: true\n   629→              },\n   630→              border: { color: '#1f2d45' }\n   631→            },\n   632→            y: {\n   633→              position: 'right',\n   634→              grid: { color: '#1a2235' },\n   635→              ticks: {\n   636→                color: '#7a8899',\n   637→                font: { size: 11 },\n   638→                callback: v => '$' + v.toLocaleString('en-US', { maximumFractionDigits: 0 })\n   639→              },\n   640→              border: { color: '#1f2d45' }\n   641→            }\n   642→          }\n   643→    }\n   644→  };\n   645→}\n   646→\n   647→function renderChart(canvasId, labels, prices, color, minimal = false) {\n   648→  const canvas = document.getElementById(canvasId);\n   649→  if (!canvas) return;\n   650→  if (charts[canvasId]) {\n   651→    charts[canvasId].destroy();\n   652→    delete charts[canvasId];\n   653→  }\n   654→  const cfg = buildChartConfig(labels, prices, color, minimal);\n   655→  charts[canvasId] = new Chart(canvas, cfg);\n   656→}\n   657→\n   658→// ─── UI update helpers ──────────────────────────────────────────────────────\n   659→function updateCard(id, price, pct, extra = {}) {\n   660→  const dir = pct >= 0 ? 'up' : 'down';\n   661→  const arrow = pct >= 0 ? '▲' : '▼';\n   662→\n   663→  const priceEl  = document.getElementById(`${id}-price`);\n   664→  const pctEl    = document.getElementById(`${id}-pct`);\n   665→  const chgEl    = document.getElementById(`${id}-chg`);\n   666→\n   667→  if (priceEl) priceEl.textContent = fmtPrice(price, id === 'btc' ? 0 : 2);\n   668→  if (pctEl) {\n   669→    pctEl.textContent = `${arrow} ${Math.abs(pct).toFixed(2)}%`;\n   670→    pctEl.className = `price-change ${dir}`;\n   671→  }\n   672→  if (chgEl && extra.changeAmt != null) {\n   673→    const sign = extra.changeAmt >= 0 ? '+' : '';\n   674→    chgEl.textContent = `${sign}${fmtPrice(extra.changeAmt, 2)} 较昨日收盘`;\n   675→    chgEl.className = `change-detail ${dir}`;\n   676→  } else if (chgEl) {\n   677→    chgEl.textContent = '';\n   678→  }\n   679→\n   680→  if (extra.marketCap) {\n   681→    const el = document.getElementById(`${id}-mcap`);\n   682→    if (el) el.textContent = fmtLarge(extra.marketCap);\n   683→  }\n   684→  if (extra.volume) {\n   685→    const el = document.getElementById(`${id}-vol`);\n   686→    if (el) el.textContent = fmtLarge(extra.volume);\n   687→  }\n   688→}\n   689→\n   690→function showError(canvasId, message) {\n   691→  const canvas = document.getElementById(canvasId);\n   692→  if (!canvas) return;\n   693→  if (charts[canvasId]) { charts[canvasId].destroy(); delete charts[canvasId]; }\n   694→  const wrap = canvas.parentElement;\n   695→  wrap.innerHTML = `<div class=\"error-state\">\n   696→    <span class=\"icon\">⚠️</span>\n   697→    <span>${message}</span>\n   698→    <span style=\"font-size:.75rem;opacity:.6\">数据加载失败，请点击刷新重试</span>\n   699→  </div>`;\n   700→}\n   701→\n   702→// ─── Load each asset ─────────────────────────────────────────────────────────\n   703→async function loadBTC(days) {\n   704→  try {\n   705→    const d = await fetchBTC(days);\n   706→    updateCard('btc', d.price, d.pct, {\n   707→      changeAmt: d.price * (d.pct / 100) / (1 + d.pct / 100),\n   708→      marketCap: d.marketCap,\n   709→      volume: d.volume\n   710→    });\n   711→    const labels = d.history.map(h => h.label);\n   712→    const prices = d.history.map(h => h.price);\n   713→    renderChart('btc-chart', labels, prices, COLORS.btc, false);\n   714→    renderChart('btc-spark', labels, prices, COLORS.btc, true);\n   715→  } catch (e) {\n   716→    console.error('BTC load error:', e);\n   717→    document.getElementById('btc-price').textContent = '数据加载失败';\n   718→    showError('btc-chart', 'BTC 数据加载失败');\n   719→  }\n   720→}\n   721→\n   722→async function loadGold(days) {\n   723→  try {\n   724→    const d = await fetchYahoo('GC=F', days);\n   725→    updateCard('gold', d.price, d.pct, { changeAmt: d.change });\n   726→    const labels = d.history.map(h => h.label);\n   727→    const prices = d.history.map(h => h.price);\n   728→    renderChart('gold-chart', labels, prices, COLORS.gold, false);\n   729→    renderChart('gold-spark', labels, prices, COLORS.gold, true);\n   730→  } catch (e) {\n   731→    console.error('Gold load error:', e);\n   732→    document.getElementById('gold-price').textContent = '数据加载失败';\n   733→    showError('gold-chart', '黄金数据加载失败');\n   734→  }\n   735→}\n   736→\n   737→async function loadSPX(days) {\n   738→  try {\n   739→    const d = await fetchYahoo('^GSPC', days);\n   740→    updateCard('spx', d.price, d.pct, { changeAmt: d.change });\n   741→    const labels = d.history.map(h => h.label);\n   742→    const prices = d.history.map(h => h.price);\n   743→    renderChart('spx-chart', labels, prices, COLORS.spx, false);\n   744→    renderChart('spx-spark', labels, prices, COLORS.spx, true);\n   745→  } catch (e) {\n   746→    console.error('SPX load error:', e);\n   747→    document.getElementById('spx-price').textContent = '数据加载失败';\n   748→    showError('spx-chart', '标普500数据加载失败');\n   749→  }\n   750→}\n   751→\n   752→// ─── Period tabs ─────────────────────────────────────────────────────────────\n   753→document.querySelectorAll('.period-btn').forEach(btn => {\n   754→  btn.addEventListener('click', async (e) => {\n   755→    const asset = btn.dataset.asset;\n   756→    const days  = parseInt(btn.dataset.days);\n   757→\n   758→    // Update active state\n   759→    document.querySelectorAll(`#${asset}-periods .period-btn`)\n   760→      .forEach(b => b.classList.remove('active'));\n   761→    btn.classList.add('active');\n   762→\n   763→    // Reload chart data only (sparkline already shown)\n   764→    if (asset === 'btc')  await loadBTC(days);\n   765→    if (asset === 'gold') await loadGold(days);\n   766→    if (asset === 'spx')  await loadSPX(days);\n   767→  });\n   768→});\n   769→\n   770→// ─── Refresh all ────────────────────────────────────────────────────────────\n   771→async function refreshAll() {\n   772→  const btn  = document.getElementById('refresh-btn');\n   773→  const icon = document.getElementById('refresh-icon');\n   774→  btn.classList.add('loading');\n   775→  btn.disabled = true;\n   776→\n   777→  // Get current selected periods\n   778→  const btcDays  = parseInt(document.querySelector('#btc-periods  .period-btn.active')?.dataset.days || 30);\n   779→  const goldDays = parseInt(document.querySelector('#gold-periods .period-btn.active')?.dataset.days || 30);\n   780→  const spxDays  = parseInt(document.querySelector('#spx-periods  .period-btn.active')?.dataset.days || 30);\n   781→\n   782→  await Promise.allSettled([\n   783→    loadBTC(btcDays),\n   784→    loadGold(goldDays),\n   785→    loadSPX(spxDays)\n   786→  ]);\n   787→\n   788→  const now = new Date().toLocaleTimeString('zh-CN');\n   789→  document.getElementById('update-time').textContent = `更新于 ${now}`;\n   790→  btn.classList.remove('loading');\n   791→  btn.disabled = false;\n   792→}\n   793→\n   794→// ─── Scroll to chart ─────────────────────────────────────────────────────────\n   795→function scrollToChart(id) {\n   796→  const el = document.getElementById(`chart-${id}`);\n   797→  if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });\n   798→}\n   799→\n   800→// ─── Auto-refresh every 60s ───────────────────────────────────────────────────\n   801→setInterval(refreshAll, 60_000);\n   802→\n   803→// ─── Init ────────────────────────────────────────────────────────────────────\n   804→refreshAll();\n   805→</script>\n   806→</body>\n   807→</html>\n   808→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"549e688c-4881-4c04-8fb4-0c9404c8037b","uuid":"aa9866f6-17d7-4e94-a427-d589ce654104","tool_use_result":{"type":"text","file":{"filePath":"/home/ubuntu/my-project/index.html","content":"<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>全球市场行情 · BTC · 黄金 · 标普500</title>\n  <script src=\"https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js\"></script>\n  <style>\n    :root {\n      --bg:       #0a0e1a;\n      --bg2:      #111827;\n      --bg3:      #1a2235;\n      --border:   #1f2d45;\n      --txt:      #e8edf5;\n      --txt2:     #7a8899;\n      --up:       #22c55e;\n      --down:     #ef4444;\n      --btc:      #f7931a;\n      --gold:     #f5c542;\n      --spx:      #38bdf8;\n      --radius:   14px;\n    }\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n\n    body {\n      background: var(--bg);\n      color: var(--txt);\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif;\n      min-height: 100vh;\n    }\n\n    /* ── Header ─────────────────────────────── */\n    header {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      padding: 20px 32px;\n      border-bottom: 1px solid var(--border);\n      background: var(--bg2);\n      position: sticky;\n      top: 0;\n      z-index: 10;\n      backdrop-filter: blur(12px);\n    }\n    .header-left h1 {\n      font-size: 1.3rem;\n      font-weight: 700;\n      letter-spacing: .5px;\n    }\n    .header-left h1 span { color: var(--spx); }\n    .header-right {\n      display: flex;\n      align-items: center;\n      gap: 16px;\n    }\n    .update-time {\n      font-size: .8rem;\n      color: var(--txt2);\n    }\n    .refresh-btn {\n      background: var(--bg3);\n      border: 1px solid var(--border);\n      color: var(--txt);\n      padding: 7px 16px;\n      border-radius: 8px;\n      cursor: pointer;\n      font-size: .85rem;\n      transition: background .2s;\n      display: flex;\n      align-items: center;\n      gap: 6px;\n    }\n    .refresh-btn:hover { background: #263047; }\n    .refresh-btn.loading svg { animation: spin .8s linear infinite; }\n    @keyframes spin { to { transform: rotate(360deg); } }\n\n    /* ── Main layout ─────────────────────────── */\n    main { max-width: 1280px; margin: 0 auto; padding: 32px 24px 64px; }\n\n    /* ── Cards ───────────────────────────────── */\n    .cards-grid {\n      display: grid;\n      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n      gap: 20px;\n      margin-bottom: 40px;\n    }\n\n    .asset-card {\n      background: var(--bg2);\n      border: 1px solid var(--border);\n      border-radius: var(--radius);\n      padding: 24px 24px 16px;\n      transition: border-color .2s, transform .2s;\n      cursor: pointer;\n      position: relative;\n      overflow: hidden;\n    }\n    .asset-card::before {\n      content: '';\n      position: absolute;\n      top: 0; left: 0; right: 0;\n      height: 3px;\n      border-radius: var(--radius) var(--radius) 0 0;\n    }\n    .asset-card.btc::before  { background: var(--btc); }\n    .asset-card.gold::before { background: var(--gold); }\n    .asset-card.spx::before  { background: var(--spx); }\n    .asset-card:hover { border-color: #2d4060; transform: translateY(-2px); }\n\n    .card-header {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      margin-bottom: 20px;\n    }\n    .asset-info {\n      display: flex;\n      align-items: center;\n      gap: 12px;\n    }\n    .asset-icon {\n      width: 44px; height: 44px;\n      border-radius: 50%;\n      display: flex; align-items: center; justify-content: center;\n      font-size: 1.3rem;\n      font-weight: 700;\n    }\n    .btc  .asset-icon { background: rgba(247,147,26,.15); color: var(--btc); }\n    .gold .asset-icon { background: rgba(245,197,66,.15); color: var(--gold); }\n    .spx  .asset-icon { background: rgba(56,189,248,.15); color: var(--spx); }\n\n    .asset-name {\n      font-weight: 700;\n      font-size: 1rem;\n    }\n    .asset-sub {\n      font-size: .75rem;\n      color: var(--txt2);\n      margin-top: 2px;\n    }\n    .asset-badge {\n      font-size: .7rem;\n      padding: 3px 10px;\n      border-radius: 20px;\n      background: var(--bg3);\n      color: var(--txt2);\n    }\n\n    .price-row {\n      display: flex;\n      align-items: flex-end;\n      gap: 12px;\n      margin-bottom: 6px;\n    }\n    .current-price {\n      font-size: 1.85rem;\n      font-weight: 700;\n      letter-spacing: -.5px;\n    }\n    .price-change {\n      font-size: .95rem;\n      font-weight: 600;\n      padding: 2px 8px;\n      border-radius: 6px;\n      margin-bottom: 4px;\n    }\n    .price-change.up   { color: var(--up);   background: rgba(34,197,94,.12); }\n    .price-change.down { color: var(--down); background: rgba(239,68,68,.12); }\n\n    .change-detail {\n      font-size: .8rem;\n      color: var(--txt2);\n      margin-bottom: 16px;\n    }\n    .change-detail.up   { color: var(--up); }\n    .change-detail.down { color: var(--down); }\n\n    .card-stats {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 8px;\n      padding: 14px 0;\n      border-top: 1px solid var(--border);\n      margin-top: 4px;\n    }\n    .stat-item .label {\n      font-size: .7rem;\n      color: var(--txt2);\n      text-transform: uppercase;\n      letter-spacing: .5px;\n    }\n    .stat-item .value {\n      font-size: .85rem;\n      font-weight: 600;\n      margin-top: 3px;\n    }\n\n    .sparkline-wrap {\n      height: 64px;\n      margin: 12px -4px 0;\n    }\n\n    /* skeleton shimmer */\n    .skeleton {\n      background: linear-gradient(90deg, var(--bg3) 25%, #1f2d45 50%, var(--bg3) 75%);\n      background-size: 200% 100%;\n      animation: shimmer 1.4s infinite;\n      border-radius: 6px;\n      display: inline-block;\n    }\n    @keyframes shimmer { to { background-position: -200% 0; } }\n\n    /* ── Charts section ──────────────────────── */\n    .charts-section { display: flex; flex-direction: column; gap: 24px; }\n\n    .chart-card {\n      background: var(--bg2);\n      border: 1px solid var(--border);\n      border-radius: var(--radius);\n      padding: 24px;\n    }\n    .chart-card-header {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      margin-bottom: 20px;\n      flex-wrap: wrap;\n      gap: 12px;\n    }\n    .chart-title {\n      display: flex;\n      align-items: center;\n      gap: 10px;\n    }\n    .chart-dot {\n      width: 10px; height: 10px;\n      border-radius: 50%;\n    }\n    .chart-dot.btc  { background: var(--btc); }\n    .chart-dot.gold { background: var(--gold); }\n    .chart-dot.spx  { background: var(--spx); }\n\n    .chart-title-text {\n      font-weight: 700;\n      font-size: 1rem;\n    }\n\n    .period-tabs {\n      display: flex;\n      gap: 4px;\n      background: var(--bg3);\n      border-radius: 8px;\n      padding: 3px;\n    }\n    .period-btn {\n      background: none;\n      border: none;\n      color: var(--txt2);\n      padding: 5px 14px;\n      border-radius: 6px;\n      cursor: pointer;\n      font-size: .8rem;\n      font-weight: 500;\n      transition: background .15s, color .15s;\n    }\n    .period-btn.active {\n      background: var(--bg);\n      color: var(--txt);\n    }\n    .period-btn:hover:not(.active) { color: var(--txt); }\n\n    .chart-wrap {\n      height: 240px;\n      position: relative;\n    }\n\n    .error-state {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      height: 120px;\n      gap: 8px;\n      color: var(--txt2);\n      font-size: .875rem;\n    }\n    .error-state .icon { font-size: 1.5rem; }\n\n    footer {\n      text-align: center;\n      padding: 24px;\n      font-size: .75rem;\n      color: var(--txt2);\n      border-top: 1px solid var(--border);\n    }\n    footer a { color: var(--spx); text-decoration: none; }\n\n    @media (max-width: 640px) {\n      header { padding: 16px; }\n      main { padding: 20px 16px 48px; }\n      .current-price { font-size: 1.5rem; }\n    }\n  </style>\n</head>\n<body>\n\n<header>\n  <div class=\"header-left\">\n    <h1>全球市场 <span>行情</span></h1>\n  </div>\n  <div class=\"header-right\">\n    <span class=\"update-time\" id=\"update-time\">--</span>\n    <button class=\"refresh-btn\" id=\"refresh-btn\" onclick=\"refreshAll()\">\n      <svg id=\"refresh-icon\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\"\n           stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <polyline points=\"23 4 23 10 17 10\"/><polyline points=\"1 20 1 14 7 14\"/>\n        <path d=\"M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15\"/>\n      </svg>\n      刷新\n    </button>\n  </div>\n</header>\n\n<main>\n  <!-- ── Price Cards ── -->\n  <div class=\"cards-grid\">\n\n    <!-- BTC Card -->\n    <div class=\"asset-card btc\" onclick=\"scrollToChart('btc')\">\n      <div class=\"card-header\">\n        <div class=\"asset-info\">\n          <div class=\"asset-icon\">₿</div>\n          <div>\n            <div class=\"asset-name\">比特币</div>\n            <div class=\"asset-sub\">Bitcoin · BTC/USD</div>\n          </div>\n        </div>\n        <div class=\"asset-badge\">加密货币</div>\n      </div>\n      <div class=\"price-row\">\n        <div class=\"current-price\" id=\"btc-price\"><span class=\"skeleton\" style=\"width:160px;height:32px\">&nbsp;</span></div>\n        <div class=\"price-change\" id=\"btc-pct\"></div>\n      </div>\n      <div class=\"change-detail\" id=\"btc-chg\">&nbsp;</div>\n      <div class=\"card-stats\">\n        <div class=\"stat-item\">\n          <div class=\"label\">市值</div>\n          <div class=\"value\" id=\"btc-mcap\">--</div>\n        </div>\n        <div class=\"stat-item\">\n          <div class=\"label\">24H 成交量</div>\n          <div class=\"value\" id=\"btc-vol\">--</div>\n        </div>\n      </div>\n      <div class=\"sparkline-wrap\"><canvas id=\"btc-spark\"></canvas></div>\n    </div>\n\n    <!-- Gold Card -->\n    <div class=\"asset-card gold\" onclick=\"scrollToChart('gold')\">\n      <div class=\"card-header\">\n        <div class=\"asset-info\">\n          <div class=\"asset-icon\">Au</div>\n          <div>\n            <div class=\"asset-name\">黄金</div>\n            <div class=\"asset-sub\">Gold · XAU/USD · 期货</div>\n          </div>\n        </div>\n        <div class=\"asset-badge\">贵金属</div>\n      </div>\n      <div class=\"price-row\">\n        <div class=\"current-price\" id=\"gold-price\"><span class=\"skeleton\" style=\"width:160px;height:32px\">&nbsp;</span></div>\n        <div class=\"price-change\" id=\"gold-pct\"></div>\n      </div>\n      <div class=\"change-detail\" id=\"gold-chg\">&nbsp;</div>\n      <div class=\"card-stats\">\n        <div class=\"stat-item\">\n          <div class=\"label\">合约</div>\n          <div class=\"value\" id=\"gold-sym\">GC=F</div>\n        </div>\n        <div class=\"stat-item\">\n          <div class=\"label\">单位</div>\n          <div class=\"value\">美元/盎司</div>\n        </div>\n      </div>\n      <div class=\"sparkline-wrap\"><canvas id=\"gold-spark\"></canvas></div>\n    </div>\n\n    <!-- S&P 500 Card -->\n    <div class=\"asset-card spx\" onclick=\"scrollToChart('spx')\">\n      <div class=\"card-header\">\n        <div class=\"asset-info\">\n          <div class=\"asset-icon\">S&P</div>\n          <div>\n            <div class=\"asset-name\">标普500</div>\n            <div class=\"asset-sub\">S&amp;P 500 · ^GSPC</div>\n          </div>\n        </div>\n        <div class=\"asset-badge\">指数</div>\n      </div>\n      <div class=\"price-row\">\n        <div class=\"current-price\" id=\"spx-price\"><span class=\"skeleton\" style=\"width:160px;height:32px\">&nbsp;</span></div>\n        <div class=\"price-change\" id=\"spx-pct\"></div>\n      </div>\n      <div class=\"change-detail\" id=\"spx-chg\">&nbsp;</div>\n      <div class=\"card-stats\">\n        <div class=\"stat-item\">\n          <div class=\"label\">交易所</div>\n          <div class=\"value\">NYSE / NASDAQ</div>\n        </div>\n        <div class=\"stat-item\">\n          <div class=\"label\">单位</div>\n          <div class=\"value\">点</div>\n        </div>\n      </div>\n      <div class=\"sparkline-wrap\"><canvas id=\"spx-spark\"></canvas></div>\n    </div>\n\n  </div>\n\n  <!-- ── Charts ── -->\n  <div class=\"charts-section\">\n\n    <!-- BTC Chart -->\n    <div class=\"chart-card\" id=\"chart-btc\">\n      <div class=\"chart-card-header\">\n        <div class=\"chart-title\">\n          <div class=\"chart-dot btc\"></div>\n          <span class=\"chart-title-text\">比特币 BTC/USD — 价格走势</span>\n        </div>\n        <div class=\"period-tabs\" id=\"btc-periods\">\n          <button class=\"period-btn\" data-asset=\"btc\" data-days=\"7\">7天</button>\n          <button class=\"period-btn active\" data-asset=\"btc\" data-days=\"30\">1月</button>\n          <button class=\"period-btn\" data-asset=\"btc\" data-days=\"90\">3月</button>\n          <button class=\"period-btn\" data-asset=\"btc\" data-days=\"365\">1年</button>\n        </div>\n      </div>\n      <div class=\"chart-wrap\"><canvas id=\"btc-chart\"></canvas></div>\n    </div>\n\n    <!-- Gold Chart -->\n    <div class=\"chart-card\" id=\"chart-gold\">\n      <div class=\"chart-card-header\">\n        <div class=\"chart-title\">\n          <div class=\"chart-dot gold\"></div>\n          <span class=\"chart-title-text\">黄金 XAU/USD — 价格走势</span>\n        </div>\n        <div class=\"period-tabs\" id=\"gold-periods\">\n          <button class=\"period-btn\" data-asset=\"gold\" data-days=\"7\">7天</button>\n          <button class=\"period-btn active\" data-asset=\"gold\" data-days=\"30\">1月</button>\n          <button class=\"period-btn\" data-asset=\"gold\" data-days=\"90\">3月</button>\n          <button class=\"period-btn\" data-asset=\"gold\" data-days=\"365\">1年</button>\n        </div>\n      </div>\n      <div class=\"chart-wrap\"><canvas id=\"gold-chart\"></canvas></div>\n    </div>\n\n    <!-- S&P 500 Chart -->\n    <div class=\"chart-card\" id=\"chart-spx\">\n      <div class=\"chart-card-header\">\n        <div class=\"chart-title\">\n          <div class=\"chart-dot spx\"></div>\n          <span class=\"chart-title-text\">标普500 ^GSPC — 价格走势</span>\n        </div>\n        <div class=\"period-tabs\" id=\"spx-periods\">\n          <button class=\"period-btn\" data-asset=\"spx\" data-days=\"7\">7天</button>\n          <button class=\"period-btn active\" data-asset=\"spx\" data-days=\"30\">1月</button>\n          <button class=\"period-btn\" data-asset=\"spx\" data-days=\"90\">3月</button>\n          <button class=\"period-btn\" data-asset=\"spx\" data-days=\"365\">1年</button>\n        </div>\n      </div>\n      <div class=\"chart-wrap\"><canvas id=\"spx-chart\"></canvas></div>\n    </div>\n\n  </div>\n</main>\n\n<footer>\n  数据来源: <a href=\"https://www.coingecko.com\" target=\"_blank\">CoinGecko</a>（BTC）&nbsp;·&nbsp;\n  <a href=\"https://finance.yahoo.com\" target=\"_blank\">Yahoo Finance</a>（黄金、标普500）&nbsp;·&nbsp;\n  仅供参考，不构成投资建议\n</footer>\n\n<script>\n// ─── Config ────────────────────────────────────────────────────────────────\nconst COINGECKO = 'https://api.coingecko.com/api/v3';\nconst PROXY     = 'https://api.allorigins.win/raw?url=';\nconst YF        = 'https://query1.finance.yahoo.com/v8/finance/chart';\n\nconst COLORS = { btc: '#f7931a', gold: '#f5c542', spx: '#38bdf8' };\n\n// ─── State ─────────────────────────────────────────────────────────────────\nconst charts = {};   // canvasId → Chart instance\n\n// ─── Number helpers ─────────────────────────────────────────────────────────\nfunction fmtPrice(n, decimals = 2) {\n  if (n == null) return '--';\n  return '$' + n.toLocaleString('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });\n}\nfunction fmtPct(n) {\n  if (n == null) return '';\n  return (n >= 0 ? '+' : '') + n.toFixed(2) + '%';\n}\nfunction fmtLarge(n) {\n  if (n == null) return '--';\n  if (n >= 1e12) return '$' + (n / 1e12).toFixed(2) + ' T';\n  if (n >= 1e9)  return '$' + (n / 1e9).toFixed(2)  + ' B';\n  if (n >= 1e6)  return '$' + (n / 1e6).toFixed(2)  + ' M';\n  return '$' + n.toLocaleString('en-US', { maximumFractionDigits: 0 });\n}\nfunction fmtDate(ts) {\n  return new Date(ts).toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' });\n}\nfunction fmtDateHour(ts) {\n  return new Date(ts).toLocaleString('zh-CN', { month: 'short', day: 'numeric', hour: '2-digit' });\n}\n\n// ─── API: BTC (CoinGecko) ───────────────────────────────────────────────────\nasync function fetchBTC(days) {\n  const [pr, cr] = await Promise.all([\n    fetch(`${COINGECKO}/simple/price?ids=bitcoin&vs_currencies=usd`\n        + `&include_24hr_change=true&include_market_cap=true&include_24hr_vol=true`),\n    fetch(`${COINGECKO}/coins/bitcoin/market_chart?vs_currency=usd&days=${days}`)\n  ]);\n  if (!pr.ok || !cr.ok) throw new Error('CoinGecko request failed');\n  const pd = await pr.json();\n  const cd = await cr.json();\n\n  const btc = pd.bitcoin;\n  const isHourly = days <= 90;\n  return {\n    price:      btc.usd,\n    pct:        btc.usd_24h_change,\n    marketCap:  btc.usd_market_cap,\n    volume:     btc.usd_24h_vol,\n    history:    cd.prices.map(([ts, p]) => ({\n      label: isHourly && days <= 7 ? fmtDateHour(ts) : fmtDate(ts),\n      price: p\n    }))\n  };\n}\n\n// ─── API: Gold & SPX (Yahoo Finance via CORS proxy) ─────────────────────────\nasync function fetchYahoo(symbol, days) {\n  const range    = days <= 7 ? '7d' : days <= 30 ? '1mo' : days <= 90 ? '3mo' : '1y';\n  const interval = days <= 7 ? '60m' : '1d';\n  const yfUrl    = `${YF}/${encodeURIComponent(symbol)}?interval=${interval}&range=${range}`;\n  const resp     = await fetch(PROXY + encodeURIComponent(yfUrl));\n  if (!resp.ok) throw new Error(`Yahoo Finance proxy error (${symbol})`);\n\n  const json   = await resp.json();\n  const result = json?.chart?.result?.[0];\n  if (!result) throw new Error(`No data returned for ${symbol}`);\n\n  const meta      = result.meta;\n  const stamps    = result.timestamp || [];\n  const closes    = result.indicators?.quote?.[0]?.close || [];\n  const prevClose = meta.chartPreviousClose ?? meta.previousClose ?? meta.regularMarketPreviousClose;\n  const cur       = meta.regularMarketPrice;\n  const change    = prevClose ? cur - prevClose : 0;\n  const pct       = prevClose ? (change / prevClose) * 100 : 0;\n  const isHourly  = days <= 7;\n\n  return {\n    price:   cur,\n    pct:     pct,\n    change:  change,\n    history: stamps\n      .map((ts, i) => ({\n        label: isHourly ? fmtDateHour(ts * 1000) : fmtDate(ts * 1000),\n        price: closes[i]\n      }))\n      .filter(d => d.price != null)\n  };\n}\n\n// ─── Chart helpers ──────────────────────────────────────────────────────────\nfunction buildChartConfig(labels, prices, color, minimal = false) {\n  return {\n    type: 'line',\n    data: {\n      labels,\n      datasets: [{\n        data: prices,\n        borderColor: color,\n        borderWidth: minimal ? 1.5 : 2,\n        pointRadius: 0,\n        tension: 0.35,\n        fill: true,\n        backgroundColor: (ctx) => {\n          const c = ctx.chart.ctx;\n          const h = ctx.chart.height;\n          const g = c.createLinearGradient(0, 0, 0, h);\n          g.addColorStop(0, color + '55');\n          g.addColorStop(1, color + '00');\n          return g;\n        }\n      }]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      animation: { duration: 500 },\n      plugins: {\n        legend: { display: false },\n        tooltip: minimal ? { enabled: false } : {\n          mode: 'index',\n          intersect: false,\n          backgroundColor: '#1a2235',\n          borderColor: '#1f2d45',\n          borderWidth: 1,\n          titleColor: '#7a8899',\n          bodyColor: '#e8edf5',\n          callbacks: {\n            label: ctx => ' $' + ctx.parsed.y.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })\n          }\n        }\n      },\n      scales: minimal\n        ? { x: { display: false }, y: { display: false } }\n        : {\n            x: {\n              grid: { color: '#1a2235' },\n              ticks: {\n                color: '#7a8899',\n                font: { size: 11 },\n                maxRotation: 0,\n                maxTicksLimit: 8,\n                autoSkip: true\n              },\n              border: { color: '#1f2d45' }\n            },\n            y: {\n              position: 'right',\n              grid: { color: '#1a2235' },\n              ticks: {\n                color: '#7a8899',\n                font: { size: 11 },\n                callback: v => '$' + v.toLocaleString('en-US', { maximumFractionDigits: 0 })\n              },\n              border: { color: '#1f2d45' }\n            }\n          }\n    }\n  };\n}\n\nfunction renderChart(canvasId, labels, prices, color, minimal = false) {\n  const canvas = document.getElementById(canvasId);\n  if (!canvas) return;\n  if (charts[canvasId]) {\n    charts[canvasId].destroy();\n    delete charts[canvasId];\n  }\n  const cfg = buildChartConfig(labels, prices, color, minimal);\n  charts[canvasId] = new Chart(canvas, cfg);\n}\n\n// ─── UI update helpers ──────────────────────────────────────────────────────\nfunction updateCard(id, price, pct, extra = {}) {\n  const dir = pct >= 0 ? 'up' : 'down';\n  const arrow = pct >= 0 ? '▲' : '▼';\n\n  const priceEl  = document.getElementById(`${id}-price`);\n  const pctEl    = document.getElementById(`${id}-pct`);\n  const chgEl    = document.getElementById(`${id}-chg`);\n\n  if (priceEl) priceEl.textContent = fmtPrice(price, id === 'btc' ? 0 : 2);\n  if (pctEl) {\n    pctEl.textContent = `${arrow} ${Math.abs(pct).toFixed(2)}%`;\n    pctEl.className = `price-change ${dir}`;\n  }\n  if (chgEl && extra.changeAmt != null) {\n    const sign = extra.changeAmt >= 0 ? '+' : '';\n    chgEl.textContent = `${sign}${fmtPrice(extra.changeAmt, 2)} 较昨日收盘`;\n    chgEl.className = `change-detail ${dir}`;\n  } else if (chgEl) {\n    chgEl.textContent = '';\n  }\n\n  if (extra.marketCap) {\n    const el = document.getElementById(`${id}-mcap`);\n    if (el) el.textContent = fmtLarge(extra.marketCap);\n  }\n  if (extra.volume) {\n    const el = document.getElementById(`${id}-vol`);\n    if (el) el.textContent = fmtLarge(extra.volume);\n  }\n}\n\nfunction showError(canvasId, message) {\n  const canvas = document.getElementById(canvasId);\n  if (!canvas) return;\n  if (charts[canvasId]) { charts[canvasId].destroy(); delete charts[canvasId]; }\n  const wrap = canvas.parentElement;\n  wrap.innerHTML = `<div class=\"error-state\">\n    <span class=\"icon\">⚠️</span>\n    <span>${message}</span>\n    <span style=\"font-size:.75rem;opacity:.6\">数据加载失败，请点击刷新重试</span>\n  </div>`;\n}\n\n// ─── Load each asset ─────────────────────────────────────────────────────────\nasync function loadBTC(days) {\n  try {\n    const d = await fetchBTC(days);\n    updateCard('btc', d.price, d.pct, {\n      changeAmt: d.price * (d.pct / 100) / (1 + d.pct / 100),\n      marketCap: d.marketCap,\n      volume: d.volume\n    });\n    const labels = d.history.map(h => h.label);\n    const prices = d.history.map(h => h.price);\n    renderChart('btc-chart', labels, prices, COLORS.btc, false);\n    renderChart('btc-spark', labels, prices, COLORS.btc, true);\n  } catch (e) {\n    console.error('BTC load error:', e);\n    document.getElementById('btc-price').textContent = '数据加载失败';\n    showError('btc-chart', 'BTC 数据加载失败');\n  }\n}\n\nasync function loadGold(days) {\n  try {\n    const d = await fetchYahoo('GC=F', days);\n    updateCard('gold', d.price, d.pct, { changeAmt: d.change });\n    const labels = d.history.map(h => h.label);\n    const prices = d.history.map(h => h.price);\n    renderChart('gold-chart', labels, prices, COLORS.gold, false);\n    renderChart('gold-spark', labels, prices, COLORS.gold, true);\n  } catch (e) {\n    console.error('Gold load error:', e);\n    document.getElementById('gold-price').textContent = '数据加载失败';\n    showError('gold-chart', '黄金数据加载失败');\n  }\n}\n\nasync function loadSPX(days) {\n  try {\n    const d = await fetchYahoo('^GSPC', days);\n    updateCard('spx', d.price, d.pct, { changeAmt: d.change });\n    const labels = d.history.map(h => h.label);\n    const prices = d.history.map(h => h.price);\n    renderChart('spx-chart', labels, prices, COLORS.spx, false);\n    renderChart('spx-spark', labels, prices, COLORS.spx, true);\n  } catch (e) {\n    console.error('SPX load error:', e);\n    document.getElementById('spx-price').textContent = '数据加载失败';\n    showError('spx-chart', '标普500数据加载失败');\n  }\n}\n\n// ─── Period tabs ─────────────────────────────────────────────────────────────\ndocument.querySelectorAll('.period-btn').forEach(btn => {\n  btn.addEventListener('click', async (e) => {\n    const asset = btn.dataset.asset;\n    const days  = parseInt(btn.dataset.days);\n\n    // Update active state\n    document.querySelectorAll(`#${asset}-periods .period-btn`)\n      .forEach(b => b.classList.remove('active'));\n    btn.classList.add('active');\n\n    // Reload chart data only (sparkline already shown)\n    if (asset === 'btc')  await loadBTC(days);\n    if (asset === 'gold') await loadGold(days);\n    if (asset === 'spx')  await loadSPX(days);\n  });\n});\n\n// ─── Refresh all ────────────────────────────────────────────────────────────\nasync function refreshAll() {\n  const btn  = document.getElementById('refresh-btn');\n  const icon = document.getElementById('refresh-icon');\n  btn.classList.add('loading');\n  btn.disabled = true;\n\n  // Get current selected periods\n  const btcDays  = parseInt(document.querySelector('#btc-periods  .period-btn.active')?.dataset.days || 30);\n  const goldDays = parseInt(document.querySelector('#gold-periods .period-btn.active')?.dataset.days || 30);\n  const spxDays  = parseInt(document.querySelector('#spx-periods  .period-btn.active')?.dataset.days || 30);\n\n  await Promise.allSettled([\n    loadBTC(btcDays),\n    loadGold(goldDays),\n    loadSPX(spxDays)\n  ]);\n\n  const now = new Date().toLocaleTimeString('zh-CN');\n  document.getElementById('update-time').textContent = `更新于 ${now}`;\n  btn.classList.remove('loading');\n  btn.disabled = false;\n}\n\n// ─── Scroll to chart ─────────────────────────────────────────────────────────\nfunction scrollToChart(id) {\n  const el = document.getElementById(`chart-${id}`);\n  if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });\n}\n\n// ─── Auto-refresh every 60s ───────────────────────────────────────────────────\nsetInterval(refreshAll, 60_000);\n\n// ─── Init ────────────────────────────────────────────────────────────────────\nrefreshAll();\n</script>\n</body>\n</html>\n","numLines":808,"startLine":1,"totalLines":808}}}
