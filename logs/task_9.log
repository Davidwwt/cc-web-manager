{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TZfY5jxwd5FAQ4adhZf68u","type":"tool_result","content":"     1→<!DOCTYPE html>\n     2→<html lang=\"zh-CN\">\n     3→<head>\n     4→  <meta charset=\"UTF-8\" />\n     5→  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n     6→  <title>全球市场行情</title>\n     7→  <script src=\"https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js\"></script>\n     8→  <script src=\"https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js\"></script>\n     9→  <style>\n    10→    :root {\n    11→      --bg:       #0b0e1a;\n    12→      --card:     #131827;\n    13→      --border:   rgba(255,255,255,0.07);\n    14→      --text:     #dde4f0;\n    15→      --muted:    #5a6480;\n    16→      --green:    #00c98b;\n    17→      --red:      #ff4d5e;\n    18→      --btc:      #f7931a;\n    19→      --gold:     #fbbf24;\n    20→      --spx:      #60a5fa;\n    21→    }\n    22→    * { box-sizing: border-box; margin: 0; padding: 0; }\n    23→    body {\n    24→      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n    25→      background: var(--bg);\n    26→      color: var(--text);\n    27→      min-height: 100vh;\n    28→    }\n    29→\n    30→    /* ── Header ── */\n    31→    header {\n    32→      background: rgba(13,16,30,0.9);\n    33→      backdrop-filter: blur(12px);\n    34→      border-bottom: 1px solid var(--border);\n    35→      padding: 0.9rem 1.5rem;\n    36→      display: flex;\n    37→      justify-content: space-between;\n    38→      align-items: center;\n    39→      position: sticky;\n    40→      top: 0;\n    41→      z-index: 99;\n    42→    }\n    43→    .brand { display: flex; align-items: center; gap: 0.6rem; }\n    44→    .brand-icon {\n    45→      width: 34px; height: 34px;\n    46→      background: linear-gradient(135deg, #3b82f6, #7c3aed);\n    47→      border-radius: 8px;\n    48→      display: flex; align-items: center; justify-content: center;\n    49→      font-size: 16px;\n    50→    }\n    51→    .brand h1 { font-size: 1.1rem; font-weight: 600; letter-spacing: -0.01em; }\n    52→    .header-meta { display: flex; align-items: center; gap: 1rem; }\n    53→    .meta-text { font-size: 0.75rem; color: var(--muted); }\n    54→    .refresh-btn {\n    55→      background: rgba(96,165,250,0.12);\n    56→      border: 1px solid rgba(96,165,250,0.3);\n    57→      color: #60a5fa;\n    58→      padding: 0.35rem 0.9rem;\n    59→      border-radius: 6px;\n    60→      cursor: pointer;\n    61→      font-size: 0.8rem;\n    62→      font-family: inherit;\n    63→      transition: background 0.2s;\n    64→    }\n    65→    .refresh-btn:hover { background: rgba(96,165,250,0.22); }\n    66→    .refresh-btn:disabled { opacity: 0.5; cursor: not-allowed; }\n    67→\n    68→    /* ── Layout ── */\n    69→    main { max-width: 1300px; margin: 0 auto; padding: 1.5rem 1.2rem 3rem; }\n    70→\n    71→    /* ── Price Cards ── */\n    72→    .price-grid {\n    73→      display: grid;\n    74→      grid-template-columns: repeat(3, 1fr);\n    75→      gap: 1rem;\n    76→      margin-bottom: 1.5rem;\n    77→    }\n    78→    @media (max-width: 760px) { .price-grid { grid-template-columns: 1fr; } }\n    79→\n    80→    .price-card {\n    81→      background: var(--card);\n    82→      border: 1px solid var(--border);\n    83→      border-radius: 14px;\n    84→      padding: 1.25rem 1.4rem;\n    85→      position: relative;\n    86→      overflow: hidden;\n    87→      transition: transform 0.18s, box-shadow 0.18s;\n    88→    }\n    89→    .price-card:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,0,0,0.35); }\n    90→    .price-card::after {\n    91→      content: '';\n    92→      position: absolute; top: 0; left: 0; right: 0; height: 2px;\n    93→    }\n    94→    .price-card.btc::after  { background: var(--btc); }\n    95→    .price-card.gold::after { background: var(--gold); }\n    96→    .price-card.spx::after  { background: var(--spx); }\n    97→\n    98→    .card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem; }\n    99→    .asset-row { display: flex; align-items: center; gap: 0.65rem; }\n   100→    .asset-icon {\n   101→      width: 38px; height: 38px; border-radius: 10px;\n   102→      display: flex; align-items: center; justify-content: center;\n   103→      font-size: 18px;\n   104→    }\n   105→    .btc  .asset-icon { background: rgba(247,147,26,0.14); }\n   106→    .gold .asset-icon { background: rgba(251,191,36,0.14); }\n   107→    .spx  .asset-icon { background: rgba(96,165,250,0.14); }\n   108→\n   109→    .asset-name { font-size: 0.95rem; font-weight: 600; }\n   110→    .asset-sub  { font-size: 0.7rem; color: var(--muted); margin-top: 1px; }\n   111→\n   112→    .price-val {\n   113→      font-size: 1.7rem; font-weight: 700;\n   114→      letter-spacing: -0.03em;\n   115→      font-variant-numeric: tabular-nums;\n   116→    }\n   117→    .price-change { display: flex; align-items: center; gap: 0.45rem; margin-top: 0.3rem; }\n   118→    .badge {\n   119→      font-size: 0.8rem; font-weight: 600;\n   120→      padding: 0.18rem 0.5rem; border-radius: 5px;\n   121→    }\n   122→    .badge.up   { background: rgba(0,201,139,0.14); color: var(--green); }\n   123→    .badge.down { background: rgba(255,77,94,0.14);  color: var(--red); }\n   124→    .change-abs { font-size: 0.75rem; color: var(--muted); }\n   125→\n   126→    /* flash on price update */\n   127→    @keyframes flashGreen { 0%,100%{background:var(--card)} 40%{background:rgba(0,201,139,0.08)} }\n   128→    @keyframes flashRed   { 0%,100%{background:var(--card)} 40%{background:rgba(255,77,94,0.08)} }\n   129→    .flash-up   { animation: flashGreen 0.7s ease; }\n   130→    .flash-down { animation: flashRed   0.7s ease; }\n   131→\n   132→    /* ── Chart Cards ── */\n   133→    .chart-card {\n   134→      background: var(--card);\n   135→      border: 1px solid var(--border);\n   136→      border-radius: 14px;\n   137→      padding: 1.25rem 1.4rem;\n   138→      margin-bottom: 1rem;\n   139→    }\n   140→    .chart-header {\n   141→      display: flex; justify-content: space-between; align-items: center;\n   142→      margin-bottom: 1rem; flex-wrap: wrap; gap: 0.6rem;\n   143→    }\n   144→    .chart-label { display: flex; align-items: center; gap: 0.5rem; }\n   145→    .dot { width: 9px; height: 9px; border-radius: 50%; }\n   146→    .chart-label h3 { font-size: 0.9rem; font-weight: 600; }\n   147→    .range-btns { display: flex; gap: 0.3rem; }\n   148→    .rbtn {\n   149→      background: transparent;\n   150→      border: 1px solid var(--border);\n   151→      color: var(--muted);\n   152→      padding: 0.25rem 0.6rem;\n   153→      border-radius: 5px;\n   154→      cursor: pointer;\n   155→      font-size: 0.75rem;\n   156→      font-family: inherit;\n   157→      transition: all 0.15s;\n   158→    }\n   159→    .rbtn:hover  { border-color: rgba(96,165,250,0.4); color: #60a5fa; }\n   160→    .rbtn.active { background: rgba(96,165,250,0.14); border-color: rgba(96,165,250,0.4); color: #60a5fa; }\n   161→\n   162→    .chart-wrap { position: relative; height: 260px; }\n   163→    .chart-overlay {\n   164→      position: absolute; inset: 0;\n   165→      display: flex; align-items: center; justify-content: center;\n   166→      border-radius: 8px; background: var(--card);\n   167→      font-size: 0.85rem; color: var(--muted);\n   168→    }\n   169→    .spinner {\n   170→      width: 28px; height: 28px;\n   171→      border: 2.5px solid var(--border);\n   172→      border-top-color: #60a5fa;\n   173→      border-radius: 50%;\n   174→      animation: spin 0.7s linear infinite;\n   175→    }\n   176→    @keyframes spin { to { transform: rotate(360deg); } }\n   177→  </style>\n   178→</head>\n   179→<body>\n   180→\n   181→<header>\n   182→  <div class=\"brand\">\n   183→    <div class=\"brand-icon\">📈</div>\n   184→    <h1>全球市场行情</h1>\n   185→  </div>\n   186→  <div class=\"header-meta\">\n   187→    <span class=\"meta-text\" id=\"last-update\">加载中...</span>\n   188→    <span class=\"meta-text\" id=\"countdown\"></span>\n   189→    <button class=\"refresh-btn\" id=\"refresh-btn\" onclick=\"refreshAll()\">刷新</button>\n   190→  </div>\n   191→</header>\n   192→\n   193→<main>\n   194→  <!-- Price Cards -->\n   195→  <div class=\"price-grid\">\n   196→    <!-- BTC -->\n   197→    <div class=\"price-card btc\" id=\"card-btc\">\n   198→      <div class=\"card-top\">\n   199→        <div class=\"asset-row\">\n   200→          <div class=\"asset-icon\">₿</div>\n   201→          <div>\n   202→            <div class=\"asset-name\">BTC</div>\n   203→            <div class=\"asset-sub\">Bitcoin · USD</div>\n   204→          </div>\n   205→        </div>\n   206→      </div>\n   207→      <div class=\"price-val\" id=\"btc-price\">--</div>\n   208→      <div class=\"price-change\">\n   209→        <span class=\"badge\" id=\"btc-pct\">--</span>\n   210→        <span class=\"change-abs\" id=\"btc-abs\">--</span>\n   211→      </div>\n   212→    </div>\n   213→\n   214→    <!-- Gold -->\n   215→    <div class=\"price-card gold\" id=\"card-gold\">\n   216→      <div class=\"card-top\">\n   217→        <div class=\"asset-row\">\n   218→          <div class=\"asset-icon\">🥇</div>\n   219→          <div>\n   220→            <div class=\"asset-name\">黄金</div>\n   221→            <div class=\"asset-sub\">Gold Futures · USD/oz</div>\n   222→          </div>\n   223→        </div>\n   224→      </div>\n   225→      <div class=\"price-val\" id=\"gold-price\">--</div>\n   226→      <div class=\"price-change\">\n   227→        <span class=\"badge\" id=\"gold-pct\">--</span>\n   228→        <span class=\"change-abs\" id=\"gold-abs\">--</span>\n   229→      </div>\n   230→    </div>\n   231→\n   232→    <!-- S&P 500 -->\n   233→    <div class=\"price-card spx\" id=\"card-spx\">\n   234→      <div class=\"card-top\">\n   235→        <div class=\"asset-row\">\n   236→          <div class=\"asset-icon\">📊</div>\n   237→          <div>\n   238→            <div class=\"asset-name\">S&amp;P 500</div>\n   239→            <div class=\"asset-sub\">标准普尔500指数</div>\n   240→          </div>\n   241→        </div>\n   242→      </div>\n   243→      <div class=\"price-val\" id=\"spx-price\">--</div>\n   244→      <div class=\"price-change\">\n   245→        <span class=\"badge\" id=\"spx-pct\">--</span>\n   246→        <span class=\"change-abs\" id=\"spx-abs\">--</span>\n   247→      </div>\n   248→    </div>\n   249→  </div>\n   250→\n   251→  <!-- BTC Chart -->\n   252→  <div class=\"chart-card\">\n   253→    <div class=\"chart-header\">\n   254→      <div class=\"chart-label\">\n   255→        <div class=\"dot\" style=\"background:var(--btc)\"></div>\n   256→        <h3>比特币 BTC/USD 走势</h3>\n   257→      </div>\n   258→      <div class=\"range-btns\" id=\"btc-ranges\">\n   259→        <button class=\"rbtn\" data-range=\"1d\" onclick=\"switchRange('btc','1d',this)\">1D</button>\n   260→        <button class=\"rbtn\" data-range=\"1w\" onclick=\"switchRange('btc','1w',this)\">1W</button>\n   261→        <button class=\"rbtn active\" data-range=\"1m\" onclick=\"switchRange('btc','1m',this)\">1M</button>\n   262→        <button class=\"rbtn\" data-range=\"3m\" onclick=\"switchRange('btc','3m',this)\">3M</button>\n   263→        <button class=\"rbtn\" data-range=\"1y\" onclick=\"switchRange('btc','1y',this)\">1Y</button>\n   264→      </div>\n   265→    </div>\n   266→    <div class=\"chart-wrap\">\n   267→      <div class=\"chart-overlay\" id=\"btc-overlay\"><div class=\"spinner\"></div></div>\n   268→      <canvas id=\"btc-chart\"></canvas>\n   269→    </div>\n   270→  </div>\n   271→\n   272→  <!-- Gold Chart -->\n   273→  <div class=\"chart-card\">\n   274→    <div class=\"chart-header\">\n   275→      <div class=\"chart-label\">\n   276→        <div class=\"dot\" style=\"background:var(--gold)\"></div>\n   277→        <h3>黄金期货 GC=F (USD/oz) 走势</h3>\n   278→      </div>\n   279→      <div class=\"range-btns\" id=\"gold-ranges\">\n   280→        <button class=\"rbtn\" data-range=\"1d\" onclick=\"switchRange('gold','1d',this)\">1D</button>\n   281→        <button class=\"rbtn\" data-range=\"1w\" onclick=\"switchRange('gold','1w',this)\">1W</button>\n   282→        <button class=\"rbtn active\" data-range=\"1m\" onclick=\"switchRange('gold','1m',this)\">1M</button>\n   283→        <button class=\"rbtn\" data-range=\"3m\" onclick=\"switchRange('gold','3m',this)\">3M</button>\n   284→        <button class=\"rbtn\" data-range=\"1y\" onclick=\"switchRange('gold','1y',this)\">1Y</button>\n   285→      </div>\n   286→    </div>\n   287→    <div class=\"chart-wrap\">\n   288→      <div class=\"chart-overlay\" id=\"gold-overlay\"><div class=\"spinner\"></div></div>\n   289→      <canvas id=\"gold-chart\"></canvas>\n   290→    </div>\n   291→  </div>\n   292→\n   293→  <!-- S&P 500 Chart -->\n   294→  <div class=\"chart-card\">\n   295→    <div class=\"chart-header\">\n   296→      <div class=\"chart-label\">\n   297→        <div class=\"dot\" style=\"background:var(--spx)\"></div>\n   298→        <h3>标普500指数 ^GSPC 走势</h3>\n   299→      </div>\n   300→      <div class=\"range-btns\" id=\"spx-ranges\">\n   301→        <button class=\"rbtn\" data-range=\"1d\" onclick=\"switchRange('spx','1d',this)\">1D</button>\n   302→        <button class=\"rbtn\" data-range=\"1w\" onclick=\"switchRange('spx','1w',this)\">1W</button>\n   303→        <button class=\"rbtn active\" data-range=\"1m\" onclick=\"switchRange('spx','1m',this)\">1M</button>\n   304→        <button class=\"rbtn\" data-range=\"3m\" onclick=\"switchRange('spx','3m',this)\">3M</button>\n   305→        <button class=\"rbtn\" data-range=\"1y\" onclick=\"switchRange('spx','1y',this)\">1Y</button>\n   306→      </div>\n   307→    </div>\n   308→    <div class=\"chart-wrap\">\n   309→      <div class=\"chart-overlay\" id=\"spx-overlay\"><div class=\"spinner\"></div></div>\n   310→      <canvas id=\"spx-chart\"></canvas>\n   311→    </div>\n   312→  </div>\n   313→</main>\n   314→\n   315→<script>\n   316→// ─── State ────────────────────────────────────────────────────────────────────\n   317→const activeRange = { btc: '1m', gold: '1m', spx: '1m' };\n   318→const chartInstances = {};\n   319→let countdownSec = 60;\n   320→let countdownTimer = null;\n   321→\n   322→// ─── Helpers ──────────────────────────────────────────────────────────────────\n   323→function fmt(price, asset) {\n   324→  const s = price.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });\n   325→  return asset === 'spx' ? s : '$' + s;\n   326→}\n   327→\n   328→function showOverlay(asset, html) {\n   329→  const el = document.getElementById(`${asset}-overlay`);\n   330→  el.innerHTML = html;\n   331→  el.style.display = 'flex';\n   332→}\n   333→function hideOverlay(asset) {\n   334→  document.getElementById(`${asset}-overlay`).style.display = 'none';\n   335→}\n   336→\n   337→// ─── Price Cards ─────────────────────────────────────────────────────────────\n   338→function updateCard(asset, d) {\n   339→  const isUp = d.changePercent >= 0;\n   340→  const sign = isUp ? '+' : '';\n   341→\n   342→  document.getElementById(`${asset}-price`).textContent = fmt(d.price, asset);\n   343→  document.getElementById(`${asset}-price`).style.color = isUp ? 'var(--green)' : 'var(--red)';\n   344→\n   345→  const pct = document.getElementById(`${asset}-pct`);\n   346→  pct.textContent = `${sign}${d.changePercent.toFixed(2)}%`;\n   347→  pct.className = `badge ${isUp ? 'up' : 'down'}`;\n   348→\n   349→  document.getElementById(`${asset}-abs`).textContent = `${sign}${d.change.toFixed(2)}`;\n   350→\n   351→  const card = document.getElementById(`card-${asset}`);\n   352→  card.classList.remove('flash-up', 'flash-down');\n   353→  void card.offsetWidth;\n   354→  card.classList.add(isUp ? 'flash-up' : 'flash-down');\n   355→}\n   356→\n   357→async function fetchPrices() {\n   358→  try {\n   359→    const r = await fetch('/api/prices');\n   360→    if (!r.ok) throw new Error(`HTTP ${r.status}`);\n   361→    const { btc, gold, spx } = await r.json();\n   362→    if (btc)  updateCard('btc',  btc);\n   363→    if (gold) updateCard('gold', gold);\n   364→    if (spx)  updateCard('spx',  spx);\n   365→    document.getElementById('last-update').textContent =\n   366→      '更新于 ' + new Date().toLocaleTimeString('zh-CN');\n   367→  } catch (e) {\n   368→    document.getElementById('last-update').textContent = '价格获取失败';\n   369→    console.error(e);\n   370→  }\n   371→}\n   372→\n   373→// ─── Charts ───────────────────────────────────────────────────────────────────\n   374→function makeGradient(ctx, chartArea, isUp) {\n   375→  const g = ctx.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);\n   376→  if (isUp) {\n   377→    g.addColorStop(0, 'rgba(0,201,139,0.18)');\n   378→    g.addColorStop(1, 'rgba(0,201,139,0.0)');\n   379→  } else {\n   380→    g.addColorStop(0, 'rgba(255,77,94,0.18)');\n   381→    g.addColorStop(1, 'rgba(255,77,94,0.0)');\n   382→  }\n   383→  return g;\n   384→}\n   385→\n   386→function renderChart(asset, data) {\n   387→  if (!data || data.length < 2) {\n   388→    showOverlay(asset, '<span>暂无数据</span>');\n   389→    return;\n   390→  }\n   391→  const isUp = data[data.length - 1].p >= data[0].p;\n   392→  const lineColor = isUp ? 'var(--green)' : 'var(--red)';\n   393→\n   394→  if (chartInstances[asset]) chartInstances[asset].destroy();\n   395→\n   396→  const ctx = document.getElementById(`${asset}-chart`).getContext('2d');\n   397→\n   398→  chartInstances[asset] = new Chart(ctx, {\n   399→    type: 'line',\n   400→    data: {\n   401→      datasets: [{\n   402→        data: data.map(d => ({ x: d.t, y: d.p })),\n   403→        borderColor: isUp ? '#00c98b' : '#ff4d5e',\n   404→        borderWidth: 1.5,\n   405→        pointRadius: 0,\n   406→        pointHoverRadius: 5,\n   407→        pointHoverBackgroundColor: isUp ? '#00c98b' : '#ff4d5e',\n   408→        fill: true,\n   409→        backgroundColor: (ctx2) => {\n   410→          const { chartArea } = ctx2.chart;\n   411→          if (!chartArea) return 'transparent';\n   412→          return makeGradient(ctx2.chart.ctx, chartArea, isUp);\n   413→        },\n   414→        tension: 0.15,\n   415→      }],\n   416→    },\n   417→    options: {\n   418→      responsive: true,\n   419→      maintainAspectRatio: false,\n   420→      animation: { duration: 400 },\n   421→      plugins: {\n   422→        legend: { display: false },\n   423→        tooltip: {\n   424→          mode: 'index',\n   425→          intersect: false,\n   426→          backgroundColor: 'rgba(10,12,22,0.95)',\n   427→          borderColor: 'rgba(255,255,255,0.09)',\n   428→          borderWidth: 1,\n   429→          padding: 11,\n   430→          titleColor: '#5a6480',\n   431→          bodyColor: '#dde4f0',\n   432→          titleFont: { size: 11 },\n   433→          bodyFont: { size: 13, weight: '600' },\n   434→          callbacks: {\n   435→            title: items => new Date(items[0].parsed.x).toLocaleString('zh-CN', {\n   436→              year: 'numeric', month: '2-digit', day: '2-digit',\n   437→              hour: '2-digit', minute: '2-digit',\n   438→            }),\n   439→            label: item => {\n   440→              const v = item.parsed.y;\n   441→              const s = v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });\n   442→              return '  ' + (asset === 'spx' ? s : '$' + s);\n   443→            },\n   444→          },\n   445→        },\n   446→      },\n   447→      scales: {\n   448→        x: {\n   449→          type: 'time',\n   450→          time: {\n   451→            displayFormats: {\n   452→              minute: 'HH:mm',\n   453→              hour: 'M/d HH:mm',\n   454→              day: 'M/d',\n   455→              week: 'M/d',\n   456→              month: 'yyyy/M',\n   457→            },\n   458→          },\n   459→          grid: { color: 'rgba(255,255,255,0.04)', drawBorder: false },\n   460→          ticks: { color: '#3d4560', maxTicksLimit: 7, font: { size: 10 } },\n   461→          border: { display: false },\n   462→        },\n   463→        y: {\n   464→          position: 'right',\n   465→          grid: { color: 'rgba(255,255,255,0.04)', drawBorder: false },\n   466→          border: { display: false },\n   467→          ticks: {\n   468→            color: '#3d4560',\n   469→            font: { size: 10 },\n   470→            maxTicksLimit: 6,\n   471→            callback: v => {\n   472→              if (v >= 100000) return '$' + (v / 1000).toFixed(0) + 'K';\n   473→              if (v >= 10000)  return '$' + (v / 1000).toFixed(1) + 'K';\n   474→              return (asset === 'spx' ? '' : '$') + v.toLocaleString('en-US', { maximumFractionDigits: 0 });\n   475→            },\n   476→          },\n   477→        },\n   478→      },\n   479→      interaction: { mode: 'nearest', axis: 'x', intersect: false },\n   480→    },\n   481→  });\n   482→\n   483→  hideOverlay(asset);\n   484→}\n   485→\n   486→async function loadChart(asset, range) {\n   487→  showOverlay(asset, '<div class=\"spinner\"></div>');\n   488→  try {\n   489→    const r = await fetch(`/api/history/${asset}?range=${range}`);\n   490→    if (!r.ok) throw new Error(`HTTP ${r.status}`);\n   491→    const data = await r.json();\n   492→    renderChart(asset, data);\n   493→  } catch (e) {\n   494→    showOverlay(asset, `<span style=\"color:var(--red);font-size:0.82rem\">加载失败: ${e.message}</span>`);\n   495→    console.error(e);\n   496→  }\n   497→}\n   498→\n   499→function switchRange(asset, range, btn) {\n   500→  activeRange[asset] = range;\n   501→  document.querySelectorAll(`#${asset}-ranges .rbtn`).forEach(b => b.classList.remove('active'));\n   502→  btn.classList.add('active');\n   503→  loadChart(asset, range);\n   504→}\n   505→\n   506→// ─── Auto Refresh ─────────────────────────────────────────────────────────────\n   507→function startCountdown() {\n   508→  clearInterval(countdownTimer);\n   509→  countdownSec = 60;\n   510→  countdownTimer = setInterval(() => {\n   511→    countdownSec--;\n   512→    document.getElementById('countdown').textContent = `${countdownSec}s 后自动刷新`;\n   513→    if (countdownSec <= 0) {\n   514→      fetchPrices();\n   515→      countdownSec = 60;\n   516→    }\n   517→  }, 1000);\n   518→}\n   519→\n   520→async function refreshAll() {\n   521→  const btn = document.getElementById('refresh-btn');\n   522→  btn.disabled = true;\n   523→  btn.textContent = '刷新中...';\n   524→  try {\n   525→    await Promise.all([\n   526→      fetchPrices(),\n   527→      ...['btc', 'gold', 'spx'].map(a => loadChart(a, activeRange[a])),\n   528→    ]);\n   529→  } finally {\n   530→    btn.disabled = false;\n   531→    btn.textContent = '刷新';\n   532→    countdownSec = 60;\n   533→  }\n   534→}\n   535→\n   536→// ─── Init ─────────────────────────────────────────────────────────────────────\n   537→async function init() {\n   538→  await fetchPrices();\n   539→  await Promise.all(['btc', 'gold', 'spx'].map(a => loadChart(a, activeRange[a])));\n   540→  startCountdown();\n   541→}\n   542→\n   543→init();\n   544→</script>\n   545→</body>\n   546→</html>\n   547→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"549e688c-4881-4c04-8fb4-0c9404c8037b","uuid":"d6667f49-0f87-4acc-ac30-361f4bedc892","tool_use_result":{"type":"text","file":{"filePath":"/home/ubuntu/my-project/public/index.html","content":"<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>全球市场行情</title>\n  <script src=\"https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js\"></script>\n  <style>\n    :root {\n      --bg:       #0b0e1a;\n      --card:     #131827;\n      --border:   rgba(255,255,255,0.07);\n      --text:     #dde4f0;\n      --muted:    #5a6480;\n      --green:    #00c98b;\n      --red:      #ff4d5e;\n      --btc:      #f7931a;\n      --gold:     #fbbf24;\n      --spx:      #60a5fa;\n    }\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    body {\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n      background: var(--bg);\n      color: var(--text);\n      min-height: 100vh;\n    }\n\n    /* ── Header ── */\n    header {\n      background: rgba(13,16,30,0.9);\n      backdrop-filter: blur(12px);\n      border-bottom: 1px solid var(--border);\n      padding: 0.9rem 1.5rem;\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      position: sticky;\n      top: 0;\n      z-index: 99;\n    }\n    .brand { display: flex; align-items: center; gap: 0.6rem; }\n    .brand-icon {\n      width: 34px; height: 34px;\n      background: linear-gradient(135deg, #3b82f6, #7c3aed);\n      border-radius: 8px;\n      display: flex; align-items: center; justify-content: center;\n      font-size: 16px;\n    }\n    .brand h1 { font-size: 1.1rem; font-weight: 600; letter-spacing: -0.01em; }\n    .header-meta { display: flex; align-items: center; gap: 1rem; }\n    .meta-text { font-size: 0.75rem; color: var(--muted); }\n    .refresh-btn {\n      background: rgba(96,165,250,0.12);\n      border: 1px solid rgba(96,165,250,0.3);\n      color: #60a5fa;\n      padding: 0.35rem 0.9rem;\n      border-radius: 6px;\n      cursor: pointer;\n      font-size: 0.8rem;\n      font-family: inherit;\n      transition: background 0.2s;\n    }\n    .refresh-btn:hover { background: rgba(96,165,250,0.22); }\n    .refresh-btn:disabled { opacity: 0.5; cursor: not-allowed; }\n\n    /* ── Layout ── */\n    main { max-width: 1300px; margin: 0 auto; padding: 1.5rem 1.2rem 3rem; }\n\n    /* ── Price Cards ── */\n    .price-grid {\n      display: grid;\n      grid-template-columns: repeat(3, 1fr);\n      gap: 1rem;\n      margin-bottom: 1.5rem;\n    }\n    @media (max-width: 760px) { .price-grid { grid-template-columns: 1fr; } }\n\n    .price-card {\n      background: var(--card);\n      border: 1px solid var(--border);\n      border-radius: 14px;\n      padding: 1.25rem 1.4rem;\n      position: relative;\n      overflow: hidden;\n      transition: transform 0.18s, box-shadow 0.18s;\n    }\n    .price-card:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,0,0,0.35); }\n    .price-card::after {\n      content: '';\n      position: absolute; top: 0; left: 0; right: 0; height: 2px;\n    }\n    .price-card.btc::after  { background: var(--btc); }\n    .price-card.gold::after { background: var(--gold); }\n    .price-card.spx::after  { background: var(--spx); }\n\n    .card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem; }\n    .asset-row { display: flex; align-items: center; gap: 0.65rem; }\n    .asset-icon {\n      width: 38px; height: 38px; border-radius: 10px;\n      display: flex; align-items: center; justify-content: center;\n      font-size: 18px;\n    }\n    .btc  .asset-icon { background: rgba(247,147,26,0.14); }\n    .gold .asset-icon { background: rgba(251,191,36,0.14); }\n    .spx  .asset-icon { background: rgba(96,165,250,0.14); }\n\n    .asset-name { font-size: 0.95rem; font-weight: 600; }\n    .asset-sub  { font-size: 0.7rem; color: var(--muted); margin-top: 1px; }\n\n    .price-val {\n      font-size: 1.7rem; font-weight: 700;\n      letter-spacing: -0.03em;\n      font-variant-numeric: tabular-nums;\n    }\n    .price-change { display: flex; align-items: center; gap: 0.45rem; margin-top: 0.3rem; }\n    .badge {\n      font-size: 0.8rem; font-weight: 600;\n      padding: 0.18rem 0.5rem; border-radius: 5px;\n    }\n    .badge.up   { background: rgba(0,201,139,0.14); color: var(--green); }\n    .badge.down { background: rgba(255,77,94,0.14);  color: var(--red); }\n    .change-abs { font-size: 0.75rem; color: var(--muted); }\n\n    /* flash on price update */\n    @keyframes flashGreen { 0%,100%{background:var(--card)} 40%{background:rgba(0,201,139,0.08)} }\n    @keyframes flashRed   { 0%,100%{background:var(--card)} 40%{background:rgba(255,77,94,0.08)} }\n    .flash-up   { animation: flashGreen 0.7s ease; }\n    .flash-down { animation: flashRed   0.7s ease; }\n\n    /* ── Chart Cards ── */\n    .chart-card {\n      background: var(--card);\n      border: 1px solid var(--border);\n      border-radius: 14px;\n      padding: 1.25rem 1.4rem;\n      margin-bottom: 1rem;\n    }\n    .chart-header {\n      display: flex; justify-content: space-between; align-items: center;\n      margin-bottom: 1rem; flex-wrap: wrap; gap: 0.6rem;\n    }\n    .chart-label { display: flex; align-items: center; gap: 0.5rem; }\n    .dot { width: 9px; height: 9px; border-radius: 50%; }\n    .chart-label h3 { font-size: 0.9rem; font-weight: 600; }\n    .range-btns { display: flex; gap: 0.3rem; }\n    .rbtn {\n      background: transparent;\n      border: 1px solid var(--border);\n      color: var(--muted);\n      padding: 0.25rem 0.6rem;\n      border-radius: 5px;\n      cursor: pointer;\n      font-size: 0.75rem;\n      font-family: inherit;\n      transition: all 0.15s;\n    }\n    .rbtn:hover  { border-color: rgba(96,165,250,0.4); color: #60a5fa; }\n    .rbtn.active { background: rgba(96,165,250,0.14); border-color: rgba(96,165,250,0.4); color: #60a5fa; }\n\n    .chart-wrap { position: relative; height: 260px; }\n    .chart-overlay {\n      position: absolute; inset: 0;\n      display: flex; align-items: center; justify-content: center;\n      border-radius: 8px; background: var(--card);\n      font-size: 0.85rem; color: var(--muted);\n    }\n    .spinner {\n      width: 28px; height: 28px;\n      border: 2.5px solid var(--border);\n      border-top-color: #60a5fa;\n      border-radius: 50%;\n      animation: spin 0.7s linear infinite;\n    }\n    @keyframes spin { to { transform: rotate(360deg); } }\n  </style>\n</head>\n<body>\n\n<header>\n  <div class=\"brand\">\n    <div class=\"brand-icon\">📈</div>\n    <h1>全球市场行情</h1>\n  </div>\n  <div class=\"header-meta\">\n    <span class=\"meta-text\" id=\"last-update\">加载中...</span>\n    <span class=\"meta-text\" id=\"countdown\"></span>\n    <button class=\"refresh-btn\" id=\"refresh-btn\" onclick=\"refreshAll()\">刷新</button>\n  </div>\n</header>\n\n<main>\n  <!-- Price Cards -->\n  <div class=\"price-grid\">\n    <!-- BTC -->\n    <div class=\"price-card btc\" id=\"card-btc\">\n      <div class=\"card-top\">\n        <div class=\"asset-row\">\n          <div class=\"asset-icon\">₿</div>\n          <div>\n            <div class=\"asset-name\">BTC</div>\n            <div class=\"asset-sub\">Bitcoin · USD</div>\n          </div>\n        </div>\n      </div>\n      <div class=\"price-val\" id=\"btc-price\">--</div>\n      <div class=\"price-change\">\n        <span class=\"badge\" id=\"btc-pct\">--</span>\n        <span class=\"change-abs\" id=\"btc-abs\">--</span>\n      </div>\n    </div>\n\n    <!-- Gold -->\n    <div class=\"price-card gold\" id=\"card-gold\">\n      <div class=\"card-top\">\n        <div class=\"asset-row\">\n          <div class=\"asset-icon\">🥇</div>\n          <div>\n            <div class=\"asset-name\">黄金</div>\n            <div class=\"asset-sub\">Gold Futures · USD/oz</div>\n          </div>\n        </div>\n      </div>\n      <div class=\"price-val\" id=\"gold-price\">--</div>\n      <div class=\"price-change\">\n        <span class=\"badge\" id=\"gold-pct\">--</span>\n        <span class=\"change-abs\" id=\"gold-abs\">--</span>\n      </div>\n    </div>\n\n    <!-- S&P 500 -->\n    <div class=\"price-card spx\" id=\"card-spx\">\n      <div class=\"card-top\">\n        <div class=\"asset-row\">\n          <div class=\"asset-icon\">📊</div>\n          <div>\n            <div class=\"asset-name\">S&amp;P 500</div>\n            <div class=\"asset-sub\">标准普尔500指数</div>\n          </div>\n        </div>\n      </div>\n      <div class=\"price-val\" id=\"spx-price\">--</div>\n      <div class=\"price-change\">\n        <span class=\"badge\" id=\"spx-pct\">--</span>\n        <span class=\"change-abs\" id=\"spx-abs\">--</span>\n      </div>\n    </div>\n  </div>\n\n  <!-- BTC Chart -->\n  <div class=\"chart-card\">\n    <div class=\"chart-header\">\n      <div class=\"chart-label\">\n        <div class=\"dot\" style=\"background:var(--btc)\"></div>\n        <h3>比特币 BTC/USD 走势</h3>\n      </div>\n      <div class=\"range-btns\" id=\"btc-ranges\">\n        <button class=\"rbtn\" data-range=\"1d\" onclick=\"switchRange('btc','1d',this)\">1D</button>\n        <button class=\"rbtn\" data-range=\"1w\" onclick=\"switchRange('btc','1w',this)\">1W</button>\n        <button class=\"rbtn active\" data-range=\"1m\" onclick=\"switchRange('btc','1m',this)\">1M</button>\n        <button class=\"rbtn\" data-range=\"3m\" onclick=\"switchRange('btc','3m',this)\">3M</button>\n        <button class=\"rbtn\" data-range=\"1y\" onclick=\"switchRange('btc','1y',this)\">1Y</button>\n      </div>\n    </div>\n    <div class=\"chart-wrap\">\n      <div class=\"chart-overlay\" id=\"btc-overlay\"><div class=\"spinner\"></div></div>\n      <canvas id=\"btc-chart\"></canvas>\n    </div>\n  </div>\n\n  <!-- Gold Chart -->\n  <div class=\"chart-card\">\n    <div class=\"chart-header\">\n      <div class=\"chart-label\">\n        <div class=\"dot\" style=\"background:var(--gold)\"></div>\n        <h3>黄金期货 GC=F (USD/oz) 走势</h3>\n      </div>\n      <div class=\"range-btns\" id=\"gold-ranges\">\n        <button class=\"rbtn\" data-range=\"1d\" onclick=\"switchRange('gold','1d',this)\">1D</button>\n        <button class=\"rbtn\" data-range=\"1w\" onclick=\"switchRange('gold','1w',this)\">1W</button>\n        <button class=\"rbtn active\" data-range=\"1m\" onclick=\"switchRange('gold','1m',this)\">1M</button>\n        <button class=\"rbtn\" data-range=\"3m\" onclick=\"switchRange('gold','3m',this)\">3M</button>\n        <button class=\"rbtn\" data-range=\"1y\" onclick=\"switchRange('gold','1y',this)\">1Y</button>\n      </div>\n    </div>\n    <div class=\"chart-wrap\">\n      <div class=\"chart-overlay\" id=\"gold-overlay\"><div class=\"spinner\"></div></div>\n      <canvas id=\"gold-chart\"></canvas>\n    </div>\n  </div>\n\n  <!-- S&P 500 Chart -->\n  <div class=\"chart-card\">\n    <div class=\"chart-header\">\n      <div class=\"chart-label\">\n        <div class=\"dot\" style=\"background:var(--spx)\"></div>\n        <h3>标普500指数 ^GSPC 走势</h3>\n      </div>\n      <div class=\"range-btns\" id=\"spx-ranges\">\n        <button class=\"rbtn\" data-range=\"1d\" onclick=\"switchRange('spx','1d',this)\">1D</button>\n        <button class=\"rbtn\" data-range=\"1w\" onclick=\"switchRange('spx','1w',this)\">1W</button>\n        <button class=\"rbtn active\" data-range=\"1m\" onclick=\"switchRange('spx','1m',this)\">1M</button>\n        <button class=\"rbtn\" data-range=\"3m\" onclick=\"switchRange('spx','3m',this)\">3M</button>\n        <button class=\"rbtn\" data-range=\"1y\" onclick=\"switchRange('spx','1y',this)\">1Y</button>\n      </div>\n    </div>\n    <div class=\"chart-wrap\">\n      <div class=\"chart-overlay\" id=\"spx-overlay\"><div class=\"spinner\"></div></div>\n      <canvas id=\"spx-chart\"></canvas>\n    </div>\n  </div>\n</main>\n\n<script>\n// ─── State ────────────────────────────────────────────────────────────────────\nconst activeRange = { btc: '1m', gold: '1m', spx: '1m' };\nconst chartInstances = {};\nlet countdownSec = 60;\nlet countdownTimer = null;\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\nfunction fmt(price, asset) {\n  const s = price.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });\n  return asset === 'spx' ? s : '$' + s;\n}\n\nfunction showOverlay(asset, html) {\n  const el = document.getElementById(`${asset}-overlay`);\n  el.innerHTML = html;\n  el.style.display = 'flex';\n}\nfunction hideOverlay(asset) {\n  document.getElementById(`${asset}-overlay`).style.display = 'none';\n}\n\n// ─── Price Cards ─────────────────────────────────────────────────────────────\nfunction updateCard(asset, d) {\n  const isUp = d.changePercent >= 0;\n  const sign = isUp ? '+' : '';\n\n  document.getElementById(`${asset}-price`).textContent = fmt(d.price, asset);\n  document.getElementById(`${asset}-price`).style.color = isUp ? 'var(--green)' : 'var(--red)';\n\n  const pct = document.getElementById(`${asset}-pct`);\n  pct.textContent = `${sign}${d.changePercent.toFixed(2)}%`;\n  pct.className = `badge ${isUp ? 'up' : 'down'}`;\n\n  document.getElementById(`${asset}-abs`).textContent = `${sign}${d.change.toFixed(2)}`;\n\n  const card = document.getElementById(`card-${asset}`);\n  card.classList.remove('flash-up', 'flash-down');\n  void card.offsetWidth;\n  card.classList.add(isUp ? 'flash-up' : 'flash-down');\n}\n\nasync function fetchPrices() {\n  try {\n    const r = await fetch('/api/prices');\n    if (!r.ok) throw new Error(`HTTP ${r.status}`);\n    const { btc, gold, spx } = await r.json();\n    if (btc)  updateCard('btc',  btc);\n    if (gold) updateCard('gold', gold);\n    if (spx)  updateCard('spx',  spx);\n    document.getElementById('last-update').textContent =\n      '更新于 ' + new Date().toLocaleTimeString('zh-CN');\n  } catch (e) {\n    document.getElementById('last-update').textContent = '价格获取失败';\n    console.error(e);\n  }\n}\n\n// ─── Charts ───────────────────────────────────────────────────────────────────\nfunction makeGradient(ctx, chartArea, isUp) {\n  const g = ctx.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);\n  if (isUp) {\n    g.addColorStop(0, 'rgba(0,201,139,0.18)');\n    g.addColorStop(1, 'rgba(0,201,139,0.0)');\n  } else {\n    g.addColorStop(0, 'rgba(255,77,94,0.18)');\n    g.addColorStop(1, 'rgba(255,77,94,0.0)');\n  }\n  return g;\n}\n\nfunction renderChart(asset, data) {\n  if (!data || data.length < 2) {\n    showOverlay(asset, '<span>暂无数据</span>');\n    return;\n  }\n  const isUp = data[data.length - 1].p >= data[0].p;\n  const lineColor = isUp ? 'var(--green)' : 'var(--red)';\n\n  if (chartInstances[asset]) chartInstances[asset].destroy();\n\n  const ctx = document.getElementById(`${asset}-chart`).getContext('2d');\n\n  chartInstances[asset] = new Chart(ctx, {\n    type: 'line',\n    data: {\n      datasets: [{\n        data: data.map(d => ({ x: d.t, y: d.p })),\n        borderColor: isUp ? '#00c98b' : '#ff4d5e',\n        borderWidth: 1.5,\n        pointRadius: 0,\n        pointHoverRadius: 5,\n        pointHoverBackgroundColor: isUp ? '#00c98b' : '#ff4d5e',\n        fill: true,\n        backgroundColor: (ctx2) => {\n          const { chartArea } = ctx2.chart;\n          if (!chartArea) return 'transparent';\n          return makeGradient(ctx2.chart.ctx, chartArea, isUp);\n        },\n        tension: 0.15,\n      }],\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      animation: { duration: 400 },\n      plugins: {\n        legend: { display: false },\n        tooltip: {\n          mode: 'index',\n          intersect: false,\n          backgroundColor: 'rgba(10,12,22,0.95)',\n          borderColor: 'rgba(255,255,255,0.09)',\n          borderWidth: 1,\n          padding: 11,\n          titleColor: '#5a6480',\n          bodyColor: '#dde4f0',\n          titleFont: { size: 11 },\n          bodyFont: { size: 13, weight: '600' },\n          callbacks: {\n            title: items => new Date(items[0].parsed.x).toLocaleString('zh-CN', {\n              year: 'numeric', month: '2-digit', day: '2-digit',\n              hour: '2-digit', minute: '2-digit',\n            }),\n            label: item => {\n              const v = item.parsed.y;\n              const s = v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });\n              return '  ' + (asset === 'spx' ? s : '$' + s);\n            },\n          },\n        },\n      },\n      scales: {\n        x: {\n          type: 'time',\n          time: {\n            displayFormats: {\n              minute: 'HH:mm',\n              hour: 'M/d HH:mm',\n              day: 'M/d',\n              week: 'M/d',\n              month: 'yyyy/M',\n            },\n          },\n          grid: { color: 'rgba(255,255,255,0.04)', drawBorder: false },\n          ticks: { color: '#3d4560', maxTicksLimit: 7, font: { size: 10 } },\n          border: { display: false },\n        },\n        y: {\n          position: 'right',\n          grid: { color: 'rgba(255,255,255,0.04)', drawBorder: false },\n          border: { display: false },\n          ticks: {\n            color: '#3d4560',\n            font: { size: 10 },\n            maxTicksLimit: 6,\n            callback: v => {\n              if (v >= 100000) return '$' + (v / 1000).toFixed(0) + 'K';\n              if (v >= 10000)  return '$' + (v / 1000).toFixed(1) + 'K';\n              return (asset === 'spx' ? '' : '$') + v.toLocaleString('en-US', { maximumFractionDigits: 0 });\n            },\n          },\n        },\n      },\n      interaction: { mode: 'nearest', axis: 'x', intersect: false },\n    },\n  });\n\n  hideOverlay(asset);\n}\n\nasync function loadChart(asset, range) {\n  showOverlay(asset, '<div class=\"spinner\"></div>');\n  try {\n    const r = await fetch(`/api/history/${asset}?range=${range}`);\n    if (!r.ok) throw new Error(`HTTP ${r.status}`);\n    const data = await r.json();\n    renderChart(asset, data);\n  } catch (e) {\n    showOverlay(asset, `<span style=\"color:var(--red);font-size:0.82rem\">加载失败: ${e.message}</span>`);\n    console.error(e);\n  }\n}\n\nfunction switchRange(asset, range, btn) {\n  activeRange[asset] = range;\n  document.querySelectorAll(`#${asset}-ranges .rbtn`).forEach(b => b.classList.remove('active'));\n  btn.classList.add('active');\n  loadChart(asset, range);\n}\n\n// ─── Auto Refresh ─────────────────────────────────────────────────────────────\nfunction startCountdown() {\n  clearInterval(countdownTimer);\n  countdownSec = 60;\n  countdownTimer = setInterval(() => {\n    countdownSec--;\n    document.getElementById('countdown').textContent = `${countdownSec}s 后自动刷新`;\n    if (countdownSec <= 0) {\n      fetchPrices();\n      countdownSec = 60;\n    }\n  }, 1000);\n}\n\nasync function refreshAll() {\n  const btn = document.getElementById('refresh-btn');\n  btn.disabled = true;\n  btn.textContent = '刷新中...';\n  try {\n    await Promise.all([\n      fetchPrices(),\n      ...['btc', 'gold', 'spx'].map(a => loadChart(a, activeRange[a])),\n    ]);\n  } finally {\n    btn.disabled = false;\n    btn.textContent = '刷新';\n    countdownSec = 60;\n  }\n}\n\n// ─── Init ─────────────────────────────────────────────────────────────────────\nasync function init() {\n  await fetchPrices();\n  await Promise.all(['btc', 'gold', 'spx'].map(a => loadChart(a, activeRange[a])));\n  startCountdown();\n}\n\ninit();\n</script>\n</body>\n</html>\n","numLines":547,"startLine":1,"totalLines":547}}}
