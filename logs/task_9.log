ems: center;\n    54→      gap: 16px;\n    55→    }\n    56→    .update-time {\n    57→      font-size: .8rem;\n    58→      color: var(--txt2);\n    59→    }\n    60→    .refresh-btn {\n    61→      background: var(--bg3);\n    62→      border: 1px solid var(--border);\n    63→      color: var(--txt);\n    64→      padding: 7px 16px;\n    65→      border-radius: 8px;\n    66→      cursor: pointer;\n    67→      font-size: .85rem;\n    68→      transition: background .2s;\n    69→      display: flex;\n    70→      align-items: center;\n    71→      gap: 6px;\n    72→    }\n    73→    .refresh-btn:hover { background: #263047; }\n    74→    .refresh-btn.loading svg { animation: spin .8s linear infinite; }\n    75→    @keyframes spin { to { transform: rotate(360deg); } }\n    76→\n    77→    /* ── Main layout ─────────────────────────── */\n    78→    main { max-width: 1280px; margin: 0 auto; padding: 32px 24px 64px; }\n    79→\n    80→    /* ── Cards ───────────────────────────────── */\n    81→    .cards-grid {\n    82→      display: grid;\n    83→      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n    84→      gap: 20px;\n    85→      margin-bottom: 40px;\n    86→    }\n    87→\n    88→    .asset-card {\n    89→      background: var(--bg2);\n    90→      border: 1px solid var(--border);\n    91→      border-radius: var(--radius);\n    92→      padding: 24px 24px 16px;\n    93→      transition: border-color .2s, transform .2s;\n    94→      cursor: pointer;\n    95→      position: relative;\n    96→      overflow: hidden;\n    97→    }\n    98→    .asset-card::before {\n    99→      content: '';\n   100→      position: absolute;\n   101→      top: 0; left: 0; right: 0;\n   102→      height: 3px;\n   103→      border-radius: var(--radius) var(--radius) 0 0;\n   104→    }\n   105→    .asset-card.btc::before  { background: var(--btc); }\n   106→    .asset-card.gold::before { background: var(--gold); }\n   107→    .asset-card.spx::before  { background: va