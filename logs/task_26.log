{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SzpTZQwjDrG91qQjTVYbuV","type":"tool_result","content":"     1→<!DOCTYPE html>\n     2→<html lang=\"zh-CN\">\n     3→<head>\n     4→  <meta charset=\"UTF-8\" />\n     5→  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n     6→  <title>Ralph — 项目管理</title>\n     7→  <style>\n     8→    :root {\n     9→      --bg:      #0b0e1a;\n    10→      --card:    #131827;\n    11→      --card2:   #171d2e;\n    12→      --border:  rgba(255,255,255,0.07);\n    13→      --text:    #dde4f0;\n    14→      --muted:   #5a6480;\n    15→      --green:   #00c98b;\n    16→      --red:     #ff4d5e;\n    17→      --blue:    #60a5fa;\n    18→      --yellow:  #fbbf24;\n    19→      --purple:  #a78bfa;\n    20→    }\n    21→    * { box-sizing: border-box; margin: 0; padding: 0; }\n    22→    body {\n    23→      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n    24→      background: var(--bg);\n    25→      color: var(--text);\n    26→      min-height: 100vh;\n    27→    }\n    28→\n    29→    /* ── Header ── */\n    30→    header {\n    31→      background: rgba(13,16,30,0.95);\n    32→      backdrop-filter: blur(12px);\n    33→      border-bottom: 1px solid var(--border);\n    34→      padding: 0 1.5rem;\n    35→      height: 56px;\n    36→      display: flex;\n    37→      align-items: center;\n    38→      gap: 1.2rem;\n    39→      position: sticky;\n    40→      top: 0;\n    41→      z-index: 100;\n    42→    }\n    43→    .brand { display: flex; align-items: center; gap: 0.55rem; flex-shrink: 0; }\n    44→    .brand-icon {\n    45→      width: 30px; height: 30px;\n    46→      background: linear-gradient(135deg, #3b82f6, #7c3aed);\n    47→      border-radius: 7px;\n    48→      display: flex; align-items: center; justify-content: center;\n    49→      font-size: 14px; font-weight: 700; color: #fff;\n    50→    }\n    51→    .brand h1 { font-size: 1rem; font-weight: 700; letter-spacing: -0.01em; white-space: nowrap; }\n    52→\n    53→    .divider-v { width: 1px; height: 22px; background: var(--border); flex-shrink: 0; }\n    54→\n    55→    /* project selector */\n    56→    .project-select-wrap { display: flex; align-items: center; gap: 0.6rem; flex: 1; min-width: 0; }\n    57→    .project-select-label { font-size: 0.75rem; color: var(--muted); white-space: nowrap; flex-shrink: 0; }\n    58→    .project-select {\n    59→      background: var(--card2);\n    60→      border: 1px solid var(--border);\n    61→      color: var(--text);\n    62→      padding: 0.3rem 0.7rem;\n    63→      border-radius: 7px;\n    64→      font-size: 0.85rem;\n    65→      font-family: inherit;\n    66→      cursor: pointer;\n    67→      min-width: 180px;\n    68→      max-width: 320px;\n    69→      outline: none;\n    70→      transition: border-color 0.15s;\n    71→    }\n    72→    .project-select:focus { border-color: rgba(96,165,250,0.5); }\n    73→    .project-select option { background: #1a2035; }\n    74→\n    75→    .header-right { display: flex; align-items: center; gap: 0.7rem; margin-left: auto; flex-shrink: 0; }\n    76→    .loop-badge {\n    77→      display: flex; align-items: center; gap: 0.35rem;\n    78→      font-size: 0.72rem; color: var(--muted);\n    79→      background: var(--card2);\n    80→      border: 1px solid var(--border);\n    81→      padding: 0.25rem 0.6rem;\n    82→      border-radius: 20px;\n    83→    }\n    84→    .loop-dot {\n    85→      width: 7px; height: 7px; border-radius: 50%;\n    86→      background: var(--muted);\n    87→      transition: background 0.3s;\n    88→    }\n    89→    .loop-dot.running { background: var(--green); box-shadow: 0 0 5px var(--green); animation: pulse 2s infinite; }\n    90→    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }\n    91→\n    92→    .btn-sm {\n    93→      background: rgba(96,165,250,0.1);\n    94→      border: 1px solid rgba(96,165,250,0.25);\n    95→      color: var(--blue);\n    96→      padding: 0.28rem 0.75rem;\n    97→      border-radius: 6px;\n    98→      cursor: pointer;\n    99→      font-size: 0.78rem;\n   100→      font-family: inherit;\n   101→      transition: background 0.15s;\n   102→      white-space: nowrap;\n   103→    }\n   104→    .btn-sm:hover { background: rgba(96,165,250,0.18); }\n   105→    .btn-sm:disabled { opacity: 0.45; cursor: not-allowed; }\n   106→    .btn-sm.danger { background: rgba(255,77,94,0.1); border-color: rgba(255,77,94,0.25); color: var(--red); }\n   107→    .btn-sm.danger:hover { background: rgba(255,77,94,0.18); }\n   108→    .btn-sm.success { background: rgba(0,201,139,0.1); border-color: rgba(0,201,139,0.25); color: var(--green); }\n   109→    .btn-sm.success:hover { background: rgba(0,201,139,0.18); }\n   110→\n   111→    /* ── Empty state ── */\n   112→    #no-project {\n   113→      display: flex; flex-direction: column; align-items: center;\n   114→      justify-content: center; height: calc(100vh - 56px);\n   115→      gap: 0.8rem; color: var(--muted);\n   116→    }\n   117→    #no-project h2 { font-size: 1.1rem; font-weight: 600; color: var(--text); }\n   118→    #no-project p { font-size: 0.85rem; }\n   119→\n   120→    /* ── Layout ── */\n   121→    #app { display: none; flex-direction: column; height: calc(100vh - 56px); }\n   122→\n   123→    /* ── Tabs ── */\n   124→    .tabs {\n   125→      display: flex; gap: 0;\n   126→      border-bottom: 1px solid var(--border);\n   127→      background: rgba(13,16,30,0.6);\n   128→      padding: 0 1.2rem;\n   129→      flex-shrink: 0;\n   130→    }\n   131→    .tab {\n   132→      padding: 0.65rem 1rem;\n   133→      font-size: 0.82rem;\n   134→      font-weight: 500;\n   135→      color: var(--muted);\n   136→      cursor: pointer;\n   137→      border-bottom: 2px solid transparent;\n   138→      margin-bottom: -1px;\n   139→      transition: color 0.15s;\n   140→      user-select: none;\n   141→    }\n   142→    .tab:hover { color: var(--text); }\n   143→    .tab.active { color: var(--blue); border-bottom-color: var(--blue); }\n   144→\n   145→    .tab-content { flex: 1; overflow: hidden; }\n   146→    .tab-pane { display: none; height: 100%; overflow: auto; padding: 1.2rem 1.4rem 2rem; }\n   147→    .tab-pane.active { display: block; }\n   148→\n   149→    /* ── Cards ── */\n   150→    .card {\n   151→      background: var(--card);\n   152→      border: 1px solid var(--border);\n   153→      border-radius: 12px;\n   154→      padding: 1.1rem 1.25rem;\n   155→      margin-bottom: 1rem;\n   156→    }\n   157→    .card-title {\n   158→      font-size: 0.78rem;\n   159→      font-weight: 600;\n   160→      color: var(--muted);\n   161→      text-transform: uppercase;\n   162→      letter-spacing: 0.05em;\n   163→      margin-bottom: 0.85rem;\n   164→    }\n   165→\n   166→    /* ── Tasks ── */\n   167→    .task-input-row {\n   168→      display: flex; gap: 0.6rem; margin-bottom: 1rem;\n   169→    }\n   170→    .task-input {\n   171→      flex: 1;\n   172→      background: var(--card2);\n   173→      border: 1px solid var(--border);\n   174→      color: var(--text);\n   175→      padding: 0.45rem 0.8rem;\n   176→      border-radius: 7px;\n   177→      font-size: 0.85rem;\n   178→      font-family: inherit;\n   179→      outline: none;\n   180→      transition: border-color 0.15s;\n   181→    }\n   182→    .task-input:focus { border-color: rgba(96,165,250,0.5); }\n   183→\n   184→    .task-list { display: flex; flex-direction: column; gap: 0.45rem; }\n   185→    .task-item {\n   186→      display: flex; align-items: center; gap: 0.7rem;\n   187→      background: var(--card2);\n   188→      border: 1px solid var(--border);\n   189→      border-radius: 8px;\n   190→      padding: 0.55rem 0.8rem;\n   191→      transition: border-color 0.15s;\n   192→    }\n   193→    .task-item:hover { border-color: rgba(255,255,255,0.12); }\n   194→    .task-status-btn {\n   195→      flex-shrink: 0;\n   196→      width: 18px; height: 18px;\n   197→      border-radius: 50%;\n   198→      border: 2px solid var(--muted);\n   199→      background: transparent;\n   200→      cursor: pointer;\n   201→      display: flex; align-items: center; justify-content: center;\n   202→      transition: all 0.15s;\n   203→      font-size: 10px;\n   204→      color: transparent;\n   205→    }\n   206→    .task-status-btn:hover { border-color: var(--green); }\n   207→    .task-item.in_progress .task-status-btn { border-color: var(--yellow); }\n   208→    .task-item.done .task-status-btn { border-color: var(--green); background: rgba(0,201,139,0.15); color: var(--green); }\n   209→    .task-title-text {\n   210→      flex: 1;\n   211→      font-size: 0.85rem;\n   212→      line-height: 1.4;\n   213→    }\n   214→    .task-item.done .task-title-text { text-decoration: line-through; color: var(--muted); }\n   215→    .task-meta {\n   216→      font-size: 0.72rem;\n   217→      color: var(--muted);\n   218→      white-space: nowrap;\n   219→      flex-shrink: 0;\n   220→    }\n   221→    .task-status-tag {\n   222→      font-size: 0.68rem;\n   223→      font-weight: 600;\n   224→      padding: 0.12rem 0.42rem;\n   225→      border-radius: 4px;\n   226→      flex-shrink: 0;\n   227→    }\n   228→    .task-status-tag.pending     { background: rgba(90,100,128,0.2); color: var(--muted); }\n   229→    .task-status-tag.in_progress { background: rgba(251,191,36,0.12); color: var(--yellow); }\n   230→    .task-status-tag.done        { background: rgba(0,201,139,0.12); color: var(--green); }\n   231→    .task-del-btn {\n   232→      flex-shrink: 0;\n   233→      background: none;\n   234→      border: none;\n   235→      color: var(--muted);\n   236→      cursor: pointer;\n   237→      font-size: 14px;\n   238→      padding: 0 0.2rem;\n   239→      opacity: 0;\n   240→      transition: opacity 0.15s, color 0.15s;\n   241→    }\n   242→    .task-item:hover .task-del-btn { opacity: 1; }\n   243→    .task-del-btn:hover { color: var(--red); }\n   244→\n   245→    .empty-hint { font-size: 0.82rem; color: var(--muted); text-align: center; padding: 2rem; }\n   246→\n   247→    /* ── Task status cycle menu ── */\n   248→    .task-cycle-btn {\n   249→      flex-shrink: 0;\n   250→      background: none; border: none;\n   251→      font-size: 0.72rem; font-weight: 600;\n   252→      cursor: pointer;\n   253→      padding: 0.12rem 0.42rem;\n   254→      border-radius: 4px;\n   255→      transition: opacity 0.15s;\n   256→    }\n   257→    .task-cycle-btn:hover { opacity: 0.75; }\n   258→\n   259→    /* ── Logs ── */\n   260→    .log-controls {\n   261→      display: flex; align-items: center; gap: 0.7rem; margin-bottom: 0.8rem; flex-wrap: wrap;\n   262→    }\n   263→    .log-controls label { font-size: 0.78rem; color: var(--muted); display: flex; align-items: center; gap: 0.4rem; }\n   264→    .log-controls input[type=checkbox] { accent-color: var(--blue); }\n   265→    .log-lines-select {\n   266→      background: var(--card2); border: 1px solid var(--border);\n   267→      color: var(--text); padding: 0.25rem 0.5rem; border-radius: 5px;\n   268→      font-size: 0.78rem; font-family: inherit; outline: none;\n   269→    }\n   270→    .log-box {\n   271→      background: #080a12;\n   272→      border: 1px solid var(--border);\n   273→      border-radius: 8px;\n   274→      padding: 0.9rem 1rem;\n   275→      font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;\n   276→      font-size: 0.75rem;\n   277→      line-height: 1.55;\n   278→      color: #a8b4c8;\n   279→      white-space: pre-wrap;\n   280→      word-break: break-all;\n   281→      max-height: calc(100vh - 280px);\n   282→      overflow-y: auto;\n   283→    }\n   284→    .log-box .log-empty { color: var(--muted); }\n   285→\n   286→    /* ── Files ── */\n   287→    .files-search-row { display: flex; gap: 0.6rem; margin-bottom: 0.8rem; }\n   288→    .files-search {\n   289→      flex: 1; background: var(--card2); border: 1px solid var(--border);\n   290→      color: var(--text); padding: 0.38rem 0.75rem; border-radius: 7px;\n   291→      font-size: 0.82rem; font-family: inherit; outline: none;\n   292→    }\n   293→    .files-search:focus { border-color: rgba(96,165,250,0.4); }\n   294→    .file-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }\n   295→    .file-table th {\n   296→      text-align: left; padding: 0.4rem 0.6rem;\n   297→      font-size: 0.7rem; font-weight: 600; color: var(--muted);\n   298→      text-transform: uppercase; letter-spacing: 0.04em;\n   299→      border-bottom: 1px solid var(--border);\n   300→    }\n   301→    .file-table td { padding: 0.38rem 0.6rem; border-bottom: 1px solid rgba(255,255,255,0.03); }\n   302→    .file-table tr:hover td { background: rgba(255,255,255,0.02); }\n   303→    .file-path { color: var(--blue); font-family: monospace; font-size: 0.78rem; }\n   304→    .file-size { color: var(--muted); white-space: nowrap; }\n   305→    .file-mtime { color: var(--muted); white-space: nowrap; font-size: 0.72rem; }\n   306→\n   307→    /* ── Status ── */\n   308→    .status-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0.9rem; }\n   309→    .stat-block {\n   310→      background: var(--card2); border: 1px solid var(--border);\n   311→      border-radius: 9px; padding: 0.9rem 1rem;\n   312→    }\n   313→    .stat-label { font-size: 0.7rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.4rem; }\n   314→    .stat-value { font-size: 0.9rem; font-weight: 600; word-break: break-all; }\n   315→    .stat-value.green { color: var(--green); }\n   316→    .stat-value.red   { color: var(--red); }\n   317→    .stat-value.muted { color: var(--muted); font-weight: 400; }\n   318→\n   319→    .git-status-lines {\n   320→      font-family: monospace; font-size: 0.75rem; line-height: 1.6;\n   321→      color: var(--muted); margin-top: 0.5rem;\n   322→    }\n   323→    .git-status-lines span { display: block; }\n   324→    .git-status-lines .M { color: var(--yellow); }\n   325→    .git-status-lines .A { color: var(--green); }\n   326→    .git-status-lines .D { color: var(--red); }\n   327→    .git-status-lines .Q { color: var(--muted); }\n   328→\n   329→    /* ── Spinner ── */\n   330→    .spinner {\n   331→      display: inline-block; width: 16px; height: 16px;\n   332→      border: 2px solid var(--border); border-top-color: var(--blue);\n   333→      border-radius: 50%; animation: spin 0.6s linear infinite;\n   334→    }\n   335→    @keyframes spin { to { transform: rotate(360deg); } }\n   336→\n   337→    /* ── Toast ── */\n   338→    #toast {\n   339→      position: fixed; bottom: 1.5rem; right: 1.5rem;\n   340→      background: var(--card); border: 1px solid var(--border);\n   341→      padding: 0.6rem 1rem; border-radius: 8px;\n   342→      font-size: 0.82rem; color: var(--text);\n   343→      box-shadow: 0 4px 20px rgba(0,0,0,0.4);\n   344→      opacity: 0; transform: translateY(8px);\n   345→      transition: opacity 0.2s, transform 0.2s;\n   346→      pointer-events: none; z-index: 999;\n   347→    }\n   348→    #toast.show { opacity: 1; transform: translateY(0); }\n   349→\n   350→    /* ── Scrollbar ── */\n   351→    ::-webkit-scrollbar { width: 6px; height: 6px; }\n   352→    ::-webkit-scrollbar-track { background: transparent; }\n   353→    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }\n   354→\n   355→    /* ── Create Project Modal ── */\n   356→    .modal-overlay {\n   357→      position: fixed; inset: 0; z-index: 500;\n   358→      background: rgba(0,0,0,0.6);\n   359→      backdrop-filter: blur(4px);\n   360→      display: flex; align-items: center; justify-content: center;\n   361→      opacity: 0; pointer-events: none;\n   362→      transition: opacity 0.2s;\n   363→    }\n   364→    .modal-overlay.open { opacity: 1; pointer-events: auto; }\n   365→\n   366→    .modal {\n   367→      background: var(--card);\n   368→      border: 1px solid var(--border);\n   369→      border-radius: 14px;\n   370→      padding: 1.6rem 1.8rem;\n   371→      width: 100%;\n   372→      max-width: 480px;\n   373→      box-shadow: 0 20px 60px rgba(0,0,0,0.5);\n   374→      transform: translateY(10px);\n   375→      transition: transform 0.2s;\n   376→    }\n   377→    .modal-overlay.open .modal { transform: translateY(0); }\n   378→\n   379→    .modal-header {\n   380→      display: flex; align-items: center; justify-content: space-between;\n   381→      margin-bottom: 1.4rem;\n   382→    }\n   383→    .modal-title { font-size: 1rem; font-weight: 700; }\n   384→    .modal-close {\n   385→      background: none; border: none; color: var(--muted);\n   386→      font-size: 1.2rem; cursor: pointer; padding: 0.1rem 0.3rem;\n   387→      border-radius: 4px; line-height: 1;\n   388→      transition: color 0.15s;\n   389→    }\n   390→    .modal-close:hover { color: var(--text); }\n   391→\n   392→    .form-group { margin-bottom: 1.1rem; }\n   393→    .form-label {\n   394→      display: block; font-size: 0.78rem; font-weight: 600;\n   395→      color: var(--muted); text-transform: uppercase;\n   396→      letter-spacing: 0.05em; margin-bottom: 0.45rem;\n   397→    }\n   398→    .form-input {\n   399→      width: 100%;\n   400→      background: var(--card2);\n   401→      border: 1px solid var(--border);\n   402→      color: var(--text);\n   403→      padding: 0.48rem 0.8rem;\n   404→      border-radius: 7px;\n   405→      font-size: 0.85rem;\n   406→      font-family: inherit;\n   407→      outline: none;\n   408→      transition: border-color 0.15s;\n   409→    }\n   410→    .form-input:focus { border-color: rgba(96,165,250,0.5); }\n   411→    .form-input::placeholder { color: var(--muted); opacity: 0.6; }\n   412→\n   413→    .radio-group { display: flex; flex-direction: column; gap: 0.5rem; }\n   414→    .radio-option {\n   415→      display: flex; align-items: center; gap: 0.6rem;\n   416→      background: var(--card2);\n   417→      border: 1px solid var(--border);\n   418→      border-radius: 8px;\n   419→      padding: 0.6rem 0.9rem;\n   420→      cursor: pointer;\n   421→      transition: border-color 0.15s;\n   422→    }\n   423→    .radio-option:hover { border-color: rgba(96,165,250,0.35); }\n   424→    .radio-option input[type=radio] { accent-color: var(--blue); cursor: pointer; flex-shrink: 0; }\n   425→    .radio-option-label { font-size: 0.84rem; flex: 1; }\n   426→    .radio-option-desc { font-size: 0.72rem; color: var(--muted); margin-top: 0.12rem; }\n   427→    .radio-option.selected { border-color: rgba(96,165,250,0.45); background: rgba(96,165,250,0.06); }\n   428→\n   429→    .conditional-field {\n   430→      margin-top: 0.6rem;\n   431→      display: none;\n   432→    }\n   433→    .conditional-field.visible { display: block; }\n   434→\n   435→    /* Toggle switch */\n   436→    .toggle-row {\n   437→      display: flex; align-items: center; justify-content: space-between;\n   438→      background: var(--card2);\n   439→      border: 1px solid var(--border);\n   440→      border-radius: 8px;\n   441→      padding: 0.65rem 0.9rem;\n   442→    }\n   443→    .toggle-info { flex: 1; }\n   444→    .toggle-info-label { font-size: 0.85rem; font-weight: 500; }\n   445→    .toggle-info-desc { font-size: 0.72rem; color: var(--muted); margin-top: 0.1rem; }\n   446→    .toggle-switch {\n   447→      position: relative; width: 40px; height: 22px; flex-shrink: 0;\n   448→    }\n   449→    .toggle-switch input { opacity: 0; width: 0; height: 0; }\n   450→    .toggle-slider {\n   451→      position: absolute; inset: 0;\n   452→      background: rgba(255,255,255,0.12);\n   453→      border-radius: 22px;\n   454→      cursor: pointer;\n   455→      transition: background 0.2s;\n   456→    }\n   457→    .toggle-slider::before {\n   458→      content: '';\n   459→      position: absolute;\n   460→      width: 16px; height: 16px;\n   461→      left: 3px; top: 3px;\n   462→      background: #fff;\n   463→      border-radius: 50%;\n   464→      transition: transform 0.2s;\n   465→    }\n   466→    .toggle-switch input:checked + .toggle-slider { background: var(--blue); }\n   467→    .toggle-switch input:checked + .toggle-slider::before { transform: translateX(18px); }\n   468→\n   469→    .modal-footer {\n   470→      display: flex; gap: 0.7rem; justify-content: flex-end;\n   471→      margin-top: 1.5rem;\n   472→    }\n   473→    .btn-cancel {\n   474→      background: rgba(255,255,255,0.05);\n   475→      border: 1px solid var(--border);\n   476→      color: var(--muted);\n   477→      padding: 0.42rem 1rem;\n   478→      border-radius: 7px;\n   479→      cursor: pointer;\n   480→      font-size: 0.84rem;\n   481→      font-family: inherit;\n   482→      transition: background 0.15s, color 0.15s;\n   483→    }\n   484→    .btn-cancel:hover { background: rgba(255,255,255,0.09); color: var(--text); }\n   485→    .btn-primary {\n   486→      background: rgba(96,165,250,0.15);\n   487→      border: 1px solid rgba(96,165,250,0.35);\n   488→      color: var(--blue);\n   489→      padding: 0.42rem 1.1rem;\n   490→      border-radius: 7px;\n   491→      cursor: pointer;\n   492→      font-size: 0.84rem;\n   493→      font-weight: 600;\n   494→      font-family: inherit;\n   495→      transition: background 0.15s;\n   496→    }\n   497→    .btn-primary:hover { background: rgba(96,165,250,0.25); }\n   498→    .btn-primary:disabled { opacity: 0.45; cursor: not-allowed; }\n   499→  </style>\n   500→</head>\n   501→<body>\n   502→\n   503→<header>\n   504→  <div class=\"brand\">\n   505→    <div class=\"brand-icon\">R</div>\n   506→    <h1>Ralph</h1>\n   507→  </div>\n   508→  <div class=\"divider-v\"></div>\n   509→  <div class=\"project-select-wrap\">\n   510→    <span class=\"project-select-label\">项目</span>\n   511→    <select class=\"project-select\" id=\"project-select\" onchange=\"onProjectChange(this.value)\">\n   512→      <option value=\"\">— 选择项目 —</option>\n   513→    </select>\n   514→  </div>\n   515→  <div class=\"header-right\">\n   516→    <div class=\"loop-badge\" id=\"loop-badge\">\n   517→      <div class=\"loop-dot\" id=\"loop-dot\"></div>\n   518→      <span id=\"loop-label\">未选择</span>\n   519→    </div>\n   520→    <button class=\"btn-sm success\" onclick=\"openCreateModal()\" title=\"创建新项目\">+ 创建项目</button>\n   521→    <button class=\"btn-sm\" id=\"btn-refresh\" onclick=\"refreshCurrent()\" title=\"刷新当前视图\">刷新</button>\n   522→  </div>\n   523→</header>\n   524→\n   525→<div id=\"no-project\">\n   526→  <h2>暂无项目</h2>\n   527→  <p>请通过 API 创建项目，或选择已有项目</p>\n   528→</div>\n   529→\n   530→<div id=\"app\">\n   531→  <div class=\"tabs\">\n   532→    <div class=\"tab active\" data-tab=\"tasks\" onclick=\"switchTab('tasks')\">任务</div>\n   533→    <div class=\"tab\" data-tab=\"logs\"  onclick=\"switchTab('logs')\">日志</div>\n   534→    <div class=\"tab\" data-tab=\"files\" onclick=\"switchTab('files')\">文件</div>\n   535→    <div class=\"tab\" data-tab=\"status\" onclick=\"switchTab('status')\">状态</div>\n   536→  </div>\n   537→  <div class=\"tab-content\">\n   538→\n   539→    <!-- Tasks -->\n   540→    <div class=\"tab-pane active\" id=\"pane-tasks\">\n   541→      <div class=\"task-input-row\">\n   542→        <input class=\"task-input\" id=\"new-task-input\" placeholder=\"添加新任务…\" onkeydown=\"onTaskKeydown(event)\" />\n   543→        <button class=\"btn-sm success\" onclick=\"addTask()\">+ 添加</button>\n   544→      </div>\n   545→      <div class=\"task-list\" id=\"task-list\">\n   546→        <div class=\"empty-hint\"><div class=\"spinner\"></div></div>\n   547→      </div>\n   548→    </div>\n   549→\n   550→    <!-- Logs -->\n   551→    <div class=\"tab-pane\" id=\"pane-logs\">\n   552→      <div class=\"log-controls\">\n   553→        <label>\n   554→          <input type=\"checkbox\" id=\"log-auto\" onchange=\"onLogAutoChange()\" />\n   555→          自动刷新 (5s)\n   556→        </label>\n   557→        <label>\n   558→          最近\n   559→          <select class=\"log-lines-select\" id=\"log-lines\" onchange=\"loadLogs()\">\n   560→            <option value=\"100\">100 行</option>\n   561→            <option value=\"300\" selected>300 行</option>\n   562→            <option value=\"500\">500 行</option>\n   563→            <option value=\"1000\">1000 行</option>\n   564→          </select>\n   565→        </label>\n   566→        <button class=\"btn-sm\" onclick=\"loadLogs()\">刷新</button>\n   567→        <span id=\"log-total\" style=\"font-size:0.75rem;color:var(--muted)\"></span>\n   568→      </div>\n   569→      <div class=\"log-box\" id=\"log-box\"><span class=\"log-empty\">加载中…</span></div>\n   570→    </div>\n   571→\n   572→    <!-- Files -->\n   573→    <div class=\"tab-pane\" id=\"pane-files\">\n   574→      <div class=\"files-search-row\">\n   575→        <input class=\"files-search\" id=\"files-search\" placeholder=\"搜索文件…\" oninput=\"renderFiles()\" />\n   576→        <button class=\"btn-sm\" onclick=\"loadFiles()\">刷新</button>\n   577→      </div>\n   578→      <table class=\"file-table\" id=\"file-table\">\n   579→        <thead><tr><th>路径</th><th>大小</th><th>修改时间</th></tr></thead>\n   580→        <tbody id=\"file-tbody\"></tbody>\n   581→      </table>\n   582→    </div>\n   583→\n   584→    <!-- Status -->\n   585→    <div class=\"tab-pane\" id=\"pane-status\">\n   586→      <div id=\"status-content\">\n   587→        <div class=\"empty-hint\"><div class=\"spinner\"></div></div>\n   588→      </div>\n   589→    </div>\n   590→\n   591→  </div>\n   592→</div>\n   593→\n   594→<div id=\"toast\"></div>\n   595→\n   596→<!-- ── Create Project Modal ── -->\n   597→<div class=\"modal-overlay\" id=\"create-modal-overlay\" onclick=\"onModalOverlayClick(event)\">\n   598→  <div class=\"modal\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"modal-title\">\n   599→    <div class=\"modal-header\">\n   600→      <span class=\"modal-title\" id=\"modal-title\">创建新项目</span>\n   601→      <button class=\"modal-close\" onclick=\"closeCreateModal()\" aria-label=\"关闭\">✕</button>\n   602→    </div>\n   603→\n   604→    <!-- 项目名称 -->\n   605→    <div class=\"form-group\">\n   606→      <label class=\"form-label\" for=\"cp-name\">项目名称 <span style=\"color:var(--red)\">*</span></label>\n   607→      <input class=\"form-input\" id=\"cp-name\" type=\"text\" placeholder=\"my-awesome-project\" maxlength=\"80\" required />\n   608→    </div>\n   609→\n   610→    <!-- 项目描述 -->\n   611→    <div class=\"form-group\">\n   612→      <label class=\"form-label\" for=\"cp-desc\">项目描述（可选）</label>\n   613→      <input class=\"form-input\" id=\"cp-desc\" type=\"text\" placeholder=\"简短描述这个项目…\" maxlength=\"200\" />\n   614→    </div>\n   615→\n   616→    <!-- Git 来源 -->\n   617→    <div class=\"form-group\">\n   618→      <label class=\"form-label\">Git 来源</label>\n   619→      <div class=\"radio-group\" id=\"cp-git-source-group\">\n   620→        <label class=\"radio-option selected\" id=\"opt-new\">\n   621→          <input type=\"radio\" name=\"cp-git-source\" value=\"new\" checked onchange=\"onGitSourceChange('new')\" />\n   622→          <div>\n   623→            <div class=\"radio-option-label\">新建空项目</div>\n   624→            <div class=\"radio-option-desc\">在本地创建一个全新的 Git 仓库</div>\n   625→          </div>\n   626→        </label>\n   627→        <label class=\"radio-option\" id=\"opt-github\">\n   628→          <input type=\"radio\" name=\"cp-git-source\" value=\"github\" onchange=\"onGitSourceChange('github')\" />\n   629→          <div>\n   630→            <div class=\"radio-option-label\">关联 GitHub 仓库</div>\n   631→            <div class=\"radio-option-desc\">Clone 并绑定一个已有的 GitHub 仓库</div>\n   632→          </div>\n   633→        </label>\n   634→        <label class=\"radio-option\" id=\"opt-dir\">\n   635→          <input type=\"radio\" name=\"cp-git-source\" value=\"dir\" onchange=\"onGitSourceChange('dir')\" />\n   636→          <div>\n   637→            <div class=\"radio-option-label\">使用已有目录</div>\n   638→            <div class=\"radio-option-desc\">绑定服务器上已存在的本地目录</div>\n   639→          </div>\n   640→        </label>\n   641→      </div>\n   642→\n   643→      <!-- 条件字段：GitHub URL -->\n   644→      <div class=\"conditional-field\" id=\"cp-github-field\">\n   645→        <input class=\"form-input\" id=\"cp-github-url\" type=\"url\"\n   646→               placeholder=\"https://github.com/user/repo.git\" />\n   647→      </div>\n   648→\n   649→      <!-- 条件字段：目录路径 -->\n   650→      <div class=\"conditional-field\" id=\"cp-dir-field\">\n   651→        <input class=\"form-input\" id=\"cp-dir-path\" type=\"text\"\n   652→               placeholder=\"/home/user/projects/my-repo\" />\n   653→      </div>\n   654→    </div>\n   655→\n   656→    <!-- 自动 push 开关 -->\n   657→    <div class=\"form-group\">\n   658→      <label class=\"form-label\">自动推送</label>\n   659→      <div class=\"toggle-row\">\n   660→        <div class=\"toggle-info\">\n   661→          <div class=\"toggle-info-label\">自动 push 到远程</div>\n   662→          <div class=\"toggle-info-desc\">每次提交后自动执行 git push</div>\n   663→        </div>\n   664→        <label class=\"toggle-switch\">\n   665→          <input type=\"checkbox\" id=\"cp-auto-push\" />\n   666→          <span class=\"toggle-slider\"></span>\n   667→        </label>\n   668→      </div>\n   669→    </div>\n   670→\n   671→    <div class=\"modal-footer\">\n   672→      <button class=\"btn-cancel\" onclick=\"closeCreateModal()\">取消</button>\n   673→      <button class=\"btn-primary\" id=\"cp-submit-btn\" onclick=\"submitCreateProject()\">创建项目</button>\n   674→    </div>\n   675→  </div>\n   676→</div>\n   677→\n   678→<script>\n   679→// ─── State ────────────────────────────────────────────────────────────────────\n   680→const LS_KEY = 'ralph_selected_project';\n   681→let projects = [];\n   682→let currentId = localStorage.getItem(LS_KEY) || '';\n   683→let currentTab = 'tasks';\n   684→let allFiles = [];\n   685→let logAutoTimer = null;\n   686→let statusRefreshTimer = null;\n   687→\n   688→// ─── Init ─────────────────────────────────────────────────────────────────────\n   689→async function init() {\n   690→  await loadProjects();\n   691→  const stored = currentId;\n   692→  if (stored && projects.find(p => p.id === stored)) {\n   693→    setProject(stored);\n   694→  } else if (projects.length > 0) {\n   695→    setProject(projects[0].id);\n   696→  } else {\n   697→    showNoProject();\n   698→  }\n   699→}\n   700→\n   701→// ─── Projects ─────────────────────────────────────────────────────────────────\n   702→async function loadProjects() {\n   703→  try {\n   704→    const r = await fetch('/api/projects');\n   705→    projects = await r.json();\n   706→  } catch { projects = []; }\n   707→  renderProjectSelect();\n   708→}\n   709→\n   710→function renderProjectSelect() {\n   711→  const sel = document.getElementById('project-select');\n   712→  sel.innerHTML = '<option value=\"\">— 选择项目 —</option>';\n   713→  projects.forEach(p => {\n   714→    const opt = document.createElement('option');\n   715→    opt.value = p.id;\n   716→    opt.textContent = p.name + (p.status === 'archived' ? ' (已归档)' : '');\n   717→    sel.appendChild(opt);\n   718→  });\n   719→  sel.value = currentId || '';\n   720→}\n   721→\n   722→function onProjectChange(id) {\n   723→  if (id) setProject(id);\n   724→  else showNoProject();\n   725→}\n   726→\n   727→function setProject(id) {\n   728→  currentId = id;\n   729→  localStorage.setItem(LS_KEY, id);\n   730→  document.getElementById('project-select').value = id;\n   731→  document.getElementById('no-project').style.display = 'none';\n   732→  document.getElementById('app').style.display = 'flex';\n   733→  stopAllAutoRefresh();\n   734→  loadCurrentTab();\n   735→  updateLoopBadge();\n   736→}\n   737→\n   738→function showNoProject() {\n   739→  document.getElementById('no-project').style.display = 'flex';\n   740→  document.getElementById('app').style.display = 'none';\n   741→  updateLoopBadge();\n   742→}\n   743→\n   744→// ─── Tabs ─────────────────────────────────────────────────────────────────────\n   745→function switchTab(tab) {\n   746→  stopAllAutoRefresh();\n   747→  currentTab = tab;\n   748→  document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === tab));\n   749→  document.querySelectorAll('.tab-pane').forEach(p => p.classList.toggle('active', p.id === `pane-${tab}`));\n   750→  loadCurrentTab();\n   751→}\n   752→\n   753→function loadCurrentTab() {\n   754→  if (!currentId) return;\n   755→  if (currentTab === 'tasks')  loadTasks();\n   756→  if (currentTab === 'logs')   loadLogs();\n   757→  if (currentTab === 'files')  loadFiles();\n   758→  if (currentTab === 'status') loadStatus();\n   759→}\n   760→\n   761→function refreshCurrent() {\n   762→  loadProjects().then(() => {\n   763→    if (currentId) {\n   764→      loadCurrentTab();\n   765→      updateLoopBadge();\n   766→    }\n   767→  });\n   768→}\n   769→\n   770→// ─── Tasks ────────────────────────────────────────────────────────────────────\n   771→async function loadTasks() {\n   772→  const list = document.getElementById('task-list');\n   773→  list.innerHTML = '<div class=\"empty-hint\"><div class=\"spinner\"></div></div>';\n   774→  try {\n   775→    const r = await fetch(`/api/projects/${currentId}/tasks`);\n   776→    const tasks = await r.json();\n   777→    renderTasks(tasks);\n   778→  } catch {\n   779→    list.innerHTML = '<div class=\"empty-hint\" style=\"color:var(--red)\">加载失败</div>';\n   780→  }\n   781→}\n   782→\n   783→const STATUS_CYCLE = { pending: 'in_progress', in_progress: 'done', done: 'pending' };\n   784→const STATUS_LABEL = { pending: '待处理', in_progress: '进行中', done: '已完成' };\n   785→const STATUS_CLASS = { pending: 'pending', in_progress: 'in_progress', done: 'done' };\n   786→\n   787→function renderTasks(tasks) {\n   788→  const list = document.getElementById('task-list');\n   789→  if (!tasks.length) {\n   790→    list.innerHTML = '<div class=\"empty-hint\">暂无任务，添加第一个吧</div>';\n   791→    return;\n   792→  }\n   793→  list.innerHTML = '';\n   794→  tasks.forEach(t => {\n   795→    const item = document.createElement('div');\n   796→    item.className = `task-item ${t.status}`;\n   797→    item.dataset.id = t.id;\n   798→\n   799→    const checkmark = t.status === 'done' ? '✓' : (t.status === 'in_progress' ? '…' : '');\n   800→    const tagCls = STATUS_CLASS[t.status] || 'pending';\n   801→    const tagLabel = STATUS_LABEL[t.status] || t.status;\n   802→    const nextStatus = STATUS_CYCLE[t.status] || 'pending';\n   803→\n   804→    item.innerHTML = `\n   805→      <button class=\"task-status-btn\" onclick=\"cycleTaskStatus('${t.id}','${nextStatus}')\" title=\"切换状态\">${checkmark}</button>\n   806→      <span class=\"task-title-text\">${escHtml(t.title)}</span>\n   807→      <span class=\"task-status-tag ${tagCls}\" onclick=\"cycleTaskStatus('${t.id}','${nextStatus}')\" style=\"cursor:pointer\" title=\"切换到: ${STATUS_LABEL[nextStatus]}\">${tagLabel}</span>\n   808→      <button class=\"task-del-btn\" onclick=\"deleteTask('${t.id}')\" title=\"删除\">✕</button>\n   809→    `;\n   810→    list.appendChild(item);\n   811→  });\n   812→}\n   813→\n   814→async function addTask() {\n   815→  const input = document.getElementById('new-task-input');\n   816→  const title = input.value.trim();\n   817→  if (!title) return;\n   818→  input.value = '';\n   819→  try {\n   820→    await fetch(`/api/projects/${currentId}/tasks`, {\n   821→      method: 'POST',\n   822→      headers: { 'Content-Type': 'application/json' },\n   823→      body: JSON.stringify({ title }),\n   824→    });\n   825→    loadTasks();\n   826→    showToast('任务已添加');\n   827→  } catch {\n   828→    showToast('添加失败', true);\n   829→  }\n   830→}\n   831→\n   832→function onTaskKeydown(e) {\n   833→  if (e.key === 'Enter') addTask();\n   834→}\n   835→\n   836→async function cycleTaskStatus(tid, nextStatus) {\n   837→  try {\n   838→    await fetch(`/api/projects/${currentId}/tasks/${tid}`, {\n   839→      method: 'PUT',\n   840→      headers: { 'Content-Type': 'application/json' },\n   841→      body: JSON.stringify({ status: nextStatus }),\n   842→    });\n   843→    loadTasks();\n   844→  } catch {\n   845→    showToast('更新失败', true);\n   846→  }\n   847→}\n   848→\n   849→async function deleteTask(tid) {\n   850→  if (!confirm('确认删除此任务？')) return;\n   851→  try {\n   852→    await fetch(`/api/projects/${currentId}/tasks/${tid}`, { method: 'DELETE' });\n   853→    loadTasks();\n   854→    showToast('任务已删除');\n   855→  } catch {\n   856→    showToast('删除失败', true);\n   857→  }\n   858→}\n   859→\n   860→// ─── Logs ─────────────────────────────────────────────────────────────────────\n   861→async function loadLogs() {\n   862→  const lines = document.getElementById('log-lines').value;\n   863→  const box = document.getElementById('log-box');\n   864→  try {\n   865→    const r = await fetch(`/api/projects/${currentId}/logs?lines=${lines}`);\n   866→    const d = await r.json();\n   867→    const atBottom = box.scrollHeight - box.scrollTop - box.clientHeight < 60;\n   868→    box.textContent = d.logs || '';\n   869→    if (!d.logs) box.innerHTML = '<span class=\"log-empty\">暂无日志</span>';\n   870→    document.getElementById('log-total').textContent = `共 ${d.total_lines || 0} 行`;\n   871→    if (atBottom) box.scrollTop = box.scrollHeight;\n   872→  } catch {\n   873→    box.innerHTML = '<span style=\"color:var(--red)\">加载失败</span>';\n   874→  }\n   875→}\n   876→\n   877→function onLogAutoChange() {\n   878→  const checked = document.getElementById('log-auto').checked;\n   879→  clearInterval(logAutoTimer);\n   880→  if (checked) logAutoTimer = setInterval(loadLogs, 5000);\n   881→}\n   882→\n   883→// ─── Files ────────────────────────────────────────────────────────────────────\n   884→async function loadFiles() {\n   885→  const tbody = document.getElementById('file-tbody');\n   886→  tbody.innerHTML = '<tr><td colspan=\"3\" class=\"empty-hint\"><div class=\"spinner\"></div></td></tr>';\n   887→  try {\n   888→    const r = await fetch(`/api/projects/${currentId}/files`);\n   889→    const d = await r.json();\n   890→    allFiles = d.files || [];\n   891→    renderFiles();\n   892→  } catch {\n   893→    tbody.innerHTML = '<tr><td colspan=\"3\" style=\"color:var(--red);padding:0.6rem\">加载失败</td></tr>';\n   894→  }\n   895→}\n   896→\n   897→function renderFiles() {\n   898→  const q = document.getElementById('files-search').value.toLowerCase();\n   899→  const files = q ? allFiles.filter(f => f.path.toLowerCase().includes(q)) : allFiles;\n   900→  const tbody = document.getElementById('file-tbody');\n   901→  if (!files.length) {\n   902→    tbody.innerHTML = '<tr><td colspan=\"3\" class=\"empty-hint\">无文件</td></tr>';\n   903→    return;\n   904→  }\n   905→  tbody.innerHTML = files.map(f => `\n   906→    <tr>\n   907→      <td class=\"file-path\">${escHtml(f.path)}</td>\n   908→      <td class=\"file-size\">${fmtSize(f.size)}</td>\n   909→      <td class=\"file-mtime\">${fmtTime(f.modified)}</td>\n   910→    </tr>\n   911→  `).join('');\n   912→}\n   913→\n   914→// ─── Status ───────────────────────────────────────────────────────────────────\n   915→async function loadStatus() {\n   916→  const cont = document.getElementById('status-content');\n   917→  cont.innerHTML = '<div class=\"empty-hint\"><div class=\"spinner\"></div></div>';\n   918→  try {\n   919→    const proj = projects.find(p => p.id === currentId);\n   920→    const [gitR, dispR] = await Promise.all([\n   921→      fetch(`/api/projects/${currentId}/git-status`).then(r => r.json()).catch(() => ({})),\n   922→      fetch('/api/dispatcher/status').then(r => r.json()).catch(() => ({})),\n   923→    ]);\n   924→    const loop = dispR[currentId] || { running: false };\n   925→    renderStatus(proj, gitR, loop);\n   926→    updateLoopBadgeFromLoop(loop);\n   927→  } catch {\n   928→    cont.innerHTML = '<div class=\"empty-hint\" style=\"color:var(--red)\">加载失败</div>';\n   929→  }\n   930→}\n   931→\n   932→function renderStatus(proj, git, loop) {\n   933→  const cont = document.getElementById('status-content');\n   934→\n   935→  const loopRunning = loop.running;\n   936→  const loopColor = loopRunning ? 'green' : 'red';\n   937→  const loopText  = loopRunning ? `运行中 (PID ${loop.pid})` : '已停止';\n   938→\n   939→  let gitCard = '';\n   940→  if (git.has_git === false) {\n   941→    gitCard = `\n   942→      <div class=\"card\">\n   943→        <div class=\"card-title\">Git 信息</div>\n   944→        <div class=\"stat-value muted\">未初始化 Git 仓库</div>\n   945→      </div>`;\n   946→  } else if (git.has_git) {\n   947→    const dirty = git.dirty ? '<span style=\"color:var(--yellow)\">有未提交变更</span>' : '<span style=\"color:var(--green)\">干净</span>';\n   948→    const unpushed = git.unpushed_commits || 0;\n   949→    const unpushedBadge = unpushed > 0\n   950→      ? `<span style=\"background:rgba(251,191,36,0.15);border:1px solid rgba(251,191,36,0.35);border-radius:12px;padding:0.15rem 0.65rem;color:var(--yellow)\">${unpushed}</span>`\n   951→      : `<span style=\"color:var(--green)\">0</span>`;\n   952→    const statusHtml = (git.status_lines || []).map(l => {\n   953→      const cls = l.startsWith('M') ? 'M' : l.startsWith('A') ? 'A' : l.startsWith('D') ? 'D' : 'Q';\n   954→      return `<span class=\"${cls}\">${escHtml(l)}</span>`;\n   955→    }).join('');\n   956→    gitCard = `\n   957→      <div class=\"card\">\n   958→        <div class=\"card-title\" style=\"display:flex;align-items:center;justify-content:space-between;margin-bottom:0.85rem\">\n   959→          <span>Git 信息</span>\n   960→          <button class=\"btn-sm success\" id=\"btn-push\" onclick=\"pushProject()\" title=\"推送到远程仓库\">↑ 推送到远程</button>\n   961→        </div>\n   962→        <div class=\"status-grid\">\n   963→          <div class=\"stat-block\" style=\"grid-column:1/-1\">\n   964→            <div class=\"stat-label\">Remote 地址</div>\n   965→            <div class=\"stat-value muted\" style=\"font-size:0.8rem;word-break:break-all;font-family:monospace\">${escHtml(git.remote || '—')}</div>\n   966→          </div>\n   967→          <div class=\"stat-block\">\n   968→            <div class=\"stat-label\">当前分支</div>\n   969→            <div class=\"stat-value\">${escHtml(git.branch || '—')}</div>\n   970→          </div>\n   971→          <div class=\"stat-block\">\n   972→            <div class=\"stat-label\">未推送 commit 数</div>\n   973→            <div class=\"stat-value\">${unpushedBadge}</div>\n   974→          </div>\n   975→          <div class=\"stat-block\">\n   976→            <div class=\"stat-label\">最近 push 时间</div>\n   977→            <div class=\"stat-value muted\">${git.last_push ? fmtTime(git.last_push) : '—'}</div>\n   978→          </div>\n   979→          <div class=\"stat-block\">\n   980→            <div class=\"stat-label\">工作区状态</div>\n   981→            <div class=\"stat-value\">${dirty}${statusHtml ? '<div class=\"git-status-lines\">' + statusHtml + '</div>' : ''}</div>\n   982→          </div>\n   983→        </div>\n   984→      </div>`;\n   985→  }\n   986→\n   987→  cont.innerHTML = `\n   988→    <div style=\"display:flex;gap:0.7rem;flex-wrap:wrap;margin-bottom:1rem\">\n   989→      <button class=\"btn-sm\" onclick=\"loadStatus()\">刷新状态</button>\n   990→    </div>\n   991→    <div class=\"card\">\n   992→      <div class=\"card-title\">项目信息</div>\n   993→      <div class=\"status-grid\">\n   994→        <div class=\"stat-block\">\n   995→          <div class=\"stat-label\">项目名称</div>\n   996→          <div class=\"stat-value\">${escHtml(proj ? proj.name : currentId)}</div>\n   997→        </div>\n   998→        <div class=\"stat-block\">\n   999→          <div class=\"stat-label\">项目状态</div>\n  1000→          <div class=\"stat-value ${proj && proj.status === 'active' ? 'green' : 'muted'}\">${proj ? proj.status : '—'}</div>\n  1001→        </div>\n  1002→        <div class=\"stat-block\">\n  1003→          <div class=\"stat-label\">Ralph Loop</div>\n  1004→          <div class=\"stat-value ${loopColor}\">${loopText}</div>\n  1005→        </div>\n  1006→        <div class=\"stat-block\">\n  1007→          <div class=\"stat-label\">项目路径</div>\n  1008→          <div class=\"stat-value muted\" style=\"font-size:0.78rem\">${escHtml(proj ? proj.path : '—')}</div>\n  1009→        </div>\n  1010→        <div class=\"stat-block\">\n  1011→          <div class=\"stat-label\">创建时间</div>\n  1012→          <div class=\"stat-value muted\">${proj ? fmtTime(proj.created_at) : '—'}</div>\n  1013→        </div>\n  1014→        ${loop.started_at ? `\n  1015→        <div class=\"stat-block\">\n  1016→          <div class=\"stat-label\">Loop 启动时间</div>\n  1017→          <div class=\"stat-value muted\">${fmtTime(new Date(loop.started_at * 1000).toISOString())}</div>\n  1018→        </div>` : ''}\n  1019→      </div>\n  1020→    </div>\n  1021→    ${gitCard}\n  1022→  `;\n  1023→}\n  1024→\n  1025→async function pushProject() {\n  1026→  const btn = document.getElementById('btn-push');\n  1027→  if (btn) { btn.disabled = true; btn.textContent = '推送中…'; }\n  1028→  try {\n  1029→    const r = await fetch(`/api/projects/${currentId}/push`, { method: 'POST' });\n  1030→    const d = await r.json();\n  1031→    if (d.success) showToast('推送成功');\n  1032→    else showToast(`推送失败: ${d.output}`, true);\n  1033→    loadStatus();\n  1034→  } catch {\n  1035→    showToast('推送请求失败', true);\n  1036→  }\n  1037→}\n  1038→\n  1039→// ─── Loop Badge ───────────────────────────────────────────────────────────────\n  1040→async function updateLoopBadge() {\n  1041→  if (!currentId) {\n  1042→    document.getElementById('loop-dot').className = 'loop-dot';\n  1043→    document.getElementById('loop-label').textContent = '未选择';\n  1044→    return;\n  1045→  }\n  1046→  try {\n  1047→    const r = await fetch('/api/dispatcher/status');\n  1048→    const d = await r.json();\n  1049→    updateLoopBadgeFromLoop(d[currentId] || { running: false });\n  1050→  } catch { /* ignore */ }\n  1051→}\n  1052→\n  1053→function updateLoopBadgeFromLoop(loop) {\n  1054→  const dot = document.getElementById('loop-dot');\n  1055→  const lbl = document.getElementById('loop-label');\n  1056→  if (loop.running) {\n  1057→    dot.className = 'loop-dot running';\n  1058→    lbl.textContent = 'Loop 运行中';\n  1059→  } else {\n  1060→    dot.className = 'loop-dot';\n  1061→    lbl.textContent = 'Loop 已停止';\n  1062→  }\n  1063→}\n  1064→\n  1065→// ─── Auto-refresh cleanup ─────────────────────────────────────────────────────\n  1066→function stopAllAutoRefresh() {\n  1067→  clearInterval(logAutoTimer); logAutoTimer = null;\n  1068→  clearInterval(statusRefreshTimer); statusRefreshTimer = null;\n  1069→  const logAutoChk = document.getElementById('log-auto');\n  1070→  if (logAutoChk) logAutoChk.checked = false;\n  1071→}\n  1072→\n  1073→// ─── Utilities ────────────────────────────────────────────────────────────────\n  1074→function escHtml(s) {\n  1075→  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');\n  1076→}\n  1077→\n  1078→function fmtSize(bytes) {\n  1079→  if (bytes == null) return '—';\n  1080→  if (bytes < 1024) return `${bytes} B`;\n  1081→  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;\n  1082→  return `${(bytes / 1024 / 1024).toFixed(2)} MB`;\n  1083→}\n  1084→\n  1085→function fmtTime(iso) {\n  1086→  if (!iso) return '—';\n  1087→  try {\n  1088→    return new Date(iso).toLocaleString('zh-CN', {\n  1089→      year: 'numeric', month: '2-digit', day: '2-digit',\n  1090→      hour: '2-digit', minute: '2-digit',\n  1091→    });\n  1092→  } catch { return iso; }\n  1093→}\n  1094→\n  1095→let toastTimer = null;\n  1096→function showToast(msg, isErr = false) {\n  1097→  const el = document.getElementById('toast');\n  1098→  el.textContent = msg;\n  1099→  el.style.borderColor = isErr ? 'rgba(255,77,94,0.3)' : 'rgba(0,201,139,0.3)';\n  1100→  el.style.color = isErr ? 'var(--red)' : 'var(--green)';\n  1101→  el.classList.add('show');\n  1102→  clearTimeout(toastTimer);\n  1103→  toastTimer = setTimeout(() => el.classList.remove('show'), 2500);\n  1104→}\n  1105→\n  1106→// ─── Create Project Modal ─────────────────────────────────────────────────────\n  1107→function openCreateModal() {\n  1108→  const overlay = document.getElementById('create-modal-overlay');\n  1109→  overlay.classList.add('open');\n  1110→  document.getElementById('cp-name').focus();\n  1111→}\n  1112→\n  1113→function closeCreateModal() {\n  1114→  document.getElementById('create-modal-overlay').classList.remove('open');\n  1115→  resetCreateForm();\n  1116→}\n  1117→\n  1118→function onModalOverlayClick(e) {\n  1119→  if (e.target === document.getElementById('create-modal-overlay')) {\n  1120→    closeCreateModal();\n  1121→  }\n  1122→}\n  1123→\n  1124→function resetCreateForm() {\n  1125→  document.getElementById('cp-name').value = '';\n  1126→  document.getElementById('cp-desc').value = '';\n  1127→  document.getElementById('cp-github-url').value = '';\n  1128→  document.getElementById('cp-dir-path').value = '';\n  1129→  document.getElementById('cp-auto-push').checked = false;\n  1130→  document.querySelector('input[name=\"cp-git-source\"][value=\"new\"]').checked = true;\n  1131→  onGitSourceChange('new');\n  1132→  const btn = document.getElementById('cp-submit-btn');\n  1133→  btn.disabled = false;\n  1134→  btn.textContent = '创建项目';\n  1135→}\n  1136→\n  1137→function onGitSourceChange(val) {\n  1138→  // Update radio option highlight\n  1139→  ['new', 'github', 'dir'].forEach(v => {\n  1140→    document.getElementById(`opt-${v}`).classList.toggle('selected', v === val);\n  1141→  });\n  1142→  document.getElementById('cp-github-field').classList.toggle('visible', val === 'github');\n  1143→  document.getElementById('cp-dir-field').classList.toggle('visible', val === 'dir');\n  1144→}\n  1145→\n  1146→async function submitCreateProject() {\n  1147→  const name = document.getElementById('cp-name').value.trim();\n  1148→  if (!name) {\n  1149→    document.getElementById('cp-name').focus();\n  1150→    showToast('项目名称不能为空', true);\n  1151→    return;\n  1152→  }\n  1153→\n  1154→  const gitSource = document.querySelector('input[name=\"cp-git-source\"]:checked').value;\n  1155→  const githubUrl = document.getElementById('cp-github-url').value.trim();\n  1156→  const dirPath   = document.getElementById('cp-dir-path').value.trim();\n  1157→\n  1158→  if (gitSource === 'github' && !githubUrl) {\n  1159→    document.getElementById('cp-github-url').focus();\n  1160→    showToast('请填写 GitHub 仓库地址', true);\n  1161→    return;\n  1162→  }\n  1163→  if (gitSource === 'dir' && !dirPath) {\n  1164→    document.getElementById('cp-dir-path').focus();\n  1165→    showToast('请填写目录路径', true);\n  1166→    return;\n  1167→  }\n  1168→\n  1169→  const payload = {\n  1170→    name,\n  1171→    description: document.getElementById('cp-desc').value.trim(),\n  1172→    git_source: gitSource,\n  1173→    auto_push: document.getElementById('cp-auto-push').checked,\n  1174→  };\n  1175→  if (gitSource === 'github') payload.github_url = githubUrl;\n  1176→  if (gitSource === 'dir')    payload.dir_path    = dirPath;\n  1177→\n  1178→  const btn = document.getElementById('cp-submit-btn');\n  1179→  btn.disabled = true;\n  1180→  btn.textContent = '创建中…';\n  1181→\n  1182→  try {\n  1183→    const r = await fetch('/api/projects', {\n  1184→      method: 'POST',\n  1185→      headers: { 'Content-Type': 'application/json' },\n  1186→      body: JSON.stringify(payload),\n  1187→    });\n  1188→    const d = await r.json();\n  1189→    if (r.ok && (d.id || d.success)) {\n  1190→      showToast('项目创建成功');\n  1191→      closeCreateModal();\n  1192→      await loadProjects();\n  1193→      const newId = d.id || (projects.length > 0 ? projects[projects.length - 1].id : null);\n  1194→      if (newId) setProject(newId);\n  1195→    } else {\n  1196→      showToast(`创建失败: ${d.error || d.message || '未知错误'}`, true);\n  1197→      btn.disabled = false;\n  1198→      btn.textContent = '创建项目';\n  1199→    }\n  1200→  } catch (err) {\n  1201→    showToast('请求失败，请重试', true);\n  1202→    btn.disabled = false;\n  1203→    btn.textContent = '创建项目';\n  1204→  }\n  1205→}\n  1206→\n  1207→// Close modal on Escape key\n  1208→document.addEventListener('keydown', e => {\n  1209→  if (e.key === 'Escape') closeCreateModal();\n  1210→});\n  1211→\n  1212→// ─── Start ────────────────────────────────────────────────────────────────────\n  1213→init();\n  1214→</script>\n  1215→</body>\n  1216→</html>\n  1217→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"1035d743-97c6-4799-8057-a51d312b7086","uuid":"7238a27e-ec57-4447-86f1-42ae2ada2ac6","tool_use_result":{"type":"text","file":{"filePath":"/home/ubuntu/my-project/static/index.html","content":"<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Ralph — 项目管理</title>\n  <style>\n    :root {\n      --bg:      #0b0e1a;\n      --card:    #131827;\n      --card2:   #171d2e;\n      --border:  rgba(255,255,255,0.07);\n      --text:    #dde4f0;\n      --muted:   #5a6480;\n      --green:   #00c98b;\n      --red:     #ff4d5e;\n      --blue:    #60a5fa;\n      --yellow:  #fbbf24;\n      --purple:  #a78bfa;\n    }\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    body {\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n      background: var(--bg);\n      color: var(--text);\n      min-height: 100vh;\n    }\n\n    /* ── Header ── */\n    header {\n      background: rgba(13,16,30,0.95);\n      backdrop-filter: blur(12px);\n      border-bottom: 1px solid var(--border);\n      padding: 0 1.5rem;\n      height: 56px;\n      display: flex;\n      align-items: center;\n      gap: 1.2rem;\n      position: sticky;\n      top: 0;\n      z-index: 100;\n    }\n    .brand { display: flex; align-items: center; gap: 0.55rem; flex-shrink: 0; }\n    .brand-icon {\n      width: 30px; height: 30px;\n      background: linear-gradient(135deg, #3b82f6, #7c3aed);\n      border-radius: 7px;\n      display: flex; align-items: center; justify-content: center;\n      font-size: 14px; font-weight: 700; color: #fff;\n    }\n    .brand h1 { font-size: 1rem; font-weight: 700; letter-spacing: -0.01em; white-space: nowrap; }\n\n    .divider-v { width: 1px; height: 22px; background: var(--border); flex-shrink: 0; }\n\n    /* project selector */\n    .project-select-wrap { display: flex; align-items: center; gap: 0.6rem; flex: 1; min-width: 0; }\n    .project-select-label { font-size: 0.75rem; color: var(--muted); white-space: nowrap; flex-shrink: 0; }\n    .project-select {\n      background: var(--card2);\n      border: 1px solid var(--border);\n      color: var(--text);\n      padding: 0.3rem 0.7rem;\n      border-radius: 7px;\n      font-size: 0.85rem;\n      font-family: inherit;\n      cursor: pointer;\n      min-width: 180px;\n      max-width: 320px;\n      outline: none;\n      transition: border-color 0.15s;\n    }\n    .project-select:focus { border-color: rgba(96,165,250,0.5); }\n    .project-select option { background: #1a2035; }\n\n    .header-right { display: flex; align-items: center; gap: 0.7rem; margin-left: auto; flex-shrink: 0; }\n    .loop-badge {\n      display: flex; align-items: center; gap: 0.35rem;\n      font-size: 0.72rem; color: var(--muted);\n      background: var(--card2);\n      border: 1px solid var(--border);\n      padding: 0.25rem 0.6rem;\n      border-radius: 20px;\n    }\n    .loop-dot {\n      width: 7px; height: 7px; border-radius: 50%;\n      background: var(--muted);\n      transition: background 0.3s;\n    }\n    .loop-dot.running { background: var(--green); box-shadow: 0 0 5px var(--green); animation: pulse 2s infinite; }\n    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }\n\n    .btn-sm {\n      background: rgba(96,165,250,0.1);\n      border: 1px solid rgba(96,165,250,0.25);\n      color: var(--blue);\n      padding: 0.28rem 0.75rem;\n      border-radius: 6px;\n      cursor: pointer;\n      font-size: 0.78rem;\n      font-family: inherit;\n      transition: background 0.15s;\n      white-space: nowrap;\n    }\n    .btn-sm:hover { background: rgba(96,165,250,0.18); }\n    .btn-sm:disabled { opacity: 0.45; cursor: not-allowed; }\n    .btn-sm.danger { background: rgba(255,77,94,0.1); border-color: rgba(255,77,94,0.25); color: var(--red); }\n    .btn-sm.danger:hover { background: rgba(255,77,94,0.18); }\n    .btn-sm.success { background: rgba(0,201,139,0.1); border-color: rgba(0,201,139,0.25); color: var(--green); }\n    .btn-sm.success:hover { background: rgba(0,201,139,0.18); }\n\n    /* ── Empty state ── */\n    #no-project {\n      display: flex; flex-direction: column; align-items: center;\n      justify-content: center; height: calc(100vh - 56px);\n      gap: 0.8rem; color: var(--muted);\n    }\n    #no-project h2 { font-size: 1.1rem; font-weight: 600; color: var(--text); }\n    #no-project p { font-size: 0.85rem; }\n\n    /* ── Layout ── */\n    #app { display: none; flex-direction: column; height: calc(100vh - 56px); }\n\n    /* ── Tabs ── */\n    .tabs {\n      display: flex; gap: 0;\n      border-bottom: 1px solid var(--border);\n      background: rgba(13,16,30,0.6);\n      padding: 0 1.2rem;\n      flex-shrink: 0;\n    }\n    .tab {\n      padding: 0.65rem 1rem;\n      font-size: 0.82rem;\n      font-weight: 500;\n      color: var(--muted);\n      cursor: pointer;\n      border-bottom: 2px solid transparent;\n      margin-bottom: -1px;\n      transition: color 0.15s;\n      user-select: none;\n    }\n    .tab:hover { color: var(--text); }\n    .tab.active { color: var(--blue); border-bottom-color: var(--blue); }\n\n    .tab-content { flex: 1; overflow: hidden; }\n    .tab-pane { display: none; height: 100%; overflow: auto; padding: 1.2rem 1.4rem 2rem; }\n    .tab-pane.active { display: block; }\n\n    /* ── Cards ── */\n    .card {\n      background: var(--card);\n      border: 1px solid var(--border);\n      border-radius: 12px;\n      padding: 1.1rem 1.25rem;\n      margin-bottom: 1rem;\n    }\n    .card-title {\n      font-size: 0.78rem;\n      font-weight: 600;\n      color: var(--muted);\n      text-transform: uppercase;\n      letter-spacing: 0.05em;\n      margin-bottom: 0.85rem;\n    }\n\n    /* ── Tasks ── */\n    .task-input-row {\n      display: flex; gap: 0.6rem; margin-bottom: 1rem;\n    }\n    .task-input {\n      flex: 1;\n      background: var(--card2);\n      border: 1px solid var(--border);\n      color: var(--text);\n      padding: 0.45rem 0.8rem;\n      border-radius: 7px;\n      font-size: 0.85rem;\n      font-family: inherit;\n      outline: none;\n      transition: border-color 0.15s;\n    }\n    .task-input:focus { border-color: rgba(96,165,250,0.5); }\n\n    .task-list { display: flex; flex-direction: column; gap: 0.45rem; }\n    .task-item {\n      display: flex; align-items: center; gap: 0.7rem;\n      background: var(--card2);\n      border: 1px solid var(--border);\n      border-radius: 8px;\n      padding: 0.55rem 0.8rem;\n      transition: border-color 0.15s;\n    }\n    .task-item:hover { border-color: rgba(255,255,255,0.12); }\n    .task-status-btn {\n      flex-shrink: 0;\n      width: 18px; height: 18px;\n      border-radius: 50%;\n      border: 2px solid var(--muted);\n      background: transparent;\n      cursor: pointer;\n      display: flex; align-items: center; justify-content: center;\n      transition: all 0.15s;\n      font-size: 10px;\n      color: transparent;\n    }\n    .task-status-btn:hover { border-color: var(--green); }\n    .task-item.in_progress .task-status-btn { border-color: var(--yellow); }\n    .task-item.done .task-status-btn { border-color: var(--green); background: rgba(0,201,139,0.15); color: var(--green); }\n    .task-title-text {\n      flex: 1;\n      font-size: 0.85rem;\n      line-height: 1.4;\n    }\n    .task-item.done .task-title-text { text-decoration: line-through; color: var(--muted); }\n    .task-meta {\n      font-size: 0.72rem;\n      color: var(--muted);\n      white-space: nowrap;\n      flex-shrink: 0;\n    }\n    .task-status-tag {\n      font-size: 0.68rem;\n      font-weight: 600;\n      padding: 0.12rem 0.42rem;\n      border-radius: 4px;\n      flex-shrink: 0;\n    }\n    .task-status-tag.pending     { background: rgba(90,100,128,0.2); color: var(--muted); }\n    .task-status-tag.in_progress { background: rgba(251,191,36,0.12); color: var(--yellow); }\n    .task-status-tag.done        { background: rgba(0,201,139,0.12); color: var(--green); }\n    .task-del-btn {\n      flex-shrink: 0;\n      background: none;\n      border: none;\n      color: var(--muted);\n      cursor: pointer;\n      font-size: 14px;\n      padding: 0 0.2rem;\n      opacity: 0;\n      transition: opacity 0.15s, color 0.15s;\n    }\n    .task-item:hover .task-del-btn { opacity: 1; }\n    .task-del-btn:hover { color: var(--red); }\n\n    .empty-hint { font-size: 0.82rem; color: var(--muted); text-align: center; padding: 2rem; }\n\n    /* ── Task status cycle menu ── */\n    .task-cycle-btn {\n      flex-shrink: 0;\n      background: none; border: none;\n      font-size: 0.72rem; font-weight: 600;\n      cursor: pointer;\n      padding: 0.12rem 0.42rem;\n      border-radius: 4px;\n      transition: opacity 0.15s;\n    }\n    .task-cycle-btn:hover { opacity: 0.75; }\n\n    /* ── Logs ── */\n    .log-controls {\n      display: flex; align-items: center; gap: 0.7rem; margin-bottom: 0.8rem; flex-wrap: wrap;\n    }\n    .log-controls label { font-size: 0.78rem; color: var(--muted); display: flex; align-items: center; gap: 0.4rem; }\n    .log-controls input[type=checkbox] { accent-color: var(--blue); }\n    .log-lines-select {\n      background: var(--card2); border: 1px solid var(--border);\n      color: var(--text); padding: 0.25rem 0.5rem; border-radius: 5px;\n      font-size: 0.78rem; font-family: inherit; outline: none;\n    }\n    .log-box {\n      background: #080a12;\n      border: 1px solid var(--border);\n      border-radius: 8px;\n      padding: 0.9rem 1rem;\n      font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;\n      font-size: 0.75rem;\n      line-height: 1.55;\n      color: #a8b4c8;\n      white-space: pre-wrap;\n      word-break: break-all;\n      max-height: calc(100vh - 280px);\n      overflow-y: auto;\n    }\n    .log-box .log-empty { color: var(--muted); }\n\n    /* ── Files ── */\n    .files-search-row { display: flex; gap: 0.6rem; margin-bottom: 0.8rem; }\n    .files-search {\n      flex: 1; background: var(--card2); border: 1px solid var(--border);\n      color: var(--text); padding: 0.38rem 0.75rem; border-radius: 7px;\n      font-size: 0.82rem; font-family: inherit; outline: none;\n    }\n    .files-search:focus { border-color: rgba(96,165,250,0.4); }\n    .file-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }\n    .file-table th {\n      text-align: left; padding: 0.4rem 0.6rem;\n      font-size: 0.7rem; font-weight: 600; color: var(--muted);\n      text-transform: uppercase; letter-spacing: 0.04em;\n      border-bottom: 1px solid var(--border);\n    }\n    .file-table td { padding: 0.38rem 0.6rem; border-bottom: 1px solid rgba(255,255,255,0.03); }\n    .file-table tr:hover td { background: rgba(255,255,255,0.02); }\n    .file-path { color: var(--blue); font-family: monospace; font-size: 0.78rem; }\n    .file-size { color: var(--muted); white-space: nowrap; }\n    .file-mtime { color: var(--muted); white-space: nowrap; font-size: 0.72rem; }\n\n    /* ── Status ── */\n    .status-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0.9rem; }\n    .stat-block {\n      background: var(--card2); border: 1px solid var(--border);\n      border-radius: 9px; padding: 0.9rem 1rem;\n    }\n    .stat-label { font-size: 0.7rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.4rem; }\n    .stat-value { font-size: 0.9rem; font-weight: 600; word-break: break-all; }\n    .stat-value.green { color: var(--green); }\n    .stat-value.red   { color: var(--red); }\n    .stat-value.muted { color: var(--muted); font-weight: 400; }\n\n    .git-status-lines {\n      font-family: monospace; font-size: 0.75rem; line-height: 1.6;\n      color: var(--muted); margin-top: 0.5rem;\n    }\n    .git-status-lines span { display: block; }\n    .git-status-lines .M { color: var(--yellow); }\n    .git-status-lines .A { color: var(--green); }\n    .git-status-lines .D { color: var(--red); }\n    .git-status-lines .Q { color: var(--muted); }\n\n    /* ── Spinner ── */\n    .spinner {\n      display: inline-block; width: 16px; height: 16px;\n      border: 2px solid var(--border); border-top-color: var(--blue);\n      border-radius: 50%; animation: spin 0.6s linear infinite;\n    }\n    @keyframes spin { to { transform: rotate(360deg); } }\n\n    /* ── Toast ── */\n    #toast {\n      position: fixed; bottom: 1.5rem; right: 1.5rem;\n      background: var(--card); border: 1px solid var(--border);\n      padding: 0.6rem 1rem; border-radius: 8px;\n      font-size: 0.82rem; color: var(--text);\n      box-shadow: 0 4px 20px rgba(0,0,0,0.4);\n      opacity: 0; transform: translateY(8px);\n      transition: opacity 0.2s, transform 0.2s;\n      pointer-events: none; z-index: 999;\n    }\n    #toast.show { opacity: 1; transform: translateY(0); }\n\n    /* ── Scrollbar ── */\n    ::-webkit-scrollbar { width: 6px; height: 6px; }\n    ::-webkit-scrollbar-track { background: transparent; }\n    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }\n\n    /* ── Create Project Modal ── */\n    .modal-overlay {\n      position: fixed; inset: 0; z-index: 500;\n      background: rgba(0,0,0,0.6);\n      backdrop-filter: blur(4px);\n      display: flex; align-items: center; justify-content: center;\n      opacity: 0; pointer-events: none;\n      transition: opacity 0.2s;\n    }\n    .modal-overlay.open { opacity: 1; pointer-events: auto; }\n\n    .modal {\n      background: var(--card);\n      border: 1px solid var(--border);\n      border-radius: 14px;\n      padding: 1.6rem 1.8rem;\n      width: 100%;\n      max-width: 480px;\n      box-shadow: 0 20px 60px rgba(0,0,0,0.5);\n      transform: translateY(10px);\n      transition: transform 0.2s;\n    }\n    .modal-overlay.open .modal { transform: translateY(0); }\n\n    .modal-header {\n      display: flex; align-items: center; justify-content: space-between;\n      margin-bottom: 1.4rem;\n    }\n    .modal-title { font-size: 1rem; font-weight: 700; }\n    .modal-close {\n      background: none; border: none; color: var(--muted);\n      font-size: 1.2rem; cursor: pointer; padding: 0.1rem 0.3rem;\n      border-radius: 4px; line-height: 1;\n      transition: color 0.15s;\n    }\n    .modal-close:hover { color: var(--text); }\n\n    .form-group { margin-bottom: 1.1rem; }\n    .form-label {\n      display: block; font-size: 0.78rem; font-weight: 600;\n      color: var(--muted); text-transform: uppercase;\n      letter-spacing: 0.05em; margin-bottom: 0.45rem;\n    }\n    .form-input {\n      width: 100%;\n      background: var(--card2);\n      border: 1px solid var(--border);\n      color: var(--text);\n      padding: 0.48rem 0.8rem;\n      border-radius: 7px;\n      font-size: 0.85rem;\n      font-family: inherit;\n      outline: none;\n      transition: border-color 0.15s;\n    }\n    .form-input:focus { border-color: rgba(96,165,250,0.5); }\n    .form-input::placeholder { color: var(--muted); opacity: 0.6; }\n\n    .radio-group { display: flex; flex-direction: column; gap: 0.5rem; }\n    .radio-option {\n      display: flex; align-items: center; gap: 0.6rem;\n      background: var(--card2);\n      border: 1px solid var(--border);\n      border-radius: 8px;\n      padding: 0.6rem 0.9rem;\n      cursor: pointer;\n      transition: border-color 0.15s;\n    }\n    .radio-option:hover { border-color: rgba(96,165,250,0.35); }\n    .radio-option input[type=radio] { accent-color: var(--blue); cursor: pointer; flex-shrink: 0; }\n    .radio-option-label { font-size: 0.84rem; flex: 1; }\n    .radio-option-desc { font-size: 0.72rem; color: var(--muted); margin-top: 0.12rem; }\n    .radio-option.selected { border-color: rgba(96,165,250,0.45); background: rgba(96,165,250,0.06); }\n\n    .conditional-field {\n      margin-top: 0.6rem;\n      display: none;\n    }\n    .conditional-field.visible { display: block; }\n\n    /* Toggle switch */\n    .toggle-row {\n      display: flex; align-items: center; justify-content: space-between;\n      background: var(--card2);\n      border: 1px solid var(--border);\n      border-radius: 8px;\n      padding: 0.65rem 0.9rem;\n    }\n    .toggle-info { flex: 1; }\n    .toggle-info-label { font-size: 0.85rem; font-weight: 500; }\n    .toggle-info-desc { font-size: 0.72rem; color: var(--muted); margin-top: 0.1rem; }\n    .toggle-switch {\n      position: relative; width: 40px; height: 22px; flex-shrink: 0;\n    }\n    .toggle-switch input { opacity: 0; width: 0; height: 0; }\n    .toggle-slider {\n      position: absolute; inset: 0;\n      background: rgba(255,255,255,0.12);\n      border-radius: 22px;\n      cursor: pointer;\n      transition: background 0.2s;\n    }\n    .toggle-slider::before {\n      content: '';\n      position: absolute;\n      width: 16px; height: 16px;\n      left: 3px; top: 3px;\n      background: #fff;\n      border-radius: 50%;\n      transition: transform 0.2s;\n    }\n    .toggle-switch input:checked + .toggle-slider { background: var(--blue); }\n    .toggle-switch input:checked + .toggle-slider::before { transform: translateX(18px); }\n\n    .modal-footer {\n      display: flex; gap: 0.7rem; justify-content: flex-end;\n      margin-top: 1.5rem;\n    }\n    .btn-cancel {\n      background: rgba(255,255,255,0.05);\n      border: 1px solid var(--border);\n      color: var(--muted);\n      padding: 0.42rem 1rem;\n      border-radius: 7px;\n      cursor: pointer;\n      font-size: 0.84rem;\n      font-family: inherit;\n      transition: background 0.15s, color 0.15s;\n    }\n    .btn-cancel:hover { background: rgba(255,255,255,0.09); color: var(--text); }\n    .btn-primary {\n      background: rgba(96,165,250,0.15);\n      border: 1px solid rgba(96,165,250,0.35);\n      color: var(--blue);\n      padding: 0.42rem 1.1rem;\n      border-radius: 7px;\n      cursor: pointer;\n      font-size: 0.84rem;\n      font-weight: 600;\n      font-family: inherit;\n      transition: background 0.15s;\n    }\n    .btn-primary:hover { background: rgba(96,165,250,0.25); }\n    .btn-primary:disabled { opacity: 0.45; cursor: not-allowed; }\n  </style>\n</head>\n<body>\n\n<header>\n  <div class=\"brand\">\n    <div class=\"brand-icon\">R</div>\n    <h1>Ralph</h1>\n  </div>\n  <div class=\"divider-v\"></div>\n  <div class=\"project-select-wrap\">\n    <span class=\"project-select-label\">项目</span>\n    <select class=\"project-select\" id=\"project-select\" onchange=\"onProjectChange(this.value)\">\n      <option value=\"\">— 选择项目 —</option>\n    </select>\n  </div>\n  <div class=\"header-right\">\n    <div class=\"loop-badge\" id=\"loop-badge\">\n      <div class=\"loop-dot\" id=\"loop-dot\"></div>\n      <span id=\"loop-label\">未选择</span>\n    </div>\n    <button class=\"btn-sm success\" onclick=\"openCreateModal()\" title=\"创建新项目\">+ 创建项目</button>\n    <button class=\"btn-sm\" id=\"btn-refresh\" onclick=\"refreshCurrent()\" title=\"刷新当前视图\">刷新</button>\n  </div>\n</header>\n\n<div id=\"no-project\">\n  <h2>暂无项目</h2>\n  <p>请通过 API 创建项目，或选择已有项目</p>\n</div>\n\n<div id=\"app\">\n  <div class=\"tabs\">\n    <div class=\"tab active\" data-tab=\"tasks\" onclick=\"switchTab('tasks')\">任务</div>\n    <div class=\"tab\" data-tab=\"logs\"  onclick=\"switchTab('logs')\">日志</div>\n    <div class=\"tab\" data-tab=\"files\" onclick=\"switchTab('files')\">文件</div>\n    <div class=\"tab\" data-tab=\"status\" onclick=\"switchTab('status')\">状态</div>\n  </div>\n  <div class=\"tab-content\">\n\n    <!-- Tasks -->\n    <div class=\"tab-pane active\" id=\"pane-tasks\">\n      <div class=\"task-input-row\">\n        <input class=\"task-input\" id=\"new-task-input\" placeholder=\"添加新任务…\" onkeydown=\"onTaskKeydown(event)\" />\n        <button class=\"btn-sm success\" onclick=\"addTask()\">+ 添加</button>\n      </div>\n      <div class=\"task-list\" id=\"task-list\">\n        <div class=\"empty-hint\"><div class=\"spinner\"></div></div>\n      </div>\n    </div>\n\n    <!-- Logs -->\n    <div class=\"tab-pane\" id=\"pane-logs\">\n      <div class=\"log-controls\">\n        <label>\n          <input type=\"checkbox\" id=\"log-auto\" onchange=\"onLogAutoChange()\" />\n          自动刷新 (5s)\n        </label>\n        <label>\n          最近\n          <select class=\"log-lines-select\" id=\"log-lines\" onchange=\"loadLogs()\">\n            <option value=\"100\">100 行</option>\n            <option value=\"300\" selected>300 行</option>\n            <option value=\"500\">500 行</option>\n            <option value=\"1000\">1000 行</option>\n          </select>\n        </label>\n        <button class=\"btn-sm\" onclick=\"loadLogs()\">刷新</button>\n        <span id=\"log-total\" style=\"font-size:0.75rem;color:var(--muted)\"></span>\n      </div>\n      <div class=\"log-box\" id=\"log-box\"><span class=\"log-empty\">加载中…</span></div>\n    </div>\n\n    <!-- Files -->\n    <div class=\"tab-pane\" id=\"pane-files\">\n      <div class=\"files-search-row\">\n        <input class=\"files-search\" id=\"files-search\" placeholder=\"搜索文件…\" oninput=\"renderFiles()\" />\n        <button class=\"btn-sm\" onclick=\"loadFiles()\">刷新</button>\n      </div>\n      <table class=\"file-table\" id=\"file-table\">\n        <thead><tr><th>路径</th><th>大小</th><th>修改时间</th></tr></thead>\n        <tbody id=\"file-tbody\"></tbody>\n      </table>\n    </div>\n\n    <!-- Status -->\n    <div class=\"tab-pane\" id=\"pane-status\">\n      <div id=\"status-content\">\n        <div class=\"empty-hint\"><div class=\"spinner\"></div></div>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<div id=\"toast\"></div>\n\n<!-- ── Create Project Modal ── -->\n<div class=\"modal-overlay\" id=\"create-modal-overlay\" onclick=\"onModalOverlayClick(event)\">\n  <div class=\"modal\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"modal-title\">\n    <div class=\"modal-header\">\n      <span class=\"modal-title\" id=\"modal-title\">创建新项目</span>\n      <button class=\"modal-close\" onclick=\"closeCreateModal()\" aria-label=\"关闭\">✕</button>\n    </div>\n\n    <!-- 项目名称 -->\n    <div class=\"form-group\">\n      <label class=\"form-label\" for=\"cp-name\">项目名称 <span style=\"color:var(--red)\">*</span></label>\n      <input class=\"form-input\" id=\"cp-name\" type=\"text\" placeholder=\"my-awesome-project\" maxlength=\"80\" required />\n    </div>\n\n    <!-- 项目描述 -->\n    <div class=\"form-group\">\n      <label class=\"form-label\" for=\"cp-desc\">项目描述（可选）</label>\n      <input class=\"form-input\" id=\"cp-desc\" type=\"text\" placeholder=\"简短描述这个项目…\" maxlength=\"200\" />\n    </div>\n\n    <!-- Git 来源 -->\n    <div class=\"form-group\">\n      <label class=\"form-label\">Git 来源</label>\n      <div class=\"radio-group\" id=\"cp-git-source-group\">\n        <label class=\"radio-option selected\" id=\"opt-new\">\n          <input type=\"radio\" name=\"cp-git-source\" value=\"new\" checked onchange=\"onGitSourceChange('new')\" />\n          <div>\n            <div class=\"radio-option-label\">新建空项目</div>\n            <div class=\"radio-option-desc\">在本地创建一个全新的 Git 仓库</div>\n          </div>\n        </label>\n        <label class=\"radio-option\" id=\"opt-github\">\n          <input type=\"radio\" name=\"cp-git-source\" value=\"github\" onchange=\"onGitSourceChange('github')\" />\n          <div>\n            <div class=\"radio-option-label\">关联 GitHub 仓库</div>\n            <div class=\"radio-option-desc\">Clone 并绑定一个已有的 GitHub 仓库</div>\n          </div>\n        </label>\n        <label class=\"radio-option\" id=\"opt-dir\">\n          <input type=\"radio\" name=\"cp-git-source\" value=\"dir\" onchange=\"onGitSourceChange('dir')\" />\n          <div>\n            <div class=\"radio-option-label\">使用已有目录</div>\n            <div class=\"radio-option-desc\">绑定服务器上已存在的本地目录</div>\n          </div>\n        </label>\n      </div>\n\n      <!-- 条件字段：GitHub URL -->\n      <div class=\"conditional-field\" id=\"cp-github-field\">\n        <input class=\"form-input\" id=\"cp-github-url\" type=\"url\"\n               placeholder=\"https://github.com/user/repo.git\" />\n      </div>\n\n      <!-- 条件字段：目录路径 -->\n      <div class=\"conditional-field\" id=\"cp-dir-field\">\n        <input class=\"form-input\" id=\"cp-dir-path\" type=\"text\"\n               placeholder=\"/home/user/projects/my-repo\" />\n      </div>\n    </div>\n\n    <!-- 自动 push 开关 -->\n    <div class=\"form-group\">\n      <label class=\"form-label\">自动推送</label>\n      <div class=\"toggle-row\">\n        <div class=\"toggle-info\">\n          <div class=\"toggle-info-label\">自动 push 到远程</div>\n          <div class=\"toggle-info-desc\">每次提交后自动执行 git push</div>\n        </div>\n        <label class=\"toggle-switch\">\n          <input type=\"checkbox\" id=\"cp-auto-push\" />\n          <span class=\"toggle-slider\"></span>\n        </label>\n      </div>\n    </div>\n\n    <div class=\"modal-footer\">\n      <button class=\"btn-cancel\" onclick=\"closeCreateModal()\">取消</button>\n      <button class=\"btn-primary\" id=\"cp-submit-btn\" onclick=\"submitCreateProject()\">创建项目</button>\n    </div>\n  </div>\n</div>\n\n<script>\n// ─── State ────────────────────────────────────────────────────────────────────\nconst LS_KEY = 'ralph_selected_project';\nlet projects = [];\nlet currentId = localStorage.getItem(LS_KEY) || '';\nlet currentTab = 'tasks';\nlet allFiles = [];\nlet logAutoTimer = null;\nlet statusRefreshTimer = null;\n\n// ─── Init ─────────────────────────────────────────────────────────────────────\nasync function init() {\n  await loadProjects();\n  const stored = currentId;\n  if (stored && projects.find(p => p.id === stored)) {\n    setProject(stored);\n  } else if (projects.length > 0) {\n    setProject(projects[0].id);\n  } else {\n    showNoProject();\n  }\n}\n\n// ─── Projects ─────────────────────────────────────────────────────────────────\nasync function loadProjects() {\n  try {\n    const r = await fetch('/api/projects');\n    projects = await r.json();\n  } catch { projects = []; }\n  renderProjectSelect();\n}\n\nfunction renderProjectSelect() {\n  const sel = document.getElementById('project-select');\n  sel.innerHTML = '<option value=\"\">— 选择项目 —</option>';\n  projects.forEach(p => {\n    const opt = document.createElement('option');\n    opt.value = p.id;\n    opt.textContent = p.name + (p.status === 'archived' ? ' (已归档)' : '');\n    sel.appendChild(opt);\n  });\n  sel.value = currentId || '';\n}\n\nfunction onProjectChange(id) {\n  if (id) setProject(id);\n  else showNoProject();\n}\n\nfunction setProject(id) {\n  currentId = id;\n  localStorage.setItem(LS_KEY, id);\n  document.getElementById('project-select').value = id;\n  document.getElementById('no-project').style.display = 'none';\n  document.getElementById('app').style.display = 'flex';\n  stopAllAutoRefresh();\n  loadCurrentTab();\n  updateLoopBadge();\n}\n\nfunction showNoProject() {\n  document.getElementById('no-project').style.display = 'flex';\n  document.getElementById('app').style.display = 'none';\n  updateLoopBadge();\n}\n\n// ─── Tabs ─────────────────────────────────────────────────────────────────────\nfunction switchTab(tab) {\n  stopAllAutoRefresh();\n  currentTab = tab;\n  document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === tab));\n  document.querySelectorAll('.tab-pane').forEach(p => p.classList.toggle('active', p.id === `pane-${tab}`));\n  loadCurrentTab();\n}\n\nfunction loadCurrentTab() {\n  if (!currentId) return;\n  if (currentTab === 'tasks')  loadTasks();\n  if (currentTab === 'logs')   loadLogs();\n  if (currentTab === 'files')  loadFiles();\n  if (currentTab === 'status') loadStatus();\n}\n\nfunction refreshCurrent() {\n  loadProjects().then(() => {\n    if (currentId) {\n      loadCurrentTab();\n      updateLoopBadge();\n    }\n  });\n}\n\n// ─── Tasks ────────────────────────────────────────────────────────────────────\nasync function loadTasks() {\n  const list = document.getElementById('task-list');\n  list.innerHTML = '<div class=\"empty-hint\"><div class=\"spinner\"></div></div>';\n  try {\n    const r = await fetch(`/api/projects/${currentId}/tasks`);\n    const tasks = await r.json();\n    renderTasks(tasks);\n  } catch {\n    list.innerHTML = '<div class=\"empty-hint\" style=\"color:var(--red)\">加载失败</div>';\n  }\n}\n\nconst STATUS_CYCLE = { pending: 'in_progress', in_progress: 'done', done: 'pending' };\nconst STATUS_LABEL = { pending: '待处理', in_progress: '进行中', done: '已完成' };\nconst STATUS_CLASS = { pending: 'pending', in_progress: 'in_progress', done: 'done' };\n\nfunction renderTasks(tasks) {\n  const list = document.getElementById('task-list');\n  if (!tasks.length) {\n    list.innerHTML = '<div class=\"empty-hint\">暂无任务，添加第一个吧</div>';\n    return;\n  }\n  list.innerHTML = '';\n  tasks.forEach(t => {\n    const item = document.createElement('div');\n    item.className = `task-item ${t.status}`;\n    item.dataset.id = t.id;\n\n    const checkmark = t.status === 'done' ? '✓' : (t.status === 'in_progress' ? '…' : '');\n    const tagCls = STATUS_CLASS[t.status] || 'pending';\n    const tagLabel = STATUS_LABEL[t.status] || t.status;\n    const nextStatus = STATUS_CYCLE[t.status] || 'pending';\n\n    item.innerHTML = `\n      <button class=\"task-status-btn\" onclick=\"cycleTaskStatus('${t.id}','${nextStatus}')\" title=\"切换状态\">${checkmark}</button>\n      <span class=\"task-title-text\">${escHtml(t.title)}</span>\n      <span class=\"task-status-tag ${tagCls}\" onclick=\"cycleTaskStatus('${t.id}','${nextStatus}')\" style=\"cursor:pointer\" title=\"切换到: ${STATUS_LABEL[nextStatus]}\">${tagLabel}</span>\n      <button class=\"task-del-btn\" onclick=\"deleteTask('${t.id}')\" title=\"删除\">✕</button>\n    `;\n    list.appendChild(item);\n  });\n}\n\nasync function addTask() {\n  const input = document.getElementById('new-task-input');\n  const title = input.value.trim();\n  if (!title) return;\n  input.value = '';\n  try {\n    await fetch(`/api/projects/${currentId}/tasks`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title }),\n    });\n    loadTasks();\n    showToast('任务已添加');\n  } catch {\n    showToast('添加失败', true);\n  }\n}\n\nfunction onTaskKeydown(e) {\n  if (e.key === 'Enter') addTask();\n}\n\nasync function cycleTaskStatus(tid, nextStatus) {\n  try {\n    await fetch(`/api/projects/${currentId}/tasks/${tid}`, {\n      method: 'PUT',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ status: nextStatus }),\n    });\n    loadTasks();\n  } catch {\n    showToast('更新失败', true);\n  }\n}\n\nasync function deleteTask(tid) {\n  if (!confirm('确认删除此任务？')) return;\n  try {\n    await fetch(`/api/projects/${currentId}/tasks/${tid}`, { method: 'DELETE' });\n    loadTasks();\n    showToast('任务已删除');\n  } catch {\n    showToast('删除失败', true);\n  }\n}\n\n// ─── Logs ─────────────────────────────────────────────────────────────────────\nasync function loadLogs() {\n  const lines = document.getElementById('log-lines').value;\n  const box = document.getElementById('log-box');\n  try {\n    const r = await fetch(`/api/projects/${currentId}/logs?lines=${lines}`);\n    const d = await r.json();\n    const atBottom = box.scrollHeight - box.scrollTop - box.clientHeight < 60;\n    box.textContent = d.logs || '';\n    if (!d.logs) box.innerHTML = '<span class=\"log-empty\">暂无日志</span>';\n    document.getElementById('log-total').textContent = `共 ${d.total_lines || 0} 行`;\n    if (atBottom) box.scrollTop = box.scrollHeight;\n  } catch {\n    box.innerHTML = '<span style=\"color:var(--red)\">加载失败</span>';\n  }\n}\n\nfunction onLogAutoChange() {\n  const checked = document.getElementById('log-auto').checked;\n  clearInterval(logAutoTimer);\n  if (checked) logAutoTimer = setInterval(loadLogs, 5000);\n}\n\n// ─── Files ────────────────────────────────────────────────────────────────────\nasync function loadFiles() {\n  const tbody = document.getElementById('file-tbody');\n  tbody.innerHTML = '<tr><td colspan=\"3\" class=\"empty-hint\"><div class=\"spinner\"></div></td></tr>';\n  try {\n    const r = await fetch(`/api/projects/${currentId}/files`);\n    const d = await r.json();\n    allFiles = d.files || [];\n    renderFiles();\n  } catch {\n    tbody.innerHTML = '<tr><td colspan=\"3\" style=\"color:var(--red);padding:0.6rem\">加载失败</td></tr>';\n  }\n}\n\nfunction renderFiles() {\n  const q = document.getElementById('files-search').value.toLowerCase();\n  const files = q ? allFiles.filter(f => f.path.toLowerCase().includes(q)) : allFiles;\n  const tbody = document.getElementById('file-tbody');\n  if (!files.length) {\n    tbody.innerHTML = '<tr><td colspan=\"3\" class=\"empty-hint\">无文件</td></tr>';\n    return;\n  }\n  tbody.innerHTML = files.map(f => `\n    <tr>\n      <td class=\"file-path\">${escHtml(f.path)}</td>\n      <td class=\"file-size\">${fmtSize(f.size)}</td>\n      <td class=\"file-mtime\">${fmtTime(f.modified)}</td>\n    </tr>\n  `).join('');\n}\n\n// ─── Status ───────────────────────────────────────────────────────────────────\nasync function loadStatus() {\n  const cont = document.getElementById('status-content');\n  cont.innerHTML = '<div class=\"empty-hint\"><div class=\"spinner\"></div></div>';\n  try {\n    const proj = projects.find(p => p.id === currentId);\n    const [gitR, dispR] = await Promise.all([\n      fetch(`/api/projects/${currentId}/git-status`).then(r => r.json()).catch(() => ({})),\n      fetch('/api/dispatcher/status').then(r => r.json()).catch(() => ({})),\n    ]);\n    const loop = dispR[currentId] || { running: false };\n    renderStatus(proj, gitR, loop);\n    updateLoopBadgeFromLoop(loop);\n  } catch {\n    cont.innerHTML = '<div class=\"empty-hint\" style=\"color:var(--red)\">加载失败</div>';\n  }\n}\n\nfunction renderStatus(proj, git, loop) {\n  const cont = document.getElementById('status-content');\n\n  const loopRunning = loop.running;\n  const loopColor = loopRunning ? 'green' : 'red';\n  const loopText  = loopRunning ? `运行中 (PID ${loop.pid})` : '已停止';\n\n  let gitCard = '';\n  if (git.has_git === false) {\n    gitCard = `\n      <div class=\"card\">\n        <div class=\"card-title\">Git 信息</div>\n        <div class=\"stat-value muted\">未初始化 Git 仓库</div>\n      </div>`;\n  } else if (git.has_git) {\n    const dirty = git.dirty ? '<span style=\"color:var(--yellow)\">有未提交变更</span>' : '<span style=\"color:var(--green)\">干净</span>';\n    const unpushed = git.unpushed_commits || 0;\n    const unpushedBadge = unpushed > 0\n      ? `<span style=\"background:rgba(251,191,36,0.15);border:1px solid rgba(251,191,36,0.35);border-radius:12px;padding:0.15rem 0.65rem;color:var(--yellow)\">${unpushed}</span>`\n      : `<span style=\"color:var(--green)\">0</span>`;\n    const statusHtml = (git.status_lines || []).map(l => {\n      const cls = l.startsWith('M') ? 'M' : l.startsWith('A') ? 'A' : l.startsWith('D') ? 'D' : 'Q';\n      return `<span class=\"${cls}\">${escHtml(l)}</span>`;\n    }).join('');\n    gitCard = `\n      <div class=\"card\">\n        <div class=\"card-title\" style=\"display:flex;align-items:center;justify-content:space-between;margin-bottom:0.85rem\">\n          <span>Git 信息</span>\n          <button class=\"btn-sm success\" id=\"btn-push\" onclick=\"pushProject()\" title=\"推送到远程仓库\">↑ 推送到远程</button>\n        </div>\n        <div class=\"status-grid\">\n          <div class=\"stat-block\" style=\"grid-column:1/-1\">\n            <div class=\"stat-label\">Remote 地址</div>\n            <div class=\"stat-value muted\" style=\"font-size:0.8rem;word-break:break-all;font-family:monospace\">${escHtml(git.remote || '—')}</div>\n          </div>\n          <div class=\"stat-block\">\n            <div class=\"stat-label\">当前分支</div>\n            <div class=\"stat-value\">${escHtml(git.branch || '—')}</div>\n          </div>\n          <div class=\"stat-block\">\n            <div class=\"stat-label\">未推送 commit 数</div>\n            <div class=\"stat-value\">${unpushedBadge}</div>\n          </div>\n          <div class=\"stat-block\">\n            <div class=\"stat-label\">最近 push 时间</div>\n            <div class=\"stat-value muted\">${git.last_push ? fmtTime(git.last_push) : '—'}</div>\n          </div>\n          <div class=\"stat-block\">\n            <div class=\"stat-label\">工作区状态</div>\n            <div class=\"stat-value\">${dirty}${statusHtml ? '<div class=\"git-status-lines\">' + statusHtml + '</div>' : ''}</div>\n          </div>\n        </div>\n      </div>`;\n  }\n\n  cont.innerHTML = `\n    <div style=\"display:flex;gap:0.7rem;flex-wrap:wrap;margin-bottom:1rem\">\n      <button class=\"btn-sm\" onclick=\"loadStatus()\">刷新状态</button>\n    </div>\n    <div class=\"card\">\n      <div class=\"card-title\">项目信息</div>\n      <div class=\"status-grid\">\n        <div class=\"stat-block\">\n          <div class=\"stat-label\">项目名称</div>\n          <div class=\"stat-value\">${escHtml(proj ? proj.name : currentId)}</div>\n        </div>\n        <div class=\"stat-block\">\n          <div class=\"stat-label\">项目状态</div>\n          <div class=\"stat-value ${proj && proj.status === 'active' ? 'green' : 'muted'}\">${proj ? proj.status : '—'}</div>\n        </div>\n        <div class=\"stat-block\">\n          <div class=\"stat-label\">Ralph Loop</div>\n          <div class=\"stat-value ${loopColor}\">${loopText}</div>\n        </div>\n        <div class=\"stat-block\">\n          <div class=\"stat-label\">项目路径</div>\n          <div class=\"stat-value muted\" style=\"font-size:0.78rem\">${escHtml(proj ? proj.path : '—')}</div>\n        </div>\n        <div class=\"stat-block\">\n          <div class=\"stat-label\">创建时间</div>\n          <div class=\"stat-value muted\">${proj ? fmtTime(proj.created_at) : '—'}</div>\n        </div>\n        ${loop.started_at ? `\n        <div class=\"stat-block\">\n          <div class=\"stat-label\">Loop 启动时间</div>\n          <div class=\"stat-value muted\">${fmtTime(new Date(loop.started_at * 1000).toISOString())}</div>\n        </div>` : ''}\n      </div>\n    </div>\n    ${gitCard}\n  `;\n}\n\nasync function pushProject() {\n  const btn = document.getElementById('btn-push');\n  if (btn) { btn.disabled = true; btn.textContent = '推送中…'; }\n  try {\n    const r = await fetch(`/api/projects/${currentId}/push`, { method: 'POST' });\n    const d = await r.json();\n    if (d.success) showToast('推送成功');\n    else showToast(`推送失败: ${d.output}`, true);\n    loadStatus();\n  } catch {\n    showToast('推送请求失败', true);\n  }\n}\n\n// ─── Loop Badge ───────────────────────────────────────────────────────────────\nasync function updateLoopBadge() {\n  if (!currentId) {\n    document.getElementById('loop-dot').className = 'loop-dot';\n    document.getElementById('loop-label').textContent = '未选择';\n    return;\n  }\n  try {\n    const r = await fetch('/api/dispatcher/status');\n    const d = await r.json();\n    updateLoopBadgeFromLoop(d[currentId] || { running: false });\n  } catch { /* ignore */ }\n}\n\nfunction updateLoopBadgeFromLoop(loop) {\n  const dot = document.getElementById('loop-dot');\n  const lbl = document.getElementById('loop-label');\n  if (loop.running) {\n    dot.className = 'loop-dot running';\n    lbl.textContent = 'Loop 运行中';\n  } else {\n    dot.className = 'loop-dot';\n    lbl.textContent = 'Loop 已停止';\n  }\n}\n\n// ─── Auto-refresh cleanup ─────────────────────────────────────────────────────\nfunction stopAllAutoRefresh() {\n  clearInterval(logAutoTimer); logAutoTimer = null;\n  clearInterval(statusRefreshTimer); statusRefreshTimer = null;\n  const logAutoChk = document.getElementById('log-auto');\n  if (logAutoChk) logAutoChk.checked = false;\n}\n\n// ─── Utilities ────────────────────────────────────────────────────────────────\nfunction escHtml(s) {\n  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');\n}\n\nfunction fmtSize(bytes) {\n  if (bytes == null) return '—';\n  if (bytes < 1024) return `${bytes} B`;\n  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;\n  return `${(bytes / 1024 / 1024).toFixed(2)} MB`;\n}\n\nfunction fmtTime(iso) {\n  if (!iso) return '—';\n  try {\n    return new Date(iso).toLocaleString('zh-CN', {\n      year: 'numeric', month: '2-digit', day: '2-digit',\n      hour: '2-digit', minute: '2-digit',\n    });\n  } catch { return iso; }\n}\n\nlet toastTimer = null;\nfunction showToast(msg, isErr = false) {\n  const el = document.getElementById('toast');\n  el.textContent = msg;\n  el.style.borderColor = isErr ? 'rgba(255,77,94,0.3)' : 'rgba(0,201,139,0.3)';\n  el.style.color = isErr ? 'var(--red)' : 'var(--green)';\n  el.classList.add('show');\n  clearTimeout(toastTimer);\n  toastTimer = setTimeout(() => el.classList.remove('show'), 2500);\n}\n\n// ─── Create Project Modal ─────────────────────────────────────────────────────\nfunction openCreateModal() {\n  const overlay = document.getElementById('create-modal-overlay');\n  overlay.classList.add('open');\n  document.getElementById('cp-name').focus();\n}\n\nfunction closeCreateModal() {\n  document.getElementById('create-modal-overlay').classList.remove('open');\n  resetCreateForm();\n}\n\nfunction onModalOverlayClick(e) {\n  if (e.target === document.getElementById('create-modal-overlay')) {\n    closeCreateModal();\n  }\n}\n\nfunction resetCreateForm() {\n  document.getElementById('cp-name').value = '';\n  document.getElementById('cp-desc').value = '';\n  document.getElementById('cp-github-url').value = '';\n  document.getElementById('cp-dir-path').value = '';\n  document.getElementById('cp-auto-push').checked = false;\n  document.querySelector('input[name=\"cp-git-source\"][value=\"new\"]').checked = true;\n  onGitSourceChange('new');\n  const btn = document.getElementById('cp-submit-btn');\n  btn.disabled = false;\n  btn.textContent = '创建项目';\n}\n\nfunction onGitSourceChange(val) {\n  // Update radio option highlight\n  ['new', 'github', 'dir'].forEach(v => {\n    document.getElementById(`opt-${v}`).classList.toggle('selected', v === val);\n  });\n  document.getElementById('cp-github-field').classList.toggle('visible', val === 'github');\n  document.getElementById('cp-dir-field').classList.toggle('visible', val === 'dir');\n}\n\nasync function submitCreateProject() {\n  const name = document.getElementById('cp-name').value.trim();\n  if (!name) {\n    document.getElementById('cp-name').focus();\n    showToast('项目名称不能为空', true);\n    return;\n  }\n\n  const gitSource = document.querySelector('input[name=\"cp-git-source\"]:checked').value;\n  const githubUrl = document.getElementById('cp-github-url').value.trim();\n  const dirPath   = document.getElementById('cp-dir-path').value.trim();\n\n  if (gitSource === 'github' && !githubUrl) {\n    document.getElementById('cp-github-url').focus();\n    showToast('请填写 GitHub 仓库地址', true);\n    return;\n  }\n  if (gitSource === 'dir' && !dirPath) {\n    document.getElementById('cp-dir-path').focus();\n    showToast('请填写目录路径', true);\n    return;\n  }\n\n  const payload = {\n    name,\n    description: document.getElementById('cp-desc').value.trim(),\n    git_source: gitSource,\n    auto_push: document.getElementById('cp-auto-push').checked,\n  };\n  if (gitSource === 'github') payload.github_url = githubUrl;\n  if (gitSource === 'dir')    payload.dir_path    = dirPath;\n\n  const btn = document.getElementById('cp-submit-btn');\n  btn.disabled = true;\n  btn.textContent = '创建中…';\n\n  try {\n    const r = await fetch('/api/projects', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify(payload),\n    });\n    const d = await r.json();\n    if (r.ok && (d.id || d.success)) {\n      showToast('项目创建成功');\n      closeCreateModal();\n      await loadProjects();\n      const newId = d.id || (projects.length > 0 ? projects[projects.length - 1].id : null);\n      if (newId) setProject(newId);\n    } else {\n      showToast(`创建失败: ${d.error || d.message || '未知错误'}`, true);\n      btn.disabled = false;\n      btn.textContent = '创建项目';\n    }\n  } catch (err) {\n    showToast('请求失败，请重试', true);\n    btn.disabled = false;\n    btn.textContent = '创建项目';\n  }\n}\n\n// Close modal on Escape key\ndocument.addEventListener('keydown', e => {\n  if (e.key === 'Escape') closeCreateModal();\n});\n\n// ─── Start ────────────────────────────────────────────────────────────────────\ninit();\n</script>\n</body>\n</html>\n","numLines":1217,"startLine":1,"totalLines":1217}}}
