{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_016AdcDFGRH9rR4vwkJf4M3b","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Vm4gzaJKPMH8jHQq8y6k6b","name":"Write","input":{"file_path":"/home/ubuntu/my-project/server.js","content":"import express from 'express';\nimport axios from 'axios';\nimport { fileURLToPath } from 'url';\nimport { dirname, join } from 'path';\n\nconst __dirname = dirname(fileURLToPath(import.meta.url));\nconst app = express();\nconst PORT = process.env.PORT || 3000;\n\napp.use(express.static(join(__dirname, 'public')));\n\n// ─── BTC via CoinGecko (free, no key) ────────────────────────────────────────\nasync function getBTCPrice() {\n  const resp = await axios.get('https://api.coingecko.com/api/v3/simple/price', {\n    params: { ids: 'bitcoin', vs_currencies: 'usd', include_24hr_change: 'true' },\n    timeout: 10000,\n  });\n  const d = resp.data.bitcoin;\n  return {\n    price: d.usd,\n    change: (d.usd * d.usd_24h_change) / 100,\n    changePercent: d.usd_24h_change,\n  };\n}\n\nasync function getBTCHistory(days) {\n  const resp = await axios.get('https://api.coingecko.com/api/v3/coins/bitcoin/market_chart', {\n    params: { vs_currency: 'usd', days },\n    timeout: 15000,\n  });\n  return resp.data.prices.map(([t, p]) => ({ t, p }));\n}\n\n// ─── Yahoo Finance via direct HTTP ────────────────────────────────────────────\nconst YF_HEADERS = {\n  'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/120.0.0.0 Safari/537.36',\n  'Accept': 'application/json',\n  'Accept-Language': 'en-US,en;q=0.9',\n};\n\nasync function getYahooPrice(symbol) {\n  const url = `https://query1.finance.yahoo.com/v8/finance/chart/${encodeURIComponent(symbol)}`;\n  const resp = await axios.get(url, {\n    params: { interval: '1d', range: '5d' },\n    headers: YF_HEADERS,\n    timeout: 12000,\n  });\n  const meta = resp.data?.chart?.result?.[0]?.meta;\n  if (!meta) throw new Error(`No data for ${symbol}`);\n  const cur   = meta.regularMarketPrice;\n  const prev  = meta.chartPreviousClose ?? meta.previousClose ?? cur;\n  const change = cur - prev;\n  return {\n    price:         cur,\n    change:        change,\n    changePercent: prev ? (change / prev) * 100 : 0,\n  };\n}\n\nasync function getYahooHistory(symbol, range, interval) {\n  const url = `https://query1.finance.yahoo.com/v8/finance/chart/${encodeURIComponent(symbol)}`;\n  const resp = await axios.get(url, {\n    params: { interval, range },\n    headers: YF_HEADERS,\n    timeout: 15000,\n  });\n  const result = resp.data?.chart?.result?.[0];\n  if (!result) throw new Error(`No history for ${symbol}`);\n  const stamps = result.timestamp || [];\n  const closes = result.indicators?.quote?.[0]?.close || [];\n  return stamps\n    .map((ts, i) => ({ t: ts * 1000, p: closes[i] }))\n    .filter(d => d.p != null);\n}\n\n// ─── Range config ─────────────────────────────────────────────────────────────\nconst RANGES = {\n  '1d':  { coinDays: 1,   yfRange: '1d',   interval: '5m'  },\n  '1w':  { coinDays: 7,   yfRange: '5d',   interval: '60m' },\n  '1m':  { coinDays: 30,  yfRange: '1mo',  interval: '1d'  },\n  '3m':  { coinDays: 90,  yfRange: '3mo',  interval: '1d'  },\n  '1y':  { coinDays: 365, yfRange: '1y',   interval: '1wk' },\n};\n\n// ─── API Routes ───────────────────────────────────────────────────────────────\napp.get('/api/prices', async (req, res) => {\n  try {\n    const [btc, gold, spx] = await Promise.all([\n      getBTCPrice(),\n      getYahooPrice('GC=F'),\n      getYahooPrice('^GSPC'),\n    ]);\n    res.json({ btc, gold, spx });\n  } catch (err) {\n    console.error('[/api/prices]', err.message);\n    res.status(500).json({ error: err.message });\n  }\n});\n\napp.get('/api/history/:asset', async (req, res) => {\n  const { asset } = req.params;\n  const cfg = RANGES[req.query.range] || RANGES['1m'];\n  try {\n    let data;\n    if (asset === 'btc') {\n      data = await getBTCHistory(cfg.coinDays);\n    } else if (asset === 'gold') {\n      data = await getYahooHistory('GC=F', cfg.yfRange, cfg.interval);\n    } else if (asset === 'spx') {\n      data = await getYahooHistory('^GSPC', cfg.yfRange, cfg.interval);\n    } else {\n      return res.status(400).json({ error: `Unknown asset: ${asset}` });\n    }\n    res.json(data);\n  } catch (err) {\n    console.error(`[/api/history/${asset}]`, err.message);\n    res.status(500).json({ error: err.message });\n  }\n});\n\napp.listen(PORT, () => {\n  console.log(`\\n  Market Dashboard → http://localhost:${PORT}\\n`);\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":206,"cache_read_input_tokens":41086,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":206},"output_tokens":9,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0e6e90df-9a4f-4c5a-98af-c0817facd39e","uuid":"6b5bc0de-da41-40d2-818c-2a2eba8217ec"}
