{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016zxjgAPjXXSNirFhrLU9ax","type":"tool_result","content":"     1→import express from 'express';\n     2→import yahooFinance from 'yahoo-finance2';\n     3→import axios from 'axios';\n     4→import { fileURLToPath } from 'url';\n     5→import { dirname, join } from 'path';\n     6→\n     7→const __dirname = dirname(fileURLToPath(import.meta.url));\n     8→const app = express();\n     9→const PORT = process.env.PORT || 3000;\n    10→\n    11→app.use(express.static(join(__dirname, 'public')));\n    12→\n    13→// ─── BTC via CoinGecko (free, no key) ────────────────────────────────────────\n    14→\n    15→async function getBTCPrice() {\n    16→  const resp = await axios.get('https://api.coingecko.com/api/v3/simple/price', {\n    17→    params: { ids: 'bitcoin', vs_currencies: 'usd', include_24hr_change: 'true' },\n    18→    timeout: 10000,\n    19→  });\n    20→  const d = resp.data.bitcoin;\n    21→  return {\n    22→    price: d.usd,\n    23→    change: (d.usd * d.usd_24h_change) / 100,\n    24→    changePercent: d.usd_24h_change,\n    25→  };\n    26→}\n    27→\n    28→async function getBTCHistory(days) {\n    29→  const resp = await axios.get('https://api.coingecko.com/api/v3/coins/bitcoin/market_chart', {\n    30→    params: { vs_currency: 'usd', days },\n    31→    timeout: 15000,\n    32→  });\n    33→  return resp.data.prices.map(([t, p]) => ({ t, p }));\n    34→}\n    35→\n    36→// ─── Gold & S&P 500 via Yahoo Finance ────────────────────────────────────────\n    37→\n    38→async function getYahooPrice(symbol) {\n    39→  const quote = await yahooFinance.quote(symbol, {}, { validateResult: false });\n    40→  return {\n    41→    price: quote.regularMarketPrice,\n    42→    change: quote.regularMarketChange,\n    43→    changePercent: quote.regularMarketChangePercent,\n    44→  };\n    45→}\n    46→\n    47→async function getYahooHistory(symbol, period1, interval) {\n    48→  const result = await yahooFinance.chart(\n    49→    symbol,\n    50→    { period1, interval, includePrePost: false },\n    51→    { validateResult: false }\n    52→  );\n    53→  return (result.quotes || [])\n    54→    .filter(q => q.close != null)\n    55→    .map(q => ({ t: new Date(q.date).getTime(), p: q.close }));\n    56→}\n    57→\n    58→// ─── Range config ─────────────────────────────────────────────────────────────\n    59→\n    60→const RANGES = {\n    61→  '1d': { coinDays: 1,   period1: () => { const d = new Date(); d.setDate(d.getDate() - 2);       return d; }, interval: '5m'  },\n    62→  '1w': { coinDays: 7,   period1: () => { const d = new Date(); d.setDate(d.getDate() - 7);       return d; }, interval: '60m' },\n    63→  '1m': { coinDays: 30,  period1: () => { const d = new Date(); d.setMonth(d.getMonth() - 1);     return d; }, interval: '1d'  },\n    64→  '3m': { coinDays: 90,  period1: () => { const d = new Date(); d.setMonth(d.getMonth() - 3);     return d; }, interval: '1d'  },\n    65→  '1y': { coinDays: 365, period1: () => { const d = new Date(); d.setFullYear(d.getFullYear()-1); return d; }, interval: '1wk' },\n    66→};\n    67→\n    68→// ─── API Routes ───────────────────────────────────────────────────────────────\n    69→\n    70→app.get('/api/prices', async (req, res) => {\n    71→  try {\n    72→    const [btc, gold, spx] = await Promise.all([\n    73→      getBTCPrice(),\n    74→      getYahooPrice('GC=F'),\n    75→      getYahooPrice('^GSPC'),\n    76→    ]);\n    77→    res.json({ btc, gold, spx });\n    78→  } catch (err) {\n    79→    console.error('[/api/prices]', err.message);\n    80→    res.status(500).json({ error: err.message });\n    81→  }\n    82→});\n    83→\n    84→app.get('/api/history/:asset', async (req, res) => {\n    85→  const { asset } = req.params;\n    86→  const cfg = RANGES[req.query.range] || RANGES['1m'];\n    87→  try {\n    88→    let data;\n    89→    if (asset === 'btc') {\n    90→      data = await getBTCHistory(cfg.coinDays);\n    91→    } else if (asset === 'gold') {\n    92→      data = await getYahooHistory('GC=F', cfg.period1(), cfg.interval);\n    93→    } else if (asset === 'spx') {\n    94→      data = await getYahooHistory('^GSPC', cfg.period1(), cfg.interval);\n    95→    } else {\n    96→      return res.status(400).json({ error: `Unknown asset: ${asset}` });\n    97→    }\n    98→    res.json(data);\n    99→  } catch (err) {\n   100→    console.error(`[/api/history/${asset}]`, err.message);\n   101→    res.status(500).json({ error: err.message });\n   102→  }\n   103→});\n   104→\n   105→app.listen(PORT, () => {\n   106→  console.log(`\\n  Market Dashboard → http://localhost:${PORT}\\n`);\n   107→});\n   108→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"0e6e90df-9a4f-4c5a-98af-c0817facd39e","uuid":"eeb993b7-77b2-47ad-af93-10ca49aebb8d","tool_use_result":{"type":"text","file":{"filePath":"/home/ubuntu/my-project/server.js","content":"import express from 'express';\nimport yahooFinance from 'yahoo-finance2';\nimport axios from 'axios';\nimport { fileURLToPath } from 'url';\nimport { dirname, join } from 'path';\n\nconst __dirname = dirname(fileURLToPath(import.meta.url));\nconst app = express();\nconst PORT = process.env.PORT || 3000;\n\napp.use(express.static(join(__dirname, 'public')));\n\n// ─── BTC via CoinGecko (free, no key) ────────────────────────────────────────\n\nasync function getBTCPrice() {\n  const resp = await axios.get('https://api.coingecko.com/api/v3/simple/price', {\n    params: { ids: 'bitcoin', vs_currencies: 'usd', include_24hr_change: 'true' },\n    timeout: 10000,\n  });\n  const d = resp.data.bitcoin;\n  return {\n    price: d.usd,\n    change: (d.usd * d.usd_24h_change) / 100,\n    changePercent: d.usd_24h_change,\n  };\n}\n\nasync function getBTCHistory(days) {\n  const resp = await axios.get('https://api.coingecko.com/api/v3/coins/bitcoin/market_chart', {\n    params: { vs_currency: 'usd', days },\n    timeout: 15000,\n  });\n  return resp.data.prices.map(([t, p]) => ({ t, p }));\n}\n\n// ─── Gold & S&P 500 via Yahoo Finance ────────────────────────────────────────\n\nasync function getYahooPrice(symbol) {\n  const quote = await yahooFinance.quote(symbol, {}, { validateResult: false });\n  return {\n    price: quote.regularMarketPrice,\n    change: quote.regularMarketChange,\n    changePercent: quote.regularMarketChangePercent,\n  };\n}\n\nasync function getYahooHistory(symbol, period1, interval) {\n  const result = await yahooFinance.chart(\n    symbol,\n    { period1, interval, includePrePost: false },\n    { validateResult: false }\n  );\n  return (result.quotes || [])\n    .filter(q => q.close != null)\n    .map(q => ({ t: new Date(q.date).getTime(), p: q.close }));\n}\n\n// ─── Range config ─────────────────────────────────────────────────────────────\n\nconst RANGES = {\n  '1d': { coinDays: 1,   period1: () => { const d = new Date(); d.setDate(d.getDate() - 2);       return d; }, interval: '5m'  },\n  '1w': { coinDays: 7,   period1: () => { const d = new Date(); d.setDate(d.getDate() - 7);       return d; }, interval: '60m' },\n  '1m': { coinDays: 30,  period1: () => { const d = new Date(); d.setMonth(d.getMonth() - 1);     return d; }, interval: '1d'  },\n  '3m': { coinDays: 90,  period1: () => { const d = new Date(); d.setMonth(d.getMonth() - 3);     return d; }, interval: '1d'  },\n  '1y': { coinDays: 365, period1: () => { const d = new Date(); d.setFullYear(d.getFullYear()-1); return d; }, interval: '1wk' },\n};\n\n// ─── API Routes ───────────────────────────────────────────────────────────────\n\napp.get('/api/prices', async (req, res) => {\n  try {\n    const [btc, gold, spx] = await Promise.all([\n      getBTCPrice(),\n      getYahooPrice('GC=F'),\n      getYahooPrice('^GSPC'),\n    ]);\n    res.json({ btc, gold, spx });\n  } catch (err) {\n    console.error('[/api/prices]', err.message);\n    res.status(500).json({ error: err.message });\n  }\n});\n\napp.get('/api/history/:asset', async (req, res) => {\n  const { asset } = req.params;\n  const cfg = RANGES[req.query.range] || RANGES['1m'];\n  try {\n    let data;\n    if (asset === 'btc') {\n      data = await getBTCHistory(cfg.coinDays);\n    } else if (asset === 'gold') {\n      data = await getYahooHistory('GC=F', cfg.period1(), cfg.interval);\n    } else if (asset === 'spx') {\n      data = await getYahooHistory('^GSPC', cfg.period1(), cfg.interval);\n    } else {\n      return res.status(400).json({ error: `Unknown asset: ${asset}` });\n    }\n    res.json(data);\n  } catch (err) {\n    console.error(`[/api/history/${asset}]`, err.message);\n    res.status(500).json({ error: err.message });\n  }\n});\n\napp.listen(PORT, () => {\n  console.log(`\\n  Market Dashboard → http://localhost:${PORT}\\n`);\n});\n","numLines":108,"startLine":1,"totalLines":108}}}
