{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HFZZFumWtRQgQGa3bGkBZW","type":"tool_result","content":"     1→\"\"\"\n     2→app.py — Ralph Project Management Backend\n     3→\n     4→REST API for managing projects and their Ralph Loops.\n     5→\n     6→Endpoints:\n     7→  GET    /api/projects\n     8→  POST   /api/projects\n     9→  GET    /api/projects/<id>\n    10→  PUT    /api/projects/<id>\n    11→  POST   /api/projects/<id>/archive\n    12→  POST   /api/projects/<id>/unarchive\n    13→  GET    /api/projects/<id>/git-status\n    14→  POST   /api/projects/<id>/push\n    15→  GET    /api/projects/<id>/logs\n    16→  GET    /api/projects/<id>/tasks\n    17→  POST   /api/projects/<id>/tasks\n    18→  PUT    /api/projects/<id>/tasks/<tid>\n    19→  DELETE /api/projects/<id>/tasks/<tid>\n    20→  GET    /api/projects/<id>/files\n    21→  GET    /api/dispatcher/status\n    22→\n    23→Environment variables:\n    24→  RALPH_DB            SQLite database path (default: projects.db)\n    25→  RALPH_LOGS_DIR      Log file directory   (default: logs/)\n    26→  RALPH_PROJECTS_DIR  Base dir for new projects (default: ~/ralph-projects)\n    27→  PORT                HTTP port (default: 5000)\n    28→\"\"\"\n    29→\n    30→import os\n    31→import sqlite3\n    32→import subprocess\n    33→import uuid\n    34→from datetime import datetime\n    35→\n    36→from flask import Flask, jsonify, request, send_from_directory\n    37→from dispatcher import get_dispatcher\n    38→\n    39→# ── App setup ────────────────────────────────────────────────────\n    40→\n    41→app = Flask(__name__, static_folder=\"static\")\n    42→\n    43→DB_PATH = os.environ.get(\"RALPH_DB\", \"projects.db\")\n    44→LOGS_DIR = os.environ.get(\"RALPH_LOGS_DIR\", \"logs\")\n    45→PROJECTS_BASE = os.environ.get(\n    46→    \"RALPH_PROJECTS_DIR\", os.path.expanduser(\"~/ralph-projects\")\n    47→)\n    48→\n    49→# ── Database ─────────────────────────────────────────────────────\n    50→\n    51→\n    52→def get_db():\n    53→    conn = sqlite3.connect(DB_PATH)\n    54→    conn.row_factory = sqlite3.Row\n    55→    conn.execute(\"PRAGMA journal_mode=WAL\")\n    56→    return conn\n    57→\n    58→\n    59→def init_db():\n    60→    conn = get_db()\n    61→    conn.executescript(\n    62→        \"\"\"\n    63→        CREATE TABLE IF NOT EXISTS projects (\n    64→            id          TEXT PRIMARY KEY,\n    65→            name        TEXT NOT NULL,\n    66→            description TEXT NOT NULL DEFAULT '',\n    67→            path        TEXT NOT NULL,\n    68→            git_remote  TEXT NOT NULL DEFAULT '',\n    69→            auto_push   INTEGER NOT NULL DEFAULT 1,\n    70→            status      TEXT NOT NULL DEFAULT 'active',\n    71→            created_at  TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))\n    72→        );\n    73→\n    74→        CREATE TABLE IF NOT EXISTS tasks (\n    75→            id          TEXT PRIMARY KEY,\n    76→            project_id  TEXT NOT NULL,\n    77→            title       TEXT NOT NULL,\n    78→            status      TEXT NOT NULL DEFAULT 'pending',\n    79→            created_at  TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\n    80→            updated_at  TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\n    81→            FOREIGN KEY (project_id) REFERENCES projects(id)\n    82→        );\n    83→        \"\"\"\n    84→    )\n    85→    conn.commit()\n    86→    conn.close()\n    87→\n    88→\n    89→# ── Helpers ──────────────────────────────────────────────────────\n    90→\n    91→\n    92→def run_git(cwd: str, *args):\n    93→    \"\"\"Run a git command; returns (stdout, stderr, returncode).\"\"\"\n    94→    result = subprocess.run(\n    95→        [\"git\"] + list(args),\n    96→        cwd=cwd,\n    97→        capture_output=True,\n    98→        text=True,\n    99→        timeout=30,\n   100→    )\n   101→    return result.stdout.strip(), result.stderr.strip(), result.returncode\n   102→\n   103→\n   104→def project_with_status(row: dict) -> dict:\n   105→    row[\"loop_status\"] = get_dispatcher().get_loop_status(row[\"id\"])\n   106→    return row\n   107→\n   108→\n   109→# ── Projects ─────────────────────────────────────────────────────\n   110→\n   111→\n   112→@app.route(\"/api/projects\", methods=[\"GET\"])\n   113→def list_projects():\n   114→    conn = get_db()\n   115→    rows = conn.execute(\n   116→        \"SELECT * FROM projects ORDER BY created_at DESC\"\n   117→    ).fetchall()\n   118→    conn.close()\n   119→    statuses = get_dispatcher().get_all_statuses()\n   120→    result = []\n   121→    for row in rows:\n   122→        p = dict(row)\n   123→        p[\"loop_status\"] = statuses.get(p[\"id\"], {\"running\": False})\n   124→        result.append(p)\n   125→    return jsonify(result)\n   126→\n   127→\n   128→@app.route(\"/api/projects\", methods=[\"POST\"])\n   129→def create_project():\n   130→    data = request.get_json(force=True)\n   131→    name = (data.get(\"name\") or \"\").strip()\n   132→    if not name:\n   133→        return jsonify({\"error\": \"name is required\"}), 400\n   134→\n   135→    git_source = data.get(\"git_source\", \"new\")  # new | github | existing\n   136→    git_remote = (data.get(\"git_remote\") or \"\").strip()\n   137→    auto_push = 1 if data.get(\"auto_push\", True) else 0\n   138→    description = (data.get(\"description\") or \"\").strip()\n   139→\n   140→    # Determine project path\n   141→    if git_source == \"existing\":\n   142→        path = os.path.expanduser((data.get(\"path\") or \"\").strip())\n   143→        if not path:\n   144→            return jsonify({\"error\": \"path is required for existing directory\"}), 400\n   145→    else:\n   146→        safe = name.lower().replace(\" \", \"-\").replace(\"/\", \"-\")\n   147→        path = os.path.join(PROJECTS_BASE, safe)\n   148→\n   149→    os.makedirs(path, exist_ok=True)\n   150→\n   151→    # Git setup\n   152→    if git_source == \"github\":\n   153→        if not git_remote:\n   154→            return jsonify({\"error\": \"git_remote is required for GitHub source\"}), 400\n   155→        out, err, rc = run_git(path, \"clone\", git_remote, \".\")\n   156→        if rc != 0:\n   157→            return jsonify({\"error\": f\"git clone failed: {err}\"}), 400\n   158→    elif git_source == \"new\":\n   159→        if not os.path.exists(os.path.join(path, \".git\")):\n   160→            run_git(path, \"init\")\n   161→\n   162→    project_id = str(uuid.uuid4())\n   163→    conn = get_db()\n   164→    conn.execute(\n   165→        \"\"\"\n   166→        INSERT INTO projects (id, name, description, path, git_remote, auto_push)\n   167→        VALUES (?, ?, ?, ?, ?, ?)\n   168→        \"\"\",\n   169→        (project_id, name, description, path, git_remote, auto_push),\n   170→    )\n   171→    conn.commit()\n   172→    project = dict(\n   173→        conn.execute(\"SELECT * FROM projects WHERE id=?\", (project_id,)).fetchone()\n   174→    )\n   175→    conn.close()\n   176→\n   177→    # Start Ralph Loop for new active project\n   178→    get_dispatcher().start_loop(project)\n   179→\n   180→    return jsonify(project_with_status(project)), 201\n   181→\n   182→\n   183→@app.route(\"/api/projects/<pid>\", methods=[\"GET\"])\n   184→def get_project(pid):\n   185→    conn = get_db()\n   186→    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n   187→    conn.close()\n   188→    if not row:\n   189→        return jsonify({\"error\": \"not found\"}), 404\n   190→    return jsonify(project_with_status(dict(row)))\n   191→\n   192→\n   193→@app.route(\"/api/projects/<pid>\", methods=[\"PUT\"])\n   194→def update_project(pid):\n   195→    data = request.get_json(force=True)\n   196→    name = (data.get(\"name\") or \"\").strip()\n   197→    if not name:\n   198→        return jsonify({\"error\": \"name is required\"}), 400\n   199→\n   200→    conn = get_db()\n   201→    conn.execute(\n   202→        \"\"\"\n   203→        UPDATE projects\n   204→        SET name=?, description=?, git_remote=?, auto_push=?\n   205→        WHERE id=?\n   206→        \"\"\",\n   207→        (\n   208→            name,\n   209→            (data.get(\"description\") or \"\").strip(),\n   210→            (data.get(\"git_remote\") or \"\").strip(),\n   211→            1 if data.get(\"auto_push\", True) else 0,\n   212→            pid,\n   213→        ),\n   214→    )\n   215→    conn.commit()\n   216→    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n   217→    conn.close()\n   218→    if not row:\n   219→        return jsonify({\"error\": \"not found\"}), 404\n   220→    return jsonify(project_with_status(dict(row)))\n   221→\n   222→\n   223→@app.route(\"/api/projects/<pid>/archive\", methods=[\"POST\"])\n   224→def archive_project(pid):\n   225→    conn = get_db()\n   226→    conn.execute(\"UPDATE projects SET status='archived' WHERE id=?\", (pid,))\n   227→    conn.commit()\n   228→    conn.close()\n   229→    get_dispatcher().stop_loop(pid)\n   230→    return jsonify({\"status\": \"archived\"})\n   231→\n   232→\n   233→@app.route(\"/api/projects/<pid>/unarchive\", methods=[\"POST\"])\n   234→def unarchive_project(pid):\n   235→    conn = get_db()\n   236→    conn.execute(\"UPDATE projects SET status='active' WHERE id=?\", (pid,))\n   237→    conn.commit()\n   238→    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n   239→    conn.close()\n   240→    if not row:\n   241→        return jsonify({\"error\": \"not found\"}), 404\n   242→    project = dict(row)\n   243→    get_dispatcher().start_loop(project)\n   244→    return jsonify(project_with_status(project))\n   245→\n   246→\n   247→# ── Git ──────────────────────────────────────────────────────────\n   248→\n   249→\n   250→@app.route(\"/api/projects/<pid>/git-status\", methods=[\"GET\"])\n   251→def git_status(pid):\n   252→    conn = get_db()\n   253→    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n   254→    conn.close()\n   255→    if not row:\n   256→        return jsonify({\"error\": \"not found\"}), 404\n   257→\n   258→    path = row[\"path\"]\n   259→    if not os.path.exists(os.path.join(path, \".git\")):\n   260→        return jsonify({\"has_git\": False})\n   261→\n   262→    result: dict = {\"has_git\": True}\n   263→\n   264→    remote_url, _, rc = run_git(path, \"remote\", \"get-url\", \"origin\")\n   265→    result[\"remote\"] = remote_url if rc == 0 else \"\"\n   266→\n   267→    # Fetch quietly to refresh remote refs\n   268→    run_git(path, \"fetch\", \"--quiet\")\n   269→\n   270→    # Unpushed commits\n   271→    unpushed, _, rc = run_git(path, \"rev-list\", \"--count\", \"@{u}..HEAD\")\n   272→    if rc == 0 and unpushed.isdigit():\n   273→        result[\"unpushed_commits\"] = int(unpushed)\n   274→    else:\n   275→        result[\"unpushed_commits\"] = 0\n   276→\n   277→    # Last push time — look at most recent commit on origin/HEAD or origin/main\n   278→    for ref in (\"origin/HEAD\", \"origin/main\", \"origin/master\"):\n   279→        last_push, _, rc = run_git(path, \"log\", \"-1\", \"--format=%ci\", ref)\n   280→        if rc == 0 and last_push:\n   281→            result[\"last_push\"] = last_push\n   282→            break\n   283→    else:\n   284→        result[\"last_push\"] = \"\"\n   285→\n   286→    # Current branch\n   287→    branch, _, _ = run_git(path, \"branch\", \"--show-current\")\n   288→    result[\"branch\"] = branch\n   289→\n   290→    # Working-tree status\n   291→    status_out, _, _ = run_git(path, \"status\", \"--short\")\n   292→    result[\"dirty\"] = bool(status_out)\n   293→    result[\"status_lines\"] = status_out.splitlines() if status_out else []\n   294→\n   295→    return jsonify(result)\n   296→\n   297→\n   298→@app.route(\"/api/projects/<pid>/push\", methods=[\"POST\"])\n   299→def manual_push(pid):\n   300→    conn = get_db()\n   301→    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n   302→    conn.close()\n   303→    if not row:\n   304→        return jsonify({\"error\": \"not found\"}), 404\n   305→\n   306→    branch, _, _ = run_git(row[\"path\"], \"branch\", \"--show-current\")\n   307→    out, err, rc = run_git(row[\"path\"], \"push\", \"origin\", branch or \"HEAD\")\n   308→    return jsonify({\"success\": rc == 0, \"output\": out or err})\n   309→\n   310→\n   311→# ── Logs ─────────────────────────────────────────────────────────\n   312→\n   313→\n   314→@app.route(\"/api/projects/<pid>/logs\", methods=[\"GET\"])\n   315→def get_logs(pid):\n   316→    log_path = os.path.join(LOGS_DIR, f\"{pid}.log\")\n   317→    lines_limit = request.args.get(\"lines\", 300, type=int)\n   318→\n   319→    if not os.path.exists(log_path):\n   320→        return jsonify({\"logs\": \"\", \"total_lines\": 0})\n   321→\n   322→    with open(log_path, \"r\", errors=\"replace\") as fh:\n   323→        all_lines = fh.readlines()\n   324→\n   325→    return jsonify(\n   326→        {\n   327→            \"logs\": \"\".join(all_lines[-lines_limit:]),\n   328→            \"total_lines\": len(all_lines),\n   329→        }\n   330→    )\n   331→\n   332→\n   333→# ── Tasks ─────────────────────────────────────────────────────────\n   334→\n   335→\n   336→@app.route(\"/api/projects/<pid>/tasks\", methods=[\"GET\"])\n   337→def list_tasks(pid):\n   338→    conn = get_db()\n   339→    rows = conn.execute(\n   340→        \"SELECT * FROM tasks WHERE project_id=? ORDER BY created_at DESC\", (pid,)\n   341→    ).fetchall()\n   342→    conn.close()\n   343→    return jsonify([dict(r) for r in rows])\n   344→\n   345→\n   346→@app.route(\"/api/projects/<pid>/tasks\", methods=[\"POST\"])\n   347→def create_task(pid):\n   348→    data = request.get_json(force=True)\n   349→    title = (data.get(\"title\") or \"\").strip()\n   350→    if not title:\n   351→        return jsonify({\"error\": \"title is required\"}), 400\n   352→\n   353→    task_id = str(uuid.uuid4())\n   354→    conn = get_db()\n   355→    conn.execute(\n   356→        \"INSERT INTO tasks (id, project_id, title) VALUES (?,?,?)\",\n   357→        (task_id, pid, title),\n   358→    )\n   359→    conn.commit()\n   360→    task = dict(conn.execute(\"SELECT * FROM tasks WHERE id=?\", (task_id,)).fetchone())\n   361→    conn.close()\n   362→    return jsonify(task), 201\n   363→\n   364→\n   365→@app.route(\"/api/projects/<pid>/tasks/<tid>\", methods=[\"PUT\"])\n   366→def update_task(pid, tid):\n   367→    data = request.get_json(force=True)\n   368→    status = data.get(\"status\", \"pending\")\n   369→    conn = get_db()\n   370→    conn.execute(\n   371→        \"UPDATE tasks SET status=?, updated_at=strftime('%Y-%m-%dT%H:%M:%SZ','now') \"\n   372→        \"WHERE id=? AND project_id=?\",\n   373→        (status, tid, pid),\n   374→    )\n   375→    conn.commit()\n   376→    row = conn.execute(\"SELECT * FROM tasks WHERE id=?\", (tid,)).fetchone()\n   377→    conn.close()\n   378→    if not row:\n   379→        return jsonify({\"error\": \"not found\"}), 404\n   380→    return jsonify(dict(row))\n   381→\n   382→\n   383→@app.route(\"/api/projects/<pid>/tasks/<tid>\", methods=[\"DELETE\"])\n   384→def delete_task(pid, tid):\n   385→    conn = get_db()\n   386→    conn.execute(\"DELETE FROM tasks WHERE id=? AND project_id=?\", (tid, pid))\n   387→    conn.commit()\n   388→    conn.close()\n   389→    return \"\", 204\n   390→\n   391→\n   392→# ── Files ─────────────────────────────────────────────────────────\n   393→\n   394→\n   395→@app.route(\"/api/projects/<pid>/files\", methods=[\"GET\"])\n   396→def list_files(pid):\n   397→    conn = get_db()\n   398→    row = conn.execute(\"SELECT path FROM projects WHERE id=?\", (pid,)).fetchone()\n   399→    conn.close()\n   400→\n   401→    if not row or not os.path.exists(row[\"path\"]):\n   402→        return jsonify({\"files\": []})\n   403→\n   404→    base = row[\"path\"]\n   405→    IGNORE = {\".git\", \"__pycache__\", \"node_modules\", \".DS_Store\", \".venv\", \"venv\"}\n   406→    files = []\n   407→\n   408→    for root, dirs, filenames in os.walk(base):\n   409→        dirs[:] = [d for d in dirs if d not in IGNORE]\n   410→        for fn in filenames:\n   411→            full = os.path.join(root, fn)\n   412→            rel = os.path.relpath(full, base)\n   413→            try:\n   414→                st = os.stat(full)\n   415→                files.append(\n   416→                    {\n   417→                        \"path\": rel,\n   418→                        \"size\": st.st_size,\n   419→                        \"modified\": datetime.fromtimestamp(st.st_mtime).isoformat(),\n   420→                    }\n   421→                )\n   422→            except OSError:\n   423→                pass\n   424→\n   425→    files.sort(key=lambda f: f[\"path\"])\n   426→    return jsonify({\"files\": files})\n   427→\n   428→\n   429→# ── Dispatcher status ─────────────────────────────────────────────\n   430→\n   431→\n   432→@app.route(\"/api/dispatcher/status\", methods=[\"GET\"])\n   433→def dispatcher_status():\n   434→    return jsonify(get_dispatcher().get_all_statuses())\n   435→\n   436→\n   437→# ── Static / SPA ──────────────────────────────────────────────────\n   438→\n   439→\n   440→@app.route(\"/\")\n   441→def index():\n   442→    return send_from_directory(\"static\", \"index.html\")\n   443→\n   444→\n   445→# ── Entry point ───────────────────────────────────────────────────\n   446→\n   447→if __name__ == \"__main__\":\n   448→    os.makedirs(LOGS_DIR, exist_ok=True)\n   449→    os.makedirs(PROJECTS_BASE, exist_ok=True)\n   450→    init_db()\n   451→\n   452→    dispatcher = get_dispatcher()\n   453→    dispatcher.start_background()\n   454→\n   455→    port = int(os.environ.get(\"PORT\", 5000))\n   456→    app.run(host=\"0.0.0.0\", port=port, debug=False, use_reloader=False)\n   457→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"79d78bd6-4286-4a94-a36f-cb2dd76cb9a6","uuid":"549c6033-2986-4daa-a545-6df86b279976","tool_use_result":{"type":"text","file":{"filePath":"/home/ubuntu/my-project/app.py","content":"\"\"\"\napp.py — Ralph Project Management Backend\n\nREST API for managing projects and their Ralph Loops.\n\nEndpoints:\n  GET    /api/projects\n  POST   /api/projects\n  GET    /api/projects/<id>\n  PUT    /api/projects/<id>\n  POST   /api/projects/<id>/archive\n  POST   /api/projects/<id>/unarchive\n  GET    /api/projects/<id>/git-status\n  POST   /api/projects/<id>/push\n  GET    /api/projects/<id>/logs\n  GET    /api/projects/<id>/tasks\n  POST   /api/projects/<id>/tasks\n  PUT    /api/projects/<id>/tasks/<tid>\n  DELETE /api/projects/<id>/tasks/<tid>\n  GET    /api/projects/<id>/files\n  GET    /api/dispatcher/status\n\nEnvironment variables:\n  RALPH_DB            SQLite database path (default: projects.db)\n  RALPH_LOGS_DIR      Log file directory   (default: logs/)\n  RALPH_PROJECTS_DIR  Base dir for new projects (default: ~/ralph-projects)\n  PORT                HTTP port (default: 5000)\n\"\"\"\n\nimport os\nimport sqlite3\nimport subprocess\nimport uuid\nfrom datetime import datetime\n\nfrom flask import Flask, jsonify, request, send_from_directory\nfrom dispatcher import get_dispatcher\n\n# ── App setup ────────────────────────────────────────────────────\n\napp = Flask(__name__, static_folder=\"static\")\n\nDB_PATH = os.environ.get(\"RALPH_DB\", \"projects.db\")\nLOGS_DIR = os.environ.get(\"RALPH_LOGS_DIR\", \"logs\")\nPROJECTS_BASE = os.environ.get(\n    \"RALPH_PROJECTS_DIR\", os.path.expanduser(\"~/ralph-projects\")\n)\n\n# ── Database ─────────────────────────────────────────────────────\n\n\ndef get_db():\n    conn = sqlite3.connect(DB_PATH)\n    conn.row_factory = sqlite3.Row\n    conn.execute(\"PRAGMA journal_mode=WAL\")\n    return conn\n\n\ndef init_db():\n    conn = get_db()\n    conn.executescript(\n        \"\"\"\n        CREATE TABLE IF NOT EXISTS projects (\n            id          TEXT PRIMARY KEY,\n            name        TEXT NOT NULL,\n            description TEXT NOT NULL DEFAULT '',\n            path        TEXT NOT NULL,\n            git_remote  TEXT NOT NULL DEFAULT '',\n            auto_push   INTEGER NOT NULL DEFAULT 1,\n            status      TEXT NOT NULL DEFAULT 'active',\n            created_at  TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))\n        );\n\n        CREATE TABLE IF NOT EXISTS tasks (\n            id          TEXT PRIMARY KEY,\n            project_id  TEXT NOT NULL,\n            title       TEXT NOT NULL,\n            status      TEXT NOT NULL DEFAULT 'pending',\n            created_at  TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\n            updated_at  TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\n            FOREIGN KEY (project_id) REFERENCES projects(id)\n        );\n        \"\"\"\n    )\n    conn.commit()\n    conn.close()\n\n\n# ── Helpers ──────────────────────────────────────────────────────\n\n\ndef run_git(cwd: str, *args):\n    \"\"\"Run a git command; returns (stdout, stderr, returncode).\"\"\"\n    result = subprocess.run(\n        [\"git\"] + list(args),\n        cwd=cwd,\n        capture_output=True,\n        text=True,\n        timeout=30,\n    )\n    return result.stdout.strip(), result.stderr.strip(), result.returncode\n\n\ndef project_with_status(row: dict) -> dict:\n    row[\"loop_status\"] = get_dispatcher().get_loop_status(row[\"id\"])\n    return row\n\n\n# ── Projects ─────────────────────────────────────────────────────\n\n\n@app.route(\"/api/projects\", methods=[\"GET\"])\ndef list_projects():\n    conn = get_db()\n    rows = conn.execute(\n        \"SELECT * FROM projects ORDER BY created_at DESC\"\n    ).fetchall()\n    conn.close()\n    statuses = get_dispatcher().get_all_statuses()\n    result = []\n    for row in rows:\n        p = dict(row)\n        p[\"loop_status\"] = statuses.get(p[\"id\"], {\"running\": False})\n        result.append(p)\n    return jsonify(result)\n\n\n@app.route(\"/api/projects\", methods=[\"POST\"])\ndef create_project():\n    data = request.get_json(force=True)\n    name = (data.get(\"name\") or \"\").strip()\n    if not name:\n        return jsonify({\"error\": \"name is required\"}), 400\n\n    git_source = data.get(\"git_source\", \"new\")  # new | github | existing\n    git_remote = (data.get(\"git_remote\") or \"\").strip()\n    auto_push = 1 if data.get(\"auto_push\", True) else 0\n    description = (data.get(\"description\") or \"\").strip()\n\n    # Determine project path\n    if git_source == \"existing\":\n        path = os.path.expanduser((data.get(\"path\") or \"\").strip())\n        if not path:\n            return jsonify({\"error\": \"path is required for existing directory\"}), 400\n    else:\n        safe = name.lower().replace(\" \", \"-\").replace(\"/\", \"-\")\n        path = os.path.join(PROJECTS_BASE, safe)\n\n    os.makedirs(path, exist_ok=True)\n\n    # Git setup\n    if git_source == \"github\":\n        if not git_remote:\n            return jsonify({\"error\": \"git_remote is required for GitHub source\"}), 400\n        out, err, rc = run_git(path, \"clone\", git_remote, \".\")\n        if rc != 0:\n            return jsonify({\"error\": f\"git clone failed: {err}\"}), 400\n    elif git_source == \"new\":\n        if not os.path.exists(os.path.join(path, \".git\")):\n            run_git(path, \"init\")\n\n    project_id = str(uuid.uuid4())\n    conn = get_db()\n    conn.execute(\n        \"\"\"\n        INSERT INTO projects (id, name, description, path, git_remote, auto_push)\n        VALUES (?, ?, ?, ?, ?, ?)\n        \"\"\",\n        (project_id, name, description, path, git_remote, auto_push),\n    )\n    conn.commit()\n    project = dict(\n        conn.execute(\"SELECT * FROM projects WHERE id=?\", (project_id,)).fetchone()\n    )\n    conn.close()\n\n    # Start Ralph Loop for new active project\n    get_dispatcher().start_loop(project)\n\n    return jsonify(project_with_status(project)), 201\n\n\n@app.route(\"/api/projects/<pid>\", methods=[\"GET\"])\ndef get_project(pid):\n    conn = get_db()\n    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n    return jsonify(project_with_status(dict(row)))\n\n\n@app.route(\"/api/projects/<pid>\", methods=[\"PUT\"])\ndef update_project(pid):\n    data = request.get_json(force=True)\n    name = (data.get(\"name\") or \"\").strip()\n    if not name:\n        return jsonify({\"error\": \"name is required\"}), 400\n\n    conn = get_db()\n    conn.execute(\n        \"\"\"\n        UPDATE projects\n        SET name=?, description=?, git_remote=?, auto_push=?\n        WHERE id=?\n        \"\"\",\n        (\n            name,\n            (data.get(\"description\") or \"\").strip(),\n            (data.get(\"git_remote\") or \"\").strip(),\n            1 if data.get(\"auto_push\", True) else 0,\n            pid,\n        ),\n    )\n    conn.commit()\n    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n    return jsonify(project_with_status(dict(row)))\n\n\n@app.route(\"/api/projects/<pid>/archive\", methods=[\"POST\"])\ndef archive_project(pid):\n    conn = get_db()\n    conn.execute(\"UPDATE projects SET status='archived' WHERE id=?\", (pid,))\n    conn.commit()\n    conn.close()\n    get_dispatcher().stop_loop(pid)\n    return jsonify({\"status\": \"archived\"})\n\n\n@app.route(\"/api/projects/<pid>/unarchive\", methods=[\"POST\"])\ndef unarchive_project(pid):\n    conn = get_db()\n    conn.execute(\"UPDATE projects SET status='active' WHERE id=?\", (pid,))\n    conn.commit()\n    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n    project = dict(row)\n    get_dispatcher().start_loop(project)\n    return jsonify(project_with_status(project))\n\n\n# ── Git ──────────────────────────────────────────────────────────\n\n\n@app.route(\"/api/projects/<pid>/git-status\", methods=[\"GET\"])\ndef git_status(pid):\n    conn = get_db()\n    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n\n    path = row[\"path\"]\n    if not os.path.exists(os.path.join(path, \".git\")):\n        return jsonify({\"has_git\": False})\n\n    result: dict = {\"has_git\": True}\n\n    remote_url, _, rc = run_git(path, \"remote\", \"get-url\", \"origin\")\n    result[\"remote\"] = remote_url if rc == 0 else \"\"\n\n    # Fetch quietly to refresh remote refs\n    run_git(path, \"fetch\", \"--quiet\")\n\n    # Unpushed commits\n    unpushed, _, rc = run_git(path, \"rev-list\", \"--count\", \"@{u}..HEAD\")\n    if rc == 0 and unpushed.isdigit():\n        result[\"unpushed_commits\"] = int(unpushed)\n    else:\n        result[\"unpushed_commits\"] = 0\n\n    # Last push time — look at most recent commit on origin/HEAD or origin/main\n    for ref in (\"origin/HEAD\", \"origin/main\", \"origin/master\"):\n        last_push, _, rc = run_git(path, \"log\", \"-1\", \"--format=%ci\", ref)\n        if rc == 0 and last_push:\n            result[\"last_push\"] = last_push\n            break\n    else:\n        result[\"last_push\"] = \"\"\n\n    # Current branch\n    branch, _, _ = run_git(path, \"branch\", \"--show-current\")\n    result[\"branch\"] = branch\n\n    # Working-tree status\n    status_out, _, _ = run_git(path, \"status\", \"--short\")\n    result[\"dirty\"] = bool(status_out)\n    result[\"status_lines\"] = status_out.splitlines() if status_out else []\n\n    return jsonify(result)\n\n\n@app.route(\"/api/projects/<pid>/push\", methods=[\"POST\"])\ndef manual_push(pid):\n    conn = get_db()\n    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n\n    branch, _, _ = run_git(row[\"path\"], \"branch\", \"--show-current\")\n    out, err, rc = run_git(row[\"path\"], \"push\", \"origin\", branch or \"HEAD\")\n    return jsonify({\"success\": rc == 0, \"output\": out or err})\n\n\n# ── Logs ─────────────────────────────────────────────────────────\n\n\n@app.route(\"/api/projects/<pid>/logs\", methods=[\"GET\"])\ndef get_logs(pid):\n    log_path = os.path.join(LOGS_DIR, f\"{pid}.log\")\n    lines_limit = request.args.get(\"lines\", 300, type=int)\n\n    if not os.path.exists(log_path):\n        return jsonify({\"logs\": \"\", \"total_lines\": 0})\n\n    with open(log_path, \"r\", errors=\"replace\") as fh:\n        all_lines = fh.readlines()\n\n    return jsonify(\n        {\n            \"logs\": \"\".join(all_lines[-lines_limit:]),\n            \"total_lines\": len(all_lines),\n        }\n    )\n\n\n# ── Tasks ─────────────────────────────────────────────────────────\n\n\n@app.route(\"/api/projects/<pid>/tasks\", methods=[\"GET\"])\ndef list_tasks(pid):\n    conn = get_db()\n    rows = conn.execute(\n        \"SELECT * FROM tasks WHERE project_id=? ORDER BY created_at DESC\", (pid,)\n    ).fetchall()\n    conn.close()\n    return jsonify([dict(r) for r in rows])\n\n\n@app.route(\"/api/projects/<pid>/tasks\", methods=[\"POST\"])\ndef create_task(pid):\n    data = request.get_json(force=True)\n    title = (data.get(\"title\") or \"\").strip()\n    if not title:\n        return jsonify({\"error\": \"title is required\"}), 400\n\n    task_id = str(uuid.uuid4())\n    conn = get_db()\n    conn.execute(\n        \"INSERT INTO tasks (id, project_id, title) VALUES (?,?,?)\",\n        (task_id, pid, title),\n    )\n    conn.commit()\n    task = dict(conn.execute(\"SELECT * FROM tasks WHERE id=?\", (task_id,)).fetchone())\n    conn.close()\n    return jsonify(task), 201\n\n\n@app.route(\"/api/projects/<pid>/tasks/<tid>\", methods=[\"PUT\"])\ndef update_task(pid, tid):\n    data = request.get_json(force=True)\n    status = data.get(\"status\", \"pending\")\n    conn = get_db()\n    conn.execute(\n        \"UPDATE tasks SET status=?, updated_at=strftime('%Y-%m-%dT%H:%M:%SZ','now') \"\n        \"WHERE id=? AND project_id=?\",\n        (status, tid, pid),\n    )\n    conn.commit()\n    row = conn.execute(\"SELECT * FROM tasks WHERE id=?\", (tid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n    return jsonify(dict(row))\n\n\n@app.route(\"/api/projects/<pid>/tasks/<tid>\", methods=[\"DELETE\"])\ndef delete_task(pid, tid):\n    conn = get_db()\n    conn.execute(\"DELETE FROM tasks WHERE id=? AND project_id=?\", (tid, pid))\n    conn.commit()\n    conn.close()\n    return \"\", 204\n\n\n# ── Files ─────────────────────────────────────────────────────────\n\n\n@app.route(\"/api/projects/<pid>/files\", methods=[\"GET\"])\ndef list_files(pid):\n    conn = get_db()\n    row = conn.execute(\"SELECT path FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n\n    if not row or not os.path.exists(row[\"path\"]):\n        return jsonify({\"files\": []})\n\n    base = row[\"path\"]\n    IGNORE = {\".git\", \"__pycache__\", \"node_modules\", \".DS_Store\", \".venv\", \"venv\"}\n    files = []\n\n    for root, dirs, filenames in os.walk(base):\n        dirs[:] = [d for d in dirs if d not in IGNORE]\n        for fn in filenames:\n            full = os.path.join(root, fn)\n            rel = os.path.relpath(full, base)\n            try:\n                st = os.stat(full)\n                files.append(\n                    {\n                        \"path\": rel,\n                        \"size\": st.st_size,\n                        \"modified\": datetime.fromtimestamp(st.st_mtime).isoformat(),\n                    }\n                )\n            except OSError:\n                pass\n\n    files.sort(key=lambda f: f[\"path\"])\n    return jsonify({\"files\": files})\n\n\n# ── Dispatcher status ─────────────────────────────────────────────\n\n\n@app.route(\"/api/dispatcher/status\", methods=[\"GET\"])\ndef dispatcher_status():\n    return jsonify(get_dispatcher().get_all_statuses())\n\n\n# ── Static / SPA ──────────────────────────────────────────────────\n\n\n@app.route(\"/\")\ndef index():\n    return send_from_directory(\"static\", \"index.html\")\n\n\n# ── Entry point ───────────────────────────────────────────────────\n\nif __name__ == \"__main__\":\n    os.makedirs(LOGS_DIR, exist_ok=True)\n    os.makedirs(PROJECTS_BASE, exist_ok=True)\n    init_db()\n\n    dispatcher = get_dispatcher()\n    dispatcher.start_background()\n\n    port = int(os.environ.get(\"PORT\", 5000))\n    app.run(host=\"0.0.0.0\", port=port, debug=False, use_reloader=False)\n","numLines":457,"startLine":1,"totalLines":457}}}
