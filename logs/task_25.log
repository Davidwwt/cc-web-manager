{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011s6Rn4tAX4DdbEpGfTF2oN","type":"tool_result","content":"     1→<!DOCTYPE html>\n     2→<html lang=\"zh-CN\">\n     3→<head>\n     4→  <meta charset=\"UTF-8\" />\n     5→  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n     6→  <title>Ralph — 项目管理</title>\n     7→  <style>\n     8→    :root {\n     9→      --bg:      #0b0e1a;\n    10→      --card:    #131827;\n    11→      --card2:   #171d2e;\n    12→      --border:  rgba(255,255,255,0.07);\n    13→      --text:    #dde4f0;\n    14→      --muted:   #5a6480;\n    15→      --green:   #00c98b;\n    16→      --red:     #ff4d5e;\n    17→      --blue:    #60a5fa;\n    18→      --yellow:  #fbbf24;\n    19→      --purple:  #a78bfa;\n    20→    }\n    21→    * { box-sizing: border-box; margin: 0; padding: 0; }\n    22→    body {\n    23→      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n    24→      background: var(--bg);\n    25→      color: var(--text);\n    26→      min-height: 100vh;\n    27→    }\n    28→\n    29→    /* ── Header ── */\n    30→    header {\n    31→      background: rgba(13,16,30,0.95);\n    32→      backdrop-filter: blur(12px);\n    33→      border-bottom: 1px solid var(--border);\n    34→      padding: 0 1.5rem;\n    35→      height: 56px;\n    36→      display: flex;\n    37→      align-items: center;\n    38→      gap: 1.2rem;\n    39→      position: sticky;\n    40→      top: 0;\n    41→      z-index: 100;\n    42→    }\n    43→    .brand { display: flex; align-items: center; gap: 0.55rem; flex-shrink: 0; }\n    44→    .brand-icon {\n    45→      width: 30px; height: 30px;\n    46→      background: linear-gradient(135deg, #3b82f6, #7c3aed);\n    47→      border-radius: 7px;\n    48→      display: flex; align-items: center; justify-content: center;\n    49→      font-size: 14px; font-weight: 700; color: #fff;\n    50→    }\n    51→    .brand h1 { font-size: 1rem; font-weight: 700; letter-spacing: -0.01em; white-space: nowrap; }\n    52→\n    53→    .divider-v { width: 1px; height: 22px; background: var(--border); flex-shrink: 0; }\n    54→\n    55→    /* project selector */\n    56→    .project-select-wrap { display: flex; align-items: center; gap: 0.6rem; flex: 1; min-width: 0; }\n    57→    .project-select-label { font-size: 0.75rem; color: var(--muted); white-space: nowrap; flex-shrink: 0; }\n    58→    .project-select {\n    59→      background: var(--card2);\n    60→      border: 1px solid var(--border);\n    61→      color: var(--text);\n    62→      padding: 0.3rem 0.7rem;\n    63→      border-radius: 7px;\n    64→      font-size: 0.85rem;\n    65→      font-family: inherit;\n    66→      cursor: pointer;\n    67→      min-width: 180px;\n    68→      max-width: 320px;\n    69→      outline: none;\n    70→      transition: border-color 0.15s;\n    71→    }\n    72→    .project-select:focus { border-color: rgba(96,165,250,0.5); }\n    73→    .project-select option { background: #1a2035; }\n    74→\n    75→    .header-right { display: flex; align-items: center; gap: 0.7rem; margin-left: auto; flex-shrink: 0; }\n    76→    .loop-badge {\n    77→      display: flex; align-items: center; gap: 0.35rem;\n    78→      font-size: 0.72rem; color: var(--muted);\n    79→      background: var(--card2);\n    80→      border: 1px solid var(--border);\n    81→      padding: 0.25rem 0.6rem;\n    82→      border-radius: 20px;\n    83→    }\n    84→    .loop-dot {\n    85→      width: 7px; height: 7px; border-radius: 50%;\n    86→      background: var(--muted);\n    87→      transition: background 0.3s;\n    88→    }\n    89→    .loop-dot.running { background: var(--green); box-shadow: 0 0 5px var(--green); animation: pulse 2s infinite; }\n    90→    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }\n    91→\n    92→    .btn-sm {\n    93→      background: rgba(96,165,250,0.1);\n    94→      border: 1px solid rgba(96,165,250,0.25);\n    95→      color: var(--blue);\n    96→      padding: 0.28rem 0.75rem;\n    97→      border-radius: 6px;\n    98→      cursor: pointer;\n    99→      font-size: 0.78rem;\n   100→      font-family: inherit;\n   101→      transition: background 0.15s;\n   102→      white-space: nowrap;\n   103→    }\n   104→    .btn-sm:hover { background: rgba(96,165,250,0.18); }\n   105→    .btn-sm:disabled { opacity: 0.45; cursor: not-allowed; }\n   106→    .btn-sm.danger { background: rgba(255,77,94,0.1); border-color: rgba(255,77,94,0.25); color: var(--red); }\n   107→    .btn-sm.danger:hover { background: rgba(255,77,94,0.18); }\n   108→    .btn-sm.success { background: rgba(0,201,139,0.1); border-color: rgba(0,201,139,0.25); color: var(--green); }\n   109→    .btn-sm.success:hover { background: rgba(0,201,139,0.18); }\n   110→\n   111→    /* ── Empty state ── */\n   112→    #no-project {\n   113→      display: flex; flex-direction: column; align-items: center;\n   114→      justify-content: center; height: calc(100vh - 56px);\n   115→      gap: 0.8rem; color: var(--muted);\n   116→    }\n   117→    #no-project h2 { font-size: 1.1rem; font-weight: 600; color: var(--text); }\n   118→    #no-project p { font-size: 0.85rem; }\n   119→\n   120→    /* ── Layout ── */\n   121→    #app { display: none; flex-direction: column; height: calc(100vh - 56px); }\n   122→\n   123→    /* ── Tabs ── */\n   124→    .tabs {\n   125→      display: flex; gap: 0;\n   126→      border-bottom: 1px solid var(--border);\n   127→      background: rgba(13,16,30,0.6);\n   128→      padding: 0 1.2rem;\n   129→      flex-shrink: 0;\n   130→    }\n   131→    .tab {\n   132→      padding: 0.65rem 1rem;\n   133→      font-size: 0.82rem;\n   134→      font-weight: 500;\n   135→      color: var(--muted);\n   136→      cursor: pointer;\n   137→      border-bottom: 2px solid transparent;\n   138→      margin-bottom: -1px;\n   139→      transition: color 0.15s;\n   140→      user-select: none;\n   141→    }\n   142→    .tab:hover { color: var(--text); }\n   143→    .tab.active { color: var(--blue); border-bottom-color: var(--blue); }\n   144→\n   145→    .tab-content { flex: 1; overflow: hidden; }\n   146→    .tab-pane { display: none; height: 100%; overflow: auto; padding: 1.2rem 1.4rem 2rem; }\n   147→    .tab-pane.active { display: block; }\n   148→\n   149→    /* ── Cards ── */\n   150→    .card {\n   151→      background: var(--card);\n   152→      border: 1px solid var(--border);\n   153→      border-radius: 12px;\n   154→      padding: 1.1rem 1.25rem;\n   155→      margin-bottom: 1rem;\n   156→    }\n   157→    .card-title {\n   158→      font-size: 0.78rem;\n   159→      font-weight: 600;\n   160→      color: var(--muted);\n   161→      text-transform: uppercase;\n   162→      letter-spacing: 0.05em;\n   163→      margin-bottom: 0.85rem;\n   164→    }\n   165→\n   166→    /* ── Tasks ── */\n   167→    .task-input-row {\n   168→      display: flex; gap: 0.6rem; margin-bottom: 1rem;\n   169→    }\n   170→    .task-input {\n   171→      flex: 1;\n   172→      background: var(--card2);\n   173→      border: 1px solid var(--border);\n   174→      color: var(--text);\n   175→      padding: 0.45rem 0.8rem;\n   176→      border-radius: 7px;\n   177→      font-size: 0.85rem;\n   178→      font-family: inherit;\n   179→      outline: none;\n   180→      transition: border-color 0.15s;\n   181→    }\n   182→    .task-input:focus { border-color: rgba(96,165,250,0.5); }\n   183→\n   184→    .task-list { display: flex; flex-direction: column; gap: 0.45rem; }\n   185→    .task-item {\n   186→      display: flex; align-items: center; gap: 0.7rem;\n   187→      background: var(--card2);\n   188→      border: 1px solid var(--border);\n   189→      border-radius: 8px;\n   190→      padding: 0.55rem 0.8rem;\n   191→      transition: border-color 0.15s;\n   192→    }\n   193→    .task-item:hover { border-color: rgba(255,255,255,0.12); }\n   194→    .task-status-btn {\n   195→      flex-shrink: 0;\n   196→      width: 18px; height: 18px;\n   197→      border-radius: 50%;\n   198→      border: 2px solid var(--muted);\n   199→      background: transparent;\n   200→      cursor: pointer;\n   201→      display: flex; align-items: center; justify-content: center;\n   202→      transition: all 0.15s;\n   203→      font-size: 10px;\n   204→      color: transparent;\n   205→    }\n   206→    .task-status-btn:hover { border-color: var(--green); }\n   207→    .task-item.in_progress .task-status-btn { border-color: var(--yellow); }\n   208→    .task-item.done .task-status-btn { border-color: var(--green); background: rgba(0,201,139,0.15); color: var(--green); }\n   209→    .task-title-text {\n   210→      flex: 1;\n   211→      font-size: 0.85rem;\n   212→      line-height: 1.4;\n   213→    }\n   214→    .task-item.done .task-title-text { text-decoration: line-through; color: var(--muted); }\n   215→    .task-meta {\n   216→      font-size: 0.72rem;\n   217→      color: var(--muted);\n   218→      white-space: nowrap;\n   219→      flex-shrink: 0;\n   220→    }\n   221→    .task-status-tag {\n   222→      font-size: 0.68rem;\n   223→      font-weight: 600;\n   224→      padding: 0.12rem 0.42rem;\n   225→      border-radius: 4px;\n   226→      flex-shrink: 0;\n   227→    }\n   228→    .task-status-tag.pending     { background: rgba(90,100,128,0.2); color: var(--muted); }\n   229→    .task-status-tag.in_progress { background: rgba(251,191,36,0.12); color: var(--yellow); }\n   230→    .task-status-tag.done        { background: rgba(0,201,139,0.12); color: var(--green); }\n   231→    .task-del-btn {\n   232→      flex-shrink: 0;\n   233→      background: none;\n   234→      border: none;\n   235→      color: var(--muted);\n   236→      cursor: pointer;\n   237→      font-size: 14px;\n   238→      padding: 0 0.2rem;\n   239→      opacity: 0;\n   240→      transition: opacity 0.15s, color 0.15s;\n   241→    }\n   242→    .task-item:hover .task-del-btn { opacity: 1; }\n   243→    .task-del-btn:hover { color: var(--red); }\n   244→\n   245→    .empty-hint { font-size: 0.82rem; color: var(--muted); text-align: center; padding: 2rem; }\n   246→\n   247→    /* ── Task status cycle menu ── */\n   248→    .task-cycle-btn {\n   249→      flex-shrink: 0;\n   250→      background: none; border: none;\n   251→      font-size: 0.72rem; font-weight: 600;\n   252→      cursor: pointer;\n   253→      padding: 0.12rem 0.42rem;\n   254→      border-radius: 4px;\n   255→      transition: opacity 0.15s;\n   256→    }\n   257→    .task-cycle-btn:hover { opacity: 0.75; }\n   258→\n   259→    /* ── Logs ── */\n   260→    .log-controls {\n   261→      display: flex; align-items: center; gap: 0.7rem; margin-bottom: 0.8rem; flex-wrap: wrap;\n   262→    }\n   263→    .log-controls label { font-size: 0.78rem; color: var(--muted); display: flex; align-items: center; gap: 0.4rem; }\n   264→    .log-controls input[type=checkbox] { accent-color: var(--blue); }\n   265→    .log-lines-select {\n   266→      background: var(--card2); border: 1px solid var(--border);\n   267→      color: var(--text); padding: 0.25rem 0.5rem; border-radius: 5px;\n   268→      font-size: 0.78rem; font-family: inherit; outline: none;\n   269→    }\n   270→    .log-box {\n   271→      background: #080a12;\n   272→      border: 1px solid var(--border);\n   273→      border-radius: 8px;\n   274→      padding: 0.9rem 1rem;\n   275→      font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;\n   276→      font-size: 0.75rem;\n   277→      line-height: 1.55;\n   278→      color: #a8b4c8;\n   279→      white-space: pre-wrap;\n   280→      word-break: break-all;\n   281→      max-height: calc(100vh - 280px);\n   282→      overflow-y: auto;\n   283→    }\n   284→    .log-box .log-empty { color: var(--muted); }\n   285→\n   286→    /* ── Files ── */\n   287→    .files-search-row { display: flex; gap: 0.6rem; margin-bottom: 0.8rem; }\n   288→    .files-search {\n   289→      flex: 1; background: var(--card2); border: 1px solid var(--border);\n   290→      color: var(--text); padding: 0.38rem 0.75rem; border-radius: 7px;\n   291→      font-size: 0.82rem; font-family: inherit; outline: none;\n   292→    }\n   293→    .files-search:focus { border-color: rgba(96,165,250,0.4); }\n   294→    .file-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }\n   295→    .file-table th {\n   296→      text-align: left; padding: 0.4rem 0.6rem;\n   297→      font-size: 0.7rem; font-weight: 600; color: var(--muted);\n   298→      text-transform: uppercase; letter-spacing: 0.04em;\n   299→      border-bottom: 1px solid var(--border);\n   300→    }\n   301→    .file-table td { padding: 0.38rem 0.6rem; border-bottom: 1px solid rgba(255,255,255,0.03); }\n   302→    .file-table tr:hover td { background: rgba(255,255,255,0.02); }\n   303→    .file-path { color: var(--blue); font-family: monospace; font-size: 0.78rem; }\n   304→    .file-size { color: var(--muted); white-space: nowrap; }\n   305→    .file-mtime { color: var(--muted); white-space: nowrap; font-size: 0.72rem; }\n   306→\n   307→    /* ── Status ── */\n   308→    .status-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0.9rem; }\n   309→    .stat-block {\n   310→      background: var(--card2); border: 1px solid var(--border);\n   311→      border-radius: 9px; padding: 0.9rem 1rem;\n   312→    }\n   313→    .stat-label { font-size: 0.7rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.4rem; }\n   314→    .stat-value { font-size: 0.9rem; font-weight: 600; word-break: break-all; }\n   315→    .stat-value.green { color: var(--green); }\n   316→    .stat-value.red   { color: var(--red); }\n   317→    .stat-value.muted { color: var(--muted); font-weight: 400; }\n   318→\n   319→    .git-status-lines {\n   320→      font-family: monospace; font-size: 0.75rem; line-height: 1.6;\n   321→      color: var(--muted); margin-top: 0.5rem;\n   322→    }\n   323→    .git-status-lines span { display: block; }\n   324→    .git-status-lines .M { color: var(--yellow); }\n   325→    .git-status-lines .A { color: var(--green); }\n   326→    .git-status-lines .D { color: var(--red); }\n   327→    .git-status-lines .Q { color: var(--muted); }\n   328→\n   329→    /* ── Spinner ── */\n   330→    .spinner {\n   331→      display: inline-block; width: 16px; height: 16px;\n   332→      border: 2px solid var(--border); border-top-color: var(--blue);\n   333→      border-radius: 50%; animation: spin 0.6s linear infinite;\n   334→    }\n   335→    @keyframes spin { to { transform: rotate(360deg); } }\n   336→\n   337→    /* ── Toast ── */\n   338→    #toast {\n   339→      position: fixed; bottom: 1.5rem; right: 1.5rem;\n   340→      background: var(--card); border: 1px solid var(--border);\n   341→      padding: 0.6rem 1rem; border-radius: 8px;\n   342→      font-size: 0.82rem; color: var(--text);\n   343→      box-shadow: 0 4px 20px rgba(0,0,0,0.4);\n   344→      opacity: 0; transform: translateY(8px);\n   345→      transition: opacity 0.2s, transform 0.2s;\n   346→      pointer-events: none; z-index: 999;\n   347→    }\n   348→    #toast.show { opacity: 1; transform: translateY(0); }\n   349→\n   350→    /* ── Scrollbar ── */\n   351→    ::-webkit-scrollbar { width: 6px; height: 6px; }\n   352→    ::-webkit-scrollbar-track { background: transparent; }\n   353→    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }\n   354→  </style>\n   355→</head>\n   356→<body>\n   357→\n   358→<header>\n   359→  <div class=\"brand\">\n   360→    <div class=\"brand-icon\">R</div>\n   361→    <h1>Ralph</h1>\n   362→  </div>\n   363→  <div class=\"divider-v\"></div>\n   364→  <div class=\"project-select-wrap\">\n   365→    <span class=\"project-select-label\">项目</span>\n   366→    <select class=\"project-select\" id=\"project-select\" onchange=\"onProjectChange(this.value)\">\n   367→      <option value=\"\">— 选择项目 —</option>\n   368→    </select>\n   369→  </div>\n   370→  <div class=\"header-right\">\n   371→    <div class=\"loop-badge\" id=\"loop-badge\">\n   372→      <div class=\"loop-dot\" id=\"loop-dot\"></div>\n   373→      <span id=\"loop-label\">未选择</span>\n   374→    </div>\n   375→    <button class=\"btn-sm\" id=\"btn-refresh\" onclick=\"refreshCurrent()\" title=\"刷新当前视图\">刷新</button>\n   376→  </div>\n   377→</header>\n   378→\n   379→<div id=\"no-project\">\n   380→  <h2>暂无项目</h2>\n   381→  <p>请通过 API 创建项目，或选择已有项目</p>\n   382→</div>\n   383→\n   384→<div id=\"app\">\n   385→  <div class=\"tabs\">\n   386→    <div class=\"tab active\" data-tab=\"tasks\" onclick=\"switchTab('tasks')\">任务</div>\n   387→    <div class=\"tab\" data-tab=\"logs\"  onclick=\"switchTab('logs')\">日志</div>\n   388→    <div class=\"tab\" data-tab=\"files\" onclick=\"switchTab('files')\">文件</div>\n   389→    <div class=\"tab\" data-tab=\"status\" onclick=\"switchTab('status')\">状态</div>\n   390→  </div>\n   391→  <div class=\"tab-content\">\n   392→\n   393→    <!-- Tasks -->\n   394→    <div class=\"tab-pane active\" id=\"pane-tasks\">\n   395→      <div class=\"task-input-row\">\n   396→        <input class=\"task-input\" id=\"new-task-input\" placeholder=\"添加新任务…\" onkeydown=\"onTaskKeydown(event)\" />\n   397→        <button class=\"btn-sm success\" onclick=\"addTask()\">+ 添加</button>\n   398→      </div>\n   399→      <div class=\"task-list\" id=\"task-list\">\n   400→        <div class=\"empty-hint\"><div class=\"spinner\"></div></div>\n   401→      </div>\n   402→    </div>\n   403→\n   404→    <!-- Logs -->\n   405→    <div class=\"tab-pane\" id=\"pane-logs\">\n   406→      <div class=\"log-controls\">\n   407→        <label>\n   408→          <input type=\"checkbox\" id=\"log-auto\" onchange=\"onLogAutoChange()\" />\n   409→          自动刷新 (5s)\n   410→        </label>\n   411→        <label>\n   412→          最近\n   413→          <select class=\"log-lines-select\" id=\"log-lines\" onchange=\"loadLogs()\">\n   414→            <option value=\"100\">100 行</option>\n   415→            <option value=\"300\" selected>300 行</option>\n   416→            <option value=\"500\">500 行</option>\n   417→            <option value=\"1000\">1000 行</option>\n   418→          </select>\n   419→        </label>\n   420→        <button class=\"btn-sm\" onclick=\"loadLogs()\">刷新</button>\n   421→        <span id=\"log-total\" style=\"font-size:0.75rem;color:var(--muted)\"></span>\n   422→      </div>\n   423→      <div class=\"log-box\" id=\"log-box\"><span class=\"log-empty\">加载中…</span></div>\n   424→    </div>\n   425→\n   426→    <!-- Files -->\n   427→    <div class=\"tab-pane\" id=\"pane-files\">\n   428→      <div class=\"files-search-row\">\n   429→        <input class=\"files-search\" id=\"files-search\" placeholder=\"搜索文件…\" oninput=\"renderFiles()\" />\n   430→        <button class=\"btn-sm\" onclick=\"loadFiles()\">刷新</button>\n   431→      </div>\n   432→      <table class=\"file-table\" id=\"file-table\">\n   433→        <thead><tr><th>路径</th><th>大小</th><th>修改时间</th></tr></thead>\n   434→        <tbody id=\"file-tbody\"></tbody>\n   435→      </table>\n   436→    </div>\n   437→\n   438→    <!-- Status -->\n   439→    <div class=\"tab-pane\" id=\"pane-status\">\n   440→      <div id=\"status-content\">\n   441→        <div class=\"empty-hint\"><div class=\"spinner\"></div></div>\n   442→      </div>\n   443→    </div>\n   444→\n   445→  </div>\n   446→</div>\n   447→\n   448→<div id=\"toast\"></div>\n   449→\n   450→<script>\n   451→// ─── State ────────────────────────────────────────────────────────────────────\n   452→const LS_KEY = 'ralph_selected_project';\n   453→let projects = [];\n   454→let currentId = localStorage.getItem(LS_KEY) || '';\n   455→let currentTab = 'tasks';\n   456→let allFiles = [];\n   457→let logAutoTimer = null;\n   458→let statusRefreshTimer = null;\n   459→\n   460→// ─── Init ─────────────────────────────────────────────────────────────────────\n   461→async function init() {\n   462→  await loadProjects();\n   463→  const stored = currentId;\n   464→  if (stored && projects.find(p => p.id === stored)) {\n   465→    setProject(stored);\n   466→  } else if (projects.length > 0) {\n   467→    setProject(projects[0].id);\n   468→  } else {\n   469→    showNoProject();\n   470→  }\n   471→}\n   472→\n   473→// ─── Projects ─────────────────────────────────────────────────────────────────\n   474→async function loadProjects() {\n   475→  try {\n   476→    const r = await fetch('/api/projects');\n   477→    projects = await r.json();\n   478→  } catch { projects = []; }\n   479→  renderProjectSelect();\n   480→}\n   481→\n   482→function renderProjectSelect() {\n   483→  const sel = document.getElementById('project-select');\n   484→  sel.innerHTML = '<option value=\"\">— 选择项目 —</option>';\n   485→  projects.forEach(p => {\n   486→    const opt = document.createElement('option');\n   487→    opt.value = p.id;\n   488→    opt.textContent = p.name + (p.status === 'archived' ? ' (已归档)' : '');\n   489→    sel.appendChild(opt);\n   490→  });\n   491→  sel.value = currentId || '';\n   492→}\n   493→\n   494→function onProjectChange(id) {\n   495→  if (id) setProject(id);\n   496→  else showNoProject();\n   497→}\n   498→\n   499→function setProject(id) {\n   500→  currentId = id;\n   501→  localStorage.setItem(LS_KEY, id);\n   502→  document.getElementById('project-select').value = id;\n   503→  document.getElementById('no-project').style.display = 'none';\n   504→  document.getElementById('app').style.display = 'flex';\n   505→  stopAllAutoRefresh();\n   506→  loadCurrentTab();\n   507→  updateLoopBadge();\n   508→}\n   509→\n   510→function showNoProject() {\n   511→  document.getElementById('no-project').style.display = 'flex';\n   512→  document.getElementById('app').style.display = 'none';\n   513→  updateLoopBadge();\n   514→}\n   515→\n   516→// ─── Tabs ─────────────────────────────────────────────────────────────────────\n   517→function switchTab(tab) {\n   518→  stopAllAutoRefresh();\n   519→  currentTab = tab;\n   520→  document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === tab));\n   521→  document.querySelectorAll('.tab-pane').forEach(p => p.classList.toggle('active', p.id === `pane-${tab}`));\n   522→  loadCurrentTab();\n   523→}\n   524→\n   525→function loadCurrentTab() {\n   526→  if (!currentId) return;\n   527→  if (currentTab === 'tasks')  loadTasks();\n   528→  if (currentTab === 'logs')   loadLogs();\n   529→  if (currentTab === 'files')  loadFiles();\n   530→  if (currentTab === 'status') loadStatus();\n   531→}\n   532→\n   533→function refreshCurrent() {\n   534→  loadProjects().then(() => {\n   535→    if (currentId) {\n   536→      loadCurrentTab();\n   537→      updateLoopBadge();\n   538→    }\n   539→  });\n   540→}\n   541→\n   542→// ─── Tasks ────────────────────────────────────────────────────────────────────\n   543→async function loadTasks() {\n   544→  const list = document.getElementById('task-list');\n   545→  list.innerHTML = '<div class=\"empty-hint\"><div class=\"spinner\"></div></div>';\n   546→  try {\n   547→    const r = await fetch(`/api/projects/${currentId}/tasks`);\n   548→    const tasks = await r.json();\n   549→    renderTasks(tasks);\n   550→  } catch {\n   551→    list.innerHTML = '<div class=\"empty-hint\" style=\"color:var(--red)\">加载失败</div>';\n   552→  }\n   553→}\n   554→\n   555→const STATUS_CYCLE = { pending: 'in_progress', in_progress: 'done', done: 'pending' };\n   556→const STATUS_LABEL = { pending: '待处理', in_progress: '进行中', done: '已完成' };\n   557→const STATUS_CLASS = { pending: 'pending', in_progress: 'in_progress', done: 'done' };\n   558→\n   559→function renderTasks(tasks) {\n   560→  const list = document.getElementById('task-list');\n   561→  if (!tasks.length) {\n   562→    list.innerHTML = '<div class=\"empty-hint\">暂无任务，添加第一个吧</div>';\n   563→    return;\n   564→  }\n   565→  list.innerHTML = '';\n   566→  tasks.forEach(t => {\n   567→    const item = document.createElement('div');\n   568→    item.className = `task-item ${t.status}`;\n   569→    item.dataset.id = t.id;\n   570→\n   571→    const checkmark = t.status === 'done' ? '✓' : (t.status === 'in_progress' ? '…' : '');\n   572→    const tagCls = STATUS_CLASS[t.status] || 'pending';\n   573→    const tagLabel = STATUS_LABEL[t.status] || t.status;\n   574→    const nextStatus = STATUS_CYCLE[t.status] || 'pending';\n   575→\n   576→    item.innerHTML = `\n   577→      <button class=\"task-status-btn\" onclick=\"cycleTaskStatus('${t.id}','${nextStatus}')\" title=\"切换状态\">${checkmark}</button>\n   578→      <span class=\"task-title-text\">${escHtml(t.title)}</span>\n   579→      <span class=\"task-status-tag ${tagCls}\" onclick=\"cycleTaskStatus('${t.id}','${nextStatus}')\" style=\"cursor:pointer\" title=\"切换到: ${STATUS_LABEL[nextStatus]}\">${tagLabel}</span>\n   580→      <button class=\"task-del-btn\" onclick=\"deleteTask('${t.id}')\" title=\"删除\">✕</button>\n   581→    `;\n   582→    list.appendChild(item);\n   583→  });\n   584→}\n   585→\n   586→async function addTask() {\n   587→  const input = document.getElementById('new-task-input');\n   588→  const title = input.value.trim();\n   589→  if (!title) return;\n   590→  input.value = '';\n   591→  try {\n   592→    await fetch(`/api/projects/${currentId}/tasks`, {\n   593→      method: 'POST',\n   594→      headers: { 'Content-Type': 'application/json' },\n   595→      body: JSON.stringify({ title }),\n   596→    });\n   597→    loadTasks();\n   598→    showToast('任务已添加');\n   599→  } catch {\n   600→    showToast('添加失败', true);\n   601→  }\n   602→}\n   603→\n   604→function onTaskKeydown(e) {\n   605→  if (e.key === 'Enter') addTask();\n   606→}\n   607→\n   608→async function cycleTaskStatus(tid, nextStatus) {\n   609→  try {\n   610→    await fetch(`/api/projects/${currentId}/tasks/${tid}`, {\n   611→      method: 'PUT',\n   612→      headers: { 'Content-Type': 'application/json' },\n   613→      body: JSON.stringify({ status: nextStatus }),\n   614→    });\n   615→    loadTasks();\n   616→  } catch {\n   617→    showToast('更新失败', true);\n   618→  }\n   619→}\n   620→\n   621→async function deleteTask(tid) {\n   622→  if (!confirm('确认删除此任务？')) return;\n   623→  try {\n   624→    await fetch(`/api/projects/${currentId}/tasks/${tid}`, { method: 'DELETE' });\n   625→    loadTasks();\n   626→    showToast('任务已删除');\n   627→  } catch {\n   628→    showToast('删除失败', true);\n   629→  }\n   630→}\n   631→\n   632→// ─── Logs ─────────────────────────────────────────────────────────────────────\n   633→async function loadLogs() {\n   634→  const lines = document.getElementById('log-lines').value;\n   635→  const box = document.getElementById('log-box');\n   636→  try {\n   637→    const r = await fetch(`/api/projects/${currentId}/logs?lines=${lines}`);\n   638→    const d = await r.json();\n   639→    const atBottom = box.scrollHeight - box.scrollTop - box.clientHeight < 60;\n   640→    box.textContent = d.logs || '';\n   641→    if (!d.logs) box.innerHTML = '<span class=\"log-empty\">暂无日志</span>';\n   642→    document.getElementById('log-total').textContent = `共 ${d.total_lines || 0} 行`;\n   643→    if (atBottom) box.scrollTop = box.scrollHeight;\n   644→  } catch {\n   645→    box.innerHTML = '<span style=\"color:var(--red)\">加载失败</span>';\n   646→  }\n   647→}\n   648→\n   649→function onLogAutoChange() {\n   650→  const checked = document.getElementById('log-auto').checked;\n   651→  clearInterval(logAutoTimer);\n   652→  if (checked) logAutoTimer = setInterval(loadLogs, 5000);\n   653→}\n   654→\n   655→// ─── Files ────────────────────────────────────────────────────────────────────\n   656→async function loadFiles() {\n   657→  const tbody = document.getElementById('file-tbody');\n   658→  tbody.innerHTML = '<tr><td colspan=\"3\" class=\"empty-hint\"><div class=\"spinner\"></div></td></tr>';\n   659→  try {\n   660→    const r = await fetch(`/api/projects/${currentId}/files`);\n   661→    const d = await r.json();\n   662→    allFiles = d.files || [];\n   663→    renderFiles();\n   664→  } catch {\n   665→    tbody.innerHTML = '<tr><td colspan=\"3\" style=\"color:var(--red);padding:0.6rem\">加载失败</td></tr>';\n   666→  }\n   667→}\n   668→\n   669→function renderFiles() {\n   670→  const q = document.getElementById('files-search').value.toLowerCase();\n   671→  const files = q ? allFiles.filter(f => f.path.toLowerCase().includes(q)) : allFiles;\n   672→  const tbody = document.getElementById('file-tbody');\n   673→  if (!files.length) {\n   674→    tbody.innerHTML = '<tr><td colspan=\"3\" class=\"empty-hint\">无文件</td></tr>';\n   675→    return;\n   676→  }\n   677→  tbody.innerHTML = files.map(f => `\n   678→    <tr>\n   679→      <td class=\"file-path\">${escHtml(f.path)}</td>\n   680→      <td class=\"file-size\">${fmtSize(f.size)}</td>\n   681→      <td class=\"file-mtime\">${fmtTime(f.modified)}</td>\n   682→    </tr>\n   683→  `).join('');\n   684→}\n   685→\n   686→// ─── Status ───────────────────────────────────────────────────────────────────\n   687→async function loadStatus() {\n   688→  const cont = document.getElementById('status-content');\n   689→  cont.innerHTML = '<div class=\"empty-hint\"><div class=\"spinner\"></div></div>';\n   690→  try {\n   691→    const proj = projects.find(p => p.id === currentId);\n   692→    const [gitR, dispR] = await Promise.all([\n   693→      fetch(`/api/projects/${currentId}/git-status`).then(r => r.json()).catch(() => ({})),\n   694→      fetch('/api/dispatcher/status').then(r => r.json()).catch(() => ({})),\n   695→    ]);\n   696→    const loop = dispR[currentId] || { running: false };\n   697→    renderStatus(proj, gitR, loop);\n   698→    updateLoopBadgeFromLoop(loop);\n   699→  } catch {\n   700→    cont.innerHTML = '<div class=\"empty-hint\" style=\"color:var(--red)\">加载失败</div>';\n   701→  }\n   702→}\n   703→\n   704→function renderStatus(proj, git, loop) {\n   705→  const cont = document.getElementById('status-content');\n   706→\n   707→  const loopRunning = loop.running;\n   708→  const loopColor = loopRunning ? 'green' : 'red';\n   709→  const loopText  = loopRunning ? `运行中 (PID ${loop.pid})` : '已停止';\n   710→\n   711→  let gitSection = '';\n   712→  if (git.has_git === false) {\n   713→    gitSection = `<div class=\"stat-block\"><div class=\"stat-label\">Git</div><div class=\"stat-value muted\">未初始化</div></div>`;\n   714→  } else if (git.has_git) {\n   715→    const dirty = git.dirty ? '<span style=\"color:var(--yellow)\">有未提交变更</span>' : '<span style=\"color:var(--green)\">干净</span>';\n   716→    const unpushed = git.unpushed_commits || 0;\n   717→    const statusHtml = (git.status_lines || []).map(l => {\n   718→      const cls = l.startsWith('M') ? 'M' : l.startsWith('A') ? 'A' : l.startsWith('D') ? 'D' : 'Q';\n   719→      return `<span class=\"${cls}\">${escHtml(l)}</span>`;\n   720→    }).join('');\n   721→    gitSection = `\n   722→      <div class=\"stat-block\">\n   723→        <div class=\"stat-label\">分支</div>\n   724→        <div class=\"stat-value\">${escHtml(git.branch || '—')}</div>\n   725→      </div>\n   726→      <div class=\"stat-block\">\n   727→        <div class=\"stat-label\">工作区</div>\n   728→        <div class=\"stat-value\">${dirty}${statusHtml ? '<div class=\"git-status-lines\">' + statusHtml + '</div>' : ''}</div>\n   729→      </div>\n   730→      <div class=\"stat-block\">\n   731→        <div class=\"stat-label\">未推送提交</div>\n   732→        <div class=\"stat-value ${unpushed ? 'yellow' : 'green'}\" style=\"${unpushed ? 'color:var(--yellow)' : ''}\">${unpushed}</div>\n   733→      </div>\n   734→      <div class=\"stat-block\">\n   735→        <div class=\"stat-label\">远程仓库</div>\n   736→        <div class=\"stat-value muted\" style=\"font-size:0.8rem\">${escHtml(git.remote || '—')}</div>\n   737→      </div>\n   738→      <div class=\"stat-block\">\n   739→        <div class=\"stat-label\">上次推送</div>\n   740→        <div class=\"stat-value muted\">${git.last_push ? fmtTime(git.last_push) : '—'}</div>\n   741→      </div>\n   742→    `;\n   743→  }\n   744→\n   745→  cont.innerHTML = `\n   746→    <div style=\"display:flex;gap:0.7rem;flex-wrap:wrap;margin-bottom:1.2rem\">\n   747→      <button class=\"btn-sm\" onclick=\"loadStatus()\">刷新状态</button>\n   748→      ${git.has_git ? `<button class=\"btn-sm success\" id=\"btn-push\" onclick=\"pushProject()\">推送到远程</button>` : ''}\n   749→    </div>\n   750→    <div class=\"status-grid\">\n   751→      <div class=\"stat-block\">\n   752→        <div class=\"stat-label\">项目名称</div>\n   753→        <div class=\"stat-value\">${escHtml(proj ? proj.name : currentId)}</div>\n   754→      </div>\n   755→      <div class=\"stat-block\">\n   756→        <div class=\"stat-label\">项目状态</div>\n   757→        <div class=\"stat-value ${proj && proj.status === 'active' ? 'green' : 'muted'}\">${proj ? proj.status : '—'}</div>\n   758→      </div>\n   759→      <div class=\"stat-block\">\n   760→        <div class=\"stat-label\">Ralph Loop</div>\n   761→        <div class=\"stat-value ${loopColor}\">${loopText}</div>\n   762→      </div>\n   763→      <div class=\"stat-block\">\n   764→        <div class=\"stat-label\">项目路径</div>\n   765→        <div class=\"stat-value muted\" style=\"font-size:0.78rem\">${escHtml(proj ? proj.path : '—')}</div>\n   766→      </div>\n   767→      <div class=\"stat-block\">\n   768→        <div class=\"stat-label\">创建时间</div>\n   769→        <div class=\"stat-value muted\">${proj ? fmtTime(proj.created_at) : '—'}</div>\n   770→      </div>\n   771→      ${loop.started_at ? `\n   772→      <div class=\"stat-block\">\n   773→        <div class=\"stat-label\">Loop 启动时间</div>\n   774→        <div class=\"stat-value muted\">${fmtTime(new Date(loop.started_at * 1000).toISOString())}</div>\n   775→      </div>` : ''}\n   776→      ${gitSection}\n   777→    </div>\n   778→  `;\n   779→}\n   780→\n   781→async function pushProject() {\n   782→  const btn = document.getElementById('btn-push');\n   783→  if (btn) { btn.disabled = true; btn.textContent = '推送中…'; }\n   784→  try {\n   785→    const r = await fetch(`/api/projects/${currentId}/push`, { method: 'POST' });\n   786→    const d = await r.json();\n   787→    if (d.success) showToast('推送成功');\n   788→    else showToast(`推送失败: ${d.output}`, true);\n   789→    loadStatus();\n   790→  } catch {\n   791→    showToast('推送请求失败', true);\n   792→  }\n   793→}\n   794→\n   795→// ─── Loop Badge ───────────────────────────────────────────────────────────────\n   796→async function updateLoopBadge() {\n   797→  if (!currentId) {\n   798→    document.getElementById('loop-dot').className = 'loop-dot';\n   799→    document.getElementById('loop-label').textContent = '未选择';\n   800→    return;\n   801→  }\n   802→  try {\n   803→    const r = await fetch('/api/dispatcher/status');\n   804→    const d = await r.json();\n   805→    updateLoopBadgeFromLoop(d[currentId] || { running: false });\n   806→  } catch { /* ignore */ }\n   807→}\n   808→\n   809→function updateLoopBadgeFromLoop(loop) {\n   810→  const dot = document.getElementById('loop-dot');\n   811→  const lbl = document.getElementById('loop-label');\n   812→  if (loop.running) {\n   813→    dot.className = 'loop-dot running';\n   814→    lbl.textContent = 'Loop 运行中';\n   815→  } else {\n   816→    dot.className = 'loop-dot';\n   817→    lbl.textContent = 'Loop 已停止';\n   818→  }\n   819→}\n   820→\n   821→// ─── Auto-refresh cleanup ─────────────────────────────────────────────────────\n   822→function stopAllAutoRefresh() {\n   823→  clearInterval(logAutoTimer); logAutoTimer = null;\n   824→  clearInterval(statusRefreshTimer); statusRefreshTimer = null;\n   825→  const logAutoChk = document.getElementById('log-auto');\n   826→  if (logAutoChk) logAutoChk.checked = false;\n   827→}\n   828→\n   829→// ─── Utilities ────────────────────────────────────────────────────────────────\n   830→function escHtml(s) {\n   831→  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');\n   832→}\n   833→\n   834→function fmtSize(bytes) {\n   835→  if (bytes == null) return '—';\n   836→  if (bytes < 1024) return `${bytes} B`;\n   837→  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;\n   838→  return `${(bytes / 1024 / 1024).toFixed(2)} MB`;\n   839→}\n   840→\n   841→function fmtTime(iso) {\n   842→  if (!iso) return '—';\n   843→  try {\n   844→    return new Date(iso).toLocaleString('zh-CN', {\n   845→      year: 'numeric', month: '2-digit', day: '2-digit',\n   846→      hour: '2-digit', minute: '2-digit',\n   847→    });\n   848→  } catch { return iso; }\n   849→}\n   850→\n   851→let toastTimer = null;\n   852→function showToast(msg, isErr = false) {\n   853→  const el = document.getElementById('toast');\n   854→  el.textContent = msg;\n   855→  el.style.borderColor = isErr ? 'rgba(255,77,94,0.3)' : 'rgba(0,201,139,0.3)';\n   856→  el.style.color = isErr ? 'var(--red)' : 'var(--green)';\n   857→  el.classList.add('show');\n   858→  clearTimeout(toastTimer);\n   859→  toastTimer = setTimeout(() => el.classList.remove('show'), 2500);\n   860→}\n   861→\n   862→// ─── Start ────────────────────────────────────────────────────────────────────\n   863→init();\n   864→</script>\n   865→</body>\n   866→</html>\n   867→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"68a4bc3c-f90f-4c91-bf96-1dc4d0b375e8","uuid":"fdd7dff3-0f49-4b99-98f6-6a2609a982c0","tool_use_result":{"type":"text","file":{"filePath":"/home/ubuntu/my-project/static/index.html","content":"<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Ralph — 项目管理</title>\n  <style>\n    :root {\n      --bg:      #0b0e1a;\n      --card:    #131827;\n      --card2:   #171d2e;\n      --border:  rgba(255,255,255,0.07);\n      --text:    #dde4f0;\n      --muted:   #5a6480;\n      --green:   #00c98b;\n      --red:     #ff4d5e;\n      --blue:    #60a5fa;\n      --yellow:  #fbbf24;\n      --purple:  #a78bfa;\n    }\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    body {\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n      background: var(--bg);\n      color: var(--text);\n      min-height: 100vh;\n    }\n\n    /* ── Header ── */\n    header {\n      background: rgba(13,16,30,0.95);\n      backdrop-filter: blur(12px);\n      border-bottom: 1px solid var(--border);\n      padding: 0 1.5rem;\n      height: 56px;\n      display: flex;\n      align-items: center;\n      gap: 1.2rem;\n      position: sticky;\n      top: 0;\n      z-index: 100;\n    }\n    .brand { display: flex; align-items: center; gap: 0.55rem; flex-shrink: 0; }\n    .brand-icon {\n      width: 30px; height: 30px;\n      background: linear-gradient(135deg, #3b82f6, #7c3aed);\n      border-radius: 7px;\n      display: flex; align-items: center; justify-content: center;\n      font-size: 14px; font-weight: 700; color: #fff;\n    }\n    .brand h1 { font-size: 1rem; font-weight: 700; letter-spacing: -0.01em; white-space: nowrap; }\n\n    .divider-v { width: 1px; height: 22px; background: var(--border); flex-shrink: 0; }\n\n    /* project selector */\n    .project-select-wrap { display: flex; align-items: center; gap: 0.6rem; flex: 1; min-width: 0; }\n    .project-select-label { font-size: 0.75rem; color: var(--muted); white-space: nowrap; flex-shrink: 0; }\n    .project-select {\n      background: var(--card2);\n      border: 1px solid var(--border);\n      color: var(--text);\n      padding: 0.3rem 0.7rem;\n      border-radius: 7px;\n      font-size: 0.85rem;\n      font-family: inherit;\n      cursor: pointer;\n      min-width: 180px;\n      max-width: 320px;\n      outline: none;\n      transition: border-color 0.15s;\n    }\n    .project-select:focus { border-color: rgba(96,165,250,0.5); }\n    .project-select option { background: #1a2035; }\n\n    .header-right { display: flex; align-items: center; gap: 0.7rem; margin-left: auto; flex-shrink: 0; }\n    .loop-badge {\n      display: flex; align-items: center; gap: 0.35rem;\n      font-size: 0.72rem; color: var(--muted);\n      background: var(--card2);\n      border: 1px solid var(--border);\n      padding: 0.25rem 0.6rem;\n      border-radius: 20px;\n    }\n    .loop-dot {\n      width: 7px; height: 7px; border-radius: 50%;\n      background: var(--muted);\n      transition: background 0.3s;\n    }\n    .loop-dot.running { background: var(--green); box-shadow: 0 0 5px var(--green); animation: pulse 2s infinite; }\n    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }\n\n    .btn-sm {\n      background: rgba(96,165,250,0.1);\n      border: 1px solid rgba(96,165,250,0.25);\n      color: var(--blue);\n      padding: 0.28rem 0.75rem;\n      border-radius: 6px;\n      cursor: pointer;\n      font-size: 0.78rem;\n      font-family: inherit;\n      transition: background 0.15s;\n      white-space: nowrap;\n    }\n    .btn-sm:hover { background: rgba(96,165,250,0.18); }\n    .btn-sm:disabled { opacity: 0.45; cursor: not-allowed; }\n    .btn-sm.danger { background: rgba(255,77,94,0.1); border-color: rgba(255,77,94,0.25); color: var(--red); }\n    .btn-sm.danger:hover { background: rgba(255,77,94,0.18); }\n    .btn-sm.success { background: rgba(0,201,139,0.1); border-color: rgba(0,201,139,0.25); color: var(--green); }\n    .btn-sm.success:hover { background: rgba(0,201,139,0.18); }\n\n    /* ── Empty state ── */\n    #no-project {\n      display: flex; flex-direction: column; align-items: center;\n      justify-content: center; height: calc(100vh - 56px);\n      gap: 0.8rem; color: var(--muted);\n    }\n    #no-project h2 { font-size: 1.1rem; font-weight: 600; color: var(--text); }\n    #no-project p { font-size: 0.85rem; }\n\n    /* ── Layout ── */\n    #app { display: none; flex-direction: column; height: calc(100vh - 56px); }\n\n    /* ── Tabs ── */\n    .tabs {\n      display: flex; gap: 0;\n      border-bottom: 1px solid var(--border);\n      background: rgba(13,16,30,0.6);\n      padding: 0 1.2rem;\n      flex-shrink: 0;\n    }\n    .tab {\n      padding: 0.65rem 1rem;\n      font-size: 0.82rem;\n      font-weight: 500;\n      color: var(--muted);\n      cursor: pointer;\n      border-bottom: 2px solid transparent;\n      margin-bottom: -1px;\n      transition: color 0.15s;\n      user-select: none;\n    }\n    .tab:hover { color: var(--text); }\n    .tab.active { color: var(--blue); border-bottom-color: var(--blue); }\n\n    .tab-content { flex: 1; overflow: hidden; }\n    .tab-pane { display: none; height: 100%; overflow: auto; padding: 1.2rem 1.4rem 2rem; }\n    .tab-pane.active { display: block; }\n\n    /* ── Cards ── */\n    .card {\n      background: var(--card);\n      border: 1px solid var(--border);\n      border-radius: 12px;\n      padding: 1.1rem 1.25rem;\n      margin-bottom: 1rem;\n    }\n    .card-title {\n      font-size: 0.78rem;\n      font-weight: 600;\n      color: var(--muted);\n      text-transform: uppercase;\n      letter-spacing: 0.05em;\n      margin-bottom: 0.85rem;\n    }\n\n    /* ── Tasks ── */\n    .task-input-row {\n      display: flex; gap: 0.6rem; margin-bottom: 1rem;\n    }\n    .task-input {\n      flex: 1;\n      background: var(--card2);\n      border: 1px solid var(--border);\n      color: var(--text);\n      padding: 0.45rem 0.8rem;\n      border-radius: 7px;\n      font-size: 0.85rem;\n      font-family: inherit;\n      outline: none;\n      transition: border-color 0.15s;\n    }\n    .task-input:focus { border-color: rgba(96,165,250,0.5); }\n\n    .task-list { display: flex; flex-direction: column; gap: 0.45rem; }\n    .task-item {\n      display: flex; align-items: center; gap: 0.7rem;\n      background: var(--card2);\n      border: 1px solid var(--border);\n      border-radius: 8px;\n      padding: 0.55rem 0.8rem;\n      transition: border-color 0.15s;\n    }\n    .task-item:hover { border-color: rgba(255,255,255,0.12); }\n    .task-status-btn {\n      flex-shrink: 0;\n      width: 18px; height: 18px;\n      border-radius: 50%;\n      border: 2px solid var(--muted);\n      background: transparent;\n      cursor: pointer;\n      display: flex; align-items: center; justify-content: center;\n      transition: all 0.15s;\n      font-size: 10px;\n      color: transparent;\n    }\n    .task-status-btn:hover { border-color: var(--green); }\n    .task-item.in_progress .task-status-btn { border-color: var(--yellow); }\n    .task-item.done .task-status-btn { border-color: var(--green); background: rgba(0,201,139,0.15); color: var(--green); }\n    .task-title-text {\n      flex: 1;\n      font-size: 0.85rem;\n      line-height: 1.4;\n    }\n    .task-item.done .task-title-text { text-decoration: line-through; color: var(--muted); }\n    .task-meta {\n      font-size: 0.72rem;\n      color: var(--muted);\n      white-space: nowrap;\n      flex-shrink: 0;\n    }\n    .task-status-tag {\n      font-size: 0.68rem;\n      font-weight: 600;\n      padding: 0.12rem 0.42rem;\n      border-radius: 4px;\n      flex-shrink: 0;\n    }\n    .task-status-tag.pending     { background: rgba(90,100,128,0.2); color: var(--muted); }\n    .task-status-tag.in_progress { background: rgba(251,191,36,0.12); color: var(--yellow); }\n    .task-status-tag.done        { background: rgba(0,201,139,0.12); color: var(--green); }\n    .task-del-btn {\n      flex-shrink: 0;\n      background: none;\n      border: none;\n      color: var(--muted);\n      cursor: pointer;\n      font-size: 14px;\n      padding: 0 0.2rem;\n      opacity: 0;\n      transition: opacity 0.15s, color 0.15s;\n    }\n    .task-item:hover .task-del-btn { opacity: 1; }\n    .task-del-btn:hover { color: var(--red); }\n\n    .empty-hint { font-size: 0.82rem; color: var(--muted); text-align: center; padding: 2rem; }\n\n    /* ── Task status cycle menu ── */\n    .task-cycle-btn {\n      flex-shrink: 0;\n      background: none; border: none;\n      font-size: 0.72rem; font-weight: 600;\n      cursor: pointer;\n      padding: 0.12rem 0.42rem;\n      border-radius: 4px;\n      transition: opacity 0.15s;\n    }\n    .task-cycle-btn:hover { opacity: 0.75; }\n\n    /* ── Logs ── */\n    .log-controls {\n      display: flex; align-items: center; gap: 0.7rem; margin-bottom: 0.8rem; flex-wrap: wrap;\n    }\n    .log-controls label { font-size: 0.78rem; color: var(--muted); display: flex; align-items: center; gap: 0.4rem; }\n    .log-controls input[type=checkbox] { accent-color: var(--blue); }\n    .log-lines-select {\n      background: var(--card2); border: 1px solid var(--border);\n      color: var(--text); padding: 0.25rem 0.5rem; border-radius: 5px;\n      font-size: 0.78rem; font-family: inherit; outline: none;\n    }\n    .log-box {\n      background: #080a12;\n      border: 1px solid var(--border);\n      border-radius: 8px;\n      padding: 0.9rem 1rem;\n      font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;\n      font-size: 0.75rem;\n      line-height: 1.55;\n      color: #a8b4c8;\n      white-space: pre-wrap;\n      word-break: break-all;\n      max-height: calc(100vh - 280px);\n      overflow-y: auto;\n    }\n    .log-box .log-empty { color: var(--muted); }\n\n    /* ── Files ── */\n    .files-search-row { display: flex; gap: 0.6rem; margin-bottom: 0.8rem; }\n    .files-search {\n      flex: 1; background: var(--card2); border: 1px solid var(--border);\n      color: var(--text); padding: 0.38rem 0.75rem; border-radius: 7px;\n      font-size: 0.82rem; font-family: inherit; outline: none;\n    }\n    .files-search:focus { border-color: rgba(96,165,250,0.4); }\n    .file-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }\n    .file-table th {\n      text-align: left; padding: 0.4rem 0.6rem;\n      font-size: 0.7rem; font-weight: 600; color: var(--muted);\n      text-transform: uppercase; letter-spacing: 0.04em;\n      border-bottom: 1px solid var(--border);\n    }\n    .file-table td { padding: 0.38rem 0.6rem; border-bottom: 1px solid rgba(255,255,255,0.03); }\n    .file-table tr:hover td { background: rgba(255,255,255,0.02); }\n    .file-path { color: var(--blue); font-family: monospace; font-size: 0.78rem; }\n    .file-size { color: var(--muted); white-space: nowrap; }\n    .file-mtime { color: var(--muted); white-space: nowrap; font-size: 0.72rem; }\n\n    /* ── Status ── */\n    .status-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0.9rem; }\n    .stat-block {\n      background: var(--card2); border: 1px solid var(--border);\n      border-radius: 9px; padding: 0.9rem 1rem;\n    }\n    .stat-label { font-size: 0.7rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.4rem; }\n    .stat-value { font-size: 0.9rem; font-weight: 600; word-break: break-all; }\n    .stat-value.green { color: var(--green); }\n    .stat-value.red   { color: var(--red); }\n    .stat-value.muted { color: var(--muted); font-weight: 400; }\n\n    .git-status-lines {\n      font-family: monospace; font-size: 0.75rem; line-height: 1.6;\n      color: var(--muted); margin-top: 0.5rem;\n    }\n    .git-status-lines span { display: block; }\n    .git-status-lines .M { color: var(--yellow); }\n    .git-status-lines .A { color: var(--green); }\n    .git-status-lines .D { color: var(--red); }\n    .git-status-lines .Q { color: var(--muted); }\n\n    /* ── Spinner ── */\n    .spinner {\n      display: inline-block; width: 16px; height: 16px;\n      border: 2px solid var(--border); border-top-color: var(--blue);\n      border-radius: 50%; animation: spin 0.6s linear infinite;\n    }\n    @keyframes spin { to { transform: rotate(360deg); } }\n\n    /* ── Toast ── */\n    #toast {\n      position: fixed; bottom: 1.5rem; right: 1.5rem;\n      background: var(--card); border: 1px solid var(--border);\n      padding: 0.6rem 1rem; border-radius: 8px;\n      font-size: 0.82rem; color: var(--text);\n      box-shadow: 0 4px 20px rgba(0,0,0,0.4);\n      opacity: 0; transform: translateY(8px);\n      transition: opacity 0.2s, transform 0.2s;\n      pointer-events: none; z-index: 999;\n    }\n    #toast.show { opacity: 1; transform: translateY(0); }\n\n    /* ── Scrollbar ── */\n    ::-webkit-scrollbar { width: 6px; height: 6px; }\n    ::-webkit-scrollbar-track { background: transparent; }\n    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }\n  </style>\n</head>\n<body>\n\n<header>\n  <div class=\"brand\">\n    <div class=\"brand-icon\">R</div>\n    <h1>Ralph</h1>\n  </div>\n  <div class=\"divider-v\"></div>\n  <div class=\"project-select-wrap\">\n    <span class=\"project-select-label\">项目</span>\n    <select class=\"project-select\" id=\"project-select\" onchange=\"onProjectChange(this.value)\">\n      <option value=\"\">— 选择项目 —</option>\n    </select>\n  </div>\n  <div class=\"header-right\">\n    <div class=\"loop-badge\" id=\"loop-badge\">\n      <div class=\"loop-dot\" id=\"loop-dot\"></div>\n      <span id=\"loop-label\">未选择</span>\n    </div>\n    <button class=\"btn-sm\" id=\"btn-refresh\" onclick=\"refreshCurrent()\" title=\"刷新当前视图\">刷新</button>\n  </div>\n</header>\n\n<div id=\"no-project\">\n  <h2>暂无项目</h2>\n  <p>请通过 API 创建项目，或选择已有项目</p>\n</div>\n\n<div id=\"app\">\n  <div class=\"tabs\">\n    <div class=\"tab active\" data-tab=\"tasks\" onclick=\"switchTab('tasks')\">任务</div>\n    <div class=\"tab\" data-tab=\"logs\"  onclick=\"switchTab('logs')\">日志</div>\n    <div class=\"tab\" data-tab=\"files\" onclick=\"switchTab('files')\">文件</div>\n    <div class=\"tab\" data-tab=\"status\" onclick=\"switchTab('status')\">状态</div>\n  </div>\n  <div class=\"tab-content\">\n\n    <!-- Tasks -->\n    <div class=\"tab-pane active\" id=\"pane-tasks\">\n      <div class=\"task-input-row\">\n        <input class=\"task-input\" id=\"new-task-input\" placeholder=\"添加新任务…\" onkeydown=\"onTaskKeydown(event)\" />\n        <button class=\"btn-sm success\" onclick=\"addTask()\">+ 添加</button>\n      </div>\n      <div class=\"task-list\" id=\"task-list\">\n        <div class=\"empty-hint\"><div class=\"spinner\"></div></div>\n      </div>\n    </div>\n\n    <!-- Logs -->\n    <div class=\"tab-pane\" id=\"pane-logs\">\n      <div class=\"log-controls\">\n        <label>\n          <input type=\"checkbox\" id=\"log-auto\" onchange=\"onLogAutoChange()\" />\n          自动刷新 (5s)\n        </label>\n        <label>\n          最近\n          <select class=\"log-lines-select\" id=\"log-lines\" onchange=\"loadLogs()\">\n            <option value=\"100\">100 行</option>\n            <option value=\"300\" selected>300 行</option>\n            <option value=\"500\">500 行</option>\n            <option value=\"1000\">1000 行</option>\n          </select>\n        </label>\n        <button class=\"btn-sm\" onclick=\"loadLogs()\">刷新</button>\n        <span id=\"log-total\" style=\"font-size:0.75rem;color:var(--muted)\"></span>\n      </div>\n      <div class=\"log-box\" id=\"log-box\"><span class=\"log-empty\">加载中…</span></div>\n    </div>\n\n    <!-- Files -->\n    <div class=\"tab-pane\" id=\"pane-files\">\n      <div class=\"files-search-row\">\n        <input class=\"files-search\" id=\"files-search\" placeholder=\"搜索文件…\" oninput=\"renderFiles()\" />\n        <button class=\"btn-sm\" onclick=\"loadFiles()\">刷新</button>\n      </div>\n      <table class=\"file-table\" id=\"file-table\">\n        <thead><tr><th>路径</th><th>大小</th><th>修改时间</th></tr></thead>\n        <tbody id=\"file-tbody\"></tbody>\n      </table>\n    </div>\n\n    <!-- Status -->\n    <div class=\"tab-pane\" id=\"pane-status\">\n      <div id=\"status-content\">\n        <div class=\"empty-hint\"><div class=\"spinner\"></div></div>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<div id=\"toast\"></div>\n\n<script>\n// ─── State ────────────────────────────────────────────────────────────────────\nconst LS_KEY = 'ralph_selected_project';\nlet projects = [];\nlet currentId = localStorage.getItem(LS_KEY) || '';\nlet currentTab = 'tasks';\nlet allFiles = [];\nlet logAutoTimer = null;\nlet statusRefreshTimer = null;\n\n// ─── Init ─────────────────────────────────────────────────────────────────────\nasync function init() {\n  await loadProjects();\n  const stored = currentId;\n  if (stored && projects.find(p => p.id === stored)) {\n    setProject(stored);\n  } else if (projects.length > 0) {\n    setProject(projects[0].id);\n  } else {\n    showNoProject();\n  }\n}\n\n// ─── Projects ─────────────────────────────────────────────────────────────────\nasync function loadProjects() {\n  try {\n    const r = await fetch('/api/projects');\n    projects = await r.json();\n  } catch { projects = []; }\n  renderProjectSelect();\n}\n\nfunction renderProjectSelect() {\n  const sel = document.getElementById('project-select');\n  sel.innerHTML = '<option value=\"\">— 选择项目 —</option>';\n  projects.forEach(p => {\n    const opt = document.createElement('option');\n    opt.value = p.id;\n    opt.textContent = p.name + (p.status === 'archived' ? ' (已归档)' : '');\n    sel.appendChild(opt);\n  });\n  sel.value = currentId || '';\n}\n\nfunction onProjectChange(id) {\n  if (id) setProject(id);\n  else showNoProject();\n}\n\nfunction setProject(id) {\n  currentId = id;\n  localStorage.setItem(LS_KEY, id);\n  document.getElementById('project-select').value = id;\n  document.getElementById('no-project').style.display = 'none';\n  document.getElementById('app').style.display = 'flex';\n  stopAllAutoRefresh();\n  loadCurrentTab();\n  updateLoopBadge();\n}\n\nfunction showNoProject() {\n  document.getElementById('no-project').style.display = 'flex';\n  document.getElementById('app').style.display = 'none';\n  updateLoopBadge();\n}\n\n// ─── Tabs ─────────────────────────────────────────────────────────────────────\nfunction switchTab(tab) {\n  stopAllAutoRefresh();\n  currentTab = tab;\n  document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === tab));\n  document.querySelectorAll('.tab-pane').forEach(p => p.classList.toggle('active', p.id === `pane-${tab}`));\n  loadCurrentTab();\n}\n\nfunction loadCurrentTab() {\n  if (!currentId) return;\n  if (currentTab === 'tasks')  loadTasks();\n  if (currentTab === 'logs')   loadLogs();\n  if (currentTab === 'files')  loadFiles();\n  if (currentTab === 'status') loadStatus();\n}\n\nfunction refreshCurrent() {\n  loadProjects().then(() => {\n    if (currentId) {\n      loadCurrentTab();\n      updateLoopBadge();\n    }\n  });\n}\n\n// ─── Tasks ────────────────────────────────────────────────────────────────────\nasync function loadTasks() {\n  const list = document.getElementById('task-list');\n  list.innerHTML = '<div class=\"empty-hint\"><div class=\"spinner\"></div></div>';\n  try {\n    const r = await fetch(`/api/projects/${currentId}/tasks`);\n    const tasks = await r.json();\n    renderTasks(tasks);\n  } catch {\n    list.innerHTML = '<div class=\"empty-hint\" style=\"color:var(--red)\">加载失败</div>';\n  }\n}\n\nconst STATUS_CYCLE = { pending: 'in_progress', in_progress: 'done', done: 'pending' };\nconst STATUS_LABEL = { pending: '待处理', in_progress: '进行中', done: '已完成' };\nconst STATUS_CLASS = { pending: 'pending', in_progress: 'in_progress', done: 'done' };\n\nfunction renderTasks(tasks) {\n  const list = document.getElementById('task-list');\n  if (!tasks.length) {\n    list.innerHTML = '<div class=\"empty-hint\">暂无任务，添加第一个吧</div>';\n    return;\n  }\n  list.innerHTML = '';\n  tasks.forEach(t => {\n    const item = document.createElement('div');\n    item.className = `task-item ${t.status}`;\n    item.dataset.id = t.id;\n\n    const checkmark = t.status === 'done' ? '✓' : (t.status === 'in_progress' ? '…' : '');\n    const tagCls = STATUS_CLASS[t.status] || 'pending';\n    const tagLabel = STATUS_LABEL[t.status] || t.status;\n    const nextStatus = STATUS_CYCLE[t.status] || 'pending';\n\n    item.innerHTML = `\n      <button class=\"task-status-btn\" onclick=\"cycleTaskStatus('${t.id}','${nextStatus}')\" title=\"切换状态\">${checkmark}</button>\n      <span class=\"task-title-text\">${escHtml(t.title)}</span>\n      <span class=\"task-status-tag ${tagCls}\" onclick=\"cycleTaskStatus('${t.id}','${nextStatus}')\" style=\"cursor:pointer\" title=\"切换到: ${STATUS_LABEL[nextStatus]}\">${tagLabel}</span>\n      <button class=\"task-del-btn\" onclick=\"deleteTask('${t.id}')\" title=\"删除\">✕</button>\n    `;\n    list.appendChild(item);\n  });\n}\n\nasync function addTask() {\n  const input = document.getElementById('new-task-input');\n  const title = input.value.trim();\n  if (!title) return;\n  input.value = '';\n  try {\n    await fetch(`/api/projects/${currentId}/tasks`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title }),\n    });\n    loadTasks();\n    showToast('任务已添加');\n  } catch {\n    showToast('添加失败', true);\n  }\n}\n\nfunction onTaskKeydown(e) {\n  if (e.key === 'Enter') addTask();\n}\n\nasync function cycleTaskStatus(tid, nextStatus) {\n  try {\n    await fetch(`/api/projects/${currentId}/tasks/${tid}`, {\n      method: 'PUT',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ status: nextStatus }),\n    });\n    loadTasks();\n  } catch {\n    showToast('更新失败', true);\n  }\n}\n\nasync function deleteTask(tid) {\n  if (!confirm('确认删除此任务？')) return;\n  try {\n    await fetch(`/api/projects/${currentId}/tasks/${tid}`, { method: 'DELETE' });\n    loadTasks();\n    showToast('任务已删除');\n  } catch {\n    showToast('删除失败', true);\n  }\n}\n\n// ─── Logs ─────────────────────────────────────────────────────────────────────\nasync function loadLogs() {\n  const lines = document.getElementById('log-lines').value;\n  const box = document.getElementById('log-box');\n  try {\n    const r = await fetch(`/api/projects/${currentId}/logs?lines=${lines}`);\n    const d = await r.json();\n    const atBottom = box.scrollHeight - box.scrollTop - box.clientHeight < 60;\n    box.textContent = d.logs || '';\n    if (!d.logs) box.innerHTML = '<span class=\"log-empty\">暂无日志</span>';\n    document.getElementById('log-total').textContent = `共 ${d.total_lines || 0} 行`;\n    if (atBottom) box.scrollTop = box.scrollHeight;\n  } catch {\n    box.innerHTML = '<span style=\"color:var(--red)\">加载失败</span>';\n  }\n}\n\nfunction onLogAutoChange() {\n  const checked = document.getElementById('log-auto').checked;\n  clearInterval(logAutoTimer);\n  if (checked) logAutoTimer = setInterval(loadLogs, 5000);\n}\n\n// ─── Files ────────────────────────────────────────────────────────────────────\nasync function loadFiles() {\n  const tbody = document.getElementById('file-tbody');\n  tbody.innerHTML = '<tr><td colspan=\"3\" class=\"empty-hint\"><div class=\"spinner\"></div></td></tr>';\n  try {\n    const r = await fetch(`/api/projects/${currentId}/files`);\n    const d = await r.json();\n    allFiles = d.files || [];\n    renderFiles();\n  } catch {\n    tbody.innerHTML = '<tr><td colspan=\"3\" style=\"color:var(--red);padding:0.6rem\">加载失败</td></tr>';\n  }\n}\n\nfunction renderFiles() {\n  const q = document.getElementById('files-search').value.toLowerCase();\n  const files = q ? allFiles.filter(f => f.path.toLowerCase().includes(q)) : allFiles;\n  const tbody = document.getElementById('file-tbody');\n  if (!files.length) {\n    tbody.innerHTML = '<tr><td colspan=\"3\" class=\"empty-hint\">无文件</td></tr>';\n    return;\n  }\n  tbody.innerHTML = files.map(f => `\n    <tr>\n      <td class=\"file-path\">${escHtml(f.path)}</td>\n      <td class=\"file-size\">${fmtSize(f.size)}</td>\n      <td class=\"file-mtime\">${fmtTime(f.modified)}</td>\n    </tr>\n  `).join('');\n}\n\n// ─── Status ───────────────────────────────────────────────────────────────────\nasync function loadStatus() {\n  const cont = document.getElementById('status-content');\n  cont.innerHTML = '<div class=\"empty-hint\"><div class=\"spinner\"></div></div>';\n  try {\n    const proj = projects.find(p => p.id === currentId);\n    const [gitR, dispR] = await Promise.all([\n      fetch(`/api/projects/${currentId}/git-status`).then(r => r.json()).catch(() => ({})),\n      fetch('/api/dispatcher/status').then(r => r.json()).catch(() => ({})),\n    ]);\n    const loop = dispR[currentId] || { running: false };\n    renderStatus(proj, gitR, loop);\n    updateLoopBadgeFromLoop(loop);\n  } catch {\n    cont.innerHTML = '<div class=\"empty-hint\" style=\"color:var(--red)\">加载失败</div>';\n  }\n}\n\nfunction renderStatus(proj, git, loop) {\n  const cont = document.getElementById('status-content');\n\n  const loopRunning = loop.running;\n  const loopColor = loopRunning ? 'green' : 'red';\n  const loopText  = loopRunning ? `运行中 (PID ${loop.pid})` : '已停止';\n\n  let gitSection = '';\n  if (git.has_git === false) {\n    gitSection = `<div class=\"stat-block\"><div class=\"stat-label\">Git</div><div class=\"stat-value muted\">未初始化</div></div>`;\n  } else if (git.has_git) {\n    const dirty = git.dirty ? '<span style=\"color:var(--yellow)\">有未提交变更</span>' : '<span style=\"color:var(--green)\">干净</span>';\n    const unpushed = git.unpushed_commits || 0;\n    const statusHtml = (git.status_lines || []).map(l => {\n      const cls = l.startsWith('M') ? 'M' : l.startsWith('A') ? 'A' : l.startsWith('D') ? 'D' : 'Q';\n      return `<span class=\"${cls}\">${escHtml(l)}</span>`;\n    }).join('');\n    gitSection = `\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">分支</div>\n        <div class=\"stat-value\">${escHtml(git.branch || '—')}</div>\n      </div>\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">工作区</div>\n        <div class=\"stat-value\">${dirty}${statusHtml ? '<div class=\"git-status-lines\">' + statusHtml + '</div>' : ''}</div>\n      </div>\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">未推送提交</div>\n        <div class=\"stat-value ${unpushed ? 'yellow' : 'green'}\" style=\"${unpushed ? 'color:var(--yellow)' : ''}\">${unpushed}</div>\n      </div>\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">远程仓库</div>\n        <div class=\"stat-value muted\" style=\"font-size:0.8rem\">${escHtml(git.remote || '—')}</div>\n      </div>\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">上次推送</div>\n        <div class=\"stat-value muted\">${git.last_push ? fmtTime(git.last_push) : '—'}</div>\n      </div>\n    `;\n  }\n\n  cont.innerHTML = `\n    <div style=\"display:flex;gap:0.7rem;flex-wrap:wrap;margin-bottom:1.2rem\">\n      <button class=\"btn-sm\" onclick=\"loadStatus()\">刷新状态</button>\n      ${git.has_git ? `<button class=\"btn-sm success\" id=\"btn-push\" onclick=\"pushProject()\">推送到远程</button>` : ''}\n    </div>\n    <div class=\"status-grid\">\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">项目名称</div>\n        <div class=\"stat-value\">${escHtml(proj ? proj.name : currentId)}</div>\n      </div>\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">项目状态</div>\n        <div class=\"stat-value ${proj && proj.status === 'active' ? 'green' : 'muted'}\">${proj ? proj.status : '—'}</div>\n      </div>\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">Ralph Loop</div>\n        <div class=\"stat-value ${loopColor}\">${loopText}</div>\n      </div>\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">项目路径</div>\n        <div class=\"stat-value muted\" style=\"font-size:0.78rem\">${escHtml(proj ? proj.path : '—')}</div>\n      </div>\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">创建时间</div>\n        <div class=\"stat-value muted\">${proj ? fmtTime(proj.created_at) : '—'}</div>\n      </div>\n      ${loop.started_at ? `\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">Loop 启动时间</div>\n        <div class=\"stat-value muted\">${fmtTime(new Date(loop.started_at * 1000).toISOString())}</div>\n      </div>` : ''}\n      ${gitSection}\n    </div>\n  `;\n}\n\nasync function pushProject() {\n  const btn = document.getElementById('btn-push');\n  if (btn) { btn.disabled = true; btn.textContent = '推送中…'; }\n  try {\n    const r = await fetch(`/api/projects/${currentId}/push`, { method: 'POST' });\n    const d = await r.json();\n    if (d.success) showToast('推送成功');\n    else showToast(`推送失败: ${d.output}`, true);\n    loadStatus();\n  } catch {\n    showToast('推送请求失败', true);\n  }\n}\n\n// ─── Loop Badge ───────────────────────────────────────────────────────────────\nasync function updateLoopBadge() {\n  if (!currentId) {\n    document.getElementById('loop-dot').className = 'loop-dot';\n    document.getElementById('loop-label').textContent = '未选择';\n    return;\n  }\n  try {\n    const r = await fetch('/api/dispatcher/status');\n    const d = await r.json();\n    updateLoopBadgeFromLoop(d[currentId] || { running: false });\n  } catch { /* ignore */ }\n}\n\nfunction updateLoopBadgeFromLoop(loop) {\n  const dot = document.getElementById('loop-dot');\n  const lbl = document.getElementById('loop-label');\n  if (loop.running) {\n    dot.className = 'loop-dot running';\n    lbl.textContent = 'Loop 运行中';\n  } else {\n    dot.className = 'loop-dot';\n    lbl.textContent = 'Loop 已停止';\n  }\n}\n\n// ─── Auto-refresh cleanup ─────────────────────────────────────────────────────\nfunction stopAllAutoRefresh() {\n  clearInterval(logAutoTimer); logAutoTimer = null;\n  clearInterval(statusRefreshTimer); statusRefreshTimer = null;\n  const logAutoChk = document.getElementById('log-auto');\n  if (logAutoChk) logAutoChk.checked = false;\n}\n\n// ─── Utilities ────────────────────────────────────────────────────────────────\nfunction escHtml(s) {\n  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');\n}\n\nfunction fmtSize(bytes) {\n  if (bytes == null) return '—';\n  if (bytes < 1024) return `${bytes} B`;\n  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;\n  return `${(bytes / 1024 / 1024).toFixed(2)} MB`;\n}\n\nfunction fmtTime(iso) {\n  if (!iso) return '—';\n  try {\n    return new Date(iso).toLocaleString('zh-CN', {\n      year: 'numeric', month: '2-digit', day: '2-digit',\n      hour: '2-digit', minute: '2-digit',\n    });\n  } catch { return iso; }\n}\n\nlet toastTimer = null;\nfunction showToast(msg, isErr = false) {\n  const el = document.getElementById('toast');\n  el.textContent = msg;\n  el.style.borderColor = isErr ? 'rgba(255,77,94,0.3)' : 'rgba(0,201,139,0.3)';\n  el.style.color = isErr ? 'var(--red)' : 'var(--green)';\n  el.classList.add('show');\n  clearTimeout(toastTimer);\n  toastTimer = setTimeout(() => el.classList.remove('show'), 2500);\n}\n\n// ─── Start ────────────────────────────────────────────────────────────────────\ninit();\n</script>\n</body>\n</html>\n","numLines":867,"startLine":1,"totalLines":867}}}
