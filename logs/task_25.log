"<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Ralph — 项目管理</title>\n  <style>\n    :root {\n      --bg:      #0b0e1a;\n      --card:    #131827;\n      --card2:   #171d2e;\n      --border:  rgba(255,255,255,0.07);\n      --text:    #dde4f0;\n      --muted:   #5a6480;\n      --green:   #00c98b;\n      --red:     #ff4d5e;\n      --blue:    #60a5fa;\n      --yellow:  #fbbf24;\n      --purple:  #a78bfa;\n    }\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    body {\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n      background: var(--bg);\n      color: var(--text);\n      min-height: 100vh;\n    }\n\n    /* ── Header ── */\n    header {\n      background: rgba(13,16,30,0.95);\n      backdrop-filter: blur(12px);\n      border-bottom: 1px solid var(--border);\n      padding: 0 1.5rem;\n      height: 56px;\n      display: flex;\n      align-items: center;\n      gap: 1.2rem;\n      position: sticky;\n      top: 0;\n      z-index: 100;\n    }\n    .brand { display: flex; align-items: center; gap: 0.55rem; flex-shrink: 0; }\n    .brand-icon {\n      width: 30px; height: 30px;\n      background: linear-gradient(135deg, #3b82f6, #7c3aed);\n      border-radius: 7px;\n      display: flex; align-items: center; justify-content: center;\n      font-size: 14px; font-weight: 700; color: #fff;\n    }\n    .brand h1 { font-size: 1rem; font-weight: 700; letter-spacing: -0.01em; white-space: nowrap; }\n\n    .divider-v { width: 1px; height: 22px; background: var(--border); flex-shrink: 0; }\n\n    /* project selector */\n    .project-select-wrap { display: flex; align-items: center; gap: 0.6rem; flex: 1; min-width: 0; }\n    .project-select-label { font-size: 0.75rem; color: var(--muted); white-space: nowrap; flex-shrink: 0; }\n    .project-select {\n      background: var(--card2);\n      border: 1px solid var(--border);\n      color: var(--text);\n      padding: 0.3rem 0.7rem;\n      border-radius: 7px;\n      font-size: 0.85rem;\n      font-family: inherit;\n      cursor: pointer;\n      min-width: 180px;\n      max-width: 320px;\n      outline: none;\n      transition: border-color 0.15s;\n    }\n    .project-select:focus { border-color: rgba(96,165,250,0.5); }\n    .project-select option { background: #1a2035; }\n\n    .header-right { display: flex; align-items: center; gap: 0.7rem; margin-left: auto; flex-shrink: 0; }\n    .loop-badge {\n      display: flex; align-items: center; gap: 0.35rem;\n      font-size: 0.72rem; color: var(--muted);\n      background: var(--card2);\n      border: 1px solid var(--border);\n      padding: 0.25rem 0.6rem;\n      border-radius: 20px;\n    }\n    .loop-dot {\n      width: 7px; height: 7px; border-radius: 50%;\n      background: var(--muted);\n      transition: background 0.3s;\n    }\n    .loop-dot.running { background: var(--green); box-shadow: 0 0 5px var(--green); animation: pulse 2s infinite; }\n    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }\n\n    .btn-sm {\n      background: rgba(96,165,250,0.1);\n      border: 1px solid rgba(96,165,250,0.25);\n      color: var(--blue);\n      padding: 0.28rem 0.75rem;\n      border-radius: 6px;\n      cursor: pointer;\n      font-size: 0.78rem;\n      font-family: inherit;\n      transition: background 0.15s;\n      white-space: nowrap;\n    }\n    .btn-sm:hover { background: rgba(96,165,250,0.18); }\n    .btn-sm:disabled { opacity: 0.45; cursor: not-allowed; }\n    .btn-sm.danger { background: rgba(255,77,94,0.1); border-color: rgba(255,77,94,0.25); color: var(--red); }\n    .btn-sm.danger:hover { background: rgba(255,77,94,0.18); }\n    .btn-sm.success { background: rgba(0,201,139,0.1); border-color: rgba(0,201,139,0.25); color: var(--green); }\n    .btn-sm.success:hover { background: rgba(0,201,139,0.18); }\n\n    /* ── Empty state ── */\n    #no-project {\n      display: flex; flex-direction: column; align-items: center;\n      justify-content: center; height: calc(100vh - 56px);\n      gap: 0.8rem; color: var(--muted);\n    }\n    #no-project h2 { font-size: 1.1rem; font-weight: 600; color: var(--text); }\n    #no-project p { font-size: 0.85rem; }\n\n    /* ── Layout ── */\n    #app { display: none; flex-direction: column; height: calc(100vh - 56px); }\n\n    /* ── Tabs ── */\n    .tabs {\n      display: flex; gap: 0;\n      border-bottom: 1px solid var(--border);\n      background: rgba(13,16,30,0.6);\n      padding: 0 1.2rem;\n      flex-shrink: 0;\n    }\n    .tab {\n      padding: 0.65rem 1rem;\n      font-size: 0.82rem;\n      font-weight: 500;\n      color: var(--muted);\n      cursor: pointer;\n      border-bottom: 2px solid transparent;\n      margin-bottom: -1px;\n      transition: color 0.15s;\n      user-select: none;\n    }\n    .tab:hover { color: var(--text); }\n    .tab.active { color: var(--blue); border-bottom-color: var(--blue); }\n\n    .tab-content { flex: 1; overflow: hidden; }\n    .tab-pane { display: none; height: 100%; overflow: auto; padding: 1.2rem 1.4rem 2rem; }\n    .tab-pane.active { display: block; }\n\n    /* ── Cards ── */\n    .card {\n      background: var(--card);\n      border: 1px solid var(--border);\n      border-radius: 12px;\n      padding: 1.1rem 1.25rem;\n      margin-bottom: 1rem;\n    }\n    .card-title {\n      font-size: 0.78rem;\n      font-weight: 600;\n      color: var(--muted);\n      text-transform: uppercase;\n      letter-spacing: 0.05em;\n      margin-bottom: 0.85rem;\n    }\n\n    /* ── Tasks ── */\n    .task-input-row {\n      display: flex; gap: 0.6rem; margin-bottom: 1rem;\n    }\n    .task-input {\n      flex: 1;\n      background: var(--card2);\n      border: 1px solid var(--border);\n      color: var(--text);\n      padding: 0.45rem 0.8rem;\n      border-radius: 7px;\n      font-size: 0.85rem;\n      font-family: inherit;\n      outline: none;\n      transition: border-color 0.15s;\n    }\n    .task-input:focus { border-color: rgba(96,165,250,0.5); }\n\n    .task-list { display: flex; flex-direction: column; gap: 0.45rem; }\n    .task-item {\n      display: flex; align-items: center; gap: 0.7rem;\n      background: var(--card2);\n      border: 1px solid var(--border);\n      border-radius: 8px;\n      padding: 0.55rem 0.8rem;\n      transition: border-color 0.15s;\n    }\n    .task-item:hover { border-color: rgba(255,255,255,0.12); }\n    .task-status-btn {\n      flex-shrink: 0;\n      width: 18px; height: 18px;\n      border-radius: 50%;\n      border: 2px solid var(--muted);\n      background: transparent;\n      cursor: pointer;\n      display: flex; align-items: center; justify-content: center;\n      transition: all 0.15s;\n      font-size: 10px;\n      color: transparent;\n    }\n    .task-status-btn:hover { border-color: var(--green); }\n    .task-item.in_progress .task-status-btn { border-color: var(--yellow); }\n    .task-item.done .task-status-btn { border-color: var(--green); background: rgba(0,201,139,0.15); color: var(--green); }\n    .task-title-text {\n      flex: 1;\n      font-size: 0.85rem;\n      line-height: 1.4;\n    }\n    .task-item.done .task-title-text { text-decoration: line-through; color: var(--muted); }\n    .task-meta {\n      font-size: 0.72rem;\n      color: var(--muted);\n      white-space: nowrap;\n      flex-shrink: 0;\n    }\n    .task-status-tag {\n      font-size: 0.68rem;\n      font-weight: 600;\n      padding: 0.12rem 0.42rem;\n      border-radius: 4px;\n      flex-shrink: 0;\n    }\n    .task-status-tag.pending     { background: rgba(90,100,128,0.2); color: var(--muted); }\n    .task-status-tag.in_progress { background: rgba(251,191,36,0.12); color: var(--yellow); }\n    .task-status-tag.done        { background: rgba(0,201,139,0.12); color: var(--green); }\n    .task-del-btn {\n      flex-shrink: 0;\n      background: none;\n      border: none;\n      color: var(--muted);\n      cursor: pointer;\n      font-size: 14px;\n      padding: 0 0.2rem;\n      opacity: 0;\n      transition: opacity 0.15s, color 0.15s;\n    }\n    .task-item:hover .task-del-btn { opacity: 1; }\n    .task-del-btn:hover { color: var(--red); }\n\n    .empty-hint { font-size: 0.82rem; color: var(--muted); text-align: center; padding: 2rem; }\n\n    /* ── Task status cycle menu ── */\n    .task-cycle-btn {\n      flex-shrink: 0;\n      background: none; border: none;\n      font-size: 0.72rem; font-weight: 600;\n      cursor: pointer;\n      padding: 0.12rem 0.42rem;\n      border-radius: 4px;\n      transition: opacity 0.15s;\n    }\n    .task-cycle-btn:hover { opacity: 0.75; }\n\n    /* ── Logs ── */\n    .log-controls {\n      display: flex; align-items: center; gap: 0.7rem; margin-bottom: 0.8rem; flex-wrap: wrap;\n    }\n    .log-controls label { font-size: 0.78rem; color: var(--muted); display: flex; align-items: center; gap: 0.4rem; }\n    .log-controls input[type=checkbox] { accent-color: var(--blue); }\n    .log-lines-select {\n      background: var(--card2); border: 1px solid var(--border);\n      color: var(--text); padding: 0.25rem 0.5rem; border-radius: 5px;\n      font-size: 0.78rem; font-family: inherit; outline: none;\n    }\n    .log-box {\n      background: #080a12;\n      border: 1px solid var(--border);\n      border-radius: 8px;\n      padding: 0.9rem 1rem;\n      font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;\n      font-size: 0.75rem;\n      line-height: 1.55;\n      color: #a8b4c8;\n      white-space: pre-wrap;\n      word-break: break-all;\n      max-height: calc(100vh - 280px);\n      overflow-y: auto;\n    }\n    .log-box .log-empty { color: var(--muted); }\n\n    /* ── Files ── */\n    .files-search-row { display: flex; gap: 0.6rem; margin-bottom: 0.8rem; }\n    .files-search {\n      flex: 1; background: var(--card2); border: 1px solid var(--border);\n      color: var(--text); padding: 0.38rem 0.75rem; border-radius: 7px;\n      font-size: 0.82rem; font-family: inherit; outline: none;\n    }\n    .files-search:focus { border-color: rgba(96,165,250,0.4); }\n    .file-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }\n    .file-table th {\n      text-align: left; padding: 0.4rem 0.6rem;\n      font-size: 0.7rem; font-weight: 600; color: var(--muted);\n      text-transform: uppercase; letter-spacing: 0.04em;\n      border-bottom: 1px solid var(--border);\n    }\n    .file-table td { padding: 0.38rem 0.6rem; border-bottom: 1px solid rgba(255,255,255,0.03); }\n    .file-table tr:hover td { background: rgba(255,255,255,0.02); }\n    .file-path { color: var(--blue); font-family: monospace; font-size: 0.78rem; }\n    .file-size { color: var(--muted); white-space: nowrap; }\n    .file-mtime { color: var(--muted); white-space: nowrap; font-size: 0.72rem; }\n\n    /* ── Status ── */\n    .status-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0.9rem; }\n    .stat-block {\n      background: var(--card2); border: 1px solid var(--border);\n      border-radius: 9px; padding: 0.9rem 1rem;\n    }\n    .stat-label { font-size: 0.7rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.4rem; }\n    .stat-value { font-size: 0.9rem; font-weight: 600; word-break: break-all; }\n    .stat-value.green { color: var(--green); }\n    .stat-value.red   { color: var(--red); }\n    .stat-value.muted { color: var(--muted); font-weight: 400; }\n\n    .git-status-lines {\n      font-family: monospace; font-size: 0.75rem; line-height: 1.6;\n      color: var(--muted); margin-top: 0.5rem;\n    }\n    .git-status-lines span { display: block; }\n    .git-status-lines .M { color: var(--yellow); }\n    .git-status-lines .A { color: var(--green); }\n    .git-status-lines .D { color: var(--red); }\n    .git-status-lines .Q { color: var(--muted); }\n\n    /* ── Spinner ── */\n    .spinner {\n      display: inline-block; width: 16px; height: 16px;\n      border: 2px solid var(--border); border-top-color: var(--blue);\n      border-radius: 50%; animation: spin 0.6s linear infinite;\n    }\n    @keyframes spin { to { transform: rotate(360deg); } }\n\n    /* ── Toast ── */\n    #toast {\n      position: fixed; bottom: 1.5rem; right: 1.5rem;\n      background: var(--card); border: 1px solid var(--border);\n      padding: 0.6rem 1rem; border-radius: 8px;\n      font-size: 0.82rem; color: var(--text);\n      box-shadow: 0 4px 20px rgba(0,0,0,0.4);\n      opacity: 0; transform: translateY(8px);\n      transition: opacity 0.2s, transform 0.2s;\n      pointer-events: none; z-index: 999;\n    }\n    #toast.show { opacity: 1; transform: translateY(0); }\n\n    /* ── Scrollbar ── */\n    ::-webkit-scrollbar { width: 6px; height: 6px; }\n    ::-webkit-scrollbar-track { background: transparent; }\n    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }\n  </style>\n</head>\n<body>\n\n<header>\n  <div class=\"brand\">\n    <div class=\"brand-icon\">R</div>\n    <h1>Ralph</h1>\n  </div>\n  <div class=\"divider-v\"></div>\n  <div class=\"project-select-wrap\">\n    <span class=\"project-select-label\">项目</span>\n    <select class=\"project-select\" id=\"project-select\" onchange=\"onProjectChange(this.value)\">\n      <option value=\"\">— 选择项目 —</option>\n    </select>\n  </div>\n  <div class=\"header-right\">\n    <div class=\"loop-badge\" id=\"loop-badge\">\n      <div class=\"loop-dot\" id=\"loop-dot\"></div>\n      <span id=\"loop-label\">未选择</span>\n    </div>\n    <button class=\"btn-sm\" id=\"btn-refresh\" onclick=\"refreshCurrent()\" title=\"刷新当前视图\">刷新</button>\n  </div>\n</header>\n\n<div id=\"no-project\">\n  <h2>暂无项目</h2>\n  <p>请通过 API 创建项目，或选择已有项目</p>\n</div>\n\n<div id=\"app\">\n  <div class=\"tabs\">\n    <div class=\"tab active\" data-tab=\"tasks\" onclick=\"switchTab('tasks')\">任务</div>\n    <div class=\"tab\" data-tab=\"logs\"  onclick=\"switchTab('logs')\">日志</div>\n    <div class=\"tab\" data-tab=\"files\" onclick=\"switchTab('files')\">文件</div>\n    <div class=\"tab\" data-tab=\"status\" onclick=\"switchTab('status')\">状态</div>\n  </div>\n  <div class=\"tab-content\">\n\n    <!-- Tasks -->\n    <div class=\"tab-pane active\" id=\"pane-tasks\">\n      <div class=\"task-input-row\">\n        <input class=\"task-input\" id=\"new-task-input\" placeholder=\"添加新任务…\" onkeydown=\"onTaskKeydown(event)\" />\n        <button class=\"btn-sm success\" onclick=\"addTask()\">+ 添加</button>\n      </div>\n      <div class=\"task-list\" id=\"task-list\">\n        <div class=\"empty-hint\"><div class=\"spinner\"></div></div>\n      </div>\n    </div>\n\n    <!-- Logs -->\n    <div class=\"tab-pane\" id=\"pane-logs\">\n      <div class=\"log-controls\">\n        <label>\n          <input type=\"checkbox\" id=\"log-auto\" onchange=\"onLogAutoChange()\" />\n          自动刷新 (5s)\n        </label>\n        <label>\n          最近\n          <select class=\"log-lines-select\" id=\"log-lines\" onchange=\"loadLogs()\">\n            <option value=\"100\">100 行</option>\n            <option value=\"300\" selected>300 行</option>\n            <option value=\"500\">500 行</option>\n            <option value=\"1000\">1000 行</option>\n          </select>\n        </label>\n        <button class=\"btn-sm\" onclick=\"loadLogs()\">刷新</button>\n        <span id=\"log-total\" style=\"font-size:0.75rem;color:var(--muted)\"></span>\n      </div>\n      <div class=\"log-box\" id=\"log-box\"><span class=\"log-empty\">加载中…</span></div>\n    </div>\n\n    <!-- Files -->\n    <div class=\"tab-pane\" id=\"pane-files\">\n      <div class=\"files-search-row\">\n        <input class=\"files-search\" id=\"files-search\" placeholder=\"搜索文件…\" oninput=\"renderFiles()\" />\n        <button class=\"btn-sm\" onclick=\"loadFiles()\">刷新</button>\n      </div>\n      <table class=\"file-table\" id=\"file-table\">\n        <thead><tr><th>路径</th><th>大小</th><th>修改时间</th></tr></thead>\n        <tbody id=\"file-tbody\"></tbody>\n      </table>\n    </div>\n\n    <!-- Status -->\n    <div class=\"tab-pane\" id=\"pane-status\">\n      <div id=\"status-content\">\n        <div class=\"empty-hint\"><div class=\"spinner\"></div></div>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<div id=\"toast\"></div>\n\n<script>\n// ─── State ────────────────────────────────────────────────────────────────────\nconst LS_KEY = 'ralph_selected_project';\nlet projects = [];\nlet currentId = localStorage.getItem(LS_KEY) || '';\nlet currentTab = 'tasks';\nlet allFiles = [];\nlet logAutoTimer = null;\nlet statusRefreshTimer = null;\n\n// ─── Init ─────────────────────────────────────────────────────────────────────\nasync function init() {\n  await loadProjects();\n  const stored = currentId;\n  if (stored && projects.find(p => p.id === stored)) {\n    setProject(stored);\n  } else if (projects.length > 0) {\n    setProject(projects[0].id);\n  } else {\n    showNoProject();\n  }\n}\n\n// ─── Projects ─────────────────────────────────────────────────────────────────\nasync function loadProjects() {\n  try {\n    const r = await fetch('/api/projects');\n    projects = await r.json();\n  } catch { projects = []; }\n  renderProjectSelect();\n}\n\nfunction renderProjectSelect() {\n  const sel = document.getElementById('project-select');\n  sel.innerHTML = '<option value=\"\">— 选择项目 —</option>';\n  projects.forEach(p => {\n    const opt = document.createElement('option');\n    opt.value = p.id;\n    opt.textContent = p.name + (p.status === 'archived' ? ' (已归档)' : '');\n    sel.appendChild(opt);\n  });\n  sel.value = currentId || '';\n}\n\nfunction onProjectChange(id) {\n  if (id) setProject(id);\n  else showNoProject();\n}\n\nfunction setProject(id) {\n  currentId = id;\n  localStorage.setItem(LS_KEY, id);\n  document.getElementById('project-select').value = id;\n  document.getElementById('no-project').style.display = 'none';\n  document.getElementById('app').style.display = 'flex';\n  stopAllAutoRefresh();\n  loadCurrentTab();\n  updateLoopBadge();\n}\n\nfunction showNoProject() {\n  document.getElementById('no-project').style.display = 'flex';\n  document.getElementById('app').style.display = 'none';\n  updateLoopBadge();\n}\n\n// ─── Tabs ─────────────────────────────────────────────────────────────────────\nfunction switchTab(tab) {\n  stopAllAutoRefresh();\n  currentTab = tab;\n  document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === tab));\n  document.querySelectorAll('.tab-pane').forEach(p => p.classList.toggle('active', p.id === `pane-${tab}`));\n  loadCurrentTab();\n}\n\nfunction loadCurrentTab() {\n  if (!currentId) return;\n  if (currentTab === 'tasks')  loadTasks();\n  if (currentTab === 'logs')   loadLogs();\n  if (currentTab === 'files')  loadFiles();\n  if (currentTab === 'status') loadStatus();\n}\n\nfunction refreshCurrent() {\n  loadProjects().then(() => {\n    if (currentId) {\n      loadCurrentTab();\n      updateLoopBadge();\n    }\n  });\n}\n\n// ─── Tasks ────────────────────────────────────────────────────────────────────\nasync function loadTasks() {\n  const list = document.getElementById('task-list');\n  list.innerHTML = '<div class=\"empty-hint\"><div class=\"spinner\"></div></div>';\n  try {\n    const r = await fetch(`/api/projects/${currentId}/tasks`);\n    const tasks = await r.json();\n    renderTasks(tasks);\n  } catch {\n    list.innerHTML = '<div class=\"empty-hint\" style=\"color:var(--red)\">加载失败</div>';\n  }\n}\n\nconst STATUS_CYCLE = { pending: 'in_progress', in_progress: 'done', done: 'pending' };\nconst STATUS_LABEL = { pending: '待处理', in_progress: '进行中', done: '已完成' };\nconst STATUS_CLASS = { pending: 'pending', in_progress: 'in_progress', done: 'done' };\n\nfunction renderTasks(tasks) {\n  const list = document.getElementById('task-list');\n  if (!tasks.length) {\n    list.innerHTML = '<div class=\"empty-hint\">暂无任务，添加第一个吧</div>';\n    return;\n  }\n  list.innerHTML = '';\n  tasks.forEach(t => {\n    const item = document.createElement('div');\n    item.className = `task-item ${t.status}`;\n    item.dataset.id = t.id;\n\n    const checkmark = t.status === 'done' ? '✓' : (t.status === 'in_progress' ? '…' : '');\n    const tagCls = STATUS_CLASS[t.status] || 'pending';\n    const tagLabel = STATUS_LABEL[t.status] || t.status;\n    const nextStatus = STATUS_CYCLE[t.status] || 'pending';\n\n    item.innerHTML = `\n      <button class=\"task-status-btn\" onclick=\"cycleTaskStatus('${t.id}','${nextStatus}')\" title=\"切换状态\">${checkmark}</button>\n      <span class=\"task-title-text\">${escHtml(t.title)}</span>\n      <span class=\"task-status-tag ${tagCls}\" onclick=\"cycleTaskStatus('${t.id}','${nextStatus}')\" style=\"cursor:pointer\" title=\"切换到: ${STATUS_LABEL[nextStatus]}\">${tagLabel}</span>\n      <button class=\"task-del-btn\" onclick=\"deleteTask('${t.id}')\" title=\"删除\">✕</button>\n    `;\n    list.appendChild(item);\n  });\n}\n\nasync function addTask() {\n  const input = document.getElementById('new-task-input');\n  const title = input.value.trim();\n  if (!title) return;\n  input.value = '';\n  try {\n    await fetch(`/api/projects/${currentId}/tasks`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title }),\n    });\n    loadTasks();\n    showToast('任务已添加');\n  } catch {\n    showToast('添加失败', true);\n  }\n}\n\nfunction onTaskKeydown(e) {\n  if (e.key === 'Enter') addTask();\n}\n\nasync function cycleTaskStatus(tid, nextStatus) {\n  try {\n    await fetch(`/api/projects/${currentId}/tasks/${tid}`, {\n      method: 'PUT',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ status: nextStatus }),\n    });\n    loadTasks();\n  } catch {\n    showToast('更新失败', true);\n  }\n}\n\nasync function deleteTask(tid) {\n  if (!confirm('确认删除此任务？')) return;\n  try {\n    await fetch(`/api/projects/${currentId}/tasks/${tid}`, { method: 'DELETE' });\n    loadTasks();\n    showToast('任务已删除');\n  } catch {\n    showToast('删除失败', true);\n  }\n}\n\n// ─── Logs ─────────────────────────────────────────────────────────────────────\nasync function loadLogs() {\n  const lines = document.getElementById('log-lines').value;\n  const box = document.getElementById('log-box');\n  try {\n    const r = await fetch(`/api/projects/${currentId}/logs?lines=${lines}`);\n    const d = await r.json();\n    const atBottom = box.scrollHeight - box.scrollTop - box.clientHeight < 60;\n    box.textContent = d.logs || '';\n    if (!d.logs) box.innerHTML = '<span class=\"log-empty\">暂无日志</span>';\n    document.getElementById('log-total').textContent = `共 ${d.total_lines || 0} 行`;\n    if (atBottom) box.scrollTop = box.scrollHeight;\n  } catch {\n    box.innerHTML = '<span style=\"color:var(--red)\">加载失败</span>';\n  }\n}\n\nfunction onLogAutoChange() {\n  const checked = document.getElementById('log-auto').checked;\n  clearInterval(logAutoTimer);\n  if (checked) logAutoTimer = setInterval(loadLogs, 5000);\n}\n\n// ─── Files ────────────────────────────────────────────────────────────────────\nasync function loadFiles() {\n  const tbody = document.getElementById('file-tbody');\n  tbody.innerHTML = '<tr><td colspan=\"3\" class=\"empty-hint\"><div class=\"spinner\"></div></td></tr>';\n  try {\n    const r = await fetch(`/api/projects/${currentId}/files`);\n    const d = await r.json();\n    allFiles = d.files || [];\n    renderFiles();\n  } catch {\n    tbody.innerHTML = '<tr><td colspan=\"3\" style=\"color:var(--red);padding:0.6rem\">加载失败</td></tr>';\n  }\n}\n\nfunction renderFiles() {\n  const q = document.getElementById('files-search').value.toLowerCase();\n  const files = q ? allFiles.filter(f => f.path.toLowerCase().includes(q)) : allFiles;\n  const tbody = document.getElementById('file-tbody');\n  if (!files.length) {\n    tbody.innerHTML = '<tr><td colspan=\"3\" class=\"empty-hint\">无文件</td></tr>';\n    return;\n  }\n  tbody.innerHTML = files.map(f => `\n    <tr>\n      <td class=\"file-path\">${escHtml(f.path)}</td>\n      <td class=\"file-size\">${fmtSize(f.size)}</td>\n      <td class=\"file-mtime\">${fmtTime(f.modified)}</td>\n    </tr>\n  `).join('');\n}\n\n// ─── Status ───────────────────────────────────────────────────────────────────\nasync function loadStatus() {\n  const cont = document.getElementById('status-content');\n  cont.innerHTML = '<div class=\"empty-hint\"><div class=\"spinner\"></div></div>';\n  try {\n    const proj = projects.find(p => p.id === currentId);\n    const [gitR, dispR] = await Promise.all([\n      fetch(`/api/projects/${currentId}/git-status`).then(r => r.json()).catch(() => ({})),\n      fetch('/api/dispatcher/status').then(r => r.json()).catch(() => ({})),\n    ]);\n    const loop = dispR[currentId] || { running: false };\n    renderStatus(proj, gitR, loop);\n    updateLoopBadgeFromLoop(loop);\n  } catch {\n    cont.innerHTML = '<div class=\"empty-hint\" style=\"color:var(--red)\">加载失败</div>';\n  }\n}\n\nfunction renderStatus(proj, git, loop) {\n  const cont = document.getElementById('status-content');\n\n  const loopRunning = loop.running;\n  const loopColor = loopRunning ? 'green' : 'red';\n  const loopText  = loopRunning ? `运行中 (PID ${loop.pid})` : '已停止';\n\n  let gitSection = '';\n  if (git.has_git === false) {\n    gitSection = `<div class=\"stat-block\"><div class=\"stat-label\">Git</div><div class=\"stat-value muted\">未初始化</div></div>`;\n  } else if (git.has_git) {\n    const dirty = git.dirty ? '<span style=\"color:var(--yellow)\">有未提交变更</span>' : '<span style=\"color:var(--green)\">干净</span>';\n    const unpushed = git.unpushed_commits || 0;\n    const statusHtml = (git.status_lines || []).map(l => {\n      const cls = l.startsWith('M') ? 'M' : l.startsWith('A') ? 'A' : l.startsWith('D') ? 'D' : 'Q';\n      return `<span class=\"${cls}\">${escHtml(l)}</span>`;\n    }).join('');\n    gitSection = `\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">分支</div>\n        <div class=\"stat-value\">${escHtml(git.branch || '—')}</div>\n      </div>\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">工作区</div>\n        <div class=\"stat-value\">${dirty}${statusHtml ? '<div class=\"git-status-lines\">' + statusHtml + '</div>' : ''}</div>\n      </div>\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">未推送提交</div>\n        <div class=\"stat-value ${unpushed ? 'yellow' : 'green'}\" style=\"${unpushed ? 'color:var(--yellow)' : ''}\">${unpushed}</div>\n      </div>\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">远程仓库</div>\n        <div class=\"stat-value muted\" style=\"font-size:0.8rem\">${escHtml(git.remote || '—')}</div>\n      </div>\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">上次推送</div>\n        <div class=\"stat-value muted\">${git.last_push ? fmtTime(git.last_push) : '—'}</div>\n      </div>\n    `;\n  }\n\n  cont.innerHTML = `\n    <div style=\"display:flex;gap:0.7rem;flex-wrap:wrap;margin-bottom:1.2rem\">\n      <button class=\"btn-sm\" onclick=\"loadStatus()\">刷新状态</button>\n      ${git.has_git ? `<button class=\"btn-sm success\" id=\"btn-push\" onclick=\"pushProject()\">推送到远程</button>` : ''}\n    </div>\n    <div class=\"status-grid\">\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">项目名称</div>\n        <div class=\"stat-value\">${escHtml(proj ? proj.name : currentId)}</div>\n      </div>\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">项目状态</div>\n        <div class=\"stat-value ${proj && proj.status === 'active' ? 'green' : 'muted'}\">${proj ? proj.status : '—'}</div>\n      </div>\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">Ralph Loop</div>\n        <div class=\"stat-value ${loopColor}\">${loopText}</div>\n      </div>\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">项目路径</div>\n        <div class=\"stat-value muted\" style=\"font-size:0.78rem\">${escHtml(proj ? proj.path : '—')}</div>\n      </div>\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">创建时间</div>\n        <div class=\"stat-value muted\">${proj ? fmtTime(proj.created_at) : '—'}</div>\n      </div>\n      ${loop.started_at ? `\n      <div class=\"stat-block\">\n        <div class=\"stat-label\">Loop 启动时间</div>\n        <div class=\"stat-value muted\">${fmtTime(new Date(loop.started_at * 1000).toISOString())}</div>\n      </div>` : ''}\n      ${gitSection}\n    </div>\n  `;\n}\n\nasync function pushProject() {\n  const btn = document.getElementById('btn-push');\n  if (btn) { btn.disabled = true; btn.textContent = '推送中…'; }\n  try {\n    const r = await fetch(`/api/projects/${currentId}/push`, { method: 'POST' });\n    const d = await r.json();\n    if (d.success) showToast('推送成功');\n    else showToast(`推送失败: ${d.output}`, true);\n    loadStatus();\n  } catch {\n    showToast('推送请求失败', true);\n  }\n}\n\n// ─── Loop Badge ───────────────────────────────────────────────────────────────\nasync function updateLoopBadge() {\n  if (!currentId) {\n    document.getElementById('loop-dot').className = 'loop-dot';\n    document.getElementById('loop-label').textContent = '未选择';\n    return;\n  }\n  try {\n    const r = await fetch('/api/dispatcher/status');\n    const d = await r.json();\n    updateLoopBadgeFromLoop(d[currentId] || { running: false });\n  } catch { /* ignore */ }\n}\n\nfunction updateLoopBadgeFromLoop(loop) {\n  const dot = document.getElementById('loop-dot');\n  const lbl = document.getElementById('loop-label');\n  if (loop.running) {\n    dot.className = 'loop-dot running';\n    lbl.textContent = 'Loop 运行中';\n  } else {\n    dot.className = 'loop-dot';\n    lbl.textContent = 'Loop 已停止';\n  }\n}\n\n// ─── Auto-refresh cleanup ─────────────────────────────────────────────────────\nfunction stopAllAutoRefresh() {\n  clearInterval(logAutoTimer); logAutoTimer = null;\n  clearInterval(statusRefreshTimer); statusRefreshTimer = null;\n  const logAutoChk = document.getElementById('log-auto');\n  if (logAutoChk) logAutoChk.checked = false;\n}\n\n// ─── Utilities ────────────────────────────────────────────────────────────────\nfunction escHtml(s) {\n  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');\n}\n\nfunction fmtSize(bytes) {\n  if (bytes == null) return '—';\n  if (bytes < 1024) return `${bytes} B`;\n  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;\n  return `${(bytes / 1024 / 1024).toFixed(2)} MB`;\n}\n\nfunction fmtTime(iso) {\n  if (!iso) return '—';\n  try {\n    return new Date(iso).toLocaleString('zh-CN', {\n      year: 'numeric', month: '2-digit', day: '2-digit',\n      hour: '2-digit', minute: '2-digit',\n    });\n  } catch { return iso; }\n}\n\nlet toastTimer = null;\nfunction showToast(msg, isErr = false) {\n  const el = document.getElementById('toast');\n  el.textContent = msg;\n  el.style.borderColor = isErr ? 'rgba(255,77,94,0.3)' : 'rgba(0,201,139,0.3)';\n  el.style.color = isErr ? 'var(--red)' : 'var(--green)';\n  el.classList.add('show');\n  clearTimeout(toastTimer);\n  toastTimer = setTimeout(() => el.classList.remove('show'), 2500);\n}\n\n// ─── Start ────────────────────────────────────────────────────────────────────\ninit();\n</script>\n</body>\n</html>\n","structuredPatch":[{"oldStart":351,"oldLines":6,"newStart":351,"newLines":151,"lines":["     ::-webkit-scrollbar { width: 6px; height: 6px; }","     ::-webkit-scrollbar-track { background: transparent; }","     ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }","+","+    /* ── Create Project Modal ── */","+    .modal-overlay {","+      position: fixed; inset: 0; z-index: 500;","+      background: rgba(0,0,0,0.6);","+      backdrop-filter: blur(4px);","+      display: flex; align-items: center; justify-content: center;","+      opacity: 0; pointer-events: none;","+      transition: opacity 0.2s;","+    }","+    .modal-overlay.open { opacity: 1; pointer-events: auto; }","+","+    .modal {","+      background: var(--card);","+      border: 1px solid var(--border);","+      border-radius: 14px;","+      padding: 1.6rem 1.8rem;","+      width: 100%;","+      max-width: 480px;","+      box-shadow: 0 20px 60px rgba(0,0,0,0.5);","+      transform: translateY(10px);","+      transition: transform 0.2s;","+    }","+    .modal-overlay.open .modal { transform: translateY(0); }","+","+    .modal-header {","+      display: flex; align-items: center; justify-content: space-between;","+      margin-bottom: 1.4rem;","+    }","+    .modal-title { font-size: 1rem; font-weight: 700; }","+    .modal-close {","+      background: none; border: none; color: var(--muted);","+      font-size: 1.2rem; cursor: pointer; padding: 0.1rem 0.3rem;","+      border-radius: 4px; line-height: 1;","+      transition: color 0.15s;","+    }","+    .modal-close:hover { color: var(--text); }","+","+    .form-group { margin-bottom: 1.1rem; }","+    .form-label {","+      display: block; font-size: 0.78rem; font-weight: 600;","+      color: var(--muted); text-transform: uppercase;","+      letter-spacing: 0.05em; margin-bottom: 0.45rem;","+    }","+    .form-input {","+      width: 100%;","+      background: var(--card2);","+      border: 1px solid var(--border);","+      color: var(--text);","+      padding: 0.48rem 0.8rem;","+      border-radius: 7px;","+      font-size: 0.85rem;","+      font-family: inherit;","+      outline: none;","+      transition: border-color 0.15s;","+    }","+    .form-input:focus { border-color: rgba(96,165,250,0.5); }","+    .form-input::placeholder { color: var(--muted); opacity: 0.6; }","+","+    .radio-group { display: flex; flex-direction: column; gap: 0.5rem; }","+    .radio-option {","+      display: flex; align-items: center; gap: 0.6rem;","+      background: var(--card2);","+      border: 1px solid var(--border);","+      border-radius: 8px;","+      padding: 0.6rem 0.9rem;","+      cursor: pointer;","+      transition: border-color 0.15s;","+    }","+    .radio-option:hover { border-color: rgba(96,165,250,0.35); }","+    .radio-option input[type=radio] { accent-color: var(--blue); cursor: pointer; flex-shrink: 0; }","+    .radio-option-label { font-size: 0.84rem; flex: 1; }","+    .radio-option-desc { font-size: 0.72rem; color: var(--muted); margin-top: 0.12rem; }","+    .radio-option.selected { border-color: rgba(96,165,250,0.45); background: rgba(96,165,250,0.06); }","+","+    .conditional-field {","+      margin-top: 0.6rem;","+      display: none;","+    }","+    .conditional-field.visible { display: block; }","+","+    /* Toggle switch */","+    .toggle-row {","+      display: flex; align-items: center; justify-content: space-between;","+      background: var(--card2);","+      border: 1px solid var(--border);","+      border-radius: 8px;","+      padding: 0.65rem 0.9rem;","+    }","+    .toggle-info { flex: 1; }","+    .toggle-info-label { font-size: 0.85rem; font-weight: 500; }","+    .toggle-info-desc { font-size: 0.72rem; color: var(--muted); margin-top: 0.1rem; }","+    .toggle-switch {","+      position: relative; width: 40px; height: 22px; flex-shrink: 0;","+    }","+    .toggle-switch input { opacity: 0; width: 0; height: 0; }","+    .toggle-slider {","+      position: absolute; inset: 0;","+      background: rgba(255,255,255,0.12);","+      border-radius: 22px;","+      cursor: pointer;","+      transition: background 0.2s;","+    }","+    .toggle-slider::before {","+      content: '';","+      position: absolute;","+      width: 16px; height: 16px;","+      left: 3px; top: 3px;","+      background: #fff;","+      border-radius: 50%;","+      transition: transform 0.2s;","+    }","+    .toggle-switch input:checked + .toggle-slider { background: var(--blue); }","+    .toggle-switch input:checked + .toggle-slider::before { transform: translateX(18px); }","+","+    .modal-footer {","+      display: flex; gap: 0.7rem; justify-content: flex-end;","+      margin-top: 1.5rem;","+    }","+    .btn-cancel {","+      background: rgba(255,255,255,0.05);","+      border: 1px solid var(--border);","+      color: var(--muted);","+      padding: 0.42rem 1rem;","+      border-radius: 7px;","+      cursor: pointer;","+      font-size: 0.84rem;","+      font-family: inherit;","+      transition: background 0.15s, color 0.15s;","+    }","+    .btn-cancel:hover { background: rgba(255,255,255,0.09); color: var(--text); }","+    .btn-primary {","+      background: rgba(96,165,250,0.15);","+      border: 1px solid rgba(96,165,250,0.35);","+      color: var(--blue);","+      padding: 0.42rem 1.1rem;","+      border-radius: 7px;","+      cursor: pointer;","+      font-size: 0.84rem;","+      font-weight: 600;","+      font-family: inherit;","+      transition: background 0.15s;","+    }","+    .btn-primary:hover { background: rgba(96,165,250,0.25); }","+    .btn-primary:disabled { opacity: 0.45; cursor: not-allowed; }","   </style>"," </head>"," <body>"]}],"userModified":false,"replaceAll":false}}
