{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PQvq5eFutHhKrXAjtTtdVX","type":"tool_result","content":"     1→\"\"\"\n     2→dispatcher.py — Ralph Loop Dispatcher\n     3→\n     4→Manages one Ralph Loop subprocess per active project.\n     5→Each loop runs the Claude Code agent inside the project's directory.\n     6→\n     7→Environment variables:\n     8→  RALPH_DB            Path to SQLite DB  (default: projects.db)\n     9→  RALPH_LOGS_DIR      Directory for log files (default: logs/)\n    10→  RALPH_SYNC_INTERVAL Seconds between DB sync passes (default: 30)\n    11→  RALPH_CMD           Shell command to run as the loop.\n    12→                      The working directory is set to the project path.\n    13→                      Default: an idle placeholder — replace with the real\n    14→                      claude command, e.g.:\n    15→                        claude --dangerously-skip-permissions --print \\\n    16→                          \"Review TASKS.md and complete the next pending task.\"\n    17→\"\"\"\n    18→\n    19→import logging\n    20→import os\n    21→import signal\n    22→import sqlite3\n    23→import subprocess\n    24→import sys\n    25→import threading\n    26→import time\n    27→\n    28→logging.basicConfig(\n    29→    level=logging.INFO,\n    30→    format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\",\n    31→    datefmt=\"%Y-%m-%d %H:%M:%S\",\n    32→)\n    33→logger = logging.getLogger(\"ralph.dispatcher\")\n    34→\n    35→DB_PATH = os.environ.get(\"RALPH_DB\", \"projects.db\")\n    36→LOGS_DIR = os.environ.get(\"RALPH_LOGS_DIR\", \"logs\")\n    37→SYNC_INTERVAL = int(os.environ.get(\"RALPH_SYNC_INTERVAL\", \"30\"))\n    38→\n    39→# Override this with your real Claude Code command.\n    40→# The process is launched with cwd = project path.\n    41→DEFAULT_RALPH_CMD = (\n    42→    'while true; do echo \"[$(date -u +%FT%T)Z] Ralph Loop heartbeat\"; sleep 60; done'\n    43→)\n    44→RALPH_CMD = os.environ.get(\"RALPH_CMD\", DEFAULT_RALPH_CMD)\n    45→\n    46→\n    47→class RalphLoopDispatcher:\n    48→    \"\"\"Manages one long-running subprocess (Ralph Loop) per active project.\"\"\"\n    49→\n    50→    def __init__(self, db_path: str = DB_PATH):\n    51→        self.db_path = db_path\n    52→        # project_id -> {\"proc\": Popen, \"name\": str, \"log_fh\": file, \"started_at\": float}\n    53→        self._procs: dict = {}\n    54→        self._lock = threading.Lock()\n    55→        self._running = False\n    56→\n    57→    # ── DB helpers ────────────────────────────────────────────────\n    58→\n    59→    def _get_db(self):\n    60→        conn = sqlite3.connect(self.db_path)\n    61→        conn.row_factory = sqlite3.Row\n    62→        return conn\n    63→\n    64→    def get_active_projects(self) -> list:\n    65→        try:\n    66→            conn = self._get_db()\n    67→            rows = conn.execute(\n    68→                \"SELECT * FROM projects WHERE status = 'active'\"\n    69→            ).fetchall()\n    70→            conn.close()\n    71→            return [dict(r) for r in rows]\n    72→        except sqlite3.OperationalError:\n    73→            return []\n    74→\n    75→    # ── Process lifecycle ─────────────────────────────────────────\n    76→\n    77→    def _is_running(self, project_id: str) -> bool:\n    78→        with self._lock:\n    79→            entry = self._procs.get(project_id)\n    80→            return entry is not None and entry[\"proc\"].poll() is None\n    81→\n    82→    def start_loop(self, project: dict) -> None:\n    83→        \"\"\"Start a Ralph Loop for the given project (no-op if already running).\"\"\"\n    84→        pid = project[\"id\"]\n    85→        name = project[\"name\"]\n    86→        path = project[\"path\"]\n    87→\n    88→        if self._is_running(pid):\n    89→            logger.debug(\"Loop already running for '%s'\", name)\n    90→            return\n    91→\n    92→        # Clean up any stale entry from a previously-crashed process.\n    93→        with self._lock:\n    94→            stale = self._procs.pop(pid, None)\n    95→        if stale:\n    96→            try:\n    97→                stale[\"log_fh\"].close()\n    98→            except Exception:\n    99→                pass\n   100→            logger.info(\"Restarting crashed loop for '%s'\", name)\n   101→\n   102→        os.makedirs(path, exist_ok=True)\n   103→        os.makedirs(LOGS_DIR, exist_ok=True)\n   104→        log_path = os.path.join(LOGS_DIR, f\"{pid}.log\")\n   105→\n   106→        try:\n   107→            log_fh = open(log_path, \"a\", encoding=\"utf-8\")\n   108→            _sep = \"=\" * 60\n   109→            log_fh.write(\n   110→                f\"\\n{_sep}\\n\"\n   111→                f\"Ralph Loop started  {time.strftime('%Y-%m-%d %H:%M:%S UTC', time.gmtime())}\\n\"\n   112→                f\"Project : {name}\\n\"\n   113→                f\"Path    : {path}\\n\"\n   114→                f\"Command : {RALPH_CMD}\\n\"\n   115→                f\"{_sep}\\n\\n\"\n   116→            )\n   117→            log_fh.flush()\n   118→\n   119→            proc = subprocess.Popen(\n   120→                RALPH_CMD,\n   121→                shell=True,\n   122→                cwd=path,\n   123→                stdout=log_fh,\n   124→                stderr=log_fh,\n   125→                stdin=subprocess.DEVNULL,\n   126→                # New process group so we can kill the whole tree\n   127→                preexec_fn=os.setsid,\n   128→            )\n   129→\n   130→            with self._lock:\n   131→                self._procs[pid] = {\n   132→                    \"proc\": proc,\n   133→                    \"name\": name,\n   134→                    \"log_fh\": log_fh,\n   135→                    \"started_at\": time.time(),\n   136→                }\n   137→\n   138→            logger.info(\"Started Ralph Loop for '%s' (PID %d)\", name, proc.pid)\n   139→\n   140→        except Exception as exc:\n   141→            logger.error(\"Failed to start loop for '%s': %s\", name, exc)\n   142→\n   143→    def stop_loop(self, project_id: str) -> None:\n   144→        \"\"\"Stop the Ralph Loop for the given project.\"\"\"\n   145→        with self._lock:\n   146→            entry = self._procs.get(project_id)\n   147→            if entry is None:\n   148→                return\n   149→\n   150→            proc = entry[\"proc\"]\n   151→            name = entry[\"name\"]\n   152→            log_fh = entry.get(\"log_fh\")\n   153→\n   154→            if proc.poll() is None:\n   155→                try:\n   156→                    os.killpg(os.getpgid(proc.pid), signal.SIGTERM)\n   157→                    proc.wait(timeout=5)\n   158→                except subprocess.TimeoutExpired:\n   159→                    try:\n   160→                        os.killpg(os.getpgid(proc.pid), signal.SIGKILL)\n   161→                    except OSError:\n   162→                        pass\n   163→                except OSError:\n   164→                    pass\n   165→\n   166→            if log_fh:\n   167→                try:\n   168→                    log_fh.write(\n   169→                        f\"\\nRalph Loop stopped  \"\n   170→                        f\"{time.strftime('%Y-%m-%d %H:%M:%S UTC', time.gmtime())}\\n\"\n   171→                    )\n   172→                    log_fh.close()\n   173→                except Exception:\n   174→                    pass\n   175→\n   176→            del self._procs[project_id]\n   177→            logger.info(\"Stopped Ralph Loop for '%s'\", name)\n   178→\n   179→    # ── Status ───────────────────────────────────────────────────\n   180→\n   181→    def get_loop_status(self, project_id: str) -> dict:\n   182→        with self._lock:\n   183→            entry = self._procs.get(project_id)\n   184→            if entry is None:\n   185→                return {\"running\": False}\n   186→            proc = entry[\"proc\"]\n   187→            running = proc.poll() is None\n   188→            return {\n   189→                \"running\": running,\n   190→                \"pid\": proc.pid if running else None,\n   191→                \"started_at\": entry.get(\"started_at\"),\n   192→                \"exit_code\": proc.returncode if not running else None,\n   193→            }\n   194→\n   195→    def get_all_statuses(self) -> dict:\n   196→        with self._lock:\n   197→            return {\n   198→                pid: {\n   199→                    \"running\": entry[\"proc\"].poll() is None,\n   200→                    \"pid\": entry[\"proc\"].pid,\n   201→                    \"name\": entry[\"name\"],\n   202→                    \"started_at\": entry.get(\"started_at\"),\n   203→                }\n   204→                for pid, entry in self._procs.items()\n   205→            }\n   206→\n   207→    # ── Sync ─────────────────────────────────────────────────────\n   208→\n   209→    def sync(self) -> None:\n   210→        \"\"\"Reconcile running loops with active projects in the DB.\"\"\"\n   211→        active = self.get_active_projects()\n   212→        active_ids = {p[\"id\"] for p in active}\n   213→\n   214→        # Stop loops for projects no longer active\n   215→        with self._lock:\n   216→            stale = set(self._procs.keys()) - active_ids\n   217→        for pid in stale:\n   218→            self.stop_loop(pid)\n   219→\n   220→        # Start (or restart crashed) loops for active projects\n   221→        for project in active:\n   222→            if not self._is_running(project[\"id\"]):\n   223→                self.start_loop(project)\n   224→\n   225→    # ── Main loop ────────────────────────────────────────────────\n   226→\n   227→    def run(self, interval: int = SYNC_INTERVAL) -> None:\n   228→        \"\"\"Blocking main loop — call start_background() for async use.\"\"\"\n   229→        self._running = True\n   230→        logger.info(\"Dispatcher started (sync interval: %ds)\", interval)\n   231→        while self._running:\n   232→            try:\n   233→                self.sync()\n   234→            except Exception as exc:\n   235→                logger.error(\"Sync error: %s\", exc)\n   236→            # Sleep in small increments so we can stop cleanly\n   237→            for _ in range(interval * 10):\n   238→                if not self._running:\n   239→                    break\n   240→                time.sleep(0.1)\n   241→        logger.info(\"Dispatcher stopped\")\n   242→\n   243→    def start_background(self) -> threading.Thread:\n   244→        \"\"\"Start the dispatcher in a daemon thread.\"\"\"\n   245→        t = threading.Thread(target=self.run, daemon=True, name=\"RalphDispatcher\")\n   246→        t.start()\n   247→        return t\n   248→\n   249→    def shutdown(self) -> None:\n   250→        \"\"\"Stop all loops and the dispatcher.\"\"\"\n   251→        self._running = False\n   252→        with self._lock:\n   253→            project_ids = list(self._procs.keys())\n   254→        for pid in project_ids:\n   255→            self.stop_loop(pid)\n   256→        logger.info(\"All Ralph Loops stopped\")\n   257→\n   258→\n   259→# ── Singleton used by app.py ─────────────────────────────────────\n   260→_dispatcher: RalphLoopDispatcher | None = None\n   261→\n   262→\n   263→def get_dispatcher() -> RalphLoopDispatcher:\n   264→    global _dispatcher\n   265→    if _dispatcher is None:\n   266→        _dispatcher = RalphLoopDispatcher()\n   267→    return _dispatcher\n   268→\n   269→\n   270→# ── Standalone entry point ───────────────────────────────────────\n   271→if __name__ == \"__main__\":\n   272→    dispatcher = RalphLoopDispatcher()\n   273→\n   274→    def _handle_signal(sig, frame):\n   275→        logger.info(\"Received signal %d — shutting down\", sig)\n   276→        dispatcher.shutdown()\n   277→        sys.exit(0)\n   278→\n   279→    signal.signal(signal.SIGINT, _handle_signal)\n   280→    signal.signal(signal.SIGTERM, _handle_signal)\n   281→\n   282→    dispatcher.run()\n   283→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"4899e921-a0c5-444b-b6a7-bc2b583e1e67","uuid":"a4487b32-4815-4b78-b1de-7d428cf05407","tool_use_result":{"type":"text","file":{"filePath":"/home/ubuntu/my-project/dispatcher.py","content":"\"\"\"\ndispatcher.py — Ralph Loop Dispatcher\n\nManages one Ralph Loop subprocess per active project.\nEach loop runs the Claude Code agent inside the project's directory.\n\nEnvironment variables:\n  RALPH_DB            Path to SQLite DB  (default: projects.db)\n  RALPH_LOGS_DIR      Directory for log files (default: logs/)\n  RALPH_SYNC_INTERVAL Seconds between DB sync passes (default: 30)\n  RALPH_CMD           Shell command to run as the loop.\n                      The working directory is set to the project path.\n                      Default: an idle placeholder — replace with the real\n                      claude command, e.g.:\n                        claude --dangerously-skip-permissions --print \\\n                          \"Review TASKS.md and complete the next pending task.\"\n\"\"\"\n\nimport logging\nimport os\nimport signal\nimport sqlite3\nimport subprocess\nimport sys\nimport threading\nimport time\n\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\",\n    datefmt=\"%Y-%m-%d %H:%M:%S\",\n)\nlogger = logging.getLogger(\"ralph.dispatcher\")\n\nDB_PATH = os.environ.get(\"RALPH_DB\", \"projects.db\")\nLOGS_DIR = os.environ.get(\"RALPH_LOGS_DIR\", \"logs\")\nSYNC_INTERVAL = int(os.environ.get(\"RALPH_SYNC_INTERVAL\", \"30\"))\n\n# Override this with your real Claude Code command.\n# The process is launched with cwd = project path.\nDEFAULT_RALPH_CMD = (\n    'while true; do echo \"[$(date -u +%FT%T)Z] Ralph Loop heartbeat\"; sleep 60; done'\n)\nRALPH_CMD = os.environ.get(\"RALPH_CMD\", DEFAULT_RALPH_CMD)\n\n\nclass RalphLoopDispatcher:\n    \"\"\"Manages one long-running subprocess (Ralph Loop) per active project.\"\"\"\n\n    def __init__(self, db_path: str = DB_PATH):\n        self.db_path = db_path\n        # project_id -> {\"proc\": Popen, \"name\": str, \"log_fh\": file, \"started_at\": float}\n        self._procs: dict = {}\n        self._lock = threading.Lock()\n        self._running = False\n\n    # ── DB helpers ────────────────────────────────────────────────\n\n    def _get_db(self):\n        conn = sqlite3.connect(self.db_path)\n        conn.row_factory = sqlite3.Row\n        return conn\n\n    def get_active_projects(self) -> list:\n        try:\n            conn = self._get_db()\n            rows = conn.execute(\n                \"SELECT * FROM projects WHERE status = 'active'\"\n            ).fetchall()\n            conn.close()\n            return [dict(r) for r in rows]\n        except sqlite3.OperationalError:\n            return []\n\n    # ── Process lifecycle ─────────────────────────────────────────\n\n    def _is_running(self, project_id: str) -> bool:\n        with self._lock:\n            entry = self._procs.get(project_id)\n            return entry is not None and entry[\"proc\"].poll() is None\n\n    def start_loop(self, project: dict) -> None:\n        \"\"\"Start a Ralph Loop for the given project (no-op if already running).\"\"\"\n        pid = project[\"id\"]\n        name = project[\"name\"]\n        path = project[\"path\"]\n\n        if self._is_running(pid):\n            logger.debug(\"Loop already running for '%s'\", name)\n            return\n\n        # Clean up any stale entry from a previously-crashed process.\n        with self._lock:\n            stale = self._procs.pop(pid, None)\n        if stale:\n            try:\n                stale[\"log_fh\"].close()\n            except Exception:\n                pass\n            logger.info(\"Restarting crashed loop for '%s'\", name)\n\n        os.makedirs(path, exist_ok=True)\n        os.makedirs(LOGS_DIR, exist_ok=True)\n        log_path = os.path.join(LOGS_DIR, f\"{pid}.log\")\n\n        try:\n            log_fh = open(log_path, \"a\", encoding=\"utf-8\")\n            _sep = \"=\" * 60\n            log_fh.write(\n                f\"\\n{_sep}\\n\"\n                f\"Ralph Loop started  {time.strftime('%Y-%m-%d %H:%M:%S UTC', time.gmtime())}\\n\"\n                f\"Project : {name}\\n\"\n                f\"Path    : {path}\\n\"\n                f\"Command : {RALPH_CMD}\\n\"\n                f\"{_sep}\\n\\n\"\n            )\n            log_fh.flush()\n\n            proc = subprocess.Popen(\n                RALPH_CMD,\n                shell=True,\n                cwd=path,\n                stdout=log_fh,\n                stderr=log_fh,\n                stdin=subprocess.DEVNULL,\n                # New process group so we can kill the whole tree\n                preexec_fn=os.setsid,\n            )\n\n            with self._lock:\n                self._procs[pid] = {\n                    \"proc\": proc,\n                    \"name\": name,\n                    \"log_fh\": log_fh,\n                    \"started_at\": time.time(),\n                }\n\n            logger.info(\"Started Ralph Loop for '%s' (PID %d)\", name, proc.pid)\n\n        except Exception as exc:\n            logger.error(\"Failed to start loop for '%s': %s\", name, exc)\n\n    def stop_loop(self, project_id: str) -> None:\n        \"\"\"Stop the Ralph Loop for the given project.\"\"\"\n        with self._lock:\n            entry = self._procs.get(project_id)\n            if entry is None:\n                return\n\n            proc = entry[\"proc\"]\n            name = entry[\"name\"]\n            log_fh = entry.get(\"log_fh\")\n\n            if proc.poll() is None:\n                try:\n                    os.killpg(os.getpgid(proc.pid), signal.SIGTERM)\n                    proc.wait(timeout=5)\n                except subprocess.TimeoutExpired:\n                    try:\n                        os.killpg(os.getpgid(proc.pid), signal.SIGKILL)\n                    except OSError:\n                        pass\n                except OSError:\n                    pass\n\n            if log_fh:\n                try:\n                    log_fh.write(\n                        f\"\\nRalph Loop stopped  \"\n                        f\"{time.strftime('%Y-%m-%d %H:%M:%S UTC', time.gmtime())}\\n\"\n                    )\n                    log_fh.close()\n                except Exception:\n                    pass\n\n            del self._procs[project_id]\n            logger.info(\"Stopped Ralph Loop for '%s'\", name)\n\n    # ── Status ───────────────────────────────────────────────────\n\n    def get_loop_status(self, project_id: str) -> dict:\n        with self._lock:\n            entry = self._procs.get(project_id)\n            if entry is None:\n                return {\"running\": False}\n            proc = entry[\"proc\"]\n            running = proc.poll() is None\n            return {\n                \"running\": running,\n                \"pid\": proc.pid if running else None,\n                \"started_at\": entry.get(\"started_at\"),\n                \"exit_code\": proc.returncode if not running else None,\n            }\n\n    def get_all_statuses(self) -> dict:\n        with self._lock:\n            return {\n                pid: {\n                    \"running\": entry[\"proc\"].poll() is None,\n                    \"pid\": entry[\"proc\"].pid,\n                    \"name\": entry[\"name\"],\n                    \"started_at\": entry.get(\"started_at\"),\n                }\n                for pid, entry in self._procs.items()\n            }\n\n    # ── Sync ─────────────────────────────────────────────────────\n\n    def sync(self) -> None:\n        \"\"\"Reconcile running loops with active projects in the DB.\"\"\"\n        active = self.get_active_projects()\n        active_ids = {p[\"id\"] for p in active}\n\n        # Stop loops for projects no longer active\n        with self._lock:\n            stale = set(self._procs.keys()) - active_ids\n        for pid in stale:\n            self.stop_loop(pid)\n\n        # Start (or restart crashed) loops for active projects\n        for project in active:\n            if not self._is_running(project[\"id\"]):\n                self.start_loop(project)\n\n    # ── Main loop ────────────────────────────────────────────────\n\n    def run(self, interval: int = SYNC_INTERVAL) -> None:\n        \"\"\"Blocking main loop — call start_background() for async use.\"\"\"\n        self._running = True\n        logger.info(\"Dispatcher started (sync interval: %ds)\", interval)\n        while self._running:\n            try:\n                self.sync()\n            except Exception as exc:\n                logger.error(\"Sync error: %s\", exc)\n            # Sleep in small increments so we can stop cleanly\n            for _ in range(interval * 10):\n                if not self._running:\n                    break\n                time.sleep(0.1)\n        logger.info(\"Dispatcher stopped\")\n\n    def start_background(self) -> threading.Thread:\n        \"\"\"Start the dispatcher in a daemon thread.\"\"\"\n        t = threading.Thread(target=self.run, daemon=True, name=\"RalphDispatcher\")\n        t.start()\n        return t\n\n    def shutdown(self) -> None:\n        \"\"\"Stop all loops and the dispatcher.\"\"\"\n        self._running = False\n        with self._lock:\n            project_ids = list(self._procs.keys())\n        for pid in project_ids:\n            self.stop_loop(pid)\n        logger.info(\"All Ralph Loops stopped\")\n\n\n# ── Singleton used by app.py ─────────────────────────────────────\n_dispatcher: RalphLoopDispatcher | None = None\n\n\ndef get_dispatcher() -> RalphLoopDispatcher:\n    global _dispatcher\n    if _dispatcher is None:\n        _dispatcher = RalphLoopDispatcher()\n    return _dispatcher\n\n\n# ── Standalone entry point ───────────────────────────────────────\nif __name__ == \"__main__\":\n    dispatcher = RalphLoopDispatcher()\n\n    def _handle_signal(sig, frame):\n        logger.info(\"Received signal %d — shutting down\", sig)\n        dispatcher.shutdown()\n        sys.exit(0)\n\n    signal.signal(signal.SIGINT, _handle_signal)\n    signal.signal(signal.SIGTERM, _handle_signal)\n\n    dispatcher.run()\n","numLines":283,"startLine":1,"totalLines":283}}}
