{"type":"rate_limit_event","rate_limit_info":{"status":"allowed","resetsAt":1771956000,"rateLimitType":"five_hour","overageStatus":"rejected","overageDisabledReason":"org_level_disabled","isUsingOverage":false},"uuid":"c6cc5c6e-bdd7-461e-bad5-84df95f75297","session_id":"8ed77ab3-b333-40a8-8a9f-a6b93e8c0982"}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01T9bDN5kdE6g4cx5foYGtDr","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01X8imWGL6poEqRj13t2sUTK","name":"Write","input":{"file_path":"/home/ubuntu/my-project/dispatcher.py","content":"\"\"\"\ndispatcher.py — Ralph Loop Dispatcher\n\nManages one Ralph Loop subprocess per active project.\nEach loop runs the Claude Code agent inside the project's directory.\n\nEnvironment variables:\n  RALPH_DB            Path to SQLite DB  (default: projects.db)\n  RALPH_LOGS_DIR      Directory for log files (default: logs/)\n  RALPH_SYNC_INTERVAL Seconds between DB sync passes (default: 30)\n  RALPH_CMD           Shell command to run as the loop.\n                      The working directory is set to the project path.\n                      Default: an idle placeholder — replace with the real\n                      claude command, e.g.:\n                        claude --dangerously-skip-permissions --print \\\n                          \"Review TASKS.md and complete the next pending task.\"\n\"\"\"\n\nimport logging\nimport os\nimport signal\nimport sqlite3\nimport subprocess\nimport sys\nimport threading\nimport time\n\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\",\n    datefmt=\"%Y-%m-%d %H:%M:%S\",\n)\nlogger = logging.getLogger(\"ralph.dispatcher\")\n\nDB_PATH = os.environ.get(\"RALPH_DB\", \"projects.db\")\nLOGS_DIR = os.environ.get(\"RALPH_LOGS_DIR\", \"logs\")\nSYNC_INTERVAL = int(os.environ.get(\"RALPH_SYNC_INTERVAL\", \"30\"))\n\n# Override this with your real Claude Code command.\n# The process is launched with cwd = project path.\nDEFAULT_RALPH_CMD = (\n    'while true; do echo \"[$(date -u +%FT%T)Z] Ralph Loop heartbeat\"; sleep 60; done'\n)\nRALPH_CMD = os.environ.get(\"RALPH_CMD\", DEFAULT_RALPH_CMD)\n\n\nclass RalphLoopDispatcher:\n    \"\"\"Manages one long-running subprocess (Ralph Loop) per active project.\"\"\"\n\n    def __init__(self, db_path: str = DB_PATH):\n        self.db_path = db_path\n        # project_id -> {\"proc\": Popen, \"name\": str, \"log_fh\": file, \"started_at\": float}\n        self._procs: dict = {}\n        self._lock = threading.Lock()\n        self._running = False\n\n    # ── DB helpers ────────────────────────────────────────────────\n\n    def _get_db(self):\n        conn = sqlite3.connect(self.db_path)\n        conn.row_factory = sqlite3.Row\n        return conn\n\n    def get_active_projects(self) -> list:\n        try:\n            conn = self._get_db()\n            rows = conn.execute(\n                \"SELECT * FROM projects WHERE status = 'active'\"\n            ).fetchall()\n            conn.close()\n            return [dict(r) for r in rows]\n        except sqlite3.OperationalError:\n            return []\n\n    # ── Process lifecycle ─────────────────────────────────────────\n\n    def _is_running(self, project_id: str) -> bool:\n        with self._lock:\n            entry = self._procs.get(project_id)\n            return entry is not None and entry[\"proc\"].poll() is None\n\n    def start_loop(self, project: dict) -> None:\n        \"\"\"Start a Ralph Loop for the given project (no-op if already running).\"\"\"\n        pid = project[\"id\"]\n        name = project[\"name\"]\n        path = project[\"path\"]\n\n        if self._is_running(pid):\n            logger.debug(\"Loop already running for '%s'\", name)\n            return\n\n        os.makedirs(path, exist_ok=True)\n        os.makedirs(LOGS_DIR, exist_ok=True)\n        log_path = os.path.join(LOGS_DIR, f\"{pid}.log\")\n\n        try:\n            log_fh = open(log_path, \"a\", encoding=\"utf-8\")\n            _sep = \"=\" * 60\n            log_fh.write(\n                f\"\\n{_sep}\\n\"\n                f\"Ralph Loop started  {time.strftime('%Y-%m-%d %H:%M:%S UTC', time.gmtime())}\\n\"\n                f\"Project : {name}\\n\"\n                f\"Path    : {path}\\n\"\n                f\"Command : {RALPH_CMD}\\n\"\n                f\"{_sep}\\n\\n\"\n            )\n            log_fh.flush()\n\n            proc = subprocess.Popen(\n                RALPH_CMD,\n                shell=True,\n                cwd=path,\n                stdout=log_fh,\n                stderr=log_fh,\n                stdin=subprocess.DEVNULL,\n                # New process group so we can kill the whole tree\n                preexec_fn=os.setsid,\n            )\n\n            with self._lock:\n                self._procs[pid] = {\n                    \"proc\": proc,\n                    \"name\": name,\n                    \"log_fh\": log_fh,\n                    \"started_at\": time.time(),\n                }\n\n            logger.info(\"Started Ralph Loop for '%s' (PID %d)\", name, proc.pid)\n\n        except Exception as exc:\n            logger.error(\"Failed to start loop for '%s': %s\", name, exc)\n\n    def stop_loop(self, project_id: str) -> None:\n        \"\"\"Stop the Ralph Loop for the given project.\"\"\"\n        with self._lock:\n            entry = self._procs.get(project_id)\n            if entry is None:\n                return\n\n            proc = entry[\"proc\"]\n            name = entry[\"name\"]\n            log_fh = entry.get(\"log_fh\")\n\n            if proc.poll() is None:\n                try:\n                    os.killpg(os.getpgid(proc.pid), signal.SIGTERM)\n                    proc.wait(timeout=5)\n                except subprocess.TimeoutExpired:\n                    try:\n                        os.killpg(os.getpgid(proc.pid), signal.SIGKILL)\n                    except OSError:\n                        pass\n                except OSError:\n                    pass\n\n            if log_fh:\n                try:\n                    log_fh.write(\n                        f\"\\nRalph Loop stopped  \"\n                        f\"{time.strftime('%Y-%m-%d %H:%M:%S UTC', time.gmtime())}\\n\"\n                    )\n                    log_fh.close()\n                except Exception:\n                    pass\n\n            del self._procs[project_id]\n            logger.info(\"Stopped Ralph Loop for '%s'\", name)\n\n    # ── Status ───────────────────────────────────────────────────\n\n    def get_loop_status(self, project_id: str) -> dict:\n        with self._lock:\n            entry = self._procs.get(project_id)\n            if entry is None:\n                return {\"running\": False}\n            proc = entry[\"proc\"]\n            running = proc.poll() is None\n            return {\n                \"running\": running,\n                \"pid\": proc.pid if running else None,\n                \"started_at\": entry.get(\"started_at\"),\n                \"exit_code\": proc.returncode if not running else None,\n            }\n\n    def get_all_statuses(self) -> dict:\n        with self._lock:\n            return {\n                pid: {\n                    \"running\": entry[\"proc\"].poll() is None,\n                    \"pid\": entry[\"proc\"].pid,\n                    \"name\": entry[\"name\"],\n                    \"started_at\": entry.get(\"started_at\"),\n                }\n                for pid, entry in self._procs.items()\n            }\n\n    # ── Sync ─────────────────────────────────────────────────────\n\n    def sync(self) -> None:\n        \"\"\"Reconcile running loops with active projects in the DB.\"\"\"\n        active = self.get_active_projects()\n        active_ids = {p[\"id\"] for p in active}\n\n        # Stop loops for projects no longer active\n        with self._lock:\n            stale = set(self._procs.keys()) - active_ids\n        for pid in stale:\n            self.stop_loop(pid)\n\n        # Start (or restart crashed) loops for active projects\n        for project in active:\n            if not self._is_running(project[\"id\"]):\n                self.start_loop(project)\n\n    # ── Main loop ────────────────────────────────────────────────\n\n    def run(self, interval: int = SYNC_INTERVAL) -> None:\n        \"\"\"Blocking main loop — call start_background() for async use.\"\"\"\n        self._running = True\n        logger.info(\"Dispatcher started (sync interval: %ds)\", interval)\n        while self._running:\n            try:\n                self.sync()\n            except Exception as exc:\n                logger.error(\"Sync error: %s\", exc)\n            # Sleep in small increments so we can stop cleanly\n            for _ in range(interval * 10):\n                if not self._running:\n                    break\n                time.sleep(0.1)\n        logger.info(\"Dispatcher stopped\")\n\n    def start_background(self) -> threading.Thread:\n        \"\"\"Start the dispatcher in a daemon thread.\"\"\"\n        t = threading.Thread(target=self.run, daemon=True, name=\"RalphDispatcher\")\n        t.start()\n        return t\n\n    def shutdown(self) -> None:\n        \"\"\"Stop all loops and the dispatcher.\"\"\"\n        self._running = False\n        with self._lock:\n            project_ids = list(self._procs.keys())\n        for pid in project_ids:\n            self.stop_loop(pid)\n        logger.info(\"All Ralph Loops stopped\")\n\n\n# ── Singleton used by app.py ─────────────────────────────────────\n_dispatcher: RalphLoopDispatcher | None = None\n\n\ndef get_dispatcher() -> RalphLoopDispatcher:\n    global _dispatcher\n    if _dispatcher is None:\n        _dispatcher = RalphLoopDispatcher()\n    return _dispatcher\n\n\n# ── Standalone entry point ───────────────────────────────────────\nif __name__ == \"__main__\":\n    dispatcher = RalphLoopDispatcher()\n\n    def _handle_signal(sig, frame):\n        logger.info(\"Received signal %d — shutting down\", sig)\n        dispatcher.shutdown()\n        sys.exit(0)\n\n    signal.signal(signal.SIGINT, _handle_signal)\n    signal.signal(signal.SIGTERM, _handle_signal)\n\n    dispatcher.run()\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":276,"cache_read_input_tokens":51813,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":276},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8ed77ab3-b333-40a8-8a9f-a6b93e8c0982","uuid":"b5352131-ef5d-4f28-a2f6-dd24b2705759"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X8imWGL6poEqRj13t2sUTK","type":"tool_result","content":"File created successfully at: /home/ubuntu/my-project/dispatcher.py"}]},"parent_tool_use_id":null,"session_id":"8ed77ab3-b333-40a8-8a9f-a6b93e8c0982","uuid":"c5b13df6-77dc-4160-9c0d-2936bb8ce46d","tool_use_result":{"type":"create","filePath":"/home/ubuntu/my-project/dispatcher.py","content":"\"\"\"\ndispatcher.py — Ralph Loop Dispatcher\n\nManages one Ralph Loop subprocess per active project.\nEach loop runs the Claude Code agent inside the project's directory.\n\nEnvironment variables:\n  RALPH_DB            Path to SQLite DB  (default: projects.db)\n  RALPH_LOGS_DIR      Directory for log files (default: logs/)\n  RALPH_SYNC_INTERVAL Seconds between DB sync passes (default: 30)\n  RALPH_CMD           Shell command to run as the loop.\n                      The working directory is set to the project path.\n                      Default: an idle placeholder — replace with the real\n                      claude command, e.g.:\n                        claude --dangerously-skip-permissions --print \\\n                          \"Review TASKS.md and complete the next pending task.\"\n\"\"\"\n\nimport logging\nimport os\nimport signal\nimport sqlite3\nimport subprocess\nimport sys\nimport threading\nimport time\n\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\",\n    datefmt=\"%Y-%m-%d %H:%M:%S\",\n)\nlogger = logging.getLogger(\"ralph.dispatcher\")\n\nDB_PATH = os.environ.get(\"RALPH_DB\", \"projects.db\")\nLOGS_DIR = os.environ.get(\"RALPH_LOGS_DIR\", \"logs\")\nSYNC_INTERVAL = int(os.environ.get(\"RALPH_SYNC_INTERVAL\", \"30\"))\n\n# Override this with your real Claude Code command.\n# The process is launched with cwd = project path.\nDEFAULT_RALPH_CMD = (\n    'while true; do echo \"[$(date -u +%FT%T)Z] Ralph Loop heartbeat\"; sleep 60; done'\n)\nRALPH_CMD = os.environ.get(\"RALPH_CMD\", DEFAULT_RALPH_CMD)\n\n\nclass RalphLoopDispatcher:\n    \"\"\"Manages one long-running subprocess (Ralph Loop) per active project.\"\"\"\n\n    def __init__(self, db_path: str = DB_PATH):\n        self.db_path = db_path\n        # project_id -> {\"proc\": Popen, \"name\": str, \"log_fh\": file, \"started_at\": float}\n        self._procs: dict = {}\n        self._lock = threading.Lock()\n        self._running = False\n\n    # ── DB helpers ────────────────────────────────────────────────\n\n    def _get_db(self):\n        conn = sqlite3.connect(self.db_path)\n        conn.row_factory = sqlite3.Row\n        return conn\n\n    def get_active_projects(self) -> list:\n        try:\n            conn = self._get_db()\n            rows = conn.execute(\n                \"SELECT * FROM projects WHERE status = 'active'\"\n            ).fetchall()\n            conn.close()\n            return [dict(r) for r in rows]\n        except sqlite3.OperationalError:\n            return []\n\n    # ── Process lifecycle ─────────────────────────────────────────\n\n    def _is_running(self, project_id: str) -> bool:\n        with self._lock:\n            entry = self._procs.get(project_id)\n            return entry is not None and entry[\"proc\"].poll() is None\n\n    def start_loop(self, project: dict) -> None:\n        \"\"\"Start a Ralph Loop for the given project (no-op if already running).\"\"\"\n        pid = project[\"id\"]\n        name = project[\"name\"]\n        path = project[\"path\"]\n\n        if self._is_running(pid):\n            logger.debug(\"Loop already running for '%s'\", name)\n            return\n\n        os.makedirs(path, exist_ok=True)\n        os.makedirs(LOGS_DIR, exist_ok=True)\n        log_path = os.path.join(LOGS_DIR, f\"{pid}.log\")\n\n        try:\n            log_fh = open(log_path, \"a\", encoding=\"utf-8\")\n            _sep = \"=\" * 60\n            log_fh.write(\n                f\"\\n{_sep}\\n\"\n                f\"Ralph Loop started  {time.strftime('%Y-%m-%d %H:%M:%S UTC', time.gmtime())}\\n\"\n                f\"Project : {name}\\n\"\n                f\"Path    : {path}\\n\"\n                f\"Command : {RALPH_CMD}\\n\"\n                f\"{_sep}\\n\\n\"\n            )\n            log_fh.flush()\n\n            proc = subprocess.Popen(\n                RALPH_CMD,\n                shell=True,\n                cwd=path,\n                stdout=log_fh,\n                stderr=log_fh,\n                stdin=subprocess.DEVNULL,\n                # New process group so we can kill the whole tree\n                preexec_fn=os.setsid,\n            )\n\n            with self._lock:\n                self._procs[pid] = {\n                    \"proc\": proc,\n                    \"name\": name,\n                    \"log_fh\": log_fh,\n                    \"started_at\": time.time(),\n                }\n\n            logger.info(\"Started Ralph Loop for '%s' (PID %d)\", name, proc.pid)\n\n        except Exception as exc:\n            logger.error(\"Failed to start loop for '%s': %s\", name, exc)\n\n    def stop_loop(self, project_id: str) -> None:\n        \"\"\"Stop the Ralph Loop for the given project.\"\"\"\n        with self._lock:\n            entry = self._procs.get(project_id)\n            if entry is None:\n                return\n\n            proc = entry[\"proc\"]\n            name = entry[\"name\"]\n            log_fh = entry.get(\"log_fh\")\n\n            if proc.poll() is None:\n                try:\n                    os.killpg(os.getpgid(proc.pid), signal.SIGTERM)\n                    proc.wait(timeout=5)\n                except subprocess.TimeoutExpired:\n                    try:\n                        os.killpg(os.getpgid(proc.pid), signal.SIGKILL)\n                    except OSError:\n                        pass\n                except OSError:\n                    pass\n\n            if log_fh:\n                try:\n                    log_fh.write(\n                        f\"\\nRalph Loop stopped  \"\n                        f\"{time.strftime('%Y-%m-%d %H:%M:%S UTC', time.gmtime())}\\n\"\n                    )\n                    log_fh.close()\n                except Exception:\n                    pass\n\n            del self._procs[project_id]\n            logger.info(\"Stopped Ralph Loop for '%s'\", name)\n\n    # ── Status ───────────────────────────────────────────────────\n\n    def get_loop_status(self, project_id: str) -> dict:\n        with self._lock:\n            entry = self._procs.get(project_id)\n            if entry is None:\n                return {\"running\": False}\n            proc = entry[\"proc\"]\n            running = proc.poll() is None\n            return {\n                \"running\": running,\n                \"pid\": proc.pid if running else None,\n                \"started_at\": entry.get(\"started_at\"),\n                \"exit_code\": proc.returncode if not running else None,\n            }\n\n    def get_all_statuses(self) -> dict:\n        with self._lock:\n            return {\n                pid: {\n                    \"running\": entry[\"proc\"].poll() is None,\n                    \"pid\": entry[\"proc\"].pid,\n                    \"name\": entry[\"name\"],\n                    \"started_at\": entry.get(\"started_at\"),\n                }\n                for pid, entry in self._procs.items()\n            }\n\n    # ── Sync ─────────────────────────────────────────────────────\n\n    def sync(self) -> None:\n        \"\"\"Reconcile running loops with active projects in the DB.\"\"\"\n        active = self.get_active_projects()\n        active_ids = {p[\"id\"] for p in active}\n\n        # Stop loops for projects no longer active\n        with self._lock:\n            stale = set(self._procs.keys()) - active_ids\n        for pid in stale:\n            self.stop_loop(pid)\n\n        # Start (or restart crashed) loops for active projects\n        for project in active:\n            if not self._is_running(project[\"id\"]):\n                self.start_loop(project)\n\n    # ── Main loop ────────────────────────────────────────────────\n\n    def run(self, interval: int = SYNC_INTERVAL) -> None:\n        \"\"\"Blocking main loop — call start_background() for async use.\"\"\"\n        self._running = True\n        logger.info(\"Dispatcher started (sync interval: %ds)\", interval)\n        while self._running:\n            try:\n                self.sync()\n            except Exception as exc:\n                logger.error(\"Sync error: %s\", exc)\n            # Sleep in small increments so we can stop cleanly\n            for _ in range(interval * 10):\n                if not self._running:\n                    break\n                time.sleep(0.1)\n        logger.info(\"Dispatcher stopped\")\n\n    def start_background(self) -> threading.Thread:\n        \"\"\"Start the dispatcher in a daemon thread.\"\"\"\n        t = threading.Thread(target=self.run, daemon=True, name=\"RalphDispatcher\")\n        t.start()\n        return t\n\n    def shutdown(self) -> None:\n        \"\"\"Stop all loops and the dispatcher.\"\"\"\n        self._running = False\n        with self._lock:\n            project_ids = list(self._procs.keys())\n        for pid in project_ids:\n            self.stop_loop(pid)\n        logger.info(\"All Ralph Loops stopped\")\n\n\n# ── Singleton used by app.py ─────────────────────────────────────\n_dispatcher: RalphLoopDispatcher | None = None\n\n\ndef get_dispatcher() -> RalphLoopDispatcher:\n    global _dispatcher\n    if _dispatcher is None:\n        _dispatcher = RalphLoopDispatcher()\n    return _dispatcher\n\n\n# ── Standalone entry point ───────────────────────────────────────\nif __name__ == \"__main__\":\n    dispatcher = RalphLoopDispatcher()\n\n    def _handle_signal(sig, frame):\n        logger.info(\"Received signal %d — shutting down\", sig)\n        dispatcher.shutdown()\n        sys.exit(0)\n\n    signal.signal(signal.SIGINT, _handle_signal)\n    signal.signal(signal.SIGTERM, _handle_signal)\n\n    dispatcher.run()\n","structuredPatch":[],"originalFile":null}}
