{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_0153dR9eP5RsHybQvcH5ZUSR","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01NB37VubJMdRZKSA7K6pmgX","name":"Write","input":{"file_path":"/home/ubuntu/my-project/app.py","content":"\"\"\"\napp.py — Ralph Project Management Backend\n\nREST API for managing projects and their Ralph Loops.\n\nEndpoints:\n  GET    /api/projects\n  POST   /api/projects\n  GET    /api/projects/<id>\n  PUT    /api/projects/<id>\n  POST   /api/projects/<id>/archive\n  POST   /api/projects/<id>/unarchive\n  GET    /api/projects/<id>/git-status\n  POST   /api/projects/<id>/push\n  GET    /api/projects/<id>/logs\n  GET    /api/projects/<id>/tasks\n  POST   /api/projects/<id>/tasks\n  PUT    /api/projects/<id>/tasks/<tid>\n  DELETE /api/projects/<id>/tasks/<tid>\n  GET    /api/projects/<id>/files\n  GET    /api/dispatcher/status\n\nEnvironment variables:\n  RALPH_DB            SQLite database path (default: projects.db)\n  RALPH_LOGS_DIR      Log file directory   (default: logs/)\n  RALPH_PROJECTS_DIR  Base dir for new projects (default: ~/ralph-projects)\n  PORT                HTTP port (default: 5000)\n\"\"\"\n\nimport os\nimport sqlite3\nimport subprocess\nimport uuid\nfrom datetime import datetime\n\nfrom flask import Flask, jsonify, request, send_from_directory\nfrom dispatcher import get_dispatcher\n\n# ── App setup ────────────────────────────────────────────────────\n\napp = Flask(__name__, static_folder=\"static\")\n\nDB_PATH = os.environ.get(\"RALPH_DB\", \"projects.db\")\nLOGS_DIR = os.environ.get(\"RALPH_LOGS_DIR\", \"logs\")\nPROJECTS_BASE = os.environ.get(\n    \"RALPH_PROJECTS_DIR\", os.path.expanduser(\"~/ralph-projects\")\n)\n\n# ── Database ─────────────────────────────────────────────────────\n\n\ndef get_db():\n    conn = sqlite3.connect(DB_PATH)\n    conn.row_factory = sqlite3.Row\n    conn.execute(\"PRAGMA journal_mode=WAL\")\n    return conn\n\n\ndef init_db():\n    conn = get_db()\n    conn.executescript(\n        \"\"\"\n        CREATE TABLE IF NOT EXISTS projects (\n            id          TEXT PRIMARY KEY,\n            name        TEXT NOT NULL,\n            description TEXT NOT NULL DEFAULT '',\n            path        TEXT NOT NULL,\n            git_remote  TEXT NOT NULL DEFAULT '',\n            auto_push   INTEGER NOT NULL DEFAULT 1,\n            status      TEXT NOT NULL DEFAULT 'active',\n            created_at  TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))\n        );\n\n        CREATE TABLE IF NOT EXISTS tasks (\n            id          TEXT PRIMARY KEY,\n            project_id  TEXT NOT NULL,\n            title       TEXT NOT NULL,\n            status      TEXT NOT NULL DEFAULT 'pending',\n            created_at  TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\n            updated_at  TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\n            FOREIGN KEY (project_id) REFERENCES projects(id)\n        );\n        \"\"\"\n    )\n    conn.commit()\n    conn.close()\n\n\n# ── Helpers ──────────────────────────────────────────────────────\n\n\ndef run_git(cwd: str, *args):\n    \"\"\"Run a git command; returns (stdout, stderr, returncode).\"\"\"\n    result = subprocess.run(\n        [\"git\"] + list(args),\n        cwd=cwd,\n        capture_output=True,\n        text=True,\n        timeout=30,\n    )\n    return result.stdout.strip(), result.stderr.strip(), result.returncode\n\n\ndef project_with_status(row: dict) -> dict:\n    row[\"loop_status\"] = get_dispatcher().get_loop_status(row[\"id\"])\n    return row\n\n\n# ── Projects ─────────────────────────────────────────────────────\n\n\n@app.route(\"/api/projects\", methods=[\"GET\"])\ndef list_projects():\n    conn = get_db()\n    rows = conn.execute(\n        \"SELECT * FROM projects ORDER BY created_at DESC\"\n    ).fetchall()\n    conn.close()\n    statuses = get_dispatcher().get_all_statuses()\n    result = []\n    for row in rows:\n        p = dict(row)\n        p[\"loop_status\"] = statuses.get(p[\"id\"], {\"running\": False})\n        result.append(p)\n    return jsonify(result)\n\n\n@app.route(\"/api/projects\", methods=[\"POST\"])\ndef create_project():\n    data = request.get_json(force=True)\n    name = (data.get(\"name\") or \"\").strip()\n    if not name:\n        return jsonify({\"error\": \"name is required\"}), 400\n\n    git_source = data.get(\"git_source\", \"new\")  # new | github | existing\n    git_remote = (data.get(\"git_remote\") or \"\").strip()\n    auto_push = 1 if data.get(\"auto_push\", True) else 0\n    description = (data.get(\"description\") or \"\").strip()\n\n    # Determine project path\n    if git_source == \"existing\":\n        path = os.path.expanduser((data.get(\"path\") or \"\").strip())\n        if not path:\n            return jsonify({\"error\": \"path is required for existing directory\"}), 400\n    else:\n        safe = name.lower().replace(\" \", \"-\").replace(\"/\", \"-\")\n        path = os.path.join(PROJECTS_BASE, safe)\n\n    os.makedirs(path, exist_ok=True)\n\n    # Git setup\n    if git_source == \"github\":\n        if not git_remote:\n            return jsonify({\"error\": \"git_remote is required for GitHub source\"}), 400\n        out, err, rc = run_git(path, \"clone\", git_remote, \".\")\n        if rc != 0:\n            return jsonify({\"error\": f\"git clone failed: {err}\"}), 400\n    elif git_source == \"new\":\n        if not os.path.exists(os.path.join(path, \".git\")):\n            run_git(path, \"init\")\n\n    project_id = str(uuid.uuid4())\n    conn = get_db()\n    conn.execute(\n        \"\"\"\n        INSERT INTO projects (id, name, description, path, git_remote, auto_push)\n        VALUES (?, ?, ?, ?, ?, ?)\n        \"\"\",\n        (project_id, name, description, path, git_remote, auto_push),\n    )\n    conn.commit()\n    project = dict(\n        conn.execute(\"SELECT * FROM projects WHERE id=?\", (project_id,)).fetchone()\n    )\n    conn.close()\n\n    # Start Ralph Loop for new active project\n    get_dispatcher().start_loop(project)\n\n    return jsonify(project_with_status(project)), 201\n\n\n@app.route(\"/api/projects/<pid>\", methods=[\"GET\"])\ndef get_project(pid):\n    conn = get_db()\n    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n    return jsonify(project_with_status(dict(row)))\n\n\n@app.route(\"/api/projects/<pid>\", methods=[\"PUT\"])\ndef update_project(pid):\n    data = request.get_json(force=True)\n    name = (data.get(\"name\") or \"\").strip()\n    if not name:\n        return jsonify({\"error\": \"name is required\"}), 400\n\n    conn = get_db()\n    conn.execute(\n        \"\"\"\n        UPDATE projects\n        SET name=?, description=?, git_remote=?, auto_push=?\n        WHERE id=?\n        \"\"\",\n        (\n            name,\n            (data.get(\"description\") or \"\").strip(),\n            (data.get(\"git_remote\") or \"\").strip(),\n            1 if data.get(\"auto_push\", True) else 0,\n            pid,\n        ),\n    )\n    conn.commit()\n    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n    return jsonify(project_with_status(dict(row)))\n\n\n@app.route(\"/api/projects/<pid>/archive\", methods=[\"POST\"])\ndef archive_project(pid):\n    conn = get_db()\n    conn.execute(\"UPDATE projects SET status='archived' WHERE id=?\", (pid,))\n    conn.commit()\n    conn.close()\n    get_dispatcher().stop_loop(pid)\n    return jsonify({\"status\": \"archived\"})\n\n\n@app.route(\"/api/projects/<pid>/unarchive\", methods=[\"POST\"])\ndef unarchive_project(pid):\n    conn = get_db()\n    conn.execute(\"UPDATE projects SET status='active' WHERE id=?\", (pid,))\n    conn.commit()\n    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n    project = dict(row)\n    get_dispatcher().start_loop(project)\n    return jsonify(project_with_status(project))\n\n\n# ── Git ──────────────────────────────────────────────────────────\n\n\n@app.route(\"/api/projects/<pid>/git-status\", methods=[\"GET\"])\ndef git_status(pid):\n    conn = get_db()\n    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n\n    path = row[\"path\"]\n    if not os.path.exists(os.path.join(path, \".git\")):\n        return jsonify({\"has_git\": False})\n\n    result: dict = {\"has_git\": True}\n\n    remote_url, _, rc = run_git(path, \"remote\", \"get-url\", \"origin\")\n    result[\"remote\"] = remote_url if rc == 0 else \"\"\n\n    # Fetch quietly to refresh remote refs\n    run_git(path, \"fetch\", \"--quiet\")\n\n    # Unpushed commits\n    unpushed, _, rc = run_git(path, \"rev-list\", \"--count\", \"@{u}..HEAD\")\n    if rc == 0 and unpushed.isdigit():\n        result[\"unpushed_commits\"] = int(unpushed)\n    else:\n        result[\"unpushed_commits\"] = 0\n\n    # Last push time — look at most recent commit on origin/HEAD or origin/main\n    for ref in (\"origin/HEAD\", \"origin/main\", \"origin/master\"):\n        last_push, _, rc = run_git(path, \"log\", \"-1\", \"--format=%ci\", ref)\n        if rc == 0 and last_push:\n            result[\"last_push\"] = last_push\n            break\n    else:\n        result[\"last_push\"] = \"\"\n\n    # Current branch\n    branch, _, _ = run_git(path, \"branch\", \"--show-current\")\n    result[\"branch\"] = branch\n\n    # Working-tree status\n    status_out, _, _ = run_git(path, \"status\", \"--short\")\n    result[\"dirty\"] = bool(status_out)\n    result[\"status_lines\"] = status_out.splitlines() if status_out else []\n\n    return jsonify(result)\n\n\n@app.route(\"/api/projects/<pid>/push\", methods=[\"POST\"])\ndef manual_push(pid):\n    conn = get_db()\n    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n\n    branch, _, _ = run_git(row[\"path\"], \"branch\", \"--show-current\")\n    out, err, rc = run_git(row[\"path\"], \"push\", \"origin\", branch or \"HEAD\")\n    return jsonify({\"success\": rc == 0, \"output\": out or err})\n\n\n# ── Logs ─────────────────────────────────────────────────────────\n\n\n@app.route(\"/api/projects/<pid>/logs\", methods=[\"GET\"])\ndef get_logs(pid):\n    log_path = os.path.join(LOGS_DIR, f\"{pid}.log\")\n    lines_limit = request.args.get(\"lines\", 300, type=int)\n\n    if not os.path.exists(log_path):\n        return jsonify({\"logs\": \"\", \"total_lines\": 0})\n\n    with open(log_path, \"r\", errors=\"replace\") as fh:\n        all_lines = fh.readlines()\n\n    return jsonify(\n        {\n            \"logs\": \"\".join(all_lines[-lines_limit:]),\n            \"total_lines\": len(all_lines),\n        }\n    )\n\n\n# ── Tasks ─────────────────────────────────────────────────────────\n\n\n@app.route(\"/api/projects/<pid>/tasks\", methods=[\"GET\"])\ndef list_tasks(pid):\n    conn = get_db()\n    rows = conn.execute(\n        \"SELECT * FROM tasks WHERE project_id=? ORDER BY created_at DESC\", (pid,)\n    ).fetchall()\n    conn.close()\n    return jsonify([dict(r) for r in rows])\n\n\n@app.route(\"/api/projects/<pid>/tasks\", methods=[\"POST\"])\ndef create_task(pid):\n    data = request.get_json(force=True)\n    title = (data.get(\"title\") or \"\").strip()\n    if not title:\n        return jsonify({\"error\": \"title is required\"}), 400\n\n    task_id = str(uuid.uuid4())\n    conn = get_db()\n    conn.execute(\n        \"INSERT INTO tasks (id, project_id, title) VALUES (?,?,?)\",\n        (task_id, pid, title),\n    )\n    conn.commit()\n    task = dict(conn.execute(\"SELECT * FROM tasks WHERE id=?\", (task_id,)).fetchone())\n    conn.close()\n    return jsonify(task), 201\n\n\n@app.route(\"/api/projects/<pid>/tasks/<tid>\", methods=[\"PUT\"])\ndef update_task(pid, tid):\n    data = request.get_json(force=True)\n    status = data.get(\"status\", \"pending\")\n    conn = get_db()\n    conn.execute(\n        \"UPDATE tasks SET status=?, updated_at=strftime('%Y-%m-%dT%H:%M:%SZ','now') \"\n        \"WHERE id=? AND project_id=?\",\n        (status, tid, pid),\n    )\n    conn.commit()\n    row = conn.execute(\"SELECT * FROM tasks WHERE id=?\", (tid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n    return jsonify(dict(row))\n\n\n@app.route(\"/api/projects/<pid>/tasks/<tid>\", methods=[\"DELETE\"])\ndef delete_task(pid, tid):\n    conn = get_db()\n    conn.execute(\"DELETE FROM tasks WHERE id=? AND project_id=?\", (tid, pid))\n    conn.commit()\n    conn.close()\n    return \"\", 204\n\n\n# ── Files ─────────────────────────────────────────────────────────\n\n\n@app.route(\"/api/projects/<pid>/files\", methods=[\"GET\"])\ndef list_files(pid):\n    conn = get_db()\n    row = conn.execute(\"SELECT path FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n\n    if not row or not os.path.exists(row[\"path\"]):\n        return jsonify({\"files\": []})\n\n    base = row[\"path\"]\n    IGNORE = {\".git\", \"__pycache__\", \"node_modules\", \".DS_Store\", \".venv\", \"venv\"}\n    files = []\n\n    for root, dirs, filenames in os.walk(base):\n        dirs[:] = [d for d in dirs if d not in IGNORE]\n        for fn in filenames:\n            full = os.path.join(root, fn)\n            rel = os.path.relpath(full, base)\n            try:\n                st = os.stat(full)\n                files.append(\n                    {\n                        \"path\": rel,\n                        \"size\": st.st_size,\n                        \"modified\": datetime.fromtimestamp(st.st_mtime).isoformat(),\n                    }\n                )\n            except OSError:\n                pass\n\n    files.sort(key=lambda f: f[\"path\"])\n    return jsonify({\"files\": files})\n\n\n# ── Dispatcher status ─────────────────────────────────────────────\n\n\n@app.route(\"/api/dispatcher/status\", methods=[\"GET\"])\ndef dispatcher_status():\n    return jsonify(get_dispatcher().get_all_statuses())\n\n\n# ── Static / SPA ──────────────────────────────────────────────────\n\n\n@app.route(\"/\")\ndef index():\n    return send_from_directory(\"static\", \"index.html\")\n\n\n# ── Entry point ───────────────────────────────────────────────────\n\nif __name__ == \"__main__\":\n    os.makedirs(LOGS_DIR, exist_ok=True)\n    os.makedirs(PROJECTS_BASE, exist_ok=True)\n    init_db()\n\n    dispatcher = get_dispatcher()\n    dispatcher.start_background()\n\n    port = int(os.environ.get(\"PORT\", 5000))\n    app.run(host=\"0.0.0.0\", port=port, debug=False, use_reloader=False)\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":276,"cache_read_input_tokens":54776,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":276},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8ed77ab3-b333-40a8-8a9f-a6b93e8c0982","uuid":"48ae6c70-adbc-4ecd-ae4a-603a4f50bcb5"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NB37VubJMdRZKSA7K6pmgX","type":"tool_result","content":"File created successfully at: /home/ubuntu/my-project/app.py"}]},"parent_tool_use_id":null,"session_id":"8ed77ab3-b333-40a8-8a9f-a6b93e8c0982","uuid":"01d079df-b6ad-43cf-8f59-32b5cb1d1023","tool_use_result":{"type":"create","filePath":"/home/ubuntu/my-project/app.py","content":"\"\"\"\napp.py — Ralph Project Management Backend\n\nREST API for managing projects and their Ralph Loops.\n\nEndpoints:\n  GET    /api/projects\n  POST   /api/projects\n  GET    /api/projects/<id>\n  PUT    /api/projects/<id>\n  POST   /api/projects/<id>/archive\n  POST   /api/projects/<id>/unarchive\n  GET    /api/projects/<id>/git-status\n  POST   /api/projects/<id>/push\n  GET    /api/projects/<id>/logs\n  GET    /api/projects/<id>/tasks\n  POST   /api/projects/<id>/tasks\n  PUT    /api/projects/<id>/tasks/<tid>\n  DELETE /api/projects/<id>/tasks/<tid>\n  GET    /api/projects/<id>/files\n  GET    /api/dispatcher/status\n\nEnvironment variables:\n  RALPH_DB            SQLite database path (default: projects.db)\n  RALPH_LOGS_DIR      Log file directory   (default: logs/)\n  RALPH_PROJECTS_DIR  Base dir for new projects (default: ~/ralph-projects)\n  PORT                HTTP port (default: 5000)\n\"\"\"\n\nimport os\nimport sqlite3\nimport subprocess\nimport uuid\nfrom datetime import datetime\n\nfrom flask import Flask, jsonify, request, send_from_directory\nfrom dispatcher import get_dispatcher\n\n# ── App setup ────────────────────────────────────────────────────\n\napp = Flask(__name__, static_folder=\"static\")\n\nDB_PATH = os.environ.get(\"RALPH_DB\", \"projects.db\")\nLOGS_DIR = os.environ.get(\"RALPH_LOGS_DIR\", \"logs\")\nPROJECTS_BASE = os.environ.get(\n    \"RALPH_PROJECTS_DIR\", os.path.expanduser(\"~/ralph-projects\")\n)\n\n# ── Database ─────────────────────────────────────────────────────\n\n\ndef get_db():\n    conn = sqlite3.connect(DB_PATH)\n    conn.row_factory = sqlite3.Row\n    conn.execute(\"PRAGMA journal_mode=WAL\")\n    return conn\n\n\ndef init_db():\n    conn = get_db()\n    conn.executescript(\n        \"\"\"\n        CREATE TABLE IF NOT EXISTS projects (\n            id          TEXT PRIMARY KEY,\n            name        TEXT NOT NULL,\n            description TEXT NOT NULL DEFAULT '',\n            path        TEXT NOT NULL,\n            git_remote  TEXT NOT NULL DEFAULT '',\n            auto_push   INTEGER NOT NULL DEFAULT 1,\n            status      TEXT NOT NULL DEFAULT 'active',\n            created_at  TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now'))\n        );\n\n        CREATE TABLE IF NOT EXISTS tasks (\n            id          TEXT PRIMARY KEY,\n            project_id  TEXT NOT NULL,\n            title       TEXT NOT NULL,\n            status      TEXT NOT NULL DEFAULT 'pending',\n            created_at  TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\n            updated_at  TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%SZ','now')),\n            FOREIGN KEY (project_id) REFERENCES projects(id)\n        );\n        \"\"\"\n    )\n    conn.commit()\n    conn.close()\n\n\n# ── Helpers ──────────────────────────────────────────────────────\n\n\ndef run_git(cwd: str, *args):\n    \"\"\"Run a git command; returns (stdout, stderr, returncode).\"\"\"\n    result = subprocess.run(\n        [\"git\"] + list(args),\n        cwd=cwd,\n        capture_output=True,\n        text=True,\n        timeout=30,\n    )\n    return result.stdout.strip(), result.stderr.strip(), result.returncode\n\n\ndef project_with_status(row: dict) -> dict:\n    row[\"loop_status\"] = get_dispatcher().get_loop_status(row[\"id\"])\n    return row\n\n\n# ── Projects ─────────────────────────────────────────────────────\n\n\n@app.route(\"/api/projects\", methods=[\"GET\"])\ndef list_projects():\n    conn = get_db()\n    rows = conn.execute(\n        \"SELECT * FROM projects ORDER BY created_at DESC\"\n    ).fetchall()\n    conn.close()\n    statuses = get_dispatcher().get_all_statuses()\n    result = []\n    for row in rows:\n        p = dict(row)\n        p[\"loop_status\"] = statuses.get(p[\"id\"], {\"running\": False})\n        result.append(p)\n    return jsonify(result)\n\n\n@app.route(\"/api/projects\", methods=[\"POST\"])\ndef create_project():\n    data = request.get_json(force=True)\n    name = (data.get(\"name\") or \"\").strip()\n    if not name:\n        return jsonify({\"error\": \"name is required\"}), 400\n\n    git_source = data.get(\"git_source\", \"new\")  # new | github | existing\n    git_remote = (data.get(\"git_remote\") or \"\").strip()\n    auto_push = 1 if data.get(\"auto_push\", True) else 0\n    description = (data.get(\"description\") or \"\").strip()\n\n    # Determine project path\n    if git_source == \"existing\":\n        path = os.path.expanduser((data.get(\"path\") or \"\").strip())\n        if not path:\n            return jsonify({\"error\": \"path is required for existing directory\"}), 400\n    else:\n        safe = name.lower().replace(\" \", \"-\").replace(\"/\", \"-\")\n        path = os.path.join(PROJECTS_BASE, safe)\n\n    os.makedirs(path, exist_ok=True)\n\n    # Git setup\n    if git_source == \"github\":\n        if not git_remote:\n            return jsonify({\"error\": \"git_remote is required for GitHub source\"}), 400\n        out, err, rc = run_git(path, \"clone\", git_remote, \".\")\n        if rc != 0:\n            return jsonify({\"error\": f\"git clone failed: {err}\"}), 400\n    elif git_source == \"new\":\n        if not os.path.exists(os.path.join(path, \".git\")):\n            run_git(path, \"init\")\n\n    project_id = str(uuid.uuid4())\n    conn = get_db()\n    conn.execute(\n        \"\"\"\n        INSERT INTO projects (id, name, description, path, git_remote, auto_push)\n        VALUES (?, ?, ?, ?, ?, ?)\n        \"\"\",\n        (project_id, name, description, path, git_remote, auto_push),\n    )\n    conn.commit()\n    project = dict(\n        conn.execute(\"SELECT * FROM projects WHERE id=?\", (project_id,)).fetchone()\n    )\n    conn.close()\n\n    # Start Ralph Loop for new active project\n    get_dispatcher().start_loop(project)\n\n    return jsonify(project_with_status(project)), 201\n\n\n@app.route(\"/api/projects/<pid>\", methods=[\"GET\"])\ndef get_project(pid):\n    conn = get_db()\n    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n    return jsonify(project_with_status(dict(row)))\n\n\n@app.route(\"/api/projects/<pid>\", methods=[\"PUT\"])\ndef update_project(pid):\n    data = request.get_json(force=True)\n    name = (data.get(\"name\") or \"\").strip()\n    if not name:\n        return jsonify({\"error\": \"name is required\"}), 400\n\n    conn = get_db()\n    conn.execute(\n        \"\"\"\n        UPDATE projects\n        SET name=?, description=?, git_remote=?, auto_push=?\n        WHERE id=?\n        \"\"\",\n        (\n            name,\n            (data.get(\"description\") or \"\").strip(),\n            (data.get(\"git_remote\") or \"\").strip(),\n            1 if data.get(\"auto_push\", True) else 0,\n            pid,\n        ),\n    )\n    conn.commit()\n    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n    return jsonify(project_with_status(dict(row)))\n\n\n@app.route(\"/api/projects/<pid>/archive\", methods=[\"POST\"])\ndef archive_project(pid):\n    conn = get_db()\n    conn.execute(\"UPDATE projects SET status='archived' WHERE id=?\", (pid,))\n    conn.commit()\n    conn.close()\n    get_dispatcher().stop_loop(pid)\n    return jsonify({\"status\": \"archived\"})\n\n\n@app.route(\"/api/projects/<pid>/unarchive\", methods=[\"POST\"])\ndef unarchive_project(pid):\n    conn = get_db()\n    conn.execute(\"UPDATE projects SET status='active' WHERE id=?\", (pid,))\n    conn.commit()\n    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n    project = dict(row)\n    get_dispatcher().start_loop(project)\n    return jsonify(project_with_status(project))\n\n\n# ── Git ──────────────────────────────────────────────────────────\n\n\n@app.route(\"/api/projects/<pid>/git-status\", methods=[\"GET\"])\ndef git_status(pid):\n    conn = get_db()\n    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n\n    path = row[\"path\"]\n    if not os.path.exists(os.path.join(path, \".git\")):\n        return jsonify({\"has_git\": False})\n\n    result: dict = {\"has_git\": True}\n\n    remote_url, _, rc = run_git(path, \"remote\", \"get-url\", \"origin\")\n    result[\"remote\"] = remote_url if rc == 0 else \"\"\n\n    # Fetch quietly to refresh remote refs\n    run_git(path, \"fetch\", \"--quiet\")\n\n    # Unpushed commits\n    unpushed, _, rc = run_git(path, \"rev-list\", \"--count\", \"@{u}..HEAD\")\n    if rc == 0 and unpushed.isdigit():\n        result[\"unpushed_commits\"] = int(unpushed)\n    else:\n        result[\"unpushed_commits\"] = 0\n\n    # Last push time — look at most recent commit on origin/HEAD or origin/main\n    for ref in (\"origin/HEAD\", \"origin/main\", \"origin/master\"):\n        last_push, _, rc = run_git(path, \"log\", \"-1\", \"--format=%ci\", ref)\n        if rc == 0 and last_push:\n            result[\"last_push\"] = last_push\n            break\n    else:\n        result[\"last_push\"] = \"\"\n\n    # Current branch\n    branch, _, _ = run_git(path, \"branch\", \"--show-current\")\n    result[\"branch\"] = branch\n\n    # Working-tree status\n    status_out, _, _ = run_git(path, \"status\", \"--short\")\n    result[\"dirty\"] = bool(status_out)\n    result[\"status_lines\"] = status_out.splitlines() if status_out else []\n\n    return jsonify(result)\n\n\n@app.route(\"/api/projects/<pid>/push\", methods=[\"POST\"])\ndef manual_push(pid):\n    conn = get_db()\n    row = conn.execute(\"SELECT * FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n\n    branch, _, _ = run_git(row[\"path\"], \"branch\", \"--show-current\")\n    out, err, rc = run_git(row[\"path\"], \"push\", \"origin\", branch or \"HEAD\")\n    return jsonify({\"success\": rc == 0, \"output\": out or err})\n\n\n# ── Logs ─────────────────────────────────────────────────────────\n\n\n@app.route(\"/api/projects/<pid>/logs\", methods=[\"GET\"])\ndef get_logs(pid):\n    log_path = os.path.join(LOGS_DIR, f\"{pid}.log\")\n    lines_limit = request.args.get(\"lines\", 300, type=int)\n\n    if not os.path.exists(log_path):\n        return jsonify({\"logs\": \"\", \"total_lines\": 0})\n\n    with open(log_path, \"r\", errors=\"replace\") as fh:\n        all_lines = fh.readlines()\n\n    return jsonify(\n        {\n            \"logs\": \"\".join(all_lines[-lines_limit:]),\n            \"total_lines\": len(all_lines),\n        }\n    )\n\n\n# ── Tasks ─────────────────────────────────────────────────────────\n\n\n@app.route(\"/api/projects/<pid>/tasks\", methods=[\"GET\"])\ndef list_tasks(pid):\n    conn = get_db()\n    rows = conn.execute(\n        \"SELECT * FROM tasks WHERE project_id=? ORDER BY created_at DESC\", (pid,)\n    ).fetchall()\n    conn.close()\n    return jsonify([dict(r) for r in rows])\n\n\n@app.route(\"/api/projects/<pid>/tasks\", methods=[\"POST\"])\ndef create_task(pid):\n    data = request.get_json(force=True)\n    title = (data.get(\"title\") or \"\").strip()\n    if not title:\n        return jsonify({\"error\": \"title is required\"}), 400\n\n    task_id = str(uuid.uuid4())\n    conn = get_db()\n    conn.execute(\n        \"INSERT INTO tasks (id, project_id, title) VALUES (?,?,?)\",\n        (task_id, pid, title),\n    )\n    conn.commit()\n    task = dict(conn.execute(\"SELECT * FROM tasks WHERE id=?\", (task_id,)).fetchone())\n    conn.close()\n    return jsonify(task), 201\n\n\n@app.route(\"/api/projects/<pid>/tasks/<tid>\", methods=[\"PUT\"])\ndef update_task(pid, tid):\n    data = request.get_json(force=True)\n    status = data.get(\"status\", \"pending\")\n    conn = get_db()\n    conn.execute(\n        \"UPDATE tasks SET status=?, updated_at=strftime('%Y-%m-%dT%H:%M:%SZ','now') \"\n        \"WHERE id=? AND project_id=?\",\n        (status, tid, pid),\n    )\n    conn.commit()\n    row = conn.execute(\"SELECT * FROM tasks WHERE id=?\", (tid,)).fetchone()\n    conn.close()\n    if not row:\n        return jsonify({\"error\": \"not found\"}), 404\n    return jsonify(dict(row))\n\n\n@app.route(\"/api/projects/<pid>/tasks/<tid>\", methods=[\"DELETE\"])\ndef delete_task(pid, tid):\n    conn = get_db()\n    conn.execute(\"DELETE FROM tasks WHERE id=? AND project_id=?\", (tid, pid))\n    conn.commit()\n    conn.close()\n    return \"\", 204\n\n\n# ── Files ─────────────────────────────────────────────────────────\n\n\n@app.route(\"/api/projects/<pid>/files\", methods=[\"GET\"])\ndef list_files(pid):\n    conn = get_db()\n    row = conn.execute(\"SELECT path FROM projects WHERE id=?\", (pid,)).fetchone()\n    conn.close()\n\n    if not row or not os.path.exists(row[\"path\"]):\n        return jsonify({\"files\": []})\n\n    base = row[\"path\"]\n    IGNORE = {\".git\", \"__pycache__\", \"node_modules\", \".DS_Store\", \".venv\", \"venv\"}\n    files = []\n\n    for root, dirs, filenames in os.walk(base):\n        dirs[:] = [d for d in dirs if d not in IGNORE]\n        for fn in filenames:\n            full = os.path.join(root, fn)\n            rel = os.path.relpath(full, base)\n            try:\n                st = os.stat(full)\n                files.append(\n                    {\n                        \"path\": rel,\n                        \"size\": st.st_size,\n                        \"modified\": datetime.fromtimestamp(st.st_mtime).isoformat(),\n                    }\n                )\n            except OSError:\n                pass\n\n    files.sort(key=lambda f: f[\"path\"])\n    return jsonify({\"files\": files})\n\n\n# ── Dispatcher status ─────────────────────────────────────────────\n\n\n@app.route(\"/api/dispatcher/status\", methods=[\"GET\"])\ndef dispatcher_status():\n    return jsonify(get_dispatcher().get_all_statuses())\n\n\n# ── Static / SPA ──────────────────────────────────────────────────\n\n\n@app.route(\"/\")\ndef index():\n    return send_from_directory(\"static\", \"index.html\")\n\n\n# ── Entry point ───────────────────────────────────────────────────\n\nif __name__ == \"__main__\":\n    os.makedirs(LOGS_DIR, exist_ok=True)\n    os.makedirs(PROJECTS_BASE, exist_ok=True)\n    init_db()\n\n    dispatcher = get_dispatcher()\n    dispatcher.start_background()\n\n    port = int(os.environ.get(\"PORT\", 5000))\n    app.run(host=\"0.0.0.0\", port=port, debug=False, use_reloader=False)\n","structuredPatch":[],"originalFile":null}}
